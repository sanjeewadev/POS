<Window x:Class="POS.BackOffice.UI.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ERP System Login" Height="360" Width="400" 
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize" WindowStyle="ToolWindow"
        Background="#D4D0C8" FontFamily="Segoe UI" FontSize="14">

    <Window.Resources>
        <Style TargetType="TextBox" x:Key="LoginInputStyle">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="#808080"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style TargetType="PasswordBox" x:Key="LoginPasswordStyle">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="#808080"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>

        <Style TargetType="Button" x:Key="SecureLoginBtnStyle">
            <Setter Property="Height" Value="42"/>
            <Setter Property="Background" Value="#003366"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#002244"/>
            <Setter Property="Content" Value="SECURE LOGIN"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#004C99"/>
                </Trigger>
                <!-- UI LOCKING: Detects when the async RelayCommand is running -->
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Content" Value="AUTHENTICATING..."/>
                    <Setter Property="Background" Value="#808080"/>
                    <Setter Property="BorderBrush" Value="#666666"/>
                    <Setter Property="Foreground" Value="#E0E0E0"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Border Background="#F9F9F9" BorderBrush="#003366" BorderThickness="2" 
                Margin="15" Padding="25" CornerRadius="2">
            <Border.Effect>
                <DropShadowEffect Color="Black" Direction="320" ShadowDepth="3" BlurRadius="8" Opacity="0.15"/>
            </Border.Effect>

            <StackPanel VerticalAlignment="Center">

                <TextBlock Text="SYSTEM AUTHENTICATION" FontWeight="ExtraBold" FontSize="18" Foreground="#003366" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                <Rectangle Height="2" Fill="#003366" Width="60" Margin="0,0,0,25"/>

                <Grid Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="90"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Username:" VerticalAlignment="Center" FontWeight="Bold" Foreground="#333"/>
                    <TextBox Grid.Column="1" Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource LoginInputStyle}"/>
                </Grid>

                <Grid Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="90"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Password:" VerticalAlignment="Center" FontWeight="Bold" Foreground="#333"/>
                    <PasswordBox Grid.Column="1" x:Name="pwdLogin" Style="{StaticResource LoginPasswordStyle}"/>
                </Grid>

                <!-- VISUAL VALIDATION: Reserves space so the UI doesn't jump when an error appears -->
                <TextBlock Text="{Binding ErrorMessage}" Foreground="#B91C1C" FontWeight="Bold" HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap" MinHeight="20" Margin="0,5,0,15"/>

                <!-- CommandParameter safely passes the PasswordBox into the ViewModel -->
                <Button Command="{Binding LoginCommand}" CommandParameter="{Binding ElementName=pwdLogin}" Style="{StaticResource SecureLoginBtnStyle}"/>

            </StackPanel>
        </Border>
    </Grid>
</Window>