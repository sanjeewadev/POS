<UserControl x:Class="POS.BackOffice.UI.Views.Pages.Reports.CashMovementDashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F3F4F6"
             FontFamily="Segoe UI, Arial">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="PAID IN / PAID OUT (CASH MOVEMENTS)" FontSize="28" FontWeight="Heavy" Foreground="#111827" Margin="0,0,0,20"/>

        <Grid Grid.Row="1" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="White" BorderBrush="#10B981" BorderThickness="0,4,0,0" CornerRadius="4" Padding="20">
                <StackPanel>
                    <TextBlock Text="TOTAL PAID IN" FontSize="14" FontWeight="Bold" Foreground="#6B7280"/>
                    <TextBlock Text="{Binding TotalPaidIn, StringFormat=Rs. \{0:N2\}}" FontSize="32" FontWeight="Heavy" Foreground="#10B981" Margin="0,5,0,0"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Background="White" BorderBrush="#EF4444" BorderThickness="0,4,0,0" CornerRadius="4" Padding="20">
                <StackPanel>
                    <TextBlock Text="TOTAL PAID OUT" FontSize="14" FontWeight="Bold" Foreground="#6B7280"/>
                    <TextBlock Text="{Binding TotalPaidOut, StringFormat=Rs. \{0:N2\}}" FontSize="32" FontWeight="Heavy" Foreground="#EF4444" Margin="0,5,0,0"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="4" Background="White" BorderBrush="#3B82F6" BorderThickness="0,4,0,0" CornerRadius="4" Padding="20">
                <StackPanel>
                    <TextBlock Text="NET DRAWER IMPACT" FontSize="14" FontWeight="Bold" Foreground="#6B7280"/>
                    <TextBlock Text="{Binding NetMovement, StringFormat=Rs. \{0:N2\}}" FontSize="32" FontWeight="Heavy" Foreground="#3B82F6" Margin="0,5,0,0"/>
                </StackPanel>
            </Border>
        </Grid>

        <Border Grid.Row="2" Background="White" CornerRadius="4" Padding="15" Margin="0,0,0,20">
            <WrapPanel VerticalAlignment="Center">

                <StackPanel Margin="0,0,20,10">
                    <TextBlock Text="Start Date" FontWeight="Bold" Foreground="#4B5563" Margin="0,0,0,5"/>
                    <DatePicker SelectedDate="{Binding StartDate}" Width="140" FontSize="14"/>
                </StackPanel>

                <StackPanel Margin="0,0,20,10">
                    <TextBlock Text="End Date" FontWeight="Bold" Foreground="#4B5563" Margin="0,0,0,5"/>
                    <DatePicker SelectedDate="{Binding EndDate}" Width="140" FontSize="14"/>
                </StackPanel>

                <StackPanel Margin="0,0,20,10">
                    <TextBlock Text="Movement Type" FontWeight="Bold" Foreground="#4B5563" Margin="0,0,0,5"/>
                    <ComboBox SelectedItem="{Binding SelectedTypeFilter}" Width="140" FontSize="14">
                        <System:String xmlns:System="clr-namespace:System;assembly=mscorlib">All Types</System:String>
                        <System:String xmlns:System="clr-namespace:System;assembly=mscorlib">Paid In</System:String>
                        <System:String xmlns:System="clr-namespace:System;assembly=mscorlib">Paid Out</System:String>
                    </ComboBox>
                </StackPanel>

                <StackPanel Margin="0,0,20,10">
                    <TextBlock Text="Search (Voucher / Remarks)" FontWeight="Bold" Foreground="#4B5563" Margin="0,0,0,5"/>
                    <TextBox Text="{Binding SearchKeyword, UpdateSourceTrigger=PropertyChanged}" Width="250" FontSize="14" Padding="5"/>
                </StackPanel>

                <Button Command="{Binding ApplyFiltersCommand}" Content="APPLY FILTERS" Background="#1F2937" Foreground="White" FontWeight="Bold" Width="130" Height="35" Margin="0,15,20,10" Cursor="Hand"/>
                <Button Command="{Binding ExportCommand}" Content="EXPORT REPORT" Background="#059669" Foreground="White" FontWeight="Bold" Width="140" Height="35" Margin="0,15,0,10" Cursor="Hand"/>
            </WrapPanel>
        </Border>

        <DataGrid Grid.Row="3" ItemsSource="{Binding MovementsList}" 
                  AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Single"
                  Background="White" RowHeight="40" FontSize="14" 
                  GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#E5E7EB" BorderThickness="1" BorderBrush="#D1D5DB">

            <DataGrid.Resources>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="#1F2937"/>
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="FontWeight" Value="Bold"/>
                    <Setter Property="Padding" Value="10,8"/>
                </Style>
            </DataGrid.Resources>

            <DataGrid.Columns>
                <DataGridTextColumn Header="Date &amp; Time" Binding="{Binding Timestamp, StringFormat=yyyy-MM-dd HH:mm}" Width="140"/>
                <DataGridTextColumn Header="Voucher No." Binding="{Binding ReferenceVoucherNo}" Width="120"/>

                <DataGridTextColumn Header="Type" Binding="{Binding MovementType}" Width="100">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="FontWeight" Value="Bold"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                            <Setter Property="Margin" Value="10,0"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding MovementType}" Value="Paid In">
                                    <Setter Property="Foreground" Value="#10B981"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding MovementType}" Value="Paid Out">
                                    <Setter Property="Foreground" Value="#EF4444"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn Header="Category" Binding="{Binding ReasonCategory}" Width="150"/>

                <DataGridTextColumn Header="Amount (Rs.)" Binding="{Binding Amount, StringFormat=N2}" Width="120">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="FontWeight" Value="Bold"/>
                            <Setter Property="TextAlignment" Value="Right"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                            <Setter Property="Margin" Value="0,0,10,0"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn Header="Cashier" Binding="{Binding CashierName}" Width="120"/>
                <DataGridTextColumn Header="Authorized By" Binding="{Binding AuthorizedBy}" Width="120"/>
                <DataGridTextColumn Header="Remarks" Binding="{Binding Remarks}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

    </Grid>
</UserControl>