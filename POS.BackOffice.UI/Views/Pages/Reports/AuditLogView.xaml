<UserControl x:Class="POS.BackOffice.UI.Views.Pages.Reports.AuditLogView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="850" d:DesignWidth="1250"
             Background="#F5F5F5">

    <UserControl.Resources>
        <!-- Standard Button Style -->
        <Style TargetType="Button" x:Key="StandardBtn">
            <Setter Property="Background" Value="#2B3C38"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#3B524E"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Search Action Button (Blue) -->
        <Style TargetType="Button" x:Key="SearchBtn" BasedOn="{StaticResource StandardBtn}">
            <Setter Property="Background" Value="#2B5B84"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1C3F5E"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Excel Export Button (Green) -->
        <Style TargetType="Button" x:Key="ExcelBtn" BasedOn="{StaticResource StandardBtn}">
            <Setter Property="Background" Value="#28A745"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#218838"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Standard Input Style -->
        <Style TargetType="Control" x:Key="StandardInput">
            <Setter Property="Padding" Value="5"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="BorderBrush" Value="#CCCCCC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Height" Value="30"/>
        </Style>

        <!-- Group Box Border Style -->
        <Style TargetType="Border" x:Key="GroupBoxBorder">
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="15"/>
            <Setter Property="Background" Value="White"/>
        </Style>

        <!-- KPI Card Style -->
        <Style TargetType="Border" x:Key="KpiCard">
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="20,15"/>
            <Setter Property="Margin" Value="0,0,15,0"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Header (Investigation Filters) -->
            <RowDefinition Height="Auto"/>
            <!-- Security KPI Cards -->
            <RowDefinition Height="*"/>
            <!-- Data Grid (Immutable Ledger) -->
            <RowDefinition Height="Auto"/>
            <!-- Footer (Export & Compliance) -->
        </Grid.RowDefinitions>

        <!-- ========================================== -->
        <!-- ZONE 1: INVESTIGATION FILTER ENGINE        -->
        <!-- ========================================== -->
        <Border Grid.Row="0" Style="{StaticResource GroupBoxBorder}" Margin="0,0,0,15">
            <StackPanel>
                <TextBlock Text="System Security &amp; Audit Log Explorer" FontSize="20" FontWeight="SemiBold" Foreground="#333333" Margin="0,0,0,15"/>

                <!-- Row 1 Filters -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="1.5*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="1.5*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Date From *" Foreground="#666666" Margin="0,0,0,5"/>
                        <DatePicker x:Name="dpFromDate" Style="{StaticResource StandardInput}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Date To *" Foreground="#666666" Margin="0,0,0,5"/>
                        <DatePicker x:Name="dpToDate" Style="{StaticResource StandardInput}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="4">
                        <TextBlock Text="User / Employee" Foreground="#666666" Margin="0,0,0,5"/>
                        <ComboBox x:Name="cmbUser" Style="{StaticResource StandardInput}" IsEditable="True" ToolTip="Leave blank for all users"/>
                    </StackPanel>

                    <StackPanel Grid.Column="6">
                        <TextBlock Text="System Module" Foreground="#666666" Margin="0,0,0,5"/>
                        <ComboBox x:Name="cmbModule" Style="{StaticResource StandardInput}">
                            <ComboBoxItem Content="All Modules" IsSelected="True"/>
                            <ComboBoxItem Content="Inventory &amp; GRN"/>
                            <ComboBoxItem Content="Sales &amp; POS"/>
                            <ComboBoxItem Content="CRM &amp; Customers"/>
                            <ComboBoxItem Content="User Management &amp; Security"/>
                            <ComboBoxItem Content="Settings &amp; Configuration"/>
                        </ComboBox>
                    </StackPanel>
                </Grid>

                <!-- Row 2 Filters -->
                <Grid Margin="0,5,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.5*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="1.5*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Action Type" Foreground="#666666" Margin="0,0,0,5"/>
                        <ComboBox x:Name="cmbActionType" Style="{StaticResource StandardInput}">
                            <ComboBoxItem Content="All Actions" IsSelected="True"/>
                            <ComboBoxItem Content="CREATE (Add New)"/>
                            <ComboBoxItem Content="UPDATE (Modify)"/>
                            <ComboBoxItem Content="DELETE (Remove)"/>
                            <ComboBoxItem Content="VOID (Cancel)"/>
                            <ComboBoxItem Content="EXPORT (Data Download)"/>
                            <ComboBoxItem Content="AUTH (Login/Logout)"/>
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Severity / Risk Level" Foreground="#A94044" FontWeight="SemiBold" Margin="0,0,0,5"/>
                        <ComboBox x:Name="cmbSeverity" Style="{StaticResource StandardInput}" Background="#FDF3F3">
                            <ComboBoxItem Content="All Levels" IsSelected="True"/>
                            <ComboBoxItem Content="INFO (Standard Operations)"/>
                            <ComboBoxItem Content="WARNING (Modifications)"/>
                            <ComboBoxItem Content="CRITICAL (Deletions, Voids, Failed Auth)"/>
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Grid.Column="4">
                        <TextBlock Text="Keyword Search (Ref No, Details)" Foreground="#666666" Margin="0,0,0,5"/>
                        <TextBox x:Name="txtKeywordSearch" Style="{StaticResource StandardInput}" ToolTip="e.g., INV-260614-001 or 'Deleted Category'"/>
                    </StackPanel>

                    <Button Grid.Column="6" x:Name="btnFetchLogs" Content="Fetch Audit Logs" Style="{StaticResource SearchBtn}" Margin="0" VerticalAlignment="Bottom" Height="30" Width="140"/>
                </Grid>
            </StackPanel>
        </Border>

        <!-- ========================================== -->
        <!-- ZONE 2: SECURITY KPI DASHBOARD             -->
        <!-- ========================================== -->
        <UniformGrid Grid.Row="1" Columns="4" Margin="0,0,-15,15">

            <!-- Card 1: Volume -->
            <Border Style="{StaticResource KpiCard}" Background="#F8F8F8" BorderBrush="#E0E0E0">
                <StackPanel>
                    <TextBlock Text="Total Events Logged" Foreground="#333333" FontSize="13" FontWeight="SemiBold"/>
                    <TextBlock x:Name="txtKpiTotalEvents" Text="1,402" FontWeight="Bold" FontSize="26" Foreground="#333333" Margin="0,5,0,0"/>
                    <TextBlock Text="In selected date range" Foreground="#666666" FontSize="11" Margin="0,2,0,0"/>
                </StackPanel>
            </Border>

            <!-- Card 2: Threats -->
            <Border Style="{StaticResource KpiCard}" Background="#FDF3F3" BorderBrush="#F5C6CB">
                <StackPanel>
                    <TextBlock Text="Critical Security Events" Foreground="#A94044" FontSize="13" FontWeight="SemiBold"/>
                    <TextBlock x:Name="txtKpiCritical" Text="12 Events" FontWeight="Bold" FontSize="26" Foreground="#A94044" Margin="0,5,0,0"/>
                    <TextBlock Text="Voids, Deletes, Failed Logins" Foreground="#A94044" FontSize="11" Margin="0,2,0,0" Opacity="0.8"/>
                </StackPanel>
            </Border>

            <!-- Card 3: User Activity -->
            <Border Style="{StaticResource KpiCard}" Background="#E2EDF8" BorderBrush="#B6D4FE">
                <StackPanel>
                    <TextBlock Text="Most Active User" Foreground="#2B5B84" FontSize="13" FontWeight="SemiBold"/>
                    <TextBlock x:Name="txtKpiActiveUser" Text="Sarah K." FontWeight="Bold" FontSize="26" Foreground="#2B5B84" Margin="0,5,0,0"/>
                    <TextBlock Text="420 actions performed" Foreground="#2B5B84" FontSize="11" Margin="0,2,0,0" Opacity="0.8"/>
                </StackPanel>
            </Border>

            <!-- Card 4: Data Exfiltration Risk -->
            <Border Style="{StaticResource KpiCard}" Background="#FFF8EB" BorderBrush="#FDE0A6">
                <StackPanel>
                    <TextBlock Text="Data Export Actions" Foreground="#D97706" FontSize="13" FontWeight="SemiBold"/>
                    <TextBlock x:Name="txtKpiExports" Text="3 Downloads" FontWeight="Bold" FontSize="26" Foreground="#D97706" Margin="0,5,0,0"/>
                    <TextBlock Text="Excel/PDF bulk extractions" Foreground="#D97706" FontSize="11" Margin="0,2,0,0" Opacity="0.8"/>
                </StackPanel>
            </Border>

        </UniformGrid>

        <!-- ========================================== -->
        <!-- ZONE 3: THE IMMUTABLE LEDGER (DATAGRID)    -->
        <!-- ========================================== -->
        <Border Grid.Row="2" Style="{StaticResource GroupBoxBorder}" Padding="0" Margin="0,0,0,15">
            <DataGrid x:Name="dgAuditLogs" 
                      AutoGenerateColumns="False" 
                      CanUserAddRows="False" 
                      CanUserDeleteRows="False" 
                      IsReadOnly="True" 
                      HeadersVisibility="Column" 
                      GridLinesVisibility="Horizontal"
                      HorizontalGridLinesBrush="#EEEEEE"
                      BorderThickness="0"
                      RowHeight="40"
                      Background="Transparent"
                      SelectionMode="Single">

                <DataGrid.Resources>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#F8F8F8"/>
                        <Setter Property="Foreground" Value="#333333"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="Padding" Value="10,10"/>
                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                        <Setter Property="BorderBrush" Value="#DDDDDD"/>
                    </Style>
                    <Style TargetType="DataGridCell">
                        <Setter Property="Padding" Value="10,0"/>
                        <Setter Property="VerticalContentAlignment" Value="Center"/>
                    </Style>
                </DataGrid.Resources>

                <DataGrid.Columns>
                    <DataGridTextColumn Header="Timestamp" Binding="{Binding Timestamp, StringFormat=dd/MM/yyyy HH:mm:ss}" Width="140" Foreground="#666666"/>

                    <DataGridTextColumn Header="Severity" Binding="{Binding Severity}" Width="90">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontWeight" Value="Bold"/>
                                <!-- In real code, a ValueConverter maps 'CRITICAL' to Red, 'INFO' to Grey, etc. -->
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="User (Role)" Binding="{Binding UserAndRole}" Width="160" FontWeight="SemiBold"/>

                    <DataGridTextColumn Header="Module" Binding="{Binding Module}" Width="120" Foreground="#2B5B84"/>

                    <DataGridTextColumn Header="Action" Binding="{Binding Action}" Width="100">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="Target Ref" Binding="{Binding ReferenceNo}" Width="120"/>

                    <DataGridTextColumn Header="Terminal / IP" Binding="{Binding IPAddress}" Width="130" Foreground="#666666"/>

                    <!-- DEEP FORENSIC ACTION COLUMN -->
                    <DataGridTemplateColumn Header="Forensics" Width="90">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="Inspect" Background="#6F42C1" Foreground="White" BorderThickness="0" Cursor="Hand" Padding="5,2" ToolTip="View exact Before &amp; After data changes (JSON Diff)"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- ========================================== -->
        <!-- ZONE 4: FOOTER (COMPLIANCE & EXPORT)       -->
        <!-- ========================================== -->
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Compliance Status -->
            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                <TextBlock Text="Strict Compliance Mode Active. Log entries are immutable and cannot be deleted or modified." FontWeight="Bold" Foreground="#A94044" Margin="0,0,0,2"/>
                <TextBlock Text="System retention policy: 365 Days. Logs older than 365 days are archived to cold storage." Foreground="#666666" FontSize="11"/>
            </StackPanel>

            <!-- Action Buttons -->
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <Button Content="Export to CSV" Style="{StaticResource ExcelBtn}" Width="140" ToolTip="Download raw data for external auditing software"/>
                <Button Content="Print Audit Report" Style="{StaticResource SearchBtn}" Width="160" Margin="0"/>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>