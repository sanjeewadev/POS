<UserControl x:Class="POS.BackOffice.UI.Views.Pages.Purchasing.PurchaseOrderView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:POS.BackOffice.UI.Views.Pages.Purchasing"
             mc:Ignorable="d"
             d:DesignHeight="850"
             d:DesignWidth="1400"
             Background="#D4D0C8"
             FontFamily="Segoe UI"
             FontSize="12">

    <UserControl.Resources>

        <local:MoqColorConverter x:Key="MoqColorConverter"/>

        <Style TargetType="TextBlock" x:Key="HeaderLabel">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#003366"/>
            <Setter Property="Margin" Value="0,5,0,5"/>
        </Style>

        <Style TargetType="TextBlock" x:Key="InlineLabel">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,5,0"/>
        </Style>

        <Style TargetType="TextBox" x:Key="ClassicInput">
            <Setter Property="Height" Value="24"/>
            <Setter Property="Padding" Value="4,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="#808080"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Style.Triggers>
                <Trigger Property="IsReadOnly" Value="True">
                    <Setter Property="Background" Value="#E5E5E5"/>
                    <Setter Property="Foreground" Value="#555"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#E5E5E5"/>
                    <Setter Property="Foreground" Value="#555"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="ComboBox" x:Key="ClassicCombo">
            <Setter Property="Height" Value="24"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="#808080"/>
            <Setter Property="Background" Value="White"/>
        </Style>

        <Style TargetType="DatePicker" x:Key="ClassicDate">
            <Setter Property="Height" Value="24"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="#808080"/>
        </Style>

        <Style TargetType="Button" x:Key="ClassicBtn">
            <Setter Property="Height" Value="26"/>
            <Setter Property="Background" Value="#E0E0E0"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderBrush" Value="#808080"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#CCCCCC"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.55"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="Button" x:Key="ActionBtn" BasedOn="{StaticResource ClassicBtn}">
            <Setter Property="Background" Value="#005555"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#003333"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#007777"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="Border" x:Key="ClassicGroupBox">
            <Setter Property="BorderBrush" Value="#A0A0A0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="#F0F0F0"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#E0E0E0"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="BorderBrush" Value="#A0A0A0"/>
        </Style>

        <Style TargetType="DataGridCell" x:Key="BaseCell">
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="4,0"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="Background" Value="Transparent"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#005555"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridCell" x:Key="FrozenCell" BasedOn="{StaticResource BaseCell}">
            <Setter Property="Background" Value="#F5F5F5"/>
        </Style>

        <Style TargetType="DataGridCell" x:Key="EditableCell" BasedOn="{StaticResource BaseCell}">
            <Setter Property="Background" Value="#FFFFE0"/>
        </Style>

    </UserControl.Resources>

    <Grid Margin="5">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="550"/>
            <ColumnDefinition Width="5"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- HEADER SETUP -->
        <Border Grid.Row="0"
                Grid.ColumnSpan="3"
                Style="{StaticResource ClassicGroupBox}">

            <StackPanel>
                <TextBlock Text="1. PURCHASE ORDER SETUP"
                           Style="{StaticResource HeaderLabel}"/>

                <WrapPanel Orientation="Horizontal" Margin="0,5,0,0">

                    <StackPanel Margin="0,0,30,5">
                        <TextBlock Text="Supplier &amp; Code *"
                                   Style="{StaticResource InlineLabel}"/>

                        <Grid Margin="0,4,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="220"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="100"/>
                            </Grid.ColumnDefinitions>

                            <ComboBox Grid.Column="0"
                                      ItemsSource="{Binding Suppliers}"
                                      SelectedItem="{Binding SelectedSupplier, Mode=TwoWay}"
                                      DisplayMemberPath="SupplierName"
                                      IsEditable="True"
                                      IsTextSearchEnabled="True"
                                      Style="{StaticResource ClassicCombo}"/>

                            <TextBox Grid.Column="2"
                                     Text="{Binding SupplierCode}"
                                     IsReadOnly="True"
                                     Style="{StaticResource ClassicInput}"
                                     FontWeight="Bold"
                                     ToolTip="Supplier Code"/>
                        </Grid>
                    </StackPanel>

                    <StackPanel Margin="0,0,30,5">
                        <TextBlock Text="Payment Terms"
                                   Style="{StaticResource InlineLabel}"/>

                        <Grid Margin="0,4,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="70"/>
                            </Grid.ColumnDefinitions>

                            <ComboBox Grid.Column="0"
                                      SelectedValue="{Binding SelectedTerms, Mode=TwoWay}"
                                      SelectedValuePath="Content"
                                      Style="{StaticResource ClassicCombo}">
                                <ComboBoxItem Content="Credit"/>
                                <ComboBoxItem Content="Cash on Delivery"/>
                                <ComboBoxItem Content="Advance Payment"/>
                            </ComboBox>

                            <TextBox Grid.Column="2"
                                     Text="{Binding CreditDaysInput, Mode=TwoWay, UpdateSourceTrigger=LostFocus, TargetNullValue=''}"
                                     Style="{StaticResource ClassicInput}"
                                     HorizontalContentAlignment="Center"
                                     ToolTip="Credit Days"/>
                        </Grid>
                    </StackPanel>

                    <StackPanel Margin="0,0,30,5">
                        <TextBlock Text="Order &amp; Expected Delivery"
                                   Style="{StaticResource InlineLabel}"/>

                        <Grid Margin="0,4,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="130"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="130"/>
                            </Grid.ColumnDefinitions>

                            <DatePicker Grid.Column="0"
                                        SelectedDate="{Binding OrderDate, Mode=TwoWay}"
                                        Style="{StaticResource ClassicDate}"
                                        ToolTip="PO Order Date"/>

                            <DatePicker Grid.Column="2"
                                        SelectedDate="{Binding ExpectedDate, Mode=TwoWay}"
                                        Style="{StaticResource ClassicDate}"
                                        ToolTip="Expected Delivery Date"/>
                        </Grid>
                    </StackPanel>

                    <StackPanel Margin="0,0,30,5">
                        <TextBlock Text="Requisitioner"
                                   Style="{StaticResource InlineLabel}"/>

                        <TextBox Text="{Binding CurrentUser}"
                                 IsReadOnly="True"
                                 Style="{StaticResource ClassicInput}"
                                 Width="150"
                                 Margin="0,4,0,0"/>
                    </StackPanel>

                    <StackPanel Margin="0,0,0,5">
                        <TextBlock Text="Status"
                                   Style="{StaticResource InlineLabel}"/>

                        <TextBox Text="{Binding StatusMessage}"
                                 IsReadOnly="True"
                                 Style="{StaticResource ClassicInput}"
                                 Width="300"
                                 Margin="0,4,0,0"
                                 Foreground="#003366"
                                 FontWeight="SemiBold"/>
                    </StackPanel>

                </WrapPanel>
            </StackPanel>
        </Border>

        <!-- LEFT SIDE: ITEM ENTRY -->
        <Border Grid.Row="1"
                Grid.Column="0"
                Style="{StaticResource ClassicGroupBox}"
                VerticalAlignment="Stretch">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="2. ITEM ENTRY CONSOLE"
                           Style="{StaticResource HeaderLabel}"
                           Foreground="#005555"
                           Margin="0,0,0,5"/>

                <!-- BARCODE / ITEM SEARCH -->
                <Border Grid.Row="1"
                        Background="#334155"
                        Padding="8"
                        BorderBrush="#1E293B"
                        BorderThickness="1"
                        Margin="0,0,0,10">

                    <StackPanel>
                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="65"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       Text="Barcode:"
                                       Foreground="#DEFF9A"
                                       Style="{StaticResource InlineLabel}"/>

                            <TextBox Grid.Column="1"
                                     Text="{Binding ScanBarcode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Height="26"
                                     FontSize="13"
                                     FontWeight="Bold"
                                     ToolTip="Scan barcode or type SKU and press Enter.">
                                <TextBox.InputBindings>
                                    <KeyBinding Key="Enter"
                                                Command="{Binding AddItemCommand}"/>
                                </TextBox.InputBindings>
                            </TextBox>
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="65"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="40"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       Text="Code:"
                                       Foreground="White"
                                       Style="{StaticResource InlineLabel}"/>

                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding AvailableItems}"
                                      SelectedItem="{Binding SelectedItem, Mode=TwoWay}"
                                      DisplayMemberPath="ItemCode"
                                      IsEditable="True"
                                      IsTextSearchEnabled="True"
                                      TextSearch.TextPath="ItemCode"
                                      Height="26"
                                      Margin="0,0,10,0"
                                      ToolTip="Select item by item code."/>

                            <TextBlock Grid.Column="2"
                                       Text="Name:"
                                       Foreground="White"
                                       Style="{StaticResource InlineLabel}"/>

                            <ComboBox Grid.Column="3"
                                      ItemsSource="{Binding AvailableItems}"
                                      SelectedItem="{Binding SelectedItem, Mode=TwoWay}"
                                      DisplayMemberPath="ItemName"
                                      IsEditable="True"
                                      IsTextSearchEnabled="True"
                                      TextSearch.TextPath="ItemName"
                                      Height="26"
                                      ToolTip="Select standard item or matrix parent."/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- MATRIX ENTRY -->
                <Border Grid.Row="2"
                        Background="#F0F8FF"
                        BorderBrush="#005555"
                        BorderThickness="1"
                        Padding="8">

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       Text="MATRIX RAPID ENTRY"
                                       FontWeight="Bold"
                                       Foreground="#003366"
                                       VerticalAlignment="Center"/>

                            <TextBox Grid.Column="1"
                                     Text="{Binding MatrixFilterText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Width="180"
                                     Height="24"
                                     Padding="4,0"
                                     Background="White"
                                     BorderBrush="#A0A0A0"
                                     BorderThickness="1"
                                     ToolTip="Search loaded variants by attributes, barcode, or supplier item code."/>
                        </Grid>

                        <DataGrid Grid.Row="1"
                                  ItemsSource="{Binding ActiveMatrixVariants}"
                                  SelectedItem="{Binding SelectedMatrixVariant, Mode=TwoWay}"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  IsReadOnly="False"
                                  HeadersVisibility="Column"
                                  Background="White"
                                  BorderBrush="#A0A0A0"
                                  BorderThickness="1"
                                  RowHeight="28"
                                  GridLinesVisibility="All"
                                  HorizontalGridLinesBrush="#E0E0E0"
                                  VerticalGridLinesBrush="#E0E0E0"
                                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                                  FrozenColumnCount="2"
                                  SelectionMode="Single">

                            <DataGrid.Resources>
                                <Style TargetType="DataGridCell" BasedOn="{StaticResource BaseCell}"/>
                            </DataGrid.Resources>

                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Attributes"
                                                    Binding="{Binding VariantDescription}"
                                                    Width="1.4*"
                                                    IsReadOnly="True"
                                                    CellStyle="{StaticResource FrozenCell}"/>

                                <DataGridTextColumn Header="Vendor SKU"
                                                    Binding="{Binding SupplierItemCode}"
                                                    Width="1*"
                                                    IsReadOnly="True"
                                                    Foreground="#005555"
                                                    FontWeight="SemiBold"
                                                    CellStyle="{StaticResource FrozenCell}"/>

                                <DataGridTemplateColumn Header="Qty" Width="80">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBox Text="{Binding OrderQty, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                     TextAlignment="Center"
                                                     FontWeight="Bold"
                                                     BorderThickness="0"
                                                     ToolTip="{Binding Moq, StringFormat=Minimum Order Qty: {0}}">
                                                <TextBox.Background>
                                                    <MultiBinding Converter="{StaticResource MoqColorConverter}">
                                                        <Binding Path="OrderQty"/>
                                                        <Binding Path="Moq"/>
                                                    </MultiBinding>
                                                </TextBox.Background>
                                            </TextBox>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTemplateColumn Header="Cost Rs." Width="95">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBox Text="{Binding ExpectedCost, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                                     TextAlignment="Right"
                                                     Background="#FFFFE0"
                                                     BorderThickness="0"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTemplateColumn Header="Disc" Width="70">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBox Text="{Binding LineDiscount, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                                     TextAlignment="Right"
                                                     Foreground="DarkRed"
                                                     Background="#FFFFE0"
                                                     BorderThickness="0"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>

                <Button Grid.Row="3"
                        Content="ADD ACTIVE MATRIX TO PO"
                        Command="{Binding AddMatrixCommand}"
                        Style="{StaticResource ActionBtn}"
                        Background="#0066CC"
                        BorderBrush="#004C99"
                        Height="36"
                        Margin="0,10,0,0"
                        FontSize="13"/>
            </Grid>
        </Border>

        <!-- RIGHT SIDE: PO CART -->
        <Grid Grid.Row="1"
              Grid.Column="2">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- PO NUMBER BAR -->
            <Border Grid.Row="0"
                    Background="#003366"
                    Padding="10"
                    BorderBrush="#002244"
                    BorderThickness="1">

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">

                        <TextBlock Text="PO NO:"
                                   Foreground="#A0C0E0"
                                   FontSize="14"
                                   FontWeight="Bold"
                                   Margin="0,0,10,0"/>

                        <TextBlock Text="[ AUTO GENERATED ON SAVE ]"
                                   Foreground="White"
                                   FontSize="14"
                                   FontWeight="Bold"/>
                    </StackPanel>

                    <TextBlock Grid.Column="1"
                               Text="Approved supplier items only"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Center"
                               Foreground="#DEFF9A"
                               FontWeight="SemiBold"/>
                </Grid>
            </Border>

            <!-- ROW ACTIONS -->
            <Border Grid.Row="1"
                    Background="#E5E5E5"
                    Padding="8"
                    BorderBrush="#A0A0A0"
                    BorderThickness="1,0,1,0">

                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Selected Row Actions:"
                               VerticalAlignment="Center"
                               FontWeight="Bold"
                               Foreground="#666"
                               Margin="0,0,10,0"/>

                    <Button Content="Remove Item"
                            Command="{Binding RemoveLineCommand}"
                            CommandParameter="{Binding SelectedLine}"
                            Style="{StaticResource ClassicBtn}"
                            Foreground="DarkRed"
                            Height="26"/>

                    <TextBlock Text="Double-click highlighted cells below to edit quantity, cost, and discount."
                               VerticalAlignment="Center"
                               Foreground="#888"
                               FontStyle="Italic"
                               Margin="20,0,0,0"/>
                </StackPanel>
            </Border>

            <!-- PO LINES -->
            <DataGrid Grid.Row="2"
                      x:Name="dgPoLines"
                      ItemsSource="{Binding PoLines}"
                      SelectedItem="{Binding SelectedLine, Mode=TwoWay}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      GridLinesVisibility="All"
                      IsReadOnly="False"
                      HorizontalGridLinesBrush="#C0C0C0"
                      VerticalGridLinesBrush="#D0D0D0"
                      RowHeight="28"
                      HeadersVisibility="Column"
                      Background="White"
                      BorderBrush="#A0A0A0"
                      BorderThickness="1"
                      SelectionMode="Single"
                      AlternatingRowBackground="#F9F9F9"
                      CellEditEnding="DgPoLines_CellEditEnding">

                <DataGrid.Resources>
                    <Style TargetType="DataGridCell" BasedOn="{StaticResource BaseCell}"/>
                </DataGrid.Resources>

                <DataGrid.Columns>
                    <DataGridTextColumn Header="Code"
                                        Binding="{Binding ItemCode}"
                                        Width="85"
                                        IsReadOnly="True"
                                        Foreground="#666"
                                        CellStyle="{StaticResource FrozenCell}"/>

                    <DataGridTextColumn Header="Attributes"
                                        Binding="{Binding VariantDescription}"
                                        Width="110"
                                        IsReadOnly="True"
                                        Foreground="#444"
                                        CellStyle="{StaticResource FrozenCell}"/>

                    <DataGridTextColumn Header="Vendor SKU"
                                        Binding="{Binding SupplierItemCode}"
                                        Width="105"
                                        IsReadOnly="True"
                                        Foreground="#005555"
                                        FontWeight="SemiBold"
                                        CellStyle="{StaticResource FrozenCell}"/>

                    <DataGridTextColumn Header="Description"
                                        Binding="{Binding Description}"
                                        Width="*"
                                        IsReadOnly="True"
                                        FontWeight="SemiBold"
                                        CellStyle="{StaticResource FrozenCell}"/>

                    <DataGridTemplateColumn Header="Qty" Width="75">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBox Text="{Binding OrderQty, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         TextAlignment="Center"
                                         FontWeight="Bold"
                                         BorderThickness="0"
                                         ToolTip="{Binding Moq, StringFormat=Minimum Order Qty: {0}}">
                                    <TextBox.Background>
                                        <MultiBinding Converter="{StaticResource MoqColorConverter}">
                                            <Binding Path="OrderQty"/>
                                            <Binding Path="Moq"/>
                                        </MultiBinding>
                                    </TextBox.Background>
                                </TextBox>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="Cost Rs." Width="95">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBox Text="{Binding ExpectedCost, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                         TextAlignment="Right"
                                         Background="#FFFFE0"
                                         BorderThickness="0"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="Disc" Width="75">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBox Text="{Binding LineDiscount, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                         TextAlignment="Right"
                                         Foreground="DarkRed"
                                         Background="#FFFFE0"
                                         BorderThickness="0"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTextColumn Header="Tax"
                                        Binding="{Binding TaxAmount, StringFormat=N2}"
                                        Width="75"
                                        IsReadOnly="True">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="Est. Total"
                                        Binding="{Binding LineTotal, StringFormat=N2}"
                                        Width="100"
                                        IsReadOnly="True"
                                        FontWeight="Bold">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                </DataGrid.Columns>
            </DataGrid>

            <!-- TOTALS FOOTER -->
            <Border Grid.Row="3"
                    Background="#D4D0C8"
                    BorderBrush="#A0A0A0"
                    BorderThickness="1"
                    Margin="0,5,0,0"
                    Padding="10">

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="15"/>
                        <ColumnDefinition Width="220"/>
                        <ColumnDefinition Width="15"/>
                        <ColumnDefinition Width="320"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Special Instructions / Supplier Notes:"
                                   Style="{StaticResource InlineLabel}"
                                   Margin="0,0,0,5"/>

                        <TextBox Text="{Binding Remarks, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 Height="75"
                                 Style="{StaticResource ClassicInput}"/>
                    </StackPanel>

                    <Rectangle Grid.Column="1"
                               Width="1"
                               Fill="#A0A0A0"
                               Margin="7,0"/>

                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                        <TextBlock Text="GLOBAL ESTIMATES"
                                   FontWeight="Bold"
                                   Foreground="#003366"
                                   Margin="0,0,0,10"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       Text="Est. Disc (-)"
                                       Style="{StaticResource InlineLabel}"
                                       Foreground="DarkRed"/>

                            <TextBox Grid.Column="1"
                                     Text="{Binding GlobalBillDiscount, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                     Style="{StaticResource ClassicInput}"
                                     HorizontalContentAlignment="Right"
                                     Background="#FEF2F2"/>
                        </Grid>

                        <TextBlock Text="Applied to total order value."
                                   FontSize="10"
                                   Foreground="#888"
                                   Margin="0,5,0,0"
                                   FontStyle="Italic"/>
                    </StackPanel>

                    <Rectangle Grid.Column="3"
                               Width="1"
                               Fill="#A0A0A0"
                               Margin="7,0"/>

                    <StackPanel Grid.Column="4" VerticalAlignment="Center">

                        <Grid Margin="0,0,0,4">
                            <TextBlock Text="EST. SUBTOTAL:"
                                       Foreground="#555"
                                       FontSize="12"
                                       FontWeight="Bold"/>

                            <TextBlock Text="{Binding Subtotal, StringFormat=Rs. \{0:N2\}}"
                                       HorizontalAlignment="Right"
                                       FontSize="12"
                                       FontWeight="Bold"/>
                        </Grid>

                        <Grid Margin="0,0,0,4">
                            <TextBlock Text="EST. DISCOUNTS:"
                                       Foreground="DarkRed"
                                       FontSize="12"
                                       FontWeight="Bold"/>

                            <TextBlock Text="{Binding TotalDiscountAmount, StringFormat=- Rs. \{0:N2\}}"
                                       HorizontalAlignment="Right"
                                       Foreground="DarkRed"
                                       FontSize="12"
                                       FontWeight="Bold"/>
                        </Grid>

                        <Grid Margin="0,0,0,8">
                            <TextBlock Text="EST. TAX:"
                                       Foreground="#555"
                                       FontSize="12"
                                       FontWeight="Bold"/>

                            <TextBlock Text="{Binding TotalTaxAmount, StringFormat=+ Rs. \{0:N2\}}"
                                       HorizontalAlignment="Right"
                                       FontSize="12"
                                       FontWeight="Bold"/>
                        </Grid>

                        <Rectangle Height="2"
                                   Fill="#333"
                                   Margin="0,0,0,8"/>

                        <Grid Margin="0,0,0,10">
                            <TextBlock Text="TOTAL EST. VALUE:"
                                       Foreground="#003366"
                                       FontSize="13"
                                       FontWeight="Bold"
                                       VerticalAlignment="Center"/>

                            <TextBlock Text="{Binding NetPayable, StringFormat=Rs. \{0:N2\}}"
                                       Foreground="#003366"
                                       FontSize="24"
                                       FontWeight="Bold"
                                       HorizontalAlignment="Right"/>
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Button Grid.Column="0"
                                    Content="Clear Form"
                                    Command="{Binding ClearCommand}"
                                    Style="{StaticResource ClassicBtn}"
                                    Height="36"/>

                            <Button Grid.Column="2"
                                    Content="SAVE PO"
                                    Command="{Binding SaveOrderCommand}"
                                    Background="#005500"
                                    Foreground="White"
                                    FontWeight="Bold"
                                    BorderBrush="#003300"
                                    BorderThickness="1"
                                    Height="36"
                                    Cursor="Hand"/>
                        </Grid>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>