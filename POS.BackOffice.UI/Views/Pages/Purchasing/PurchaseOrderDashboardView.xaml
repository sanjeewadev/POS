<UserControl x:Class="POS.BackOffice.UI.Views.Pages.Purchasing.PurchaseOrderDashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:conv="clr-namespace:POS.BackOffice.UI.Converters"
             mc:Ignorable="d"
             d:DesignHeight="750"
             d:DesignWidth="1300"
             Background="#D4D0C8"
             FontFamily="Segoe UI"
             FontSize="12">

    <UserControl.Resources>

        <conv:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>

        <Style TargetType="TextBlock" x:Key="HeaderLabel">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#003366"/>
        </Style>

        <Style TargetType="TextBlock" x:Key="InlineLabel">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,5,0"/>
        </Style>

        <Style TargetType="TextBox" x:Key="ClassicInput">
            <Setter Property="Height" Value="26"/>
            <Setter Property="Padding" Value="6,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="#808080"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Style.Triggers>
                <Trigger Property="IsReadOnly" Value="True">
                    <Setter Property="Background" Value="#E5E5E5"/>
                    <Setter Property="Foreground" Value="#555"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="ComboBox" x:Key="ClassicCombo">
            <Setter Property="Height" Value="26"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="#808080"/>
            <Setter Property="Background" Value="White"/>
        </Style>

        <Style TargetType="DatePicker" x:Key="ClassicDate">
            <Setter Property="Height" Value="26"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="#808080"/>
        </Style>

        <Style TargetType="Button" x:Key="ClassicBtn">
            <Setter Property="Height" Value="28"/>
            <Setter Property="Background" Value="#E0E0E0"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="15,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderBrush" Value="#808080"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#CCCCCC"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.55"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="Button" x:Key="ActionBtn" BasedOn="{StaticResource ClassicBtn}">
            <Setter Property="Background" Value="#005555"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#003333"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#007777"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="Button" x:Key="ViewBtn" BasedOn="{StaticResource ClassicBtn}">
            <Setter Property="Background" Value="#0066CC"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#004C99"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="Height" Value="24"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#E0E0E0"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="BorderBrush" Value="#A0A0A0"/>
        </Style>

        <Style TargetType="DataGridCell" x:Key="BaseCell">
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="6,0"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="Background" Value="Transparent"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#005555"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridCell" x:Key="FrozenCell" BasedOn="{StaticResource BaseCell}">
            <Setter Property="Background" Value="#F5F5F5"/>
        </Style>

    </UserControl.Resources>

    <Grid Margin="10">

        <!-- MASTER DASHBOARD -->
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="8"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- FILTER PANEL -->
            <Border Grid.Row="0"
                    Background="#F0F0F0"
                    BorderBrush="#A0A0A0"
                    BorderThickness="1"
                    Padding="10">

                <StackPanel>
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   Text="PURCHASE ORDER DASHBOARD"
                                   Style="{StaticResource HeaderLabel}"
                                   VerticalAlignment="Center"/>

                        <TextBlock Grid.Column="1"
                                   Text="{Binding StatusMessage}"
                                   VerticalAlignment="Center"
                                   Foreground="#666"
                                   FontSize="11"
                                   Margin="15,0"/>

                        <StackPanel Grid.Column="2" Orientation="Horizontal">
                            <Button Content="SEARCH"
                                    Command="{Binding SearchCommand}"
                                    Style="{StaticResource ActionBtn}"
                                    Margin="0,0,10,0"/>

                            <Button Content="REFRESH"
                                    Command="{Binding RefreshDatabaseCommand}"
                                    Style="{StaticResource ClassicBtn}"
                                    Margin="0,0,10,0"/>

                            <Button Content="CLEAR FILTERS"
                                    Command="{Binding ClearFiltersCommand}"
                                    Style="{StaticResource ClassicBtn}"
                                    Foreground="DarkRed"/>
                        </StackPanel>
                    </Grid>

                    <WrapPanel Orientation="Horizontal" VerticalAlignment="Center">

                        <StackPanel Orientation="Horizontal" Margin="0,0,15,5">
                            <TextBlock Text="Search:"
                                       Style="{StaticResource InlineLabel}"/>

                            <TextBox Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Width="180"
                                     Style="{StaticResource ClassicInput}"
                                     ToolTip="PO Number or Supplier">
                                <TextBox.InputBindings>
                                    <KeyBinding Key="Enter" Command="{Binding SearchCommand}"/>
                                </TextBox.InputBindings>
                            </TextBox>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,0,15,5">
                            <TextBlock Text="Supplier:"
                                       Style="{StaticResource InlineLabel}"/>

                            <ComboBox ItemsSource="{Binding FilterSuppliers}"
                                      SelectedItem="{Binding SelectedSupplierFilter, Mode=TwoWay}"
                                      DisplayMemberPath="SupplierName"
                                      Width="210"
                                      IsEditable="True"
                                      IsTextSearchEnabled="True"
                                      Style="{StaticResource ClassicCombo}"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,0,15,5">
                            <TextBlock Text="Status:"
                                       Style="{StaticResource InlineLabel}"/>

                            <ComboBox ItemsSource="{Binding FilterStatuses}"
                                      SelectedItem="{Binding SelectedStatusFilter, Mode=TwoWay}"
                                      Width="150"
                                      Style="{StaticResource ClassicCombo}"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,0,15,5">
                            <TextBlock Text="From:"
                                       Style="{StaticResource InlineLabel}"/>

                            <DatePicker SelectedDate="{Binding FilterStartDate, Mode=TwoWay}"
                                        Width="125"
                                        Style="{StaticResource ClassicDate}"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,0,15,5">
                            <TextBlock Text="To:"
                                       Style="{StaticResource InlineLabel}"/>

                            <DatePicker SelectedDate="{Binding FilterEndDate, Mode=TwoWay}"
                                        Width="125"
                                        Style="{StaticResource ClassicDate}"/>
                        </StackPanel>
                    </WrapPanel>
                </StackPanel>
            </Border>

            <!-- GRID -->
            <DataGrid Grid.Row="2"
                      ItemsSource="{Binding PurchaseOrders}"
                      SelectedItem="{Binding SelectedPo, Mode=TwoWay}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      IsReadOnly="True"
                      GridLinesVisibility="All"
                      HorizontalGridLinesBrush="#C0C0C0"
                      VerticalGridLinesBrush="#D0D0D0"
                      RowHeight="32"
                      HeadersVisibility="Column"
                      Background="White"
                      BorderBrush="#A0A0A0"
                      BorderThickness="1"
                      SelectionMode="Single"
                      AlternatingRowBackground="#F9F9F9">

                <DataGrid.Resources>
                    <Style TargetType="DataGridCell" BasedOn="{StaticResource BaseCell}"/>
                </DataGrid.Resources>

                <DataGrid.Columns>
                    <DataGridTemplateColumn Header="Actions" Width="95">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="View"
                                        Command="{Binding DataContext.ViewDetailsCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}"
                                        Style="{StaticResource ViewBtn}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTextColumn Header="PO Number"
                                        Binding="{Binding PoNumber}"
                                        Width="130"
                                        FontWeight="Bold"
                                        Foreground="#003366"/>

                    <DataGridTextColumn Header="Supplier Name"
                                        Binding="{Binding SupplierName}"
                                        Width="*"/>

                    <DataGridTextColumn Header="Order Date"
                                        Binding="{Binding OrderDate, StringFormat=d}"
                                        Width="105"/>

                    <DataGridTextColumn Header="Expected"
                                        Binding="{Binding ExpectedDate, StringFormat=d}"
                                        Width="105"/>

                    <DataGridTextColumn Header="Est. Total"
                                        Binding="{Binding NetPayable, StringFormat=N2}"
                                        Width="120"
                                        FontWeight="Bold"
                                        Foreground="#005500">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="Status"
                                        Binding="{Binding Status}"
                                        Width="145">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="Created By"
                                        Binding="{Binding CreatedBy}"
                                        Width="120"
                                        Foreground="#666"/>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>

        <!-- DETAILS OVERLAY -->
        <Grid Background="#D4D0C8"
              Visibility="{Binding ViewingPoDetails, Converter={StaticResource NullToVisibilityConverter}}">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- DETAILS HEADER -->
            <Border Grid.Row="0"
                    Background="#003366"
                    Padding="15,10"
                    BorderBrush="#002244"
                    BorderThickness="1">

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0"
                            Content="GO BACK"
                            Command="{Binding CloseDetailsCommand}"
                            Style="{StaticResource ClassicBtn}"
                            Background="#E0E0E0"
                            Foreground="Black"
                            Margin="0,0,20,0"/>

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">

                        <TextBlock Text="PO DETAILS:"
                                   Foreground="#A0C0E0"
                                   FontSize="18"
                                   FontWeight="Bold"/>

                        <TextBlock Text="{Binding ViewingPoDetails.PoNumber}"
                                   Foreground="White"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Margin="8,0,20,0"/>

                        <Border Background="#005555"
                                CornerRadius="4"
                                Padding="8,2">

                            <TextBlock Text="{Binding ViewingPoDetails.Status}"
                                       Foreground="White"
                                       FontWeight="Bold"
                                       FontSize="12"/>
                        </Border>
                    </StackPanel>

                    <Button Grid.Column="2"
                            Content="CANCEL PO"
                            Command="{Binding CancelPoCommand}"
                            Style="{StaticResource ClassicBtn}"
                            Background="#FEF2F2"
                            Foreground="DarkRed"
                            BorderBrush="DarkRed"
                            Margin="0,0,10,0"
                            Padding="15,0"/>

                    <Button Grid.Column="3"
                            Content="CLONE TO NEW PO"
                            Command="{Binding ClonePoCommand}"
                            Style="{StaticResource ActionBtn}"
                            Background="#0066CC"
                            BorderBrush="#004C99"
                            Margin="0,0,10,0"
                            Padding="15,0"/>

                    <Button Grid.Column="4"
                            Content="EXPORT PDF"
                            Command="{Binding PrintPoCommand}"
                            Style="{StaticResource ActionBtn}"
                            Background="#D97706"
                            BorderBrush="#B45309"
                            Padding="20,0"/>
                </Grid>
            </Border>

            <!-- DETAILS SUMMARY -->
            <Border Grid.Row="1"
                    Background="White"
                    BorderBrush="#A0A0A0"
                    BorderThickness="1,0,1,1"
                    Padding="15">

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.2*"/>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="1.2*"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="SUPPLIER"
                                   Foreground="#888"
                                   FontSize="10"
                                   FontWeight="Bold"
                                   Margin="0,0,0,2"/>

                        <TextBlock Text="{Binding ViewingPoDetails.Supplier.SupplierName}"
                                   FontSize="14"
                                   FontWeight="Bold"
                                   Foreground="#003366"/>

                        <TextBlock Text="{Binding ViewingPoDetails.Supplier.ContactPerson}"
                                   FontSize="12"
                                   Foreground="#444"
                                   Margin="0,2,0,0"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1">
                        <TextBlock Text="TIMELINE"
                                   Foreground="#888"
                                   FontSize="10"
                                   FontWeight="Bold"
                                   Margin="0,0,0,2"/>

                        <TextBlock Text="{Binding ViewingPoDetails.OrderDate, StringFormat={}{0:dd MMM yyyy}}"
                                   FontSize="12"
                                   FontWeight="SemiBold"/>

                        <TextBlock Text="{Binding ViewingPoDetails.ExpectedDate, StringFormat=Expected: {0:dd MMM yyyy}}"
                                   FontSize="12"
                                   Foreground="#005500"
                                   Margin="0,2,0,0"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="TERMS / REMARKS"
                                   Foreground="#888"
                                   FontSize="10"
                                   FontWeight="Bold"
                                   Margin="0,0,0,2"/>

                        <TextBlock Text="{Binding ViewingPoDetails.Terms}"
                                   FontSize="12"
                                   FontWeight="SemiBold"/>

                        <TextBlock Text="{Binding ViewingPoDetails.Remarks}"
                                   FontSize="11"
                                   Foreground="#666"
                                   Margin="0,2,0,0"
                                   TextTrimming="CharacterEllipsis"/>
                    </StackPanel>

                    <StackPanel Grid.Column="3"
                                HorizontalAlignment="Right">

                        <TextBlock Text="NET PAYABLE"
                                   Foreground="#888"
                                   FontSize="10"
                                   FontWeight="Bold"
                                   Margin="0,0,0,2"
                                   HorizontalAlignment="Right"/>

                        <TextBlock Text="{Binding ViewingPoDetails.NetPayable, StringFormat=N2}"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   Foreground="#005500"/>

                        <TextBlock Text="Rs."
                                   FontSize="11"
                                   Foreground="#666"
                                   HorizontalAlignment="Right"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- DETAILS LINES -->
            <DataGrid Grid.Row="2"
                      ItemsSource="{Binding ViewingPoDetails.PoLines}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      IsReadOnly="True"
                      GridLinesVisibility="All"
                      HorizontalGridLinesBrush="#C0C0C0"
                      VerticalGridLinesBrush="#D0D0D0"
                      RowHeight="30"
                      HeadersVisibility="Column"
                      Background="White"
                      BorderBrush="#A0A0A0"
                      BorderThickness="1"
                      SelectionMode="Single"
                      AlternatingRowBackground="#F9F9F9"
                      Margin="0,10,0,0">

                <DataGrid.Resources>
                    <Style TargetType="DataGridCell" BasedOn="{StaticResource BaseCell}"/>
                </DataGrid.Resources>

                <DataGrid.Columns>
                    <DataGridTextColumn Header="Internal Code"
                                        Binding="{Binding ItemCode}"
                                        Width="105"
                                        Foreground="#666"
                                        FontWeight="SemiBold"
                                        CellStyle="{StaticResource FrozenCell}"/>

                    <DataGridTextColumn Header="Item Description"
                                        Binding="{Binding Description}"
                                        Width="*"
                                        FontWeight="Bold"
                                        CellStyle="{StaticResource FrozenCell}"/>

                    <DataGridTextColumn Header="Variant"
                                        Binding="{Binding VariantDescription}"
                                        Width="150"
                                        Foreground="#444"/>

                    <DataGridTextColumn Header="Vendor SKU"
                                        Binding="{Binding SupplierItemCode}"
                                        Width="120"
                                        Foreground="#005555"
                                        FontWeight="SemiBold"/>

                    <DataGridTextColumn Header="Order Qty"
                                        Binding="{Binding OrderQty, StringFormat=N3}"
                                        Width="85">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="Received"
                                        Binding="{Binding ReceivedQty, StringFormat=N3}"
                                        Width="85"
                                        Foreground="#005500">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="Remaining"
                                        Binding="{Binding RemainingQty, StringFormat=N3}"
                                        Width="90">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="Unit Cost"
                                        Binding="{Binding ExpectedCost, StringFormat=N2}"
                                        Width="95">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="Discount"
                                        Binding="{Binding LineDiscount, StringFormat=N2}"
                                        Width="85"
                                        Foreground="DarkRed">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="Tax"
                                        Binding="{Binding TaxAmount, StringFormat=N2}"
                                        Width="80">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="Line Total"
                                        Binding="{Binding LineTotal, StringFormat=N2}"
                                        Width="110"
                                        FontWeight="Bold">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="Line Status"
                                        Binding="{Binding LineStatus}"
                                        Width="130">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </Grid>
</UserControl>