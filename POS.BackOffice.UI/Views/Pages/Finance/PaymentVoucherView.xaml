<UserControl x:Class="POS.BackOffice.UI.Views.Pages.Finance.PaymentVoucherView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="850" d:DesignWidth="1250"
             Background="#F5F5F5">

    <UserControl.Resources>
        <Style TargetType="Button" x:Key="StandardBtn">
            <Setter Property="Background" Value="#2B3C38"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#3B524E"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="Button" x:Key="PostBtn" BasedOn="{StaticResource StandardBtn}">
            <Setter Property="Background" Value="#6F42C1"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#5936A2"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="Button" x:Key="AutoBtn" BasedOn="{StaticResource StandardBtn}">
            <Setter Property="Background" Value="#2B5B84"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1C3F5E"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="Control" x:Key="StandardInput">
            <Setter Property="Padding" Value="5"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="BorderBrush" Value="#CCCCCC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Height" Value="30"/>
        </Style>

        <Style TargetType="Border" x:Key="GroupBoxBorder">
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="15"/>
            <Setter Property="Background" Value="White"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource GroupBoxBorder}" Margin="0,0,0,15">
            <StackPanel>
                <Grid Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Payment Voucher (Supplier Settlement)" FontSize="20" FontWeight="SemiBold" Foreground="#6F42C1"/>

                    <Border Grid.Column="1" Background="#FFF3CD" BorderBrush="#FFEEBA" BorderThickness="1" CornerRadius="4" Padding="10,5">
                        <TextBlock Text="Status: DRAFT" FontWeight="Bold" Foreground="#856404"/>
                    </Border>
                </Grid>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="1.5*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Supplier / Vendor *" Foreground="#2B5B84" FontWeight="SemiBold" Margin="0,0,0,5"/>
                        <ComboBox x:Name="cmbSupplier" Style="{StaticResource StandardInput}" IsEditable="True" Margin="0,0,0,5" ToolTip="Selecting a vendor loads their unpaid GRNs"/>

                        <Border Background="#FDF3F3" BorderBrush="#F5C6CB" BorderThickness="1" CornerRadius="2" Padding="5">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <TextBlock Text="Total Outstanding Payable:" Foreground="#A94044" FontSize="12" Margin="0,0,10,0"/>
                                <TextBlock x:Name="txtTotalDebt" Text="Rs. 0.00" Foreground="#A94044" FontSize="12" FontWeight="Bold"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Payment Date *" Foreground="#666666" Margin="0,0,0,5"/>
                        <DatePicker x:Name="dpPaymentDate" Style="{StaticResource StandardInput}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="4">
                        <TextBlock Text="Authorized By *" Foreground="#A94044" FontWeight="SemiBold" Margin="0,0,0,5"/>
                        <TextBox x:Name="txtAuthorizedBy" Style="{StaticResource StandardInput}" ToolTip="Manager or Director authorizing this cash outflow"/>
                    </StackPanel>

                    <StackPanel Grid.Column="6">
                        <TextBlock Text="Voucher No." Foreground="#666666" Margin="0,0,0,5"/>
                        <TextBox x:Name="txtVoucherNo" Style="{StaticResource StandardInput}" Background="#EEEEEE" IsReadOnly="True" Text="[Auto-Generated]"/>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Background="#F9F5FF" BorderBrush="#E5D6FA" BorderThickness="1" CornerRadius="4" Padding="15" Margin="0,0,0,15">
            <StackPanel>
                <TextBlock Text="Payment Source &amp; Physical Outflow" FontWeight="SemiBold" Foreground="#6F42C1" Margin="0,0,0,10"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="1.5*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="1.5*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="1.5*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Method *" Foreground="#333333" Margin="0,0,0,5"/>
                        <ComboBox x:Name="cmbPaymentMethod" Style="{StaticResource StandardInput}" Margin="0">
                            <ComboBoxItem Content="Cash"/>
                            <ComboBoxItem Content="Cheque" IsSelected="True"/>
                            <ComboBoxItem Content="Bank Transfer"/>
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Paying From (Source) *" Foreground="#A94044" FontWeight="SemiBold" Margin="0,0,0,5"/>
                        <ComboBox x:Name="cmbSourceAccount" Style="{StaticResource StandardInput}" Margin="0" Background="#FFFFE0" ToolTip="Which bank account or safe is this money leaving from?">
                            <ComboBoxItem Content="Main Shop Petty Cash"/>
                            <ComboBoxItem Content="BOC Current Account"/>
                            <ComboBoxItem Content="Commercial Bank Account"/>
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Grid.Column="4">
                        <TextBlock Text="Total Amount Paid *" Foreground="#6F42C1" FontWeight="Bold" Margin="0,0,0,5"/>
                        <TextBox x:Name="txtAmountPaid" Style="{StaticResource StandardInput}" HorizontalContentAlignment="Right" Background="#FFFFE0" FontWeight="Bold" Margin="0" Text="0.00"/>
                    </StackPanel>

                    <StackPanel Grid.Column="6">
                        <TextBlock Text="Cheque / Transfer Ref No." Foreground="#666666" Margin="0,0,0,5"/>
                        <TextBox x:Name="txtReferenceNo" Style="{StaticResource StandardInput}" Margin="0"/>
                    </StackPanel>

                    <StackPanel Grid.Column="8">
                        <TextBlock Text="Cheque Date" Foreground="#666666" Margin="0,0,0,5"/>
                        <DatePicker x:Name="dpChequeDate" Style="{StaticResource StandardInput}" Margin="0" ToolTip="Use for Post-Dated Cheques (PDC)"/>
                    </StackPanel>

                    <Button Grid.Column="10" x:Name="btnAutoAllocate" Content="Auto-Allocate" Style="{StaticResource AutoBtn}" Margin="0" VerticalAlignment="Bottom" Height="30" Width="110" ToolTip="Automatically distributes the Paid Amount to the oldest unpaid bills"/>
                </Grid>
            </StackPanel>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource GroupBoxBorder}" Padding="0" Margin="0,0,0,15">
            <DockPanel>
                <Border DockPanel.Dock="Top" Background="#F8F8F8" BorderBrush="#DDDDDD" BorderThickness="0,0,0,1" Padding="15,10">
                    <TextBlock Text="Unpaid Supplier Bills (Goods Received Notes)" FontWeight="SemiBold" Foreground="#333333"/>
                </Border>

                <DataGrid x:Name="dgUnpaidBills" 
                          AutoGenerateColumns="False" 
                          CanUserAddRows="False" 
                          CanUserDeleteRows="False" 
                          HeadersVisibility="Column" 
                          GridLinesVisibility="Horizontal"
                          HorizontalGridLinesBrush="#EEEEEE"
                          BorderThickness="0"
                          RowHeight="40"
                          Background="Transparent">

                    <DataGrid.Resources>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#FFFFFF"/>
                            <Setter Property="Foreground" Value="#666666"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="Padding" Value="15,10"/>
                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                            <Setter Property="BorderBrush" Value="#DDDDDD"/>
                        </Style>
                        <Style TargetType="DataGridCell">
                            <Setter Property="Padding" Value="15,0"/>
                            <Setter Property="VerticalContentAlignment" Value="Center"/>
                        </Style>
                    </DataGrid.Resources>

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="GRN / Invoice No." Binding="{Binding GRNNo}" Width="140" IsReadOnly="True" FontWeight="SemiBold"/>
                        <DataGridTextColumn Header="Bill Date" Binding="{Binding BillDate, StringFormat=dd/MM/yyyy}" Width="100" IsReadOnly="True"/>

                        <DataGridTextColumn Header="Due Date" Binding="{Binding DueDate, StringFormat=dd/MM/yyyy}" Width="100" IsReadOnly="True">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#A94044"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="Original Amt" Binding="{Binding OriginalAmount, StringFormat=N2}" Width="110" IsReadOnly="True">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Right"/>
                                    <Setter Property="Foreground" Value="#666666"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="Outstanding Balance" Binding="{Binding OutstandingBalance, StringFormat=N2}" Width="140" IsReadOnly="True">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Right"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                    <Setter Property="Foreground" Value="#A94044"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTemplateColumn Header="Discount Rcvd (Rs.)" Width="140">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBox Text="{Binding DiscountReceived, StringFormat=N2, UpdateSourceTrigger=PropertyChanged}" 
                                             Background="#F4FAF6" BorderBrush="#CCCCCC" BorderThickness="1" 
                                             HorizontalContentAlignment="Right" VerticalContentAlignment="Center" 
                                             Padding="5" Foreground="#28A745" ToolTip="Enter any early payment discount granted by the supplier to clear this bill"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="Paying Now (Rs.)" Width="140">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBox Text="{Binding AllocatedAmount, StringFormat=N2, UpdateSourceTrigger=PropertyChanged}" 
                                             Background="#FFFFE0" BorderBrush="#CCCCCC" BorderThickness="1" 
                                             HorizontalContentAlignment="Right" VerticalContentAlignment="Center" 
                                             Padding="5" FontWeight="Bold" Foreground="#6F42C1"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </DockPanel>
        </Border>

        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#F8F8F8" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="4" Padding="15" Margin="0,0,20,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Payment Narration / Remarks:" Foreground="#666666" FontSize="12" Margin="0,0,0,5"/>
                        <TextBox x:Name="txtRemarks" Height="65" TextWrapping="Wrap" AcceptsReturn="True" BorderBrush="#CCCCCC" BorderThickness="1" Padding="5"/>
                    </StackPanel>

                    <Grid Grid.Column="2" HorizontalAlignment="Right" MinWidth="320">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <DockPanel Grid.Row="0" Margin="0,0,0,5">
                            <TextBlock Text="Total Paid (Physical Outflow):" Foreground="#333333"/>
                            <TextBlock x:Name="txtSummaryPaid" Text="Rs. 0.00" FontWeight="SemiBold" HorizontalAlignment="Right" Foreground="#333333"/>
                        </DockPanel>

                        <DockPanel Grid.Row="1" Margin="0,0,0,5">
                            <TextBlock Text="Total Discount Claimed:" Foreground="#28A745"/>
                            <TextBlock x:Name="txtSummaryDiscount" Text="Rs. 0.00" HorizontalAlignment="Right" Foreground="#28A745"/>
                        </DockPanel>

                        <DockPanel Grid.Row="2" Margin="0,0,0,10">
                            <TextBlock Text="Total Allocated to Bills:" Foreground="#6F42C1"/>
                            <TextBlock x:Name="txtSummaryAllocated" Text="Rs. 0.00" FontWeight="Bold" HorizontalAlignment="Right" Foreground="#6F42C1"/>
                        </DockPanel>

                        <Border Grid.Row="3" Background="#E2EDF8" BorderBrush="#B6D4FE" BorderThickness="1" Padding="5,2" CornerRadius="2">
                            <DockPanel>
                                <TextBlock Text="Unallocated Balance (Advance):" Foreground="#2B5B84" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                <TextBlock x:Name="txtUnallocated" Text="Rs. 0.00" FontWeight="Bold" FontSize="16" Foreground="#2B5B84" HorizontalAlignment="Right" ToolTip="This amount will remain as a positive credit on your account with this supplier"/>
                            </DockPanel>
                        </Border>
                    </Grid>
                </Grid>
            </Border>

            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Bottom">
                <Button Content="Clear Form" Style="{StaticResource StandardBtn}" Background="#777777" Width="100"/>
                <Button Content="POST PAYMENT VOUCHER" Style="{StaticResource PostBtn}" Width="210" Margin="0" ToolTip="Deducts money from CashBook and clears allocated Accounts Payable debts"/>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>