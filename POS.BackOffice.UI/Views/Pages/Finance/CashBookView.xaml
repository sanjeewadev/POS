<UserControl x:Class="POS.BackOffice.UI.Views.Pages.Finance.CashBookView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="850" d:DesignWidth="1250"
             Background="#F5F5F5">

    <UserControl.Resources>
        <!-- Standard Button Style -->
        <Style TargetType="Button" x:Key="StandardBtn">
            <Setter Property="Background" Value="#2B3C38"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#3B524E"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Search / Load Button (Blue) -->
        <Style TargetType="Button" x:Key="SearchBtn" BasedOn="{StaticResource StandardBtn}">
            <Setter Property="Background" Value="#2B5B84"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1C3F5E"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Excel Export Button (Green) -->
        <Style TargetType="Button" x:Key="ExcelBtn" BasedOn="{StaticResource StandardBtn}">
            <Setter Property="Background" Value="#28A745"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#218838"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Quick Date Button Style -->
        <Style TargetType="Button" x:Key="QuickDateBtn" BasedOn="{StaticResource StandardBtn}">
            <Setter Property="Background" Value="#E2EDF8"/>
            <Setter Property="Foreground" Value="#2B5B84"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Margin" Value="0,0,5,0"/>
            <Setter Property="BorderBrush" Value="#B6D4FE"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#B6D4FE"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Standard Input Style -->
        <Style TargetType="Control" x:Key="StandardInput">
            <Setter Property="Padding" Value="5"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="BorderBrush" Value="#CCCCCC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Height" Value="30"/>
        </Style>

        <!-- Group Box Border Style -->
        <Style TargetType="Border" x:Key="GroupBoxBorder">
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="15"/>
            <Setter Property="Background" Value="White"/>
        </Style>

        <!-- KPI Card Style -->
        <Style TargetType="Border" x:Key="KpiCard">
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="20,15"/>
            <Setter Property="Margin" Value="0,0,15,0"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Header (Ledger Controls) -->
            <RowDefinition Height="Auto"/>
            <!-- KPI Dashboard Cards -->
            <RowDefinition Height="*"/>
            <!-- Data Grid (Transaction Ledger) -->
            <RowDefinition Height="Auto"/>
            <!-- Footer (Bank Reconciliation) -->
        </Grid.RowDefinitions>

        <!-- ========================================== -->
        <!-- ZONE 1: LEDGER ENGINE CONTROLS (FILTERS)   -->
        <!-- ========================================== -->
        <Border Grid.Row="0" Style="{StaticResource GroupBoxBorder}" Margin="0,0,0,15">
            <StackPanel>
                <TextBlock Text="Cash Book &amp; Bank Ledger" FontSize="20" FontWeight="SemiBold" Foreground="#333333" Margin="0,0,0,15"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="1.5*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="1.5*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- The Critical Account Selector -->
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Select Account Ledger *" Foreground="#2B5B84" FontWeight="SemiBold" Margin="0,0,0,5"/>
                        <ComboBox x:Name="cmbAccountLedger" Style="{StaticResource StandardInput}" Background="#F0F8FF" ToolTip="Select which cash box or bank account to view">
                            <ComboBoxItem Content="Main Shop Petty Cash" IsSelected="True"/>
                            <ComboBoxItem Content="Bank of Ceylon - Current A/C"/>
                            <ComboBoxItem Content="Commercial Bank - Savings"/>
                            <ComboBoxItem Content="Undeposited Cheques"/>
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Date From *" Foreground="#666666" Margin="0,0,0,5"/>
                        <DatePicker x:Name="dpFromDate" Style="{StaticResource StandardInput}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="4">
                        <TextBlock Text="Date To *" Foreground="#666666" Margin="0,0,0,5"/>
                        <DatePicker x:Name="dpToDate" Style="{StaticResource StandardInput}"/>
                    </StackPanel>

                    <Button Grid.Column="6" x:Name="btnLoadLedger" Content="Load Ledger" Style="{StaticResource SearchBtn}" Margin="0" VerticalAlignment="Bottom" Height="30" Width="130"/>
                </Grid>

                <!-- Quick Filters -->
                <Grid Margin="0,5,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <TextBlock Text="Quick Dates:" VerticalAlignment="Center" Foreground="#666666" Margin="0,0,10,0"/>
                        <Button Content="This Month" Style="{StaticResource QuickDateBtn}"/>
                        <Button Content="Last Month" Style="{StaticResource QuickDateBtn}"/>
                        <Button Content="This Quarter" Style="{StaticResource QuickDateBtn}"/>
                        <Button Content="This Year" Style="{StaticResource QuickDateBtn}"/>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>

        <!-- ========================================== -->
        <!-- ZONE 2: FINANCIAL KPI SUMMARY CARDS        -->
        <!-- ========================================== -->
        <UniformGrid Grid.Row="1" Columns="4" Margin="0,0,-15,15">

            <!-- Card 1: Opening Balance -->
            <Border Style="{StaticResource KpiCard}" Background="#E2EDF8" BorderBrush="#B6D4FE">
                <StackPanel>
                    <TextBlock Text="Opening Balance" Foreground="#2B5B84" FontSize="13" FontWeight="SemiBold"/>
                    <TextBlock x:Name="txtKpiOpening" Text="Rs. 150,000.00" FontWeight="Bold" FontSize="24" Foreground="#2B5B84" Margin="0,5,0,0"/>
                    <TextBlock Text="As of selected From Date" Foreground="#2B5B84" FontSize="11" Margin="0,2,0,0" Opacity="0.8"/>
                </StackPanel>
            </Border>

            <!-- Card 2: Total Money IN -->
            <Border Style="{StaticResource KpiCard}" Background="#F4FAF6" BorderBrush="#C3E6CB">
                <StackPanel>
                    <TextBlock Text="Total Debits (Money IN)" Foreground="#28A745" FontSize="13" FontWeight="SemiBold"/>
                    <TextBlock x:Name="txtKpiMoneyIn" Text="Rs. 420,500.00" FontWeight="Bold" FontSize="24" Foreground="#28A745" Margin="0,5,0,0"/>
                    <TextBlock Text="Receipts &amp; Deposits" Foreground="#28A745" FontSize="11" Margin="0,2,0,0" Opacity="0.8"/>
                </StackPanel>
            </Border>

            <!-- Card 3: Total Money OUT -->
            <Border Style="{StaticResource KpiCard}" Background="#FDF3F3" BorderBrush="#F5C6CB">
                <StackPanel>
                    <TextBlock Text="Total Credits (Money OUT)" Foreground="#A94044" FontSize="13" FontWeight="SemiBold"/>
                    <TextBlock x:Name="txtKpiMoneyOut" Text="Rs. 210,000.00" FontWeight="Bold" FontSize="24" Foreground="#A94044" Margin="0,5,0,0"/>
                    <TextBlock Text="Payments &amp; Expenses" Foreground="#A94044" FontSize="11" Margin="0,2,0,0" Opacity="0.8"/>
                </StackPanel>
            </Border>

            <!-- Card 4: Closing Balance (The most important number) -->
            <Border Style="{StaticResource KpiCard}" Background="#F9F5FF" BorderBrush="#E5D6FA">
                <StackPanel>
                    <TextBlock Text="Closing / Running Balance" Foreground="#6F42C1" FontSize="13" FontWeight="SemiBold"/>
                    <TextBlock x:Name="txtKpiClosing" Text="Rs. 360,500.00" FontWeight="Bold" FontSize="24" Foreground="#6F42C1" Margin="0,5,0,0"/>
                    <TextBlock Text="Actual expected physical funds" Foreground="#6F42C1" FontSize="11" Margin="0,2,0,0" Opacity="0.8"/>
                </StackPanel>
            </Border>

        </UniformGrid>

        <!-- ========================================== -->
        <!-- ZONE 3: TRANSACTION LEDGER (THE GRID)      -->
        <!-- ========================================== -->
        <Border Grid.Row="2" Style="{StaticResource GroupBoxBorder}" Padding="0" Margin="0,0,0,15">
            <DataGrid x:Name="dgCashBook" 
                      AutoGenerateColumns="False" 
                      CanUserAddRows="False" 
                      CanUserDeleteRows="False" 
                      HeadersVisibility="Column" 
                      GridLinesVisibility="Horizontal"
                      HorizontalGridLinesBrush="#EEEEEE"
                      BorderThickness="0"
                      RowHeight="40"
                      Background="Transparent"
                      SelectionMode="Single">

                <DataGrid.Resources>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#F8F8F8"/>
                        <Setter Property="Foreground" Value="#333333"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="Padding" Value="10,10"/>
                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                        <Setter Property="BorderBrush" Value="#DDDDDD"/>
                    </Style>
                    <Style TargetType="DataGridCell">
                        <Setter Property="Padding" Value="10,0"/>
                        <Setter Property="VerticalContentAlignment" Value="Center"/>
                    </Style>
                </DataGrid.Resources>

                <DataGrid.Columns>
                    <!-- Reconciliation Checkbox (For Bank Rec Mode) -->
                    <DataGridCheckBoxColumn Header="Clr" Binding="{Binding IsCleared, UpdateSourceTrigger=PropertyChanged}" Width="50">
                        <DataGridCheckBoxColumn.ElementStyle>
                            <Style TargetType="CheckBox">
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="ToolTip" Value="Mark as Cleared on Bank Statement"/>
                            </Style>
                        </DataGridCheckBoxColumn.ElementStyle>
                    </DataGridCheckBoxColumn>

                    <DataGridTextColumn Header="Date" Binding="{Binding TransactionDate, StringFormat=dd/MM/yyyy}" Width="100" IsReadOnly="True"/>

                    <DataGridTextColumn Header="Doc Ref." Binding="{Binding ReferenceNo}" Width="130" IsReadOnly="True" Foreground="#666666"/>

                    <DataGridTextColumn Header="Type" Binding="{Binding DocumentType}" Width="130" IsReadOnly="True" FontWeight="SemiBold"/>

                    <DataGridTextColumn Header="Narration / Description" Binding="{Binding Narration}" Width="*" IsReadOnly="True"/>

                    <!-- Money IN (Debits) -->
                    <DataGridTextColumn Header="Money IN (Rs.)" Binding="{Binding MoneyIn, StringFormat=N2}" Width="130" IsReadOnly="True">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="Foreground" Value="#28A745"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <!-- Money OUT (Credits) -->
                    <DataGridTextColumn Header="Money OUT (Rs.)" Binding="{Binding MoneyOut, StringFormat=N2}" Width="130" IsReadOnly="True">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="Foreground" Value="#A94044"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <!-- Running Balance -->
                    <DataGridTextColumn Header="Balance (Rs.)" Binding="{Binding RunningBalance, StringFormat=N2}" Width="130" IsReadOnly="True">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="Foreground" Value="#6F42C1"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <!-- View Document Action -->
                    <DataGridTemplateColumn Header="Action" Width="70">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="View" Background="#2B5B84" Foreground="White" BorderThickness="0" Cursor="Hand" Padding="5,2" ToolTip="Open the original source document"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- ========================================== -->
        <!-- ZONE 4: FOOTER (BANK RECONCILIATION)       -->
        <!-- ========================================== -->
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Enterprise Feature: Bank Reconciliation Engine -->
            <Border Grid.Column="0" Background="#FFF8EB" BorderBrush="#FDE0A6" BorderThickness="1" CornerRadius="4" Padding="15" Margin="0,0,20,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Rec Mode Toggle -->
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <CheckBox x:Name="chkReconciliationMode" Content="Enable Bank Reconciliation Mode" FontWeight="Bold" Foreground="#D97706" ToolTip="Allows you to match system entries against your physical bank statement"/>
                        <TextBlock Text="Check off cleared items in the grid (Clr)" Foreground="#D97706" FontSize="11" Margin="20,2,0,0"/>
                    </StackPanel>

                    <!-- Statement Balance Input -->
                    <StackPanel Grid.Column="2" VerticalAlignment="Center" Orientation="Horizontal">
                        <TextBlock Text="Bank Statement Ending Balance:" Foreground="#333333" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBox x:Name="txtStatementBalance" Width="140" Height="30" Text="0.00" HorizontalContentAlignment="Right" FontWeight="Bold" BorderBrush="#CCCCCC" BorderThickness="1" Padding="5"/>
                    </StackPanel>

                    <!-- Variance Indicator -->
                    <StackPanel Grid.Column="4" VerticalAlignment="Center" HorizontalAlignment="Right">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Unreconciled Variance:" Foreground="#666666" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <Border Background="#FDF3F3" BorderBrush="#F5C6CB" BorderThickness="1" CornerRadius="2" Padding="10,5">
                                <TextBlock x:Name="txtVariance" Text="Rs. 0.00" FontWeight="Bold" Foreground="#A94044"/>
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Action Buttons -->
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Bottom">
                <Button Content="Export Ledger (Excel)" Style="{StaticResource ExcelBtn}" Width="160"/>
                <Button Content="Print Statement" Style="{StaticResource SearchBtn}" Width="140" Margin="0"/>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>