<UserControl x:Class="POS.BackOffice.UI.Views.Pages.Finance.BankDepositView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="850" d:DesignWidth="1250"
             Background="#F5F5F5">

    <UserControl.Resources>
        <!-- Standard Button Style -->
        <Style TargetType="Button" x:Key="StandardBtn">
            <Setter Property="Background" Value="#2B3C38"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#3B524E"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Post Action Button (Trustworthy Bank Blue) -->
        <Style TargetType="Button" x:Key="PostBtn" BasedOn="{StaticResource StandardBtn}">
            <Setter Property="Background" Value="#0052CC"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#0043A6"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Fetch/Action Button (Teal) -->
        <Style TargetType="Button" x:Key="ActionBtn" BasedOn="{StaticResource StandardBtn}">
            <Setter Property="Background" Value="#17A2B8"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#138496"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Denomination/Upload Button (Outline Style) -->
        <Style TargetType="Button" x:Key="OutlineBtn" BasedOn="{StaticResource StandardBtn}">
            <Setter Property="Background" Value="#E2EDF8"/>
            <Setter Property="Foreground" Value="#0052CC"/>
            <Setter Property="BorderBrush" Value="#B6D4FE"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#B6D4FE"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Standard Input Style -->
        <Style TargetType="Control" x:Key="StandardInput">
            <Setter Property="Padding" Value="5"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="BorderBrush" Value="#CCCCCC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Height" Value="30"/>
        </Style>

        <!-- Group Box Border Style -->
        <Style TargetType="Border" x:Key="GroupBoxBorder">
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="15"/>
            <Setter Property="Background" Value="White"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Header (Destination) -->
            <RowDefinition Height="Auto"/>
            <!-- Source Filter (Origin) -->
            <RowDefinition Height="*"/>
            <!-- Data Grid (Undeposited Funds Checklist) -->
            <RowDefinition Height="Auto"/>
            <!-- Footer (Totals & Slip Info) -->
        </Grid.RowDefinitions>

        <!-- ========================================== -->
        <!-- ZONE 1: DOCUMENT HEADER (DESTINATION)      -->
        <!-- ========================================== -->
        <Border Grid.Row="0" Style="{StaticResource GroupBoxBorder}" Margin="0,0,0,15">
            <StackPanel>
                <Grid Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Bank Deposit (Asset Transfer)" FontSize="20" FontWeight="SemiBold" Foreground="#0052CC"/>

                    <Border Grid.Column="1" Background="#FFF3CD" BorderBrush="#FFEEBA" BorderThickness="1" CornerRadius="4" Padding="10,5">
                        <TextBlock Text="Status: DRAFT" FontWeight="Bold" Foreground="#856404"/>
                    </Border>
                </Grid>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="1.5*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="1.5*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Target Bank Account (Destination) *" Foreground="#0052CC" FontWeight="SemiBold" Margin="0,0,0,5"/>
                        <ComboBox x:Name="cmbTargetAccount" Style="{StaticResource StandardInput}" Background="#F0F8FF" ToolTip="Which bank account is receiving this money?">
                            <ComboBoxItem Content="Bank of Ceylon - Current A/C (12345678)" IsSelected="True"/>
                            <ComboBoxItem Content="Commercial Bank - Savings (87654321)"/>
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Deposit Date *" Foreground="#666666" Margin="0,0,0,5"/>
                        <DatePicker x:Name="dpDepositDate" Style="{StaticResource StandardInput}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="4">
                        <TextBlock Text="Deposited By (Employee) *" Foreground="#666666" FontWeight="SemiBold" Margin="0,0,0,5"/>
                        <TextBox x:Name="txtDepositedBy" Style="{StaticResource StandardInput}" ToolTip="Name of the person physically taking the funds to the bank"/>
                    </StackPanel>

                    <StackPanel Grid.Column="6">
                        <TextBlock Text="Deposit Ref No." Foreground="#666666" Margin="0,0,0,5"/>
                        <TextBox x:Name="txtDepositNo" Style="{StaticResource StandardInput}" Background="#EEEEEE" IsReadOnly="True" Text="[Auto-Generated]"/>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>

        <!-- ========================================== -->
        <!-- ZONE 2: SOURCE FILTER (ORIGIN)             -->
        <!-- ========================================== -->
        <Border Grid.Row="1" Background="#F8FAFC" BorderBrush="#DAE4F0" BorderThickness="1" CornerRadius="4" Padding="15" Margin="0,0,0,15">
            <StackPanel>
                <TextBlock Text="Find Undeposited Funds" FontWeight="SemiBold" Foreground="#17A2B8" Margin="0,0,0,10"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="1.5*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Source Location (Origin)" Foreground="#333333" Margin="0,0,0,5"/>
                        <ComboBox x:Name="cmbSourceLocation" Style="{StaticResource StandardInput}" Margin="0">
                            <ComboBoxItem Content="Main Branch Safe / Petty Cash" IsSelected="True"/>
                            <ComboBoxItem Content="Undeposited Cheques Ledger"/>
                            <ComboBoxItem Content="Till 01 Drawer"/>
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Filter Tender Type" Foreground="#333333" Margin="0,0,0,5"/>
                        <ComboBox x:Name="cmbTenderFilter" Style="{StaticResource StandardInput}" Margin="0">
                            <ComboBoxItem Content="Show All (Cash &amp; Cheques)" IsSelected="True"/>
                            <ComboBoxItem Content="Cash Only"/>
                            <ComboBoxItem Content="Cheques Only"/>
                        </ComboBox>
                    </StackPanel>

                    <Button Grid.Column="4" x:Name="btnFetchFunds" Content="Fetch Pending Funds" Style="{StaticResource ActionBtn}" Margin="0" VerticalAlignment="Bottom" Height="30" Width="160" ToolTip="Loads all money sitting in the selected safe into the grid below"/>
                </Grid>
            </StackPanel>
        </Border>

        <!-- ========================================== -->
        <!-- ZONE 3: UNDEPOSITED FUNDS GRID (CHECKLIST) -->
        <!-- ========================================== -->
        <Border Grid.Row="2" Style="{StaticResource GroupBoxBorder}" Padding="0" Margin="0,0,0,15">
            <DockPanel>
                <Border DockPanel.Dock="Top" Background="#F8F8F8" BorderBrush="#DDDDDD" BorderThickness="0,0,0,1" Padding="15,10">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Pending Funds Checklist" FontWeight="SemiBold" Foreground="#333333" VerticalAlignment="Center" Margin="0,0,15,0"/>
                        <Button Content="Select All" Background="Transparent" Foreground="#0052CC" BorderThickness="0" Cursor="Hand" Padding="5,0" FontWeight="SemiBold"/>
                        <Button Content="Deselect All" Background="Transparent" Foreground="#A94044" BorderThickness="0" Cursor="Hand" Padding="15,0,5,0"/>
                    </StackPanel>
                </Border>

                <DataGrid x:Name="dgPendingFunds" 
                          AutoGenerateColumns="False" 
                          CanUserAddRows="False" 
                          CanUserDeleteRows="False" 
                          HeadersVisibility="Column" 
                          GridLinesVisibility="Horizontal"
                          HorizontalGridLinesBrush="#EEEEEE"
                          BorderThickness="0"
                          RowHeight="40"
                          Background="Transparent"
                          SelectionMode="Single">

                    <DataGrid.Resources>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#FFFFFF"/>
                            <Setter Property="Foreground" Value="#666666"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="Padding" Value="15,10"/>
                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                            <Setter Property="BorderBrush" Value="#DDDDDD"/>
                        </Style>
                        <Style TargetType="DataGridCell">
                            <Setter Property="Padding" Value="15,0"/>
                            <Setter Property="VerticalContentAlignment" Value="Center"/>
                        </Style>
                    </DataGrid.Resources>

                    <DataGrid.Columns>
                        <!-- THE INTERACTIVE CHECKBOX -->
                        <DataGridCheckBoxColumn Header="Select" Binding="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}" Width="70">
                            <DataGridCheckBoxColumn.ElementStyle>
                                <Style TargetType="CheckBox">
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <!-- Scale up the checkbox for easier clicking -->
                                    <Setter Property="LayoutTransform">
                                        <Setter.Value>
                                            <ScaleTransform ScaleX="1.3" ScaleY="1.3"/>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </DataGridCheckBoxColumn.ElementStyle>
                        </DataGridCheckBoxColumn>

                        <DataGridTextColumn Header="Date Received" Binding="{Binding DateReceived, StringFormat=dd/MM/yyyy}" Width="120" IsReadOnly="True"/>
                        <DataGridTextColumn Header="Origin Ref (Receipt No)" Binding="{Binding ReceiptNo}" Width="150" IsReadOnly="True" Foreground="#666666"/>
                        <DataGridTextColumn Header="Customer / Source" Binding="{Binding SourceName}" Width="*" IsReadOnly="True"/>

                        <DataGridTextColumn Header="Tender Type" Binding="{Binding TenderType}" Width="120" IsReadOnly="True">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="Foreground" Value="#0052CC"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="Cheque / Ref No." Binding="{Binding ReferenceNo}" Width="140" IsReadOnly="True" Foreground="#666666"/>

                        <DataGridTextColumn Header="Amount (Rs.)" Binding="{Binding Amount, StringFormat=N2}" Width="140" IsReadOnly="True">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Right"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                    <Setter Property="Foreground" Value="#333333"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </DockPanel>
        </Border>

        <!-- ========================================== -->
        <!-- ZONE 4: FOOTER (RECONCILIATION & SLIP)     -->
        <!-- ========================================== -->
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT: Bank Slip Info & Denominations -->
            <Border Grid.Column="0" Background="#F8F8F8" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="4" Padding="15">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,0,10">
                        <TextBlock Text="Physical Bank Slip ID / Ref *" Foreground="#0052CC" FontWeight="SemiBold" FontSize="12" Margin="0,0,0,5"/>
                        <TextBox x:Name="txtBankSlipId" Style="{StaticResource StandardInput}" Margin="0" Background="#FFFFE0" ToolTip="The serial number printed on the paper deposit slip given to the teller"/>
                    </StackPanel>

                    <StackPanel Grid.Row="0" Grid.Column="2" Margin="0,0,0,10" VerticalAlignment="Bottom">
                        <!-- Auditor's Feature: Receipt Upload -->
                        <Button Content="📎 Attach Stamped Bank Slip" Style="{StaticResource OutlineBtn}" Height="30" Margin="0" ToolTip="Upload a scanned image or photo of the bank teller's stamped receipt"/>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3" Orientation="Horizontal">
                        <TextBlock Text="Narration:" Foreground="#666666" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBox x:Name="txtNarration" Width="300" Height="30" BorderBrush="#CCCCCC" BorderThickness="1" Padding="5" Margin="0,0,15,0"/>

                        <!-- ENTERPRISE FEATURE: Denomination Calculator -->
                        <Button x:Name="btnDenominations" Content="🧮 Enter Cash Denominations" Style="{StaticResource OutlineBtn}" Height="30" Padding="15,0" ToolTip="Opens a calculator to log the exact count of physical notes (Rs. 5000, Rs. 1000, etc.)"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- RIGHT: Total Settlement & Action -->
            <Border Grid.Column="2" Background="#E2EDF8" BorderBrush="#B6D4FE" BorderThickness="1" CornerRadius="4" Padding="15">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Subtotals -->
                    <DockPanel Grid.Row="0" Margin="0,0,0,5">
                        <TextBlock Text="Selected Cash:" Foreground="#666666"/>
                        <TextBlock x:Name="txtSumCash" Text="Rs. 0.00" HorizontalAlignment="Right" Foreground="#666666"/>
                    </DockPanel>

                    <DockPanel Grid.Row="1" Margin="0,0,0,10">
                        <TextBlock Text="Selected Cheques:" Foreground="#666666"/>
                        <TextBlock x:Name="txtSumCheques" Text="Rs. 0.00" HorizontalAlignment="Right" Foreground="#666666"/>
                    </DockPanel>

                    <Rectangle Grid.Row="2" Height="1" Fill="#B6D4FE" Margin="0,0,0,10"/>

                    <!-- Grand Total -->
                    <DockPanel Grid.Row="3" Margin="0,0,0,15">
                        <TextBlock Text="TOTAL DEPOSIT:" Foreground="#0052CC" FontWeight="Bold" VerticalAlignment="Center"/>
                        <TextBlock x:Name="txtGrandTotal" Text="Rs. 0.00" FontWeight="Bold" FontSize="22" Foreground="#0052CC" HorizontalAlignment="Right"/>
                    </DockPanel>

                    <!-- Action Button -->
                    <Button Grid.Row="4" Content="POST BANK DEPOSIT" Style="{StaticResource PostBtn}" Height="45" Margin="0" ToolTip="Moves the selected funds from the Safe Ledger to the Bank Ledger"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>