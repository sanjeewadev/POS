<UserControl x:Class="POS.BackOffice.UI.Views.Pages.Crm.LoyaltyDiscountAdminView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#D4D0C8" FontFamily="Segoe UI" FontSize="12">
    <UserControl.Resources>
        <Style TargetType="TextBlock" x:Key="HeaderLabel">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#003366"/>
            <Setter Property="Margin" Value="0,5,0,5"/>
        </Style>
        <Style TargetType="TextBlock" x:Key="InlineLabel">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,5,0"/>
        </Style>
        <Style TargetType="TextBox" x:Key="ClassicInput">
            <Setter Property="Height" Value="24"/>
            <Setter Property="Padding" Value="4,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="#808080"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
        </Style>
        <Style TargetType="ComboBox" x:Key="ClassicCombo">
            <Setter Property="Height" Value="24"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="#808080"/>
            <Setter Property="Background" Value="White"/>
        </Style>
        <Style TargetType="DatePicker" x:Key="ClassicDate">
            <Setter Property="Height" Value="24"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="#808080"/>
        </Style>
        <Style TargetType="Button" x:Key="ClassicBtn">
            <Setter Property="Height" Value="26"/>
            <Setter Property="Background" Value="#E0E0E0"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="15,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderBrush" Value="#808080"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#CCCCCC"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="Button" x:Key="ActionBtn" BasedOn="{StaticResource ClassicBtn}">
            <Setter Property="Background" Value="#005555"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#003333"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#007777"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="Border" x:Key="ClassicGroupBox">
            <Setter Property="BorderBrush" Value="#A0A0A0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="#F0F0F0"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="5">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="650"/>
            <ColumnDefinition Width="5"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#003366" Padding="10" BorderBrush="#002244" BorderThickness="1" Margin="0,0,0,5">
                <TextBlock Text="1. DISCOUNT TEMPLATE BUILDER" Foreground="White" FontSize="14" FontWeight="Bold" VerticalAlignment="Center"/>
            </Border>

            <Border Grid.Row="1" Style="{StaticResource ClassicGroupBox}">
                <StackPanel>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Profile Name *" Style="{StaticResource InlineLabel}"/>
                        <TextBox Grid.Column="1" Text="{Binding CurrentProfile.ProfileName}" Style="{StaticResource ClassicInput}" Background="#FFFFE0" FontWeight="Bold" ToolTip="e.g., VIP Gold 10% Off"/>
                    </Grid>

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Disc Type *" Style="{StaticResource InlineLabel}"/>
                        <ComboBox Grid.Column="1" SelectedValue="{Binding CurrentProfile.DiscountType}" SelectedValuePath="Content" Style="{StaticResource ClassicCombo}">
                            <ComboBoxItem Content="Percentage" IsSelected="True"/>
                            <ComboBoxItem Content="FixedAmount"/>
                        </ComboBox>

                        <TextBlock Grid.Column="3" Text="Value *" Style="{StaticResource InlineLabel}" Foreground="DarkRed"/>
                        <TextBox Grid.Column="4" Text="{Binding CurrentProfile.DiscountValue}" Style="{StaticResource ClassicInput}" HorizontalContentAlignment="Right" Background="#FFFFE0" FontWeight="Bold"/>
                    </Grid>

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Target Scope *" Style="{StaticResource InlineLabel}"/>
                        <ComboBox Grid.Column="1" SelectedValue="{Binding CurrentProfile.Scope}" SelectedValuePath="Content" Style="{StaticResource ClassicCombo}">
                            <ComboBoxItem Content="All" IsSelected="True"/>
                            <ComboBoxItem Content="Category"/>
                            <ComboBoxItem Content="SpecificItem"/>
                        </ComboBox>

                        <TextBlock Grid.Column="3" Text="Target Code:" Style="{StaticResource InlineLabel}"/>
                        <TextBox Grid.Column="4" Text="{Binding CurrentProfile.TargetCode}" Style="{StaticResource ClassicInput}" ToolTip="Leave blank if Scope is 'All'. Otherwise enter Category Name or Item Code."/>
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Content="🗑️ DELETE" Command="{Binding DeleteProfileCommand}" Style="{StaticResource ClassicBtn}" Foreground="DarkRed" BorderBrush="DarkRed"/>
                        <Button Grid.Column="2" Content="CLEAR" Command="{Binding ClearProfileCommand}" Style="{StaticResource ClassicBtn}" Margin="0,0,10,0"/>
                        <Button Grid.Column="3" Content="💾 SAVE PROFILE" Command="{Binding SaveProfileCommand}" Style="{StaticResource ActionBtn}"/>
                    </Grid>
                </StackPanel>
            </Border>

            <DataGrid Grid.Row="2" x:Name="dgProfiles" ItemsSource="{Binding Profiles}" SelectedItem="{Binding SelectedProfile}" 
                      AutoGenerateColumns="False" CanUserAddRows="False" GridLinesVisibility="All" 
                      HorizontalGridLinesBrush="#C0C0C0" VerticalGridLinesBrush="#D0D0D0" 
                      RowHeight="26" HeadersVisibility="Column" Background="White" BorderBrush="#A0A0A0" BorderThickness="1" 
                      SelectionMode="Single" AlternatingRowBackground="#F9F9F9" IsReadOnly="True" Margin="0,5,0,0">
                <DataGrid.Resources>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#E0E0E0"/>
                        <Setter Property="Foreground" Value="Black"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="Padding" Value="5"/>
                        <Setter Property="BorderThickness" Value="0,0,1,1"/>
                        <Setter Property="BorderBrush" Value="#A0A0A0"/>
                    </Style>
                </DataGrid.Resources>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Profile Name" Binding="{Binding ProfileName}" Width="*" FontWeight="Bold"/>
                    <DataGridTextColumn Header="Type" Binding="{Binding DiscountType}" Width="100"/>
                    <DataGridTextColumn Header="Value" Binding="{Binding DiscountValue, StringFormat=N2}" Width="80">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="DarkRed"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="HorizontalAlignment" Value="Right"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Scope" Binding="{Binding Scope}" Width="100"/>
                    <DataGridTextColumn Header="Target" Binding="{Binding TargetCode}" Width="100"/>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>

        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#003366" Padding="10" BorderBrush="#002244" BorderThickness="1" Margin="0,0,0,5">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="2. MANUAL CUSTOMER ASSIGNMENT" Foreground="White" FontSize="14" FontWeight="Bold" Margin="0,0,15,0" VerticalAlignment="Center"/>
                    <TextBox Grid.Column="1" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ClassicInput}" Height="26" Padding="5,0"/>
                    <Button Grid.Column="2" Content="SEARCH" Command="{Binding SearchCustomersCommand}" Style="{StaticResource ClassicBtn}" Height="26" Margin="5,0,0,0"/>
                </Grid>
            </Border>

            <DataGrid Grid.Row="1" x:Name="dgCustomers" ItemsSource="{Binding Customers}" SelectedItem="{Binding SelectedCustomer}" 
                      AutoGenerateColumns="False" CanUserAddRows="False" GridLinesVisibility="All" 
                      HorizontalGridLinesBrush="#C0C0C0" VerticalGridLinesBrush="#D0D0D0" 
                      RowHeight="26" HeadersVisibility="Column" Background="White" BorderBrush="#A0A0A0" BorderThickness="1" 
                      SelectionMode="Single" AlternatingRowBackground="#F9F9F9" IsReadOnly="True">
                <DataGrid.Resources>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#E0E0E0"/>
                        <Setter Property="Foreground" Value="Black"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="Padding" Value="5"/>
                        <Setter Property="BorderThickness" Value="0,0,1,1"/>
                        <Setter Property="BorderBrush" Value="#A0A0A0"/>
                    </Style>
                </DataGrid.Resources>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Customer Name" Binding="{Binding FullName}" Width="*" FontWeight="SemiBold"/>
                    <DataGridTextColumn Header="Phone" Binding="{Binding Phone}" Width="100"/>
                    <DataGridTextColumn Header="Active Discount" Binding="{Binding LoyaltyDiscountProfile.ProfileName}" Width="130" Foreground="#005500" FontWeight="Bold"/>
                    <DataGridTextColumn Header="Expiry" Binding="{Binding LoyaltyDiscountExpiryDate, StringFormat=yyyy-MM-dd}" Width="80"/>
                </DataGrid.Columns>
            </DataGrid>

            <Border Grid.Row="2" Style="{StaticResource ClassicGroupBox}" Margin="0,5,0,0">
                <StackPanel>
                    <TextBlock Text="Attach Discount To Selected Customer:" Style="{StaticResource HeaderLabel}" Foreground="#005555" Margin="0,0,0,5"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="60"/>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="Select Rule:" Style="{StaticResource InlineLabel}"/>
                        <ComboBox Grid.Column="1" ItemsSource="{Binding Profiles}" SelectedItem="{Binding AssignProfile}" DisplayMemberPath="ProfileName" Style="{StaticResource ClassicCombo}" Background="#FFFFE0"/>

                        <TextBlock Grid.Column="3" Text="Expiry:" Style="{StaticResource InlineLabel}"/>
                        <DatePicker Grid.Column="4" SelectedDate="{Binding AssignExpiryDate}" Style="{StaticResource ClassicDate}" Background="#FFFFE0"/>

                        <Button Grid.Column="6" Content="LINK DISCOUNT" Command="{Binding AssignDiscountCommand}" Style="{StaticResource ActionBtn}" Background="#005500" BorderBrush="#003300"/>
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>