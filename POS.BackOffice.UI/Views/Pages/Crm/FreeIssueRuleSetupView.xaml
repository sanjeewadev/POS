<UserControl x:Class="POS.BackOffice.UI.Views.Pages.Crm.FreeIssueRuleSetupView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#D4D0C8"
             FontFamily="Segoe UI"
             FontSize="13">

    <UserControl.Resources>
        <Style TargetType="TextBlock" x:Key="LabelText">
            <Setter Property="Foreground" Value="#111827"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
        </Style>

        <Style TargetType="TextBox" x:Key="ClassicInput">
            <Setter Property="Height" Value="31"/>
            <Setter Property="Padding" Value="7,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="#808080"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#111827"/>
        </Style>

        <Style TargetType="ComboBox" x:Key="ClassicCombo">
            <Setter Property="Height" Value="31"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="#808080"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
        </Style>

        <Style TargetType="DatePicker" x:Key="ClassicDatePicker">
            <Setter Property="Height" Value="31"/>
            <Setter Property="BorderBrush" Value="#808080"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style TargetType="Button" x:Key="ClassicBtn">
            <Setter Property="Height" Value="32"/>
            <Setter Property="MinWidth" Value="90"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="#E5E7EB"/>
            <Setter Property="Foreground" Value="#111827"/>
            <Setter Property="BorderBrush" Value="#808080"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style TargetType="Button" x:Key="PrimaryBtn" BasedOn="{StaticResource ClassicBtn}">
            <Setter Property="Background" Value="#003366"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#002244"/>
        </Style>

        <Style TargetType="Button" x:Key="SaveBtn" BasedOn="{StaticResource ClassicBtn}">
            <Setter Property="Background" Value="#005500"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#003300"/>
        </Style>

        <Style TargetType="Button" x:Key="WarningBtn" BasedOn="{StaticResource ClassicBtn}">
            <Setter Property="Background" Value="#F59E0B"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="BorderBrush" Value="#B45309"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#2B3C38"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="8,7"/>
            <Setter Property="BorderBrush" Value="#1F2937"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0"
                Background="#003366"
                BorderBrush="#002244"
                BorderThickness="1"
                Padding="12"
                Margin="0,0,0,8">

            <Grid>
                <TextBlock Text="FREE ISSUE RULE SETUP"
                           Foreground="White"
                           FontSize="22"
                           FontWeight="Heavy"
                           HorizontalAlignment="Left"
                           VerticalAlignment="Center"/>

                <TextBlock Text="Admin-controlled free item and supplier recoverable rules"
                           Foreground="#BFD7EF"
                           FontSize="13"
                           FontWeight="Bold"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.15*"/>
                <ColumnDefinition Width="1.25*"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT: RULE LIST -->
            <Border Grid.Column="0"
                    Background="#F0F0F0"
                    BorderBrush="#808080"
                    BorderThickness="1"
                    Padding="10"
                    Margin="0,0,8,0">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="155"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   Text="Filter:"
                                   Style="{StaticResource LabelText}"/>

                        <ComboBox Grid.Column="1"
                                  ItemsSource="{Binding FilterOptions}"
                                  SelectedItem="{Binding SelectedFilter, Mode=TwoWay}"
                                  Style="{StaticResource ClassicCombo}"/>

                        <TextBlock Grid.Column="3"
                                   Text="Search:"
                                   Style="{StaticResource LabelText}"/>

                        <TextBox Grid.Column="4"
                                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource ClassicInput}">
                            <TextBox.InputBindings>
                                <KeyBinding Key="Enter" Command="{Binding SearchCommand}"/>
                            </TextBox.InputBindings>
                        </TextBox>

                        <Button Grid.Column="6"
                                Content="SEARCH"
                                Command="{Binding SearchCommand}"
                                Style="{StaticResource PrimaryBtn}"
                                Margin="0,0,6,0"/>

                        <Button Grid.Column="7"
                                Content="REFRESH"
                                Command="{Binding RefreshCommand}"
                                Style="{StaticResource ClassicBtn}"/>
                    </Grid>

                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding Rules}"
                              SelectedItem="{Binding SelectedRule, Mode=TwoWay}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              IsReadOnly="True"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              HorizontalGridLinesBrush="#D1D5DB"
                              VerticalGridLinesBrush="#D1D5DB"
                              BorderBrush="#808080"
                              BorderThickness="1"
                              Background="White"
                              AlternatingRowBackground="#F9FAFB"
                              RowHeight="34"
                              FontSize="13">

                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Rule"
                                                Binding="{Binding RuleName}"
                                                Width="190"
                                                FontWeight="Bold"/>

                            <DataGridTextColumn Header="Type"
                                                Binding="{Binding DisplayFreeIssueType}"
                                                Width="135"/>

                            <DataGridTextColumn Header="Applies To"
                                                Binding="{Binding DisplayAppliesTo}"
                                                Width="160"/>

                            <DataGridTextColumn Header="Supplier"
                                                Binding="{Binding SupplierName}"
                                                Width="150"/>

                            <DataGridTextColumn Header="From"
                                                Binding="{Binding ValidFrom, StringFormat=yyyy-MM-dd}"
                                                Width="95"/>

                            <DataGridTextColumn Header="To"
                                                Binding="{Binding ValidTo, StringFormat=yyyy-MM-dd}"
                                                Width="95"/>

                            <DataGridCheckBoxColumn Header="Active"
                                                    Binding="{Binding IsActive}"
                                                    Width="65"/>

                            <DataGridCheckBoxColumn Header="Mgr"
                                                    Binding="{Binding RequiresManagerApproval}"
                                                    Width="55"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <!-- RIGHT: EDITOR -->
            <ScrollViewer Grid.Column="1"
                          VerticalScrollBarVisibility="Auto">

                <Border Background="#F0F0F0"
                        BorderBrush="#808080"
                        BorderThickness="1"
                        Padding="12">

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"
                                   Text="RULE EDITOR"
                                   Foreground="#003366"
                                   FontSize="16"
                                   FontWeight="Heavy"
                                   Margin="0,0,0,10"/>

                        <!-- BASIC -->
                        <GroupBox Grid.Row="1"
                                  Header="Basic Rule"
                                  FontWeight="Bold"
                                  Margin="0,0,0,8">

                            <Grid Margin="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="130"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Grid.RowDefinitions>
                                    <RowDefinition Height="36"/>
                                    <RowDefinition Height="36"/>
                                    <RowDefinition Height="36"/>
                                    <RowDefinition Height="36"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Rule Name:" Style="{StaticResource LabelText}"/>
                                <TextBox Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="3"
                                         Text="{Binding RuleName, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource ClassicInput}"/>

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Free Type:" Style="{StaticResource LabelText}"/>
                                <ComboBox Grid.Row="1" Grid.Column="1"
                                          ItemsSource="{Binding FreeIssueTypes}"
                                          SelectedItem="{Binding FreeIssueType, Mode=TwoWay}"
                                          Style="{StaticResource ClassicCombo}"/>

                                <TextBlock Grid.Row="1" Grid.Column="2" Text="Reason:" Style="{StaticResource LabelText}" Margin="12,0,6,0"/>
                                <ComboBox Grid.Row="1" Grid.Column="3"
                                          ItemsSource="{Binding Reasons}"
                                          SelectedItem="{Binding SelectedReason, Mode=TwoWay}"
                                          DisplayMemberPath="ReasonName"
                                          Style="{StaticResource ClassicCombo}"/>

                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Reason Code:" Style="{StaticResource LabelText}"/>
                                <TextBox Grid.Row="2" Grid.Column="1"
                                         Text="{Binding ReasonCode, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource ClassicInput}"/>

                                <TextBlock Grid.Row="2" Grid.Column="2" Text="Reason Name:" Style="{StaticResource LabelText}" Margin="12,0,6,0"/>
                                <TextBox Grid.Row="2" Grid.Column="3"
                                         Text="{Binding ReasonName, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource ClassicInput}"/>

                                <TextBlock Grid.Row="3" Grid.Column="0" Text="Active:" Style="{StaticResource LabelText}"/>
                                <CheckBox Grid.Row="3" Grid.Column="1"
                                          IsChecked="{Binding IsActive}"
                                          VerticalAlignment="Center"
                                          Content="Rule is active"/>
                            </Grid>
                        </GroupBox>

                        <!-- APPLIES TO -->
                        <GroupBox Grid.Row="2"
                                  Header="Applies To"
                                  FontWeight="Bold"
                                  Margin="0,0,0,8">

                            <Grid Margin="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="130"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Grid.RowDefinitions>
                                    <RowDefinition Height="36"/>
                                    <RowDefinition Height="36"/>
                                    <RowDefinition Height="36"/>
                                    <RowDefinition Height="36"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Applies Type:" Style="{StaticResource LabelText}"/>
                                <ComboBox Grid.Row="0" Grid.Column="1"
                                          ItemsSource="{Binding AppliesToTypes}"
                                          SelectedItem="{Binding AppliesToType, Mode=TwoWay}"
                                          Style="{StaticResource ClassicCombo}"/>

                                <TextBlock Grid.Row="0" Grid.Column="2" Text="Barcode:" Style="{StaticResource LabelText}" Margin="12,0,6,0"/>
                                <TextBox Grid.Row="0" Grid.Column="3"
                                         Text="{Binding Barcode, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource ClassicInput}"/>

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Item Variant ID:" Style="{StaticResource LabelText}"/>
                                <TextBox Grid.Row="1" Grid.Column="1"
                                         Text="{Binding ItemVariantIdInput, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource ClassicInput}"/>

                                <TextBlock Grid.Row="1" Grid.Column="2" Text="SKU:" Style="{StaticResource LabelText}" Margin="12,0,6,0"/>
                                <TextBox Grid.Row="1" Grid.Column="3"
                                         Text="{Binding SkuCode, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource ClassicInput}"/>

                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Item Parent ID:" Style="{StaticResource LabelText}"/>
                                <TextBox Grid.Row="2" Grid.Column="1"
                                         Text="{Binding ItemParentIdInput, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource ClassicInput}"/>

                                <TextBlock Grid.Row="2" Grid.Column="2" Text="Item Name:" Style="{StaticResource LabelText}" Margin="12,0,6,0"/>
                                <TextBox Grid.Row="2" Grid.Column="3"
                                         Text="{Binding ItemName, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource ClassicInput}"/>

                                <TextBlock Grid.Row="3" Grid.Column="0" Text="Category ID:" Style="{StaticResource LabelText}"/>
                                <TextBox Grid.Row="3" Grid.Column="1"
                                         Text="{Binding CategoryIdInput, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource ClassicInput}"/>

                                <TextBlock Grid.Row="3" Grid.Column="2" Text="SubCategory ID:" Style="{StaticResource LabelText}" Margin="12,0,6,0"/>
                                <TextBox Grid.Row="3" Grid.Column="3"
                                         Text="{Binding SubCategoryIdInput, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource ClassicInput}"/>
                            </Grid>
                        </GroupBox>

                        <!-- SUPPLIER -->
                        <GroupBox Grid.Row="3"
                                  Header="Supplier Recoverable Settings"
                                  FontWeight="Bold"
                                  Margin="0,0,0,8">

                            <Grid Margin="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="130"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Grid.RowDefinitions>
                                    <RowDefinition Height="36"/>
                                    <RowDefinition Height="36"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Supplier ID:" Style="{StaticResource LabelText}"/>
                                <TextBox Grid.Row="0" Grid.Column="1"
                                         Text="{Binding SupplierIdInput, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource ClassicInput}"/>

                                <TextBlock Grid.Row="0" Grid.Column="2" Text="Supplier:" Style="{StaticResource LabelText}" Margin="12,0,6,0"/>
                                <TextBox Grid.Row="0" Grid.Column="3"
                                         Text="{Binding SupplierName, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource ClassicInput}"/>

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Claim Mode:" Style="{StaticResource LabelText}"/>
                                <ComboBox Grid.Row="1" Grid.Column="1"
                                          ItemsSource="{Binding ClaimValueModes}"
                                          SelectedItem="{Binding ClaimValueMode, Mode=TwoWay}"
                                          Style="{StaticResource ClassicCombo}"/>

                                <TextBlock Grid.Row="1" Grid.Column="2" Text="Fixed Value:" Style="{StaticResource LabelText}" Margin="12,0,6,0"/>
                                <TextBox Grid.Row="1" Grid.Column="3"
                                         Text="{Binding FixedClaimValue, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:N2}}"
                                         Style="{StaticResource ClassicInput}"
                                         HorizontalContentAlignment="Right"/>
                            </Grid>
                        </GroupBox>

                        <!-- VALIDITY AND LIMITS -->
                        <GroupBox Grid.Row="4"
                                  Header="Validity / Limits"
                                  FontWeight="Bold"
                                  Margin="0,0,0,8">

                            <Grid Margin="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="130"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Grid.RowDefinitions>
                                    <RowDefinition Height="36"/>
                                    <RowDefinition Height="36"/>
                                    <RowDefinition Height="36"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Valid From:" Style="{StaticResource LabelText}"/>
                                <DatePicker Grid.Row="0" Grid.Column="1"
                                            SelectedDate="{Binding ValidFrom, Mode=TwoWay}"
                                            Style="{StaticResource ClassicDatePicker}"/>

                                <TextBlock Grid.Row="0" Grid.Column="2" Text="Valid To:" Style="{StaticResource LabelText}" Margin="12,0,6,0"/>
                                <DatePicker Grid.Row="0" Grid.Column="3"
                                            SelectedDate="{Binding ValidTo, Mode=TwoWay}"
                                            Style="{StaticResource ClassicDatePicker}"/>

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Max Qty / Inv:" Style="{StaticResource LabelText}"/>
                                <TextBox Grid.Row="1" Grid.Column="1"
                                         Text="{Binding MaxQtyPerInvoice, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:N3}}"
                                         Style="{StaticResource ClassicInput}"
                                         HorizontalContentAlignment="Right"/>

                                <TextBlock Grid.Row="1" Grid.Column="2" Text="Max Qty / Day:" Style="{StaticResource LabelText}" Margin="12,0,6,0"/>
                                <TextBox Grid.Row="1" Grid.Column="3"
                                         Text="{Binding MaxQtyPerDay, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:N3}}"
                                         Style="{StaticResource ClassicInput}"
                                         HorizontalContentAlignment="Right"/>

                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Max Value / Inv:" Style="{StaticResource LabelText}"/>
                                <TextBox Grid.Row="2" Grid.Column="1"
                                         Text="{Binding MaxValuePerInvoice, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:N2}}"
                                         Style="{StaticResource ClassicInput}"
                                         HorizontalContentAlignment="Right"/>

                                <TextBlock Grid.Row="2" Grid.Column="2" Text="Max Value / Day:" Style="{StaticResource LabelText}" Margin="12,0,6,0"/>
                                <TextBox Grid.Row="2" Grid.Column="3"
                                         Text="{Binding MaxValuePerDay, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:N2}}"
                                         Style="{StaticResource ClassicInput}"
                                         HorizontalContentAlignment="Right"/>
                            </Grid>
                        </GroupBox>

                        <!-- SECURITY -->
                        <GroupBox Grid.Row="5"
                                  Header="Approval / Security"
                                  FontWeight="Bold"
                                  Margin="0,0,0,8">

                            <Grid Margin="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Grid.RowDefinitions>
                                    <RowDefinition Height="32"/>
                                    <RowDefinition Height="32"/>
                                    <RowDefinition Height="36"/>
                                    <RowDefinition Height="70"/>
                                </Grid.RowDefinitions>

                                <CheckBox Grid.Row="0" Grid.Column="0"
                                          Content="Requires Manager Approval"
                                          IsChecked="{Binding RequiresManagerApproval}"
                                          VerticalAlignment="Center"/>

                                <CheckBox Grid.Row="0" Grid.Column="1"
                                          Content="Requires Admin Approval"
                                          IsChecked="{Binding RequiresAdminApproval}"
                                          VerticalAlignment="Center"/>

                                <CheckBox Grid.Row="1" Grid.Column="0"
                                          Content="Allow Cashier Without Approval"
                                          IsChecked="{Binding AllowCashierWithoutApproval}"
                                          VerticalAlignment="Center"/>

                                <Grid Grid.Row="2" Grid.ColumnSpan="2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="160"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0" Text="Approval Threshold:" Style="{StaticResource LabelText}"/>
                                    <TextBox Grid.Column="1"
                                             Text="{Binding ManagerApprovalThreshold, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:N2}}"
                                             Style="{StaticResource ClassicInput}"
                                             HorizontalContentAlignment="Right"/>
                                </Grid>

                                <TextBox Grid.Row="3" Grid.ColumnSpan="2"
                                         Text="{Binding Remarks, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource ClassicInput}"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto"
                                         ToolTip="Remarks"/>
                            </Grid>
                        </GroupBox>

                        <!-- BUTTONS -->
                        <Grid Grid.Row="6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Button Grid.Column="1"
                                    Content="NEW"
                                    Command="{Binding NewRuleCommand}"
                                    Style="{StaticResource ClassicBtn}"
                                    Margin="0,0,8,0"/>

                            <Button Grid.Column="2"
                                    Content="SAVE RULE"
                                    Command="{Binding SaveCommand}"
                                    Style="{StaticResource SaveBtn}"
                                    Margin="0,0,8,0"/>

                            <Button Grid.Column="3"
                                    Content="ACTIVE / INACTIVE"
                                    Command="{Binding ToggleActiveCommand}"
                                    Style="{StaticResource WarningBtn}"
                                    MinWidth="140"/>
                        </Grid>
                    </Grid>
                </Border>
            </ScrollViewer>
        </Grid>

        <!-- STATUS -->
        <Border Grid.Row="2"
                Background="{Binding StatusColorHex}"
                BorderBrush="#808080"
                BorderThickness="1"
                Padding="9"
                Margin="0,8,0,0">

            <TextBlock Text="{Binding StatusText}"
                       Foreground="White"
                       FontWeight="Bold"
                       TextWrapping="Wrap"/>
        </Border>
    </Grid>
</UserControl>