<UserControl x:Class="POS.BackOffice.UI.Views.Pages.Crm.CustomerLedgerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#D4D0C8" FontFamily="Segoe UI" FontSize="12">

    <UserControl.Resources>
        <Style TargetType="TextBlock" x:Key="HeaderLabel">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#003366"/>
            <Setter Property="Margin" Value="0,5,0,5"/>
        </Style>

        <Style TargetType="TextBlock" x:Key="InlineLabel">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,5,0"/>
        </Style>

        <Style TargetType="TextBox" x:Key="ClassicInput">
            <Setter Property="Height" Value="24"/>
            <Setter Property="Padding" Value="4,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="#808080"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
        </Style>

        <Style TargetType="ComboBox" x:Key="ClassicCombo">
            <Setter Property="Height" Value="24"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="#808080"/>
            <Setter Property="Background" Value="White"/>
        </Style>

        <Style TargetType="DatePicker" x:Key="ClassicDate">
            <Setter Property="Height" Value="24"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="#808080"/>
        </Style>

        <Style TargetType="Button" x:Key="ClassicBtn">
            <Setter Property="Height" Value="26"/>
            <Setter Property="Background" Value="#E0E0E0"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="15,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderBrush" Value="#808080"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#CCCCCC"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="Border" x:Key="ClassicGroupBox">
            <Setter Property="BorderBrush" Value="#A0A0A0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="#F0F0F0"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="5">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#003366" Padding="15" BorderBrush="#002244" BorderThickness="1" Margin="0,0,0,5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="CUSTOMER FINANCIAL LEDGER" Foreground="White" FontSize="14" FontWeight="Bold" Margin="0,0,0,10"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Select Account:" Foreground="#A0C0E0" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <ComboBox Grid.Column="1" ItemsSource="{Binding AvailableCustomers}" SelectedItem="{Binding SelectedCustomer}" 
                                  DisplayMemberPath="FullName" IsEditable="True" IsTextSearchEnabled="True" TextSearch.TextPath="FullName"
                                  Style="{StaticResource ClassicCombo}" Width="300" FontWeight="Bold"/>
                        <Button Grid.Column="2" Content="LOAD LEDGER" Command="{Binding LoadLedgerCommand}" Style="{StaticResource ClassicBtn}" Background="#D0E4F5" BorderBrush="#003366" Foreground="#003366" Height="24" Padding="15,0" Margin="10,0,0,0"/>
                    </Grid>
                </StackPanel>

                <Border Grid.Column="2" Background="#F8F8F8" BorderBrush="#A0A0A0" BorderThickness="2" Padding="15,5" MinWidth="250">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="TOTAL OUTSTANDING BALANCE" FontSize="11" FontWeight="Bold" Foreground="#555" HorizontalAlignment="Center"/>

                        <TextBlock Text="{Binding SelectedCustomer.CurrentBalance, StringFormat=Rs. \{0:N2\}}" FontSize="26" FontWeight="Heavy" HorizontalAlignment="Center" Margin="0,5,0,0">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#8B0000"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasPositiveCredit}" Value="True">
                                            <Setter Property="Foreground" Value="#005500"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding SelectedCustomer}" Value="{x:Null}">
                                            <Setter Property="Text" Value="Rs. 0.00"/>
                                            <Setter Property="Foreground" Value="#555"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <DataGrid Grid.Row="1" ItemsSource="{Binding LedgerEntries}" 
                  AutoGenerateColumns="False" CanUserAddRows="False" GridLinesVisibility="All" 
                  HorizontalGridLinesBrush="#C0C0C0" VerticalGridLinesBrush="#D0D0D0" 
                  RowHeight="26" HeadersVisibility="Column" Background="White" BorderBrush="#A0A0A0" BorderThickness="1" 
                  SelectionMode="Single" AlternatingRowBackground="#F9F9F9" IsReadOnly="True" Margin="0,0,0,5">
            <DataGrid.Resources>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="#E0E0E0"/>
                    <Setter Property="Foreground" Value="Black"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                    <Setter Property="Padding" Value="6"/>
                    <Setter Property="BorderThickness" Value="0,0,1,1"/>
                    <Setter Property="BorderBrush" Value="#A0A0A0"/>
                </Style>
            </DataGrid.Resources>
            <DataGrid.Columns>
                <DataGridTextColumn Header="Date &amp; Time" Binding="{Binding TransactionDate, StringFormat=yyyy-MM-dd HH:mm}" Width="130"/>
                <DataGridTextColumn Header="Ref No." Binding="{Binding DocumentRef}" Width="120" FontWeight="Bold"/>
                <DataGridTextColumn Header="Transaction Type" Binding="{Binding TransactionType}" Width="150" FontWeight="SemiBold"/>

                <DataGridTextColumn Header="Debit (+ Debt) Rs." Binding="{Binding DebitAmount, StringFormat=N2}" Width="130" Foreground="#8B0000" FontWeight="Bold">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Right"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                            <Setter Property="Padding" Value="0,0,5,0"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn Header="Credit (- Payment) Rs." Binding="{Binding CreditAmount, StringFormat=N2}" Width="140" Foreground="#005500" FontWeight="Bold">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Right"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                            <Setter Property="Padding" Value="0,0,5,0"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn Header="Remarks / Notes" Binding="{Binding Remarks}" Width="*"/>
                <DataGridTextColumn Header="User" Binding="{Binding ProcessedBy}" Width="100" Foreground="#666"/>
            </DataGrid.Columns>
        </DataGrid>

        <Border Grid.Row="2" Style="{StaticResource ClassicGroupBox}" Margin="0" Padding="15">
            <Grid IsEnabled="{Binding IsCustomerSelected}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="STATEMENT PERIOD" Style="{StaticResource HeaderLabel}" Margin="0,0,15,0" VerticalAlignment="Center"/>

                    <TextBlock Text="From:" Style="{StaticResource InlineLabel}"/>
                    <DatePicker SelectedDate="{Binding FilterStartDate}" Style="{StaticResource ClassicDate}" Width="120" Margin="0,0,10,0"/>

                    <TextBlock Text="To:" Style="{StaticResource InlineLabel}"/>
                    <DatePicker SelectedDate="{Binding FilterEndDate}" Style="{StaticResource ClassicDate}" Width="120" Margin="0,0,15,0"/>

                    <Button Content="FILTER STATEMENT" Command="{Binding FilterStatementCommand}" Style="{StaticResource ClassicBtn}" Height="26"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">

                    <Button Command="{Binding PrintStatementCommand}" Content="🖨️ PRINT PDF STATEMENT" Style="{StaticResource ClassicBtn}" Height="35" Margin="0,0,15,0" Padding="20,0"/>

                    <Button Command="{Binding OpenReceivePaymentDialogCommand}" Content="💵 RECEIVE PAYMENT" Foreground="White" FontWeight="Heavy" FontSize="13" BorderThickness="0" Height="35" Padding="25,0" Cursor="Hand">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="#059669"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#047857"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>