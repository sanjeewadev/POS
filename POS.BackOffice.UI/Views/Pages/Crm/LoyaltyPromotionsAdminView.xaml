<UserControl x:Class="POS.BackOffice.UI.Views.Pages.Crm.LoyaltyPromotionsAdminView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#D4D0C8" FontFamily="Segoe UI" FontSize="12">

    <UserControl.Resources>
        <Style TargetType="TextBlock" x:Key="HeaderLabel">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#003366"/>
            <Setter Property="Margin" Value="0,5,0,5"/>
        </Style>

        <Style TargetType="TextBlock" x:Key="InlineLabel">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,5,0"/>
        </Style>

        <Style TargetType="TextBox" x:Key="ClassicInput">
            <Setter Property="Height" Value="24"/>
            <Setter Property="Padding" Value="4,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="#808080"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
        </Style>

        <Style TargetType="ComboBox" x:Key="ClassicCombo">
            <Setter Property="Height" Value="24"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="#808080"/>
            <Setter Property="Background" Value="White"/>
        </Style>

        <Style TargetType="DatePicker" x:Key="ClassicDate">
            <Setter Property="Height" Value="24"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="#808080"/>
        </Style>

        <Style TargetType="Button" x:Key="ClassicBtn">
            <Setter Property="Height" Value="26"/>
            <Setter Property="Background" Value="#E0E0E0"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="15,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderBrush" Value="#808080"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#CCCCCC"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="Button" x:Key="ActionBtn" BasedOn="{StaticResource ClassicBtn}">
            <Setter Property="Background" Value="#005555"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#003333"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#007777"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="Border" x:Key="ClassicGroupBox">
            <Setter Property="BorderBrush" Value="#A0A0A0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="#F0F0F0"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="5">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="5*"/>
            <RowDefinition Height="5*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#003366" Padding="10" BorderBrush="#002244" BorderThickness="1" Margin="0,0,0,5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="LOYALTY &amp; PROMOTIONS ENGINE" Foreground="White" FontSize="14" FontWeight="Bold" Margin="0,0,20,0" VerticalAlignment="Center"/>

                <WrapPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Status:" Foreground="#A0C0E0" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,5,0"/>
                    <ComboBox SelectedItem="{Binding SelectedStatusFilter}" Style="{StaticResource ClassicCombo}" Width="110" Margin="0,0,15,0">
                        <System:String xmlns:System="clr-namespace:System;assembly=mscorlib">Active</System:String>
                        <System:String xmlns:System="clr-namespace:System;assembly=mscorlib">Upcoming</System:String>
                        <System:String xmlns:System="clr-namespace:System;assembly=mscorlib">Expired/Disabled</System:String>
                        <System:String xmlns:System="clr-namespace:System;assembly=mscorlib">All</System:String>
                    </ComboBox>

                    <TextBlock Text="Rule Family:" Foreground="#A0C0E0" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,5,0"/>
                    <ComboBox SelectedItem="{Binding SelectedFamilyFilter}" Style="{StaticResource ClassicCombo}" Width="130" Margin="0,0,15,0">
                        <System:String xmlns:System="clr-namespace:System;assembly=mscorlib">All Families</System:String>
                        <System:String xmlns:System="clr-namespace:System;assembly=mscorlib">Customer-Centric</System:String>
                        <System:String xmlns:System="clr-namespace:System;assembly=mscorlib">Product-Centric</System:String>
                        <System:String xmlns:System="clr-namespace:System;assembly=mscorlib">Cart/Volume-Centric</System:String>
                    </ComboBox>

                    <TextBlock Text="Search (Rule Name):" Foreground="#A0C0E0" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,5,0"/>
                    <TextBox Text="{Binding SearchKeyword, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ClassicInput}" Width="180" Margin="0,0,15,0"/>

                    <Button Content="[ F5 - REFRESH ]" Command="{Binding RefreshDataCommand}" Style="{StaticResource ClassicBtn}" Background="#D0E4F5" BorderBrush="#003366" Foreground="#003366" Height="24" Padding="10,0"/>
                </WrapPanel>
            </Grid>
        </Border>

        <DataGrid Grid.Row="1" ItemsSource="{Binding PromoRulesList}" SelectedItem="{Binding SelectedRule}" 
                  AutoGenerateColumns="False" CanUserAddRows="False" GridLinesVisibility="All" 
                  HorizontalGridLinesBrush="#C0C0C0" VerticalGridLinesBrush="#D0D0D0" 
                  RowHeight="26" HeadersVisibility="Column" Background="White" BorderBrush="#A0A0A0" BorderThickness="1" 
                  SelectionMode="Single" AlternatingRowBackground="#F9F9F9" IsReadOnly="True" Margin="0,0,0,5">
            <DataGrid.Resources>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="#E0E0E0"/>
                    <Setter Property="Foreground" Value="Black"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                    <Setter Property="Padding" Value="5"/>
                    <Setter Property="BorderThickness" Value="0,0,1,1"/>
                    <Setter Property="BorderBrush" Value="#A0A0A0"/>
                </Style>
            </DataGrid.Resources>
            <DataGrid.Columns>
                <DataGridTextColumn Header="Priority" Binding="{Binding Priority}" Width="60" FontWeight="Bold">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Center"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Rule Name" Binding="{Binding RuleName}" Width="200" FontWeight="Bold"/>
                <DataGridTextColumn Header="Rule Family" Binding="{Binding FamilyType}" Width="140"/>
                <DataGridTextColumn Header="Reward" Binding="{Binding RewardDescription}" Width="120" Foreground="#005500" FontWeight="Bold"/>

                <DataGridTextColumn Header="Start Date" Binding="{Binding StartDate, StringFormat=yyyy-MM-dd HH:mm}" Width="130"/>
                <DataGridTextColumn Header="End Date" Binding="{Binding EndDate, StringFormat=yyyy-MM-dd HH:mm}" Width="130"/>

                <DataGridCheckBoxColumn Header="Active" Binding="{Binding IsActive}" Width="60">
                    <DataGridCheckBoxColumn.ElementStyle>
                        <Style TargetType="CheckBox">
                            <Setter Property="HorizontalAlignment" Value="Center"/>
                            <Setter Property="IsHitTestVisible" Value="False"/>
                        </Style>
                    </DataGridCheckBoxColumn.ElementStyle>
                </DataGridCheckBoxColumn>
            </DataGrid.Columns>
        </DataGrid>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="6*"/>
                <ColumnDefinition Width="4*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource ClassicGroupBox}" Margin="0,0,5,0" VerticalAlignment="Stretch">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#E0E0E0" BorderBrush="#A0A0A0" BorderThickness="0,0,0,1" Padding="8,4" Margin="0,0,0,10">
                        <TextBlock Text="RULE CONFIGURATION BUILDER" Style="{StaticResource HeaderLabel}" Margin="0"/>
                    </Border>

                    <StackPanel Grid.Row="1">
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="60"/>
                                <ColumnDefinition Width="80"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Rule Name *" Style="{StaticResource InlineLabel}"/>
                            <TextBox Grid.Column="1" Text="{Binding InputRuleName, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ClassicInput}" FontWeight="Bold" Background="#FFFFE0"/>

                            <TextBlock Grid.Column="3" Text="Priority *" Style="{StaticResource InlineLabel}"/>
                            <TextBox Grid.Column="4" Text="{Binding InputPriority}" Style="{StaticResource ClassicInput}" HorizontalContentAlignment="Center" ToolTip="1 = Highest Priority (Overrides others)"/>
                        </Grid>

                        <Rectangle Height="1" Fill="#C0C0C0" Margin="0,0,0,10"/>

                        <TextBlock Text="Target Condition (When does this apply?)" Style="{StaticResource InlineLabel}" Foreground="#003366" Margin="0,0,0,5"/>
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ComboBox Grid.Column="0" SelectedItem="{Binding InputTargetFamily}" Style="{StaticResource ClassicCombo}" Margin="0,0,10,0">
                                <System:String xmlns:System="clr-namespace:System;assembly=mscorlib">Specific Item</System:String>
                                <System:String xmlns:System="clr-namespace:System;assembly=mscorlib">Customer Group</System:String>
                                <System:String xmlns:System="clr-namespace:System;assembly=mscorlib">Minimum Spend</System:String>
                            </ComboBox>
                            <TextBox Grid.Column="1" Text="{Binding InputTargetValue}" Style="{StaticResource ClassicInput}" Margin="0,0,10,0" ToolTip="Enter Item Code, Group Name, or Amount"/>
                            <Button Grid.Column="2" Content="SEEK" Command="{Binding OpenSeekDialogCommand}" Style="{StaticResource ClassicBtn}" Padding="10,0" Height="24"/>
                        </Grid>

                        <Rectangle Height="1" Fill="#C0C0C0" Margin="0,0,0,10"/>

                        <TextBlock Text="The Reward (What do they get?)" Style="{StaticResource InlineLabel}" Foreground="#005500" Margin="0,0,0,5"/>
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <ComboBox Grid.Column="0" SelectedItem="{Binding InputRewardType}" Style="{StaticResource ClassicCombo}" Margin="0,0,10,0">
                                <System:String xmlns:System="clr-namespace:System;assembly=mscorlib">Percentage (%)</System:String>
                                <System:String xmlns:System="clr-namespace:System;assembly=mscorlib">Flat Amount (Rs.)</System:String>
                            </ComboBox>
                            <TextBox Grid.Column="1" Text="{Binding InputRewardValue}" Style="{StaticResource ClassicInput}" FontWeight="Bold" Foreground="#005500" HorizontalContentAlignment="Right" Margin="0,0,10,0"/>
                        </Grid>

                        <Rectangle Height="1" Fill="#C0C0C0" Margin="0,0,0,10"/>

                        <TextBlock Text="Time Constraints (Optional)" Style="{StaticResource InlineLabel}" Margin="0,0,0,5"/>
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="130"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="60"/>
                                <ColumnDefinition Width="130"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Valid From:" Style="{StaticResource InlineLabel}"/>
                            <DatePicker Grid.Column="1" SelectedDate="{Binding InputStartDate}" Style="{StaticResource ClassicDate}"/>

                            <TextBlock Grid.Column="3" Text="Valid To:" Style="{StaticResource InlineLabel}"/>
                            <DatePicker Grid.Column="4" SelectedDate="{Binding InputEndDate}" Style="{StaticResource ClassicDate}"/>
                        </Grid>

                        <CheckBox Content="Rule is currently ACTIVE" IsChecked="{Binding InputIsActive}" FontWeight="Bold" Foreground="#003366" Margin="0,5,0,0"/>
                    </StackPanel>

                    <Grid Grid.Row="2" Margin="0,15,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Content="🗑️ DELETE RULE" Command="{Binding DeleteRuleCommand}" Style="{StaticResource ClassicBtn}" Foreground="DarkRed" BorderBrush="DarkRed" Padding="15,0" Height="30"/>
                        <Button Grid.Column="2" Content="💾 SAVE &amp; ACTIVATE RULE" Command="{Binding SaveRuleCommand}" Style="{StaticResource ActionBtn}" Background="#005500" BorderBrush="#003300" Padding="20,0" Height="30" FontSize="13"/>
                    </Grid>
                </Grid>
            </Border>

            <Border Grid.Column="1" Background="#F8F8F8" BorderBrush="#A0A0A0" BorderThickness="1" Padding="0" VerticalAlignment="Stretch">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#333333" BorderBrush="#222222" BorderThickness="0,0,0,1" Padding="10">
                        <StackPanel>
                            <TextBlock Text="🔮 CONFLICT SIMULATOR" Foreground="White" FontSize="13" FontWeight="Bold" Margin="0,0,0,2"/>
                            <TextBlock Text="Test rules before saving to prevent margin erosion." Foreground="#CCCCCC" FontSize="10" FontStyle="Italic"/>
                        </StackPanel>
                    </Border>

                    <StackPanel Grid.Row="1" Margin="15">
                        <TextBlock Text="Test Parameters" FontWeight="Bold" Foreground="#555" Margin="0,0,0,10"/>

                        <TextBlock Text="Test Customer Group:" Style="{StaticResource InlineLabel}"/>
                        <ComboBox SelectedItem="{Binding SimCustomerGroup}" Style="{StaticResource ClassicCombo}" Margin="0,0,0,10">
                            <System:String xmlns:System="clr-namespace:System;assembly=mscorlib">None / Walk-In</System:String>
                            <System:String xmlns:System="clr-namespace:System;assembly=mscorlib">VIP Gold</System:String>
                            <System:String xmlns:System="clr-namespace:System;assembly=mscorlib">Wholesale</System:String>
                        </ComboBox>

                        <TextBlock Text="Test Item Code:" Style="{StaticResource InlineLabel}"/>
                        <TextBox Text="{Binding SimItemCode}" Style="{StaticResource ClassicInput}" Margin="0,0,0,10"/>

                        <Button Content="▶ RUN SIMULATION" Command="{Binding RunSimulationCommand}" Style="{StaticResource ClassicBtn}" Background="#003366" Foreground="White" BorderBrush="#002244" Height="30" Margin="0,10,0,15"/>

                        <Rectangle Height="1" Fill="#C0C0C0" Margin="0,0,0,15"/>

                        <TextBlock Text="Simulation Results:" FontWeight="Bold" Foreground="#333" Margin="0,0,0,5"/>
                        <Border Background="#111827" BorderBrush="#000000" BorderThickness="2" Padding="10" MinHeight="100">
                            <TextBlock Text="{Binding SimulationOutput}" Foreground="#10B981" FontFamily="Consolas" TextWrapping="Wrap" FontSize="11"/>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>