<UserControl x:Class="POS.BackOffice.UI.Views.Pages.InventoryPages.SupplierView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="700"
             d:DesignWidth="1200"
             Background="{DynamicResource WindowBackgroundBrush}"
             FontFamily="Segoe UI"
             FontSize="12">

    <UserControl.Resources>

        <Style TargetType="TextBlock" x:Key="HeaderLabel">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{DynamicResource HeaderTextBrush}"/>
            <Setter Property="Margin" Value="0,5,0,5"/>
        </Style>

        <Style TargetType="TextBlock" x:Key="InlineLabel">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,5,0"/>
        </Style>

        <Style TargetType="TextBox" x:Key="ClassicInput">
            <Setter Property="Height" Value="24"/>
            <Setter Property="Padding" Value="4,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="{DynamicResource InputBoxBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="{DynamicResource WhiteBackgroundBrush}"/>
            <Style.Triggers>
                <Trigger Property="IsReadOnly" Value="True">
                    <Setter Property="Background" Value="{DynamicResource ButtonDefaultBrush}"/>
                    <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="{DynamicResource ButtonDefaultBrush}"/>
                    <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="Button" x:Key="ClassicBtn">
            <Setter Property="Height" Value="26"/>
            <Setter Property="Background" Value="{DynamicResource ButtonDefaultBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="15,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderBrush" Value="{DynamicResource InputBoxBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource ButtonHoverBrush}"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.55"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="Button" x:Key="ActionBtn" BasedOn="{StaticResource ClassicBtn}">
            <Setter Property="Background" Value="{DynamicResource ActionBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource WhiteBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource InputBoxBorderBrush}"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource ActionHoverBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="Border" x:Key="ClassicGroupBox">
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="{DynamicResource PanelBackgroundBrush}"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{DynamicResource DataGridHeaderBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
        </Style>

        <Style TargetType="DataGridCell" x:Key="BaseCell">
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="4,0"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource LightSelectionBrush}"/>
                    <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

    </UserControl.Resources>

    <Grid Margin="5">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="420"/>
            <ColumnDefinition Width="5"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- LEFT SIDE: SUPPLIER FORM -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- IDENTITY -->
            <Border Grid.Row="0" Style="{StaticResource ClassicGroupBox}">
                <StackPanel>
                    <TextBlock Text="1. SUPPLIER IDENTITY"
                               Style="{StaticResource HeaderLabel}"
                               Margin="0,0,0,5"/>

                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="105"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   Text="Supplier Code *"
                                   Style="{StaticResource InlineLabel}"
                                   Foreground="{DynamicResource WarningTextBrush}"/>

                        <TextBox Grid.Column="1"
                                 Text="{Binding SupplierCode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 IsReadOnly="{Binding IsCodeReadOnly}"
                                 Style="{StaticResource ClassicInput}"
                                 FontWeight="Bold"
                                 MaxLength="20"
                                 CharacterCasing="Upper"
                                 ToolTip="Cannot be edited after saving."/>
                    </Grid>

                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="105"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   Text="Supplier Name *"
                                   Style="{StaticResource InlineLabel}"
                                   Foreground="{DynamicResource WarningTextBrush}"/>

                        <TextBox Grid.Column="1"
                                 Text="{Binding SupplierName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource ClassicInput}"
                                 FontWeight="Bold"
                                 MaxLength="150"/>
                    </Grid>

                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="105"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   Text="Company Name"
                                   Style="{StaticResource InlineLabel}"/>

                        <TextBox Grid.Column="1"
                                 Text="{Binding CompanyName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource ClassicInput}"
                                 MaxLength="150"/>
                    </Grid>

                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="105"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   Text="Contact Person"
                                   Style="{StaticResource InlineLabel}"/>

                        <TextBox Grid.Column="1"
                                 Text="{Binding ContactPerson, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource ClassicInput}"
                                 MaxLength="50"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- CONTACT -->
            <Border Grid.Row="1" Style="{StaticResource ClassicGroupBox}">
                <StackPanel>
                    <TextBlock Text="2. CONTACT &amp; LOCATION"
                               Style="{StaticResource HeaderLabel}"
                               Foreground="{DynamicResource SuccessBorderBrush}"
                               Margin="0,0,0,5"/>

                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="105"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   Text="Phone 1 *"
                                   Style="{StaticResource InlineLabel}"
                                   Foreground="{DynamicResource WarningTextBrush}"/>

                        <TextBox Grid.Column="1"
                                 Text="{Binding Phone1, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource ClassicInput}"
                                 FontWeight="Bold"
                                 MaxLength="20"
                                 ToolTip="Mobile or main supplier phone number."/>
                    </Grid>

                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="105"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   Text="Phone 2"
                                   Style="{StaticResource InlineLabel}"/>

                        <TextBox Grid.Column="1"
                                 Text="{Binding Phone2, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource ClassicInput}"
                                 MaxLength="20"/>
                    </Grid>

                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="105"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   Text="Email"
                                   Style="{StaticResource InlineLabel}"/>

                        <TextBox Grid.Column="1"
                                 Text="{Binding Email, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource ClassicInput}"
                                 MaxLength="100"/>
                    </Grid>

                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="105"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   Text="Billing Address"
                                   Style="{StaticResource InlineLabel}"
                                   VerticalAlignment="Top"
                                   Margin="0,5,0,0"/>

                        <TextBox Grid.Column="1"
                                 Text="{Binding Address, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource ClassicInput}"
                                 Height="45"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 VerticalContentAlignment="Top"
                                 Padding="4"
                                 MaxLength="250"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- FINANCIALS -->
            <Border Grid.Row="2" Style="{StaticResource ClassicGroupBox}">
                <StackPanel>
                    <TextBlock Text="3. FINANCIALS &amp; TAX"
                               Style="{StaticResource HeaderLabel}"
                               Foreground="{DynamicResource WarningTextBrush}"
                               Margin="0,0,0,5"/>

                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="125"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <CheckBox Grid.Column="0"
                                  Content="Has VAT Number"
                                  IsChecked="{Binding HasVat, Mode=TwoWay}"
                                  VerticalAlignment="Center"
                                  FontWeight="SemiBold"
                                  Foreground="{DynamicResource PrimaryTextBrush}"/>

                        <TextBox Grid.Column="1"
                                 Text="{Binding VatNumber, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource ClassicInput}"
                                 IsEnabled="{Binding HasVat}"
                                 MaxLength="50"/>
                    </Grid>

                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="125"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   Text="Credit Days"
                                   Style="{StaticResource InlineLabel}"/>

                        <TextBox Grid.Column="1"
                                 Text="{Binding DefaultCreditDays, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                 Style="{StaticResource ClassicInput}"
                                 HorizontalContentAlignment="Right"
                                 ToolTip="Used to calculate PO/GRN payment due dates."/>

                        <TextBlock Grid.Column="2"
                                   Text="Default supplier credit period"
                                   FontSize="10"
                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                   FontStyle="Italic"
                                   VerticalAlignment="Center"
                                   Margin="8,0,0,0"/>
                    </Grid>

                    <Rectangle Height="1"
                               Fill="{DynamicResource LightBorderBrush}"
                               Margin="0,0,0,8"/>

                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="125"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   Text="Current Bal Rs."
                                   Style="{StaticResource InlineLabel}"
                                   Foreground="{DynamicResource WarningTextBrush}"/>

                        <TextBox Grid.Column="1"
                                 Text="{Binding CurrentBalance, Mode=OneWay, StringFormat={}{0:N2}}"
                                 Style="{StaticResource ClassicInput}"
                                 IsReadOnly="True"
                                 HorizontalContentAlignment="Right"
                                 FontWeight="Bold"
                                 Foreground="{DynamicResource WarningTextBrush}"
                                 ToolTip="This balance is managed automatically by GRNs, supplier returns, and payments."/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- SETTINGS -->
            <Border Grid.Row="3"
                    Style="{StaticResource ClassicGroupBox}"
                    VerticalAlignment="Top">
                <StackPanel>
                    <TextBlock Text="4. SETTINGS &amp; MAINTENANCE"
                               Style="{StaticResource HeaderLabel}"
                               Foreground="{DynamicResource WarningTextBrush}"
                               Margin="0,0,0,5"/>

                    <CheckBox Content="Suspend / Deactivate Supplier"
                              IsChecked="{Binding IsDeactivated, Mode=TwoWay}"
                              FontWeight="Bold"
                              Foreground="{DynamicResource WarningTextBrush}"
                              Margin="0,5,0,0"/>

                    <TextBlock Text="Suspended suppliers will not appear in new Purchase Orders, GRNs, or supplier assignment dropdowns."
                               FontSize="10"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               Margin="20,2,0,0"
                               FontStyle="Italic"
                               TextWrapping="Wrap"/>

                    <TextBlock Text="Use delete only for unused test or wrongly-created suppliers."
                               FontSize="10"
                               Foreground="{DynamicResource WarningTextBrush}"
                               Margin="20,8,0,0"
                               FontStyle="Italic"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <!-- ACTIONS / STATUS -->
            <Border Grid.Row="4"
                    Background="{DynamicResource PanelBackgroundBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    Padding="10"
                    Margin="0,5,0,0">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="{Binding StatusMessage}"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               FontSize="11"
                               Margin="0,0,0,8"
                               TextWrapping="Wrap"/>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0"
                                Content="DELETE"
                                Command="{Binding DeleteCommand}"
                                Style="{StaticResource ClassicBtn}"
                                Foreground="{DynamicResource WarningTextBrush}"
                                BorderBrush="{DynamicResource WarningTextBrush}"
                                Padding="15,0"
                                Height="30"
                                ToolTip="Deletes only if the supplier has no linked records."/>

                        <Button Grid.Column="2"
                                Content="CLEAR"
                                Command="{Binding ClearCommand}"
                                Style="{StaticResource ClassicBtn}"
                                Margin="0,0,10,0"
                                Padding="15,0"
                                Height="30"/>

                        <Button Grid.Column="3"
                                Content="SAVE SUPPLIER"
                                Command="{Binding SaveCommand}"
                                Style="{StaticResource ActionBtn}"
                                Padding="20,0"
                                Height="30"
                                FontSize="13"/>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <!-- RIGHT SIDE: SUPPLIER DATABASE -->
        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- SEARCH HEADER -->
            <Border Grid.Row="0"
                    Background="{DynamicResource HeaderTextBrush}"
                    Padding="10"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1">

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="SUPPLIER DATABASE"
                               Foreground="{DynamicResource WhiteBackgroundBrush}"
                               FontSize="14"
                               FontWeight="Bold"
                               Margin="0,0,15,0"
                               VerticalAlignment="Center"/>

                    <TextBox Grid.Column="1"
                             Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource ClassicInput}"
                             Height="28"
                             Padding="5,0"
                             Margin="0,0,10,0"
                             ToolTip="Search by supplier code, name, company, contact person, or phone. Press Enter or click Search.">

                        <TextBox.InputBindings>
                            <KeyBinding Key="Enter"
                                        Command="{Binding SearchCommand}"/>
                        </TextBox.InputBindings>
                    </TextBox>

                    <Button Grid.Column="2"
                            Content="SEARCH"
                            Command="{Binding SearchCommand}"
                            Style="{StaticResource ClassicBtn}"
                            Height="28"
                            Padding="15,0"
                            Margin="0,0,8,0"/>

                    <Button Grid.Column="3"
                            Content="REFRESH"
                            Command="{Binding RefreshCommand}"
                            Style="{StaticResource ClassicBtn}"
                            Height="28"
                            Padding="15,0"/>
                </Grid>
            </Border>

            <!-- DATA GRID -->
            <DataGrid Grid.Row="1"
                      ItemsSource="{Binding Suppliers}"
                      SelectedItem="{Binding SelectedSupplier, Mode=TwoWay}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      IsReadOnly="True"
                      GridLinesVisibility="All"
                      HorizontalGridLinesBrush="{DynamicResource LightBorderBrush}"
                      VerticalGridLinesBrush="{DynamicResource LightBorderBrush}"
                      RowHeight="26"
                      HeadersVisibility="Column"
                      Background="{DynamicResource WhiteBackgroundBrush}"
                      BorderBrush="{DynamicResource BorderBrush}"
                      BorderThickness="1,0,1,1"
                      SelectionMode="Single"
                      AlternatingRowBackground="{DynamicResource DataGridAlternatingRow}">

                <DataGrid.Resources>
                    <Style TargetType="DataGridCell" BasedOn="{StaticResource BaseCell}"/>
                </DataGrid.Resources>

                <DataGrid.Columns>
                    <DataGridTextColumn Header="Code"
                                        Binding="{Binding SupplierCode}"
                                        Width="90"
                                        IsReadOnly="True"
                                        FontWeight="SemiBold"/>

                    <DataGridTextColumn Header="Supplier Name"
                                        Binding="{Binding SupplierName}"
                                        Width="180"
                                        IsReadOnly="True"
                                        FontWeight="Bold"/>

                    <DataGridTextColumn Header="Company Name"
                                        Binding="{Binding CompanyName}"
                                        Width="170"
                                        IsReadOnly="True"/>

                    <DataGridTextColumn Header="Phone 1"
                                        Binding="{Binding Phone1}"
                                        Width="105"
                                        IsReadOnly="True"/>

                    <DataGridTextColumn Header="Contact Person"
                                        Binding="{Binding ContactPerson}"
                                        Width="120"
                                        IsReadOnly="True"
                                        Foreground="{DynamicResource SecondaryTextBrush}"/>

                    <DataGridTextColumn Header="Credit Days"
                                        Binding="{Binding DefaultCreditDays}"
                                        Width="85"
                                        IsReadOnly="True"/>

                    <DataGridTextColumn Header="Balance Rs."
                                        Binding="{Binding CurrentBalance, StringFormat={}{0:N2}}"
                                        Width="100"
                                        IsReadOnly="True"
                                        FontWeight="Bold"
                                        Foreground="{DynamicResource WarningTextBrush}">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                <Setter Property="Padding" Value="0,0,5,0"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="Status"
                                        Binding="{Binding StatusText}"
                                        Width="90"
                                        IsReadOnly="True"/>

                    <DataGridTextColumn Header="Created"
                                        Binding="{Binding CreatedAt, StringFormat={}{0:yyyy-MM-dd HH:mm}}"
                                        Width="135"
                                        IsReadOnly="True"/>

                    <DataGridTextColumn Header="Updated"
                                        Binding="{Binding UpdatedAt, StringFormat={}{0:yyyy-MM-dd HH:mm}}"
                                        Width="135"
                                        IsReadOnly="True"/>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </Grid>
</UserControl>