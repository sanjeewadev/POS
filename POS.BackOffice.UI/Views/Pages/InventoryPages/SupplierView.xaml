<UserControl x:Class="POS.BackOffice.UI.Views.Pages.InventoryPages.SupplierView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="1200"
             Background="#D4D0C8" FontFamily="Segoe UI" FontSize="12">
    <UserControl.Resources>

        <Style TargetType="TextBlock" x:Key="HeaderLabel">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#003366"/>
            <Setter Property="Margin" Value="0,5,0,5"/>
        </Style>

        <Style TargetType="TextBlock" x:Key="InlineLabel">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,5,0"/>
        </Style>

        <Style TargetType="TextBox" x:Key="ClassicInput">
            <Setter Property="Height" Value="24"/>
            <Setter Property="Padding" Value="4,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="#808080"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
        </Style>

        <Style TargetType="Button" x:Key="ClassicBtn">
            <Setter Property="Height" Value="26"/>
            <Setter Property="Background" Value="#E0E0E0"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="15,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderBrush" Value="#808080"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#CCCCCC"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="Button" x:Key="ActionBtn" BasedOn="{StaticResource ClassicBtn}">
            <Setter Property="Background" Value="#005555"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#003333"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#007777"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="Border" x:Key="ClassicGroupBox">
            <Setter Property="BorderBrush" Value="#A0A0A0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="#F0F0F0"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="5">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="420"/>
            <ColumnDefinition Width="5"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Style="{StaticResource ClassicGroupBox}">
                <StackPanel>
                    <TextBlock Text="1. SUPPLIER IDENTITY" Style="{StaticResource HeaderLabel}" Margin="0,0,0,5"/>

                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Supplier Code *" Style="{StaticResource InlineLabel}" Foreground="DarkRed"/>
                        <TextBox Grid.Column="1" Text="{Binding SupplierCode}" Style="{StaticResource ClassicInput}" Background="#FFFFE0" FontWeight="Bold"/>

                        <TextBlock Grid.Column="3" Text="Contact Person:" Style="{StaticResource InlineLabel}"/>
                        <TextBox Grid.Column="4" Text="{Binding ContactPerson}" Style="{StaticResource ClassicInput}"/>
                    </Grid>

                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Supplier Name *" Style="{StaticResource InlineLabel}"/>
                        <TextBox Grid.Column="1" Text="{Binding SupplierName}" Style="{StaticResource ClassicInput}" FontWeight="Bold"/>
                    </Grid>

                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Company Name:" Style="{StaticResource InlineLabel}"/>
                        <TextBox Grid.Column="1" Text="{Binding CompanyName}" Style="{StaticResource ClassicInput}"/>
                    </Grid>
                </StackPanel>
            </Border>

            <Border Grid.Row="1" Style="{StaticResource ClassicGroupBox}">
                <StackPanel>
                    <TextBlock Text="2. CONTACT &amp; LOCATION" Style="{StaticResource HeaderLabel}" Foreground="#005555" Margin="0,0,0,5"/>

                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Phone 1 (Mob) *" Style="{StaticResource InlineLabel}"/>
                        <TextBox Grid.Column="1" Text="{Binding Phone1}" Style="{StaticResource ClassicInput}" FontWeight="Bold"/>
                    </Grid>

                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Phone 2 (Off):" Style="{StaticResource InlineLabel}"/>
                        <TextBox Grid.Column="1" Text="{Binding Phone2}" Style="{StaticResource ClassicInput}"/>
                    </Grid>

                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Email Address:" Style="{StaticResource InlineLabel}"/>
                        <TextBox Grid.Column="1" Text="{Binding Email}" Style="{StaticResource ClassicInput}"/>
                    </Grid>

                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Billing Address:" Style="{StaticResource InlineLabel}" VerticalAlignment="Top" Margin="0,5,0,0"/>
                        <TextBox Grid.Column="1" Text="{Binding Address}" Style="{StaticResource ClassicInput}" Height="48" AcceptsReturn="True" TextWrapping="Wrap" VerticalContentAlignment="Top" Padding="4"/>
                    </Grid>
                </StackPanel>
            </Border>

            <Border Grid.Row="2" Style="{StaticResource ClassicGroupBox}">
                <StackPanel>
                    <TextBlock Text="3. FINANCIALS &amp; TAX" Style="{StaticResource HeaderLabel}" Foreground="#B8860B" Margin="0,0,0,5"/>

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <CheckBox Grid.Column="0" x:Name="chkHasVat" Content="Has VAT / BR Number" IsChecked="{Binding HasVat}" VerticalAlignment="Center" FontWeight="SemiBold"/>
                        <TextBox Grid.Column="1" Text="{Binding VatNumber}" Style="{StaticResource ClassicInput}" IsEnabled="{Binding ElementName=chkHasVat, Path=IsChecked}"/>
                    </Grid>

                    <Rectangle Height="1" Fill="#C0C0C0" Margin="0,0,0,8"/>

                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Def. Cr. Days:" Style="{StaticResource InlineLabel}" Foreground="#005500"/>
                        <TextBox Grid.Column="1" Text="{Binding DefaultCreditDays}" Style="{StaticResource ClassicInput}" HorizontalContentAlignment="Center"/>

                        <TextBlock Grid.Column="3" Text="Current Bal:" Style="{StaticResource InlineLabel}" Foreground="DarkRed"/>
                        <TextBox Grid.Column="4" Text="{Binding CurrentBalance, StringFormat=Rs. \{0:N2\}}" Style="{StaticResource ClassicInput}" IsReadOnly="True" Background="#E5E5E5" HorizontalContentAlignment="Right" FontWeight="Bold" Foreground="DarkRed"/>
                    </Grid>
                </StackPanel>
            </Border>

            <Border Grid.Row="3" Style="{StaticResource ClassicGroupBox}" VerticalAlignment="Stretch">
                <StackPanel>
                    <TextBlock Text="4. SETTINGS &amp; MAINTENANCE" Style="{StaticResource HeaderLabel}" Foreground="DarkRed" Margin="0,0,0,5"/>
                    <CheckBox Content="Suspend / Deactivate Supplier" IsChecked="{Binding IsDeactivated}" FontWeight="Bold" Foreground="DarkRed" Margin="0,5,0,0"/>
                    <TextBlock Text="(Suspended suppliers will not appear in new Purchase Orders or GRNs)" FontSize="10" Foreground="#888" Margin="20,2,0,0" FontStyle="Italic"/>
                </StackPanel>
            </Border>

            <Border Grid.Row="4" Background="#E8E8E8" BorderBrush="#A0A0A0" BorderThickness="1" Padding="10" Margin="0,5,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0" Content="🗑️ DELETE" Command="{Binding DeleteCommand}" Style="{StaticResource ClassicBtn}" Foreground="DarkRed" BorderBrush="DarkRed" Padding="15,0" Height="30"/>

                    <Button Grid.Column="2" Content="CLEAR" Command="{Binding ClearCommand}" Style="{StaticResource ClassicBtn}" Margin="0,0,10,0" Padding="15,0" Height="30"/>
                    <Button Grid.Column="3" Content="💾 SAVE SUPPLIER" Command="{Binding SaveCommand}" Style="{StaticResource ActionBtn}" Padding="20,0" Height="30" FontSize="13"/>
                </Grid>
            </Border>
        </Grid>

        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#003366" Padding="10" BorderBrush="#002244" BorderThickness="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="SUPPLIER DATABASE" Foreground="White" FontSize="14" FontWeight="Bold" Margin="0,0,15,0" VerticalAlignment="Center"/>

                    <TextBox Grid.Column="1" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ClassicInput}" Height="28" Padding="5,0"/>

                    <Button Grid.Column="2" Content="SEARCH" Command="{Binding SearchCommand}" Style="{StaticResource ClassicBtn}" Height="28" Margin="5,0,0,0"/>
                    <Button Grid.Column="3" Content="REFRESH" Command="{Binding RefreshCommand}" Style="{StaticResource ClassicBtn}" Height="28" Margin="5,0,0,0"/>
                </Grid>
            </Border>

            <DataGrid Grid.Row="1" x:Name="dgSuppliers" ItemsSource="{Binding Suppliers}" SelectedItem="{Binding SelectedSupplier}" 
                      AutoGenerateColumns="False" CanUserAddRows="False" GridLinesVisibility="All" 
                      HorizontalGridLinesBrush="#C0C0C0" VerticalGridLinesBrush="#D0D0D0" 
                      RowHeight="26" HeadersVisibility="Column" Background="White" BorderBrush="#A0A0A0" BorderThickness="1,0,1,1" 
                      SelectionMode="Single" AlternatingRowBackground="#F9F9F9">

                <DataGrid.Resources>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#E0E0E0"/>
                        <Setter Property="Foreground" Value="Black"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="Padding" Value="5"/>
                        <Setter Property="BorderThickness" Value="0,0,1,1"/>
                        <Setter Property="BorderBrush" Value="#A0A0A0"/>
                    </Style>
                    <Style TargetType="DataGridCell">
                        <Setter Property="VerticalContentAlignment" Value="Center"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Padding" Value="4,0"/>
                        <Setter Property="Foreground" Value="Black"/>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#005555"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.Resources>

                <DataGrid.Columns>
                    <DataGridTextColumn Header="Code" Binding="{Binding SupplierCode}" Width="80" IsReadOnly="True" FontWeight="SemiBold"/>
                    <DataGridTextColumn Header="Supplier Name" Binding="{Binding SupplierName}" Width="*" IsReadOnly="True" FontWeight="Bold"/>
                    <DataGridTextColumn Header="Company Name" Binding="{Binding CompanyName}" Width="*" IsReadOnly="True"/>

                    <DataGridTextColumn Header="Phone (Mob)" Binding="{Binding Phone1}" Width="100" IsReadOnly="True"/>
                    <DataGridTextColumn Header="Contact Person" Binding="{Binding ContactPerson}" Width="120" IsReadOnly="True" Foreground="#666"/>

                    <DataGridTextColumn Header="Balance Rs." Binding="{Binding CurrentBalance, StringFormat=N2}" Width="90" IsReadOnly="True" FontWeight="Bold" Foreground="DarkRed">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Right"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="Status" Binding="{Binding StatusText}" Width="80" IsReadOnly="True"/>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </Grid>
</UserControl>