<UserControl x:Class="POS.BackOffice.UI.Views.Pages.InventoryPages.SubCategoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="700"
             d:DesignWidth="1200"
             Background="{DynamicResource WindowBackgroundBrush}"
             FontFamily="Segoe UI"
             FontSize="12">

    <UserControl.Resources>

        <Style TargetType="TextBlock" x:Key="HeaderLabel">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{DynamicResource HeaderTextBrush}"/>
            <Setter Property="Margin" Value="0,5,0,5"/>
        </Style>

        <Style TargetType="TextBlock" x:Key="InlineLabel">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,5,0"/>
        </Style>

        <Style TargetType="TextBox" x:Key="ClassicInput">
            <Setter Property="Height" Value="24"/>
            <Setter Property="Padding" Value="4,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="{DynamicResource InputBoxBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="{DynamicResource WhiteBackgroundBrush}"/>
            <Style.Triggers>
                <Trigger Property="IsReadOnly" Value="True">
                    <Setter Property="Background" Value="{DynamicResource ButtonDefaultBrush}"/>
                    <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="ComboBox" x:Key="ClassicCombo">
            <Setter Property="Height" Value="24"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="{DynamicResource InputBoxBorderBrush}"/>
            <Setter Property="Background" Value="{DynamicResource WhiteBackgroundBrush}"/>
            <Setter Property="IsTextSearchEnabled" Value="True"/>
        </Style>

        <Style TargetType="Button" x:Key="ClassicBtn">
            <Setter Property="Height" Value="26"/>
            <Setter Property="Background" Value="{DynamicResource ButtonDefaultBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="15,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderBrush" Value="{DynamicResource InputBoxBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource ButtonHoverBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="Button" x:Key="ActionBtn" BasedOn="{StaticResource ClassicBtn}">
            <Setter Property="Background" Value="{DynamicResource ActionBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource WhiteBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource InputBoxBorderBrush}"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource ActionHoverBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="Border" x:Key="ClassicGroupBox">
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="{DynamicResource PanelBackgroundBrush}"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>

    </UserControl.Resources>

    <Grid Margin="5">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="380"/>
            <ColumnDefinition Width="5"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- LEFT SIDE: ENTRY FORM -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Style="{StaticResource ClassicGroupBox}">
                <StackPanel>
                    <TextBlock Text="1. SUB-CATEGORY DEFINITION"
                               Style="{StaticResource HeaderLabel}"
                               Margin="0,0,0,5"/>

                    <!-- Parent category search by code -->
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="115"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   Text="Parent Cat Code *"
                                   Style="{StaticResource InlineLabel}"
                                   Foreground="{DynamicResource HeaderTextBrush}"/>

                        <ComboBox Grid.Column="1"
                                  ItemsSource="{Binding ParentCategories}"
                                  SelectedItem="{Binding SelectedParentCategory, Mode=TwoWay}"
                                  DisplayMemberPath="CategoryCode"
                                  TextSearch.TextPath="CategoryCode"
                                  IsEditable="False"
                                  IsEnabled="{Binding IsParentSelectionEnabled}"
                                  Style="{StaticResource ClassicCombo}"
                                  ToolTip="Select parent category by code. Type while the dropdown is focused to search by code."/>
                    </Grid>

                    <!-- Parent category search by name -->
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="115"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   Text="Parent Cat Name *"
                                   Style="{StaticResource InlineLabel}"
                                   Foreground="{DynamicResource HeaderTextBrush}"/>

                        <ComboBox Grid.Column="1"
                                  ItemsSource="{Binding ParentCategories}"
                                  SelectedItem="{Binding SelectedParentCategory, Mode=TwoWay}"
                                  DisplayMemberPath="CategoryName"
                                  TextSearch.TextPath="CategoryName"
                                  IsEditable="False"
                                  IsEnabled="{Binding IsParentSelectionEnabled}"
                                  Style="{StaticResource ClassicCombo}"
                                  ToolTip="Select parent category by name. Type while the dropdown is focused to search by name."/>
                    </Grid>

                    <Rectangle Height="1"
                               Fill="{DynamicResource LightBorderBrush}"
                               Margin="0,0,0,8"/>

                    <!-- Sub-category code -->
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="115"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   Text="Sub-Cat Code *"
                                   Style="{StaticResource InlineLabel}"
                                   Foreground="{DynamicResource WarningTextBrush}"/>

                        <Border Grid.Column="1"
                                BorderBrush="{DynamicResource InputBoxBorderBrush}"
                                BorderThickness="1"
                                Height="24">

                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="{DynamicResource WhiteBackgroundBrush}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsCodeReadOnly}" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource ButtonDefaultBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0"
                                        Background="{DynamicResource ButtonDefaultBrush}"
                                        BorderBrush="{DynamicResource LightBorderBrush}"
                                        BorderThickness="0,0,1,0">

                                    <TextBlock Text="{Binding ParentPrefix}"
                                               Foreground="{DynamicResource SecondaryTextBrush}"
                                               Padding="6,0"
                                               VerticalAlignment="Center"
                                               FontWeight="Bold"/>
                                </Border>

                                <TextBox Grid.Column="1"
                                         Text="{Binding SubCategorySuffix, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         IsReadOnly="{Binding IsCodeReadOnly}"
                                         BorderThickness="0"
                                         Background="Transparent"
                                         VerticalContentAlignment="Center"
                                         Padding="4,0"
                                         FontWeight="Bold"
                                         CharacterCasing="Upper"
                                         MaxLength="20"
                                         ToolTip="Enter suffix only. Example: SOFT. Final code becomes CAT-SOFT."/>
                            </Grid>
                        </Border>
                    </Grid>

                    <!-- Sub-category name -->
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="115"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   Text="Sub-Cat Name *"
                                   Style="{StaticResource InlineLabel}"/>

                        <TextBox Grid.Column="1"
                                 Text="{Binding SubCategoryName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource ClassicInput}"
                                 FontWeight="Bold"
                                 MaxLength="100"/>
                    </Grid>

                    <TextBlock Text="Code supports A-Z, 0-9, dash, and underscore only. Parent and code lock after saving."
                               FontSize="10"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               Margin="115,3,0,0"
                               FontStyle="Italic"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <Border Grid.Row="1"
                    Style="{StaticResource ClassicGroupBox}"
                    VerticalAlignment="Top">
                <StackPanel>
                    <TextBlock Text="2. SETTINGS"
                               Style="{StaticResource HeaderLabel}"
                               Foreground="{DynamicResource WarningTextBrush}"
                               Margin="0,0,0,5"/>

                    <CheckBox Content="Deactivate Sub-Category"
                              IsChecked="{Binding IsDeactivated, Mode=TwoWay}"
                              FontWeight="Bold"
                              Foreground="{DynamicResource WarningTextBrush}"
                              Margin="0,5,0,0"/>

                    <TextBlock Text="Deactivated sub-categories will not appear during new item creation."
                               FontSize="10"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               Margin="20,2,0,0"
                               FontStyle="Italic"
                               TextWrapping="Wrap"/>

                    <TextBlock Text="Use delete only for unused test or wrongly-created sub-categories."
                               FontSize="10"
                               Foreground="{DynamicResource WarningTextBrush}"
                               Margin="20,8,0,0"
                               FontStyle="Italic"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <Border Grid.Row="2"
                    Background="{DynamicResource PanelBackgroundBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    Padding="10"
                    Margin="0,5,0,0">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="{Binding StatusMessage}"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               FontSize="11"
                               Margin="0,0,0,8"
                               TextWrapping="Wrap"/>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0"
                                Content="DELETE"
                                Command="{Binding DeleteCommand}"
                                Style="{StaticResource ClassicBtn}"
                                Foreground="{DynamicResource WarningTextBrush}"
                                BorderBrush="{DynamicResource WarningTextBrush}"
                                Padding="15,0"
                                Height="30"
                                ToolTip="Deletes only if the sub-category has no linked item records."/>

                        <Button Grid.Column="2"
                                Content="CLEAR"
                                Command="{Binding ClearCommand}"
                                Style="{StaticResource ClassicBtn}"
                                Margin="0,0,10,0"
                                Padding="15,0"
                                Height="30"/>

                        <Button Grid.Column="3"
                                Content="SAVE"
                                Command="{Binding SaveCommand}"
                                Style="{StaticResource ActionBtn}"
                                Padding="20,0"
                                Height="30"
                                FontSize="13"/>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <!-- RIGHT SIDE: DATABASE -->
        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="{DynamicResource HeaderTextBrush}"
                    Padding="10"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1">

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="170"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="SUB-CATEGORY DATABASE"
                               Foreground="{DynamicResource WhiteBackgroundBrush}"
                               FontSize="14"
                               FontWeight="Bold"
                               Margin="0,0,15,0"
                               VerticalAlignment="Center"/>

                    <TextBox Grid.Column="1"
                             Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource ClassicInput}"
                             Height="28"
                             Padding="5,0"
                             Margin="0,0,10,0"
                             ToolTip="Search by parent code, parent name, sub-category code, or sub-category name. Press Enter or click Search.">

                        <TextBox.InputBindings>
                            <KeyBinding Key="Enter"
                                        Command="{Binding SearchCommand}"/>
                        </TextBox.InputBindings>
                    </TextBox>

                    <TextBlock Grid.Column="2"
                               Text="Filter:"
                               Foreground="{DynamicResource WhiteBackgroundBrush}"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               Margin="0,0,8,0"/>

                    <ComboBox Grid.Column="3"
                              ItemsSource="{Binding FilterCategories}"
                              SelectedItem="{Binding SelectedFilterCategory, Mode=TwoWay}"
                              DisplayMemberPath="CategoryName"
                              TextSearch.TextPath="CategoryName"
                              IsEditable="False"
                              Style="{StaticResource ClassicCombo}"
                              Height="28"
                              Margin="0,0,10,0"/>

                    <Button Grid.Column="4"
                            Content="SEARCH"
                            Command="{Binding SearchCommand}"
                            Style="{StaticResource ClassicBtn}"
                            Height="28"
                            Padding="15,0"
                            Margin="0,0,8,0"/>

                    <Button Grid.Column="5"
                            Content="REFRESH"
                            Command="{Binding LoadSubCategoriesCommand}"
                            Style="{StaticResource ClassicBtn}"
                            Height="28"
                            Padding="15,0"/>
                </Grid>
            </Border>

            <DataGrid Grid.Row="1"
                      x:Name="dgSubCategories"
                      ItemsSource="{Binding SubCategories}"
                      SelectedItem="{Binding SelectedSubCategory, Mode=TwoWay}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      IsReadOnly="True"
                      GridLinesVisibility="All"
                      HorizontalGridLinesBrush="{DynamicResource LightBorderBrush}"
                      VerticalGridLinesBrush="{DynamicResource LightBorderBrush}"
                      RowHeight="26"
                      HeadersVisibility="Column"
                      Background="{DynamicResource WhiteBackgroundBrush}"
                      BorderBrush="{DynamicResource BorderBrush}"
                      BorderThickness="1,0,1,1"
                      SelectionMode="Single"
                      AlternatingRowBackground="{DynamicResource DataGridAlternatingRow}">

                <DataGrid.Resources>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="{DynamicResource DataGridHeaderBackground}"/>
                        <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="Padding" Value="5"/>
                        <Setter Property="BorderThickness" Value="0,0,1,1"/>
                        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
                    </Style>

                    <Style TargetType="DataGridCell">
                        <Setter Property="VerticalContentAlignment" Value="Center"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Padding" Value="4,0"/>
                        <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="{DynamicResource LightSelectionBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.Resources>

                <DataGrid.Columns>
                    <DataGridTextColumn Header="Parent Code"
                                        Binding="{Binding Category.CategoryCode}"
                                        Width="110"
                                        IsReadOnly="True"
                                        FontWeight="Bold"/>

                    <DataGridTextColumn Header="Parent Category"
                                        Binding="{Binding Category.CategoryName}"
                                        Width="160"
                                        IsReadOnly="True"
                                        FontWeight="SemiBold"
                                        Foreground="{DynamicResource HeaderTextBrush}"/>

                    <DataGridTextColumn Header="Sub-Cat Code"
                                        Binding="{Binding SubCategoryCode}"
                                        Width="120"
                                        IsReadOnly="True"
                                        FontWeight="Bold"/>

                    <DataGridTextColumn Header="Sub-Category Name"
                                        Binding="{Binding SubCategoryName}"
                                        Width="*"
                                        IsReadOnly="True"/>

                    <DataGridCheckBoxColumn Header="Deactivated"
                                            Binding="{Binding IsDeactivated}"
                                            Width="105">
                        <DataGridCheckBoxColumn.ElementStyle>
                            <Style TargetType="CheckBox">
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="IsHitTestVisible" Value="False"/>
                            </Style>
                        </DataGridCheckBoxColumn.ElementStyle>
                    </DataGridCheckBoxColumn>

                    <DataGridTextColumn Header="Created"
                                        Binding="{Binding CreatedAt, StringFormat={}{0:yyyy-MM-dd HH:mm}}"
                                        Width="135"
                                        IsReadOnly="True"/>

                    <DataGridTextColumn Header="Updated"
                                        Binding="{Binding UpdatedAt, StringFormat={}{0:yyyy-MM-dd HH:mm}}"
                                        Width="135"
                                        IsReadOnly="True"/>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </Grid>
</UserControl>