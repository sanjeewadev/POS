<UserControl x:Class="POS.BackOffice.UI.Views.Pages.InventoryPages.CategoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="700"
             d:DesignWidth="1200"
             Background="{DynamicResource WindowBackgroundBrush}"
             FontFamily="Segoe UI"
             FontSize="12">

    <UserControl.Resources>

        <Style TargetType="TextBlock" x:Key="HeaderLabel">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{DynamicResource HeaderTextBrush}"/>
            <Setter Property="Margin" Value="0,5,0,5"/>
        </Style>

        <Style TargetType="TextBlock" x:Key="InlineLabel">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,5,0"/>
        </Style>

        <Style TargetType="TextBox" x:Key="ClassicInput">
            <Setter Property="Height" Value="24"/>
            <Setter Property="Padding" Value="4,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="{DynamicResource InputBoxBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="{DynamicResource WhiteBackgroundBrush}"/>
            <Style.Triggers>
                <Trigger Property="IsReadOnly" Value="True">
                    <Setter Property="Background" Value="{DynamicResource ButtonDefaultBrush}"/>
                    <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="ComboBox" x:Key="ClassicCombo">
            <Setter Property="Height" Value="24"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="{DynamicResource InputBoxBorderBrush}"/>
            <Setter Property="Background" Value="{DynamicResource WhiteBackgroundBrush}"/>
        </Style>

        <Style TargetType="Button" x:Key="ClassicBtn">
            <Setter Property="Height" Value="26"/>
            <Setter Property="Background" Value="{DynamicResource ButtonDefaultBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="15,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderBrush" Value="{DynamicResource InputBoxBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource ButtonHoverBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="Button" x:Key="ActionBtn" BasedOn="{StaticResource ClassicBtn}">
            <Setter Property="Background" Value="{DynamicResource ActionBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource WhiteBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource InputBoxBorderBrush}"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource ActionHoverBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="Border" x:Key="ClassicGroupBox">
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="{DynamicResource PanelBackgroundBrush}"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>

    </UserControl.Resources>

    <Grid Margin="5">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="380"/>
            <ColumnDefinition Width="5"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- LEFT SIDE: ENTRY FORM -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Style="{StaticResource ClassicGroupBox}">
                <StackPanel>
                    <TextBlock Text="1. CATEGORY DEFINITION"
                               Style="{StaticResource HeaderLabel}"
                               Margin="0,0,0,5"/>

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="105"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   Text="Category Code *"
                                   Style="{StaticResource InlineLabel}"
                                   Foreground="{DynamicResource WarningTextBrush}"/>

                        <TextBox Grid.Column="1"
                                 x:Name="txtCategoryCode"
                                 Text="{Binding CategoryCode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 IsReadOnly="{Binding IsCodeReadOnly}"
                                 Style="{StaticResource ClassicInput}"
                                 FontWeight="Bold"
                                 CharacterCasing="Upper"
                                 MaxLength="20"
                                 ToolTip="Enter a unique code. Example: CAT-001. Cannot be changed after saving."/>
                    </Grid>

                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="105"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   Text="Category Name *"
                                   Style="{StaticResource InlineLabel}"/>

                        <TextBox Grid.Column="1"
                                 x:Name="txtCategoryName"
                                 Text="{Binding CategoryName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource ClassicInput}"
                                 FontWeight="Bold"
                                 MaxLength="100"/>
                    </Grid>

                    <TextBlock Text="Category code supports A-Z, 0-9, dash, and underscore only."
                               FontSize="10"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               Margin="105,3,0,0"
                               FontStyle="Italic"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <Border Grid.Row="1"
                    Style="{StaticResource ClassicGroupBox}"
                    VerticalAlignment="Top">
                <StackPanel>
                    <TextBlock Text="2. SETTINGS"
                               Style="{StaticResource HeaderLabel}"
                               Foreground="{DynamicResource WarningTextBrush}"
                               Margin="0,0,0,5"/>

                    <CheckBox x:Name="chkIsDeactivated"
                              Content="Deactivate Category"
                              IsChecked="{Binding IsDeactivated, Mode=TwoWay}"
                              FontWeight="Bold"
                              Foreground="{DynamicResource WarningTextBrush}"
                              Margin="0,5,0,0"/>

                    <TextBlock Text="Deactivated categories and their sub-categories will be hidden from new item creation."
                               FontSize="10"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               Margin="20,2,0,0"
                               FontStyle="Italic"
                               TextWrapping="Wrap"/>

                    <TextBlock Text="Use delete only for unused test or wrongly-created categories."
                               FontSize="10"
                               Foreground="{DynamicResource WarningTextBrush}"
                               Margin="20,8,0,0"
                               FontStyle="Italic"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <Border Grid.Row="2"
                    Background="{DynamicResource PanelBackgroundBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    Padding="10"
                    Margin="0,5,0,0">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="{Binding StatusMessage}"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               FontSize="11"
                               Margin="0,0,0,8"
                               TextWrapping="Wrap"/>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0"
                                Content="DELETE"
                                Command="{Binding DeleteCommand}"
                                Style="{StaticResource ClassicBtn}"
                                Foreground="{DynamicResource WarningTextBrush}"
                                BorderBrush="{DynamicResource WarningTextBrush}"
                                Padding="15,0"
                                Height="30"
                                ToolTip="Deletes only if the category has no linked records."/>

                        <Button Grid.Column="2"
                                Content="CLEAR"
                                Command="{Binding ClearCommand}"
                                Style="{StaticResource ClassicBtn}"
                                Margin="0,0,10,0"
                                Padding="15,0"
                                Height="30"/>

                        <Button Grid.Column="3"
                                Content="SAVE"
                                Command="{Binding SaveCommand}"
                                Style="{StaticResource ActionBtn}"
                                Padding="20,0"
                                Height="30"
                                FontSize="13"/>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <!-- RIGHT SIDE: CATEGORY DATABASE -->
        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="{DynamicResource HeaderTextBrush}"
                    Padding="10"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1">

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="CATEGORY DATABASE"
                               Foreground="{DynamicResource WhiteBackgroundBrush}"
                               FontSize="14"
                               FontWeight="Bold"
                               Margin="0,0,15,0"
                               VerticalAlignment="Center"/>

                    <TextBox Grid.Column="1"
                             x:Name="txtSearch"
                             Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource ClassicInput}"
                             Height="28"
                             Padding="5,0"
                             Margin="0,0,10,0"
                             ToolTip="Search by code or name. Press Enter or click Search.">

                        <TextBox.InputBindings>
                            <KeyBinding Key="Enter"
                                        Command="{Binding SearchCommand}"/>
                        </TextBox.InputBindings>
                    </TextBox>

                    <Button Grid.Column="2"
                            Content="SEARCH"
                            Command="{Binding SearchCommand}"
                            Style="{StaticResource ClassicBtn}"
                            Height="28"
                            Padding="15,0"
                            Margin="0,0,8,0"/>

                    <Button Grid.Column="3"
                            Content="REFRESH"
                            Command="{Binding LoadDataCommand}"
                            Style="{StaticResource ClassicBtn}"
                            Height="28"
                            Padding="15,0"/>
                </Grid>
            </Border>

            <DataGrid Grid.Row="1"
                      x:Name="dgCategories"
                      ItemsSource="{Binding Categories}"
                      SelectedItem="{Binding SelectedCategory, Mode=TwoWay}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      IsReadOnly="True"
                      HeadersVisibility="Column"
                      GridLinesVisibility="All"
                      HorizontalGridLinesBrush="{DynamicResource LightBorderBrush}"
                      VerticalGridLinesBrush="{DynamicResource LightBorderBrush}"
                      RowHeight="26"
                      Background="{DynamicResource WhiteBackgroundBrush}"
                      BorderBrush="{DynamicResource BorderBrush}"
                      BorderThickness="1,0,1,1"
                      SelectionMode="Single"
                      AlternatingRowBackground="{DynamicResource DataGridAlternatingRow}">

                <DataGrid.Resources>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="{DynamicResource DataGridHeaderBackground}"/>
                        <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="Padding" Value="5"/>
                        <Setter Property="BorderThickness" Value="0,0,1,1"/>
                        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
                    </Style>

                    <Style TargetType="DataGridCell">
                        <Setter Property="VerticalContentAlignment" Value="Center"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Padding" Value="4,0"/>
                        <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="{DynamicResource LightSelectionBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.Resources>

                <DataGrid.Columns>
                    <DataGridTextColumn Header="Category Code"
                                        Binding="{Binding CategoryCode}"
                                        Width="120"
                                        IsReadOnly="True"
                                        FontWeight="Bold"/>

                    <DataGridTextColumn Header="Category Name"
                                        Binding="{Binding CategoryName}"
                                        Width="*"
                                        IsReadOnly="True"/>

                    <DataGridCheckBoxColumn Header="Deactivated"
                                            Binding="{Binding IsDeactivated}"
                                            Width="110">
                        <DataGridCheckBoxColumn.ElementStyle>
                            <Style TargetType="CheckBox">
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="IsHitTestVisible" Value="False"/>
                            </Style>
                        </DataGridCheckBoxColumn.ElementStyle>
                    </DataGridCheckBoxColumn>

                    <DataGridTextColumn Header="Created"
                                        Binding="{Binding CreatedAt, StringFormat={}{0:yyyy-MM-dd HH:mm}}"
                                        Width="135"
                                        IsReadOnly="True"/>

                    <DataGridTextColumn Header="Updated"
                                        Binding="{Binding UpdatedAt, StringFormat={}{0:yyyy-MM-dd HH:mm}}"
                                        Width="135"
                                        IsReadOnly="True"/>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </Grid>
</UserControl>