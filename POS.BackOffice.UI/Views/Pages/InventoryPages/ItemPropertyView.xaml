<UserControl x:Class="POS.BackOffice.UI.Views.Pages.InventoryPages.ItemPropertyView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="1200"
             Background="{DynamicResource WindowBackgroundBrush}" FontFamily="Segoe UI" FontSize="12">

    <UserControl.Resources>

        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>

        <Style TargetType="TextBlock" x:Key="HeaderLabel">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{DynamicResource HeaderTextBrush}"/>
            <Setter Property="Margin" Value="0,5,0,5"/>
        </Style>

        <Style TargetType="TextBlock" x:Key="InlineLabel">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,5,0"/>
        </Style>

        <Style TargetType="TextBox" x:Key="ClassicInput">
            <Setter Property="Height" Value="24"/>
            <Setter Property="Padding" Value="4,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="{DynamicResource InputBoxBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="{DynamicResource WhiteBackgroundBrush}"/>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="{DynamicResource ButtonDefaultBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="Button" x:Key="ClassicBtn">
            <Setter Property="Height" Value="26"/>
            <Setter Property="Background" Value="{DynamicResource ButtonDefaultBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="15,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderBrush" Value="{DynamicResource InputBoxBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource ButtonHoverBrush}"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.5"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="Button" x:Key="ActionBtn" BasedOn="{StaticResource ClassicBtn}">
            <Setter Property="Background" Value="{DynamicResource ActionBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource WhiteBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource InputBoxBorderBrush}"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource ActionHoverBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="Border" x:Key="ClassicGroupBox">
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="{DynamicResource PanelBackgroundBrush}"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>

        <Style TargetType="DataGridCell" x:Key="BaseCell">
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="4,0"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource LightSelectionBrush}"/>
                    <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Margin="5">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="450"/>
            <ColumnDefinition Width="5"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Style="{StaticResource ClassicGroupBox}">
                <StackPanel>
                    <TextBlock Text="1. ATTRIBUTE GROUP DEFINITION" Style="{StaticResource HeaderLabel}" Margin="0,0,0,10"/>

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Group Name *" Style="{StaticResource InlineLabel}" Foreground="{DynamicResource WarningTextBrush}"/>
                        <TextBox Grid.Column="1" Text="{Binding GroupNameInput, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ClassicInput}" FontWeight="Bold" ToolTip="e.g., Color, Size, Storage"/>
                    </Grid>

                    <CheckBox Content="Deactivate Group" IsChecked="{Binding IsGroupDeactivated, Mode=TwoWay}" FontWeight="Bold" Foreground="{DynamicResource WarningTextBrush}" Margin="100,0,0,10"/>

                    <Grid Margin="0,5,0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Assign to Categories:" Style="{StaticResource InlineLabel}" VerticalAlignment="Center"/>
                        <TextBox Grid.Column="1" Text="{Binding CategorySearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                 Style="{StaticResource ClassicInput}" Height="22" Margin="10,0,0,0" ToolTip="Search categories..."/>
                    </Grid>

                    <Border Background="{DynamicResource WhiteBackgroundBrush}" BorderBrush="{DynamicResource InputBoxBorderBrush}" BorderThickness="1" Height="120" Margin="0,0,0,10">
                        <ListBox ItemsSource="{Binding Categories}" BorderThickness="0" Background="Transparent" ScrollViewer.VerticalScrollBarVisibility="Auto">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <CheckBox Content="{Binding CategoryName}" 
                                              IsChecked="{Binding IsSelected, Mode=TwoWay}" 
                                              Margin="5,2" 
                                              Cursor="Hand" 
                                              VerticalContentAlignment="Center"
                                              Visibility="{Binding IsVisible, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Border>

                    <Border Background="{DynamicResource WindowBackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="5">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" Content="🗑️ DELETE" Command="{Binding DeleteGroupCommand}" Style="{StaticResource ClassicBtn}" Foreground="{DynamicResource WarningTextBrush}" BorderBrush="{DynamicResource WarningTextBrush}" Padding="10,0"/>
                            <Button Grid.Column="2" Content="CLEAR" Command="{Binding ClearGroupCommand}" Style="{StaticResource ClassicBtn}" Margin="0,0,5,0" Padding="10,0"/>
                            <Button Grid.Column="3" Content="💾 SAVE GROUP" Command="{Binding SaveGroupCommand}" Style="{StaticResource ActionBtn}" Padding="15,0"/>
                        </Grid>
                    </Border>
                </StackPanel>
            </Border>

            <Border Grid.Row="1" Background="{DynamicResource HeaderTextBrush}" Padding="5" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="5,0,0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="GROUPS DATABASE" Foreground="{DynamicResource WhiteBackgroundBrush}" FontSize="12" FontWeight="Bold" VerticalAlignment="Center"/>
                        <TextBox Grid.Column="1" Text="{Binding GroupSearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                 Style="{StaticResource ClassicInput}" Height="22" Margin="10,0,5,0" ToolTip="Search groups..."/>
                    </Grid>

                    <DataGrid Grid.Row="1" ItemsSource="{Binding AttributeGroups}" SelectedItem="{Binding SelectedAttributeGroup, Mode=TwoWay}" 
                              AutoGenerateColumns="False" CanUserAddRows="False" GridLinesVisibility="All" 
                              HorizontalGridLinesBrush="{DynamicResource LightBorderBrush}" VerticalGridLinesBrush="{DynamicResource LightBorderBrush}" 
                              RowHeight="26" HeadersVisibility="Column" Background="{DynamicResource WhiteBackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" 
                              SelectionMode="Single" AlternatingRowBackground="{DynamicResource DataGridAlternatingRow}">
                        <DataGrid.Resources>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="{DynamicResource DataGridHeaderBackground}"/>
                                <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="Padding" Value="5"/>
                                <Setter Property="BorderThickness" Value="0,0,1,1"/>
                                <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
                            </Style>
                            <Style TargetType="DataGridCell" BasedOn="{StaticResource BaseCell}"/>
                        </DataGrid.Resources>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Group Name" Binding="{Binding GroupName}" Width="*" IsReadOnly="True" FontWeight="Bold"/>
                            <DataGridCheckBoxColumn Header="Status (Deactivated)" Binding="{Binding IsDeactivated}" Width="130">
                                <DataGridCheckBoxColumn.ElementStyle>
                                    <Style TargetType="CheckBox">
                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="IsHitTestVisible" Value="False"/>
                                    </Style>
                                </DataGridCheckBoxColumn.ElementStyle>
                            </DataGridCheckBoxColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>

        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Style="{StaticResource ClassicGroupBox}" IsEnabled="{Binding IsValueManagerEnabled}">
                <StackPanel>
                    <TextBlock Text="2. ATTRIBUTE VALUES (Rapid Entry)" Style="{StaticResource HeaderLabel}" Foreground="{DynamicResource SuccessBorderBrush}" Margin="0,0,0,10"/>

                    <TextBlock Text="{Binding ValueManagerHeader, TargetNullValue='Please select a Group from the left to add values.'}" FontSize="11" FontStyle="Italic" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,10"/>

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Value Name *" Style="{StaticResource InlineLabel}" Foreground="{DynamicResource WarningTextBrush}"/>
                        <TextBox Grid.Column="1" Text="{Binding ValueNameInput, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ClassicInput}" Background="{DynamicResource HighlightBackgroundBrush}" FontWeight="Bold" ToolTip="e.g., Red, XL, 512GB"/>
                    </Grid>

                    <CheckBox Content="Deactivate Value" IsChecked="{Binding IsValueDeactivated, Mode=TwoWay}" FontWeight="Bold" Foreground="{DynamicResource WarningTextBrush}" Margin="100,0,0,10"/>

                    <Border Background="{DynamicResource WindowBackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="5">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" Content="🗑️ DELETE" Command="{Binding DeleteValueCommand}" Style="{StaticResource ClassicBtn}" Foreground="{DynamicResource WarningTextBrush}" BorderBrush="{DynamicResource WarningTextBrush}" Padding="10,0"/>
                            <Button Grid.Column="2" Content="CLEAR" Command="{Binding ClearValueCommand}" Style="{StaticResource ClassicBtn}" Margin="0,0,5,0" Padding="10,0"/>
                            <Button Grid.Column="3" Content="💾 SAVE VALUE" Command="{Binding SaveValueCommand}" Style="{StaticResource ActionBtn}" Padding="15,0"/>
                        </Grid>
                    </Border>
                </StackPanel>
            </Border>

            <Border Grid.Row="1" Background="{DynamicResource HeaderTextBrush}" Padding="5" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Margin="0,5,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="VALUES DATABASE" Foreground="{DynamicResource WhiteBackgroundBrush}" FontSize="12" FontWeight="Bold" VerticalAlignment="Center" Margin="5,0,15,0"/>
                        <TextBox Grid.Column="2" Text="{Binding ValueSearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ClassicInput}" Height="24" Padding="5,0" Margin="0,0,5,0" ToolTip="Search Values..."/>
                        <Button Grid.Column="3" Content="SEARCH" Command="{Binding SearchValuesCommand}" Style="{StaticResource ClassicBtn}" Height="24" Padding="10,0"/>
                    </Grid>

                    <DataGrid Grid.Row="1" ItemsSource="{Binding AttributeValues}" SelectedItem="{Binding SelectedAttributeValue, Mode=TwoWay}" 
                              AutoGenerateColumns="False" CanUserAddRows="False" GridLinesVisibility="All" 
                              HorizontalGridLinesBrush="{DynamicResource LightBorderBrush}" VerticalGridLinesBrush="{DynamicResource LightBorderBrush}" 
                              RowHeight="26" HeadersVisibility="Column" Background="{DynamicResource WhiteBackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" 
                              SelectionMode="Single" AlternatingRowBackground="{DynamicResource DataGridAlternatingRow}">
                        <DataGrid.Resources>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="{DynamicResource DataGridHeaderBackground}"/>
                                <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="Padding" Value="5"/>
                                <Setter Property="BorderThickness" Value="0,0,1,1"/>
                                <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
                            </Style>
                            <Style TargetType="DataGridCell" BasedOn="{StaticResource BaseCell}"/>
                        </DataGrid.Resources>

                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Value Name" Binding="{Binding ValueName}" Width="*" IsReadOnly="True" FontWeight="Bold"/>
                            <DataGridCheckBoxColumn Header="Status (Deactivated)" Binding="{Binding IsDeactivated}" Width="130">
                                <DataGridCheckBoxColumn.ElementStyle>
                                    <Style TargetType="CheckBox">
                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="IsHitTestVisible" Value="False"/>
                                    </Style>
                                </DataGridCheckBoxColumn.ElementStyle>
                            </DataGridCheckBoxColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>