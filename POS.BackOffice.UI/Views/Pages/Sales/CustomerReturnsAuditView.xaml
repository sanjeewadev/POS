<UserControl x:Class="POS.BackOffice.UI.Views.Pages.Sales.CustomerReturnsAuditView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#D4D0C8" FontFamily="Segoe UI" FontSize="12">

    <UserControl.Resources>
        <Style TargetType="TextBlock" x:Key="HeaderLabel">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#003366"/>
            <Setter Property="Margin" Value="0,5,0,5"/>
        </Style>

        <Style TargetType="TextBlock" x:Key="InlineLabel">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,5,0"/>
        </Style>

        <Style TargetType="TextBox" x:Key="ClassicInput">
            <Setter Property="Height" Value="24"/>
            <Setter Property="Padding" Value="4,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="#808080"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
        </Style>

        <Style TargetType="ComboBox" x:Key="ClassicCombo">
            <Setter Property="Height" Value="24"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="#808080"/>
            <Setter Property="Background" Value="White"/>
        </Style>

        <Style TargetType="DatePicker" x:Key="ClassicDate">
            <Setter Property="Height" Value="24"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="#808080"/>
        </Style>

        <Style TargetType="Button" x:Key="ClassicBtn">
            <Setter Property="Height" Value="26"/>
            <Setter Property="Background" Value="#E0E0E0"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="15,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderBrush" Value="#808080"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#CCCCCC"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="Border" x:Key="ClassicGroupBox">
            <Setter Property="BorderBrush" Value="#A0A0A0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="#F0F0F0"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="5">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="3*"/>
            <RowDefinition Height="2*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#003366" Padding="10" BorderBrush="#002244" BorderThickness="1" Margin="0,0,0,5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="CUSTOMER RETURNS AUDIT LEDGER" Foreground="White" FontSize="14" FontWeight="Bold" Margin="0,0,20,0" VerticalAlignment="Center"/>

                <WrapPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="From Date:" Foreground="#A0C0E0" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,5,0"/>
                    <DatePicker SelectedDate="{Binding FilterStartDate}" Style="{StaticResource ClassicDate}" Width="110" Margin="0,0,10,0"/>

                    <TextBlock Text="To:" Foreground="#A0C0E0" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,5,0"/>
                    <DatePicker SelectedDate="{Binding FilterEndDate}" Style="{StaticResource ClassicDate}" Width="110" Margin="0,0,15,0"/>

                    <TextBlock Text="Action Filter:" Foreground="#A0C0E0" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,5,0"/>
                    <ComboBox SelectedItem="{Binding SelectedActionFilter}" Style="{StaticResource ClassicCombo}" Width="140" Margin="0,0,15,0">
                        <System:String xmlns:System="clr-namespace:System;assembly=mscorlib">All Returns</System:String>
                        <System:String xmlns:System="clr-namespace:System;assembly=mscorlib">Contains Damaged</System:String>
                        <System:String xmlns:System="clr-namespace:System;assembly=mscorlib">Blind Returns (No Inv)</System:String>
                    </ComboBox>

                    <TextBlock Text="Search (Return/Inv/Cashier):" Foreground="#A0C0E0" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,5,0"/>
                    <TextBox Text="{Binding SearchKeyword, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ClassicInput}" Width="160" Margin="0,0,15,0"/>

                    <Button Content="[ F5 - REFRESH ]" Command="{Binding RefreshDataCommand}" Style="{StaticResource ClassicBtn}" Background="#D0E4F5" BorderBrush="#003366" Foreground="#003366" Height="24" Padding="10,0"/>
                </WrapPanel>
            </Grid>
        </Border>

        <DataGrid Grid.Row="1" ItemsSource="{Binding ReturnsList}" SelectedItem="{Binding SelectedReturn}" 
                  AutoGenerateColumns="False" CanUserAddRows="False" GridLinesVisibility="All" 
                  HorizontalGridLinesBrush="#C0C0C0" VerticalGridLinesBrush="#D0D0D0" 
                  RowHeight="26" HeadersVisibility="Column" Background="White" BorderBrush="#A0A0A0" BorderThickness="1" 
                  SelectionMode="Single" AlternatingRowBackground="#F9F9F9" IsReadOnly="True" Margin="0,0,0,5">
            <DataGrid.Resources>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="#E0E0E0"/>
                    <Setter Property="Foreground" Value="Black"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                    <Setter Property="Padding" Value="5"/>
                    <Setter Property="BorderThickness" Value="0,0,1,1"/>
                    <Setter Property="BorderBrush" Value="#A0A0A0"/>
                </Style>
            </DataGrid.Resources>
            <DataGrid.Columns>
                <DataGridTextColumn Header="Return No." Binding="{Binding ReturnNo}" Width="130" FontWeight="Bold"/>
                <DataGridTextColumn Header="Date &amp; Time" Binding="{Binding ReturnDate, StringFormat=yyyy-MM-dd HH:mm}" Width="130"/>

                <DataGridTextColumn Header="Original Inv No." Binding="{Binding OriginalInvoiceNo}" Width="130">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="VerticalAlignment" Value="Center"/>
                            <Setter Property="Padding" Value="4,0"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding OriginalInvoiceNo}" Value="{x:Null}">
                                    <Setter Property="Text" Value="[ BLIND RETURN ]"/>
                                    <Setter Property="Foreground" Value="#D97706"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding OriginalInvoiceNo}" Value="">
                                    <Setter Property="Text" Value="[ BLIND RETURN ]"/>
                                    <Setter Property="Foreground" Value="#D97706"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn Header="Terminal" Binding="{Binding TerminalNo}" Width="70"/>
                <DataGridTextColumn Header="Cashier" Binding="{Binding CashierName}" Width="120"/>
                <DataGridTextColumn Header="Auth By" Binding="{Binding AuthorizedBy}" Width="120"/>

                <DataGridTextColumn Header="Refund Method" Binding="{Binding RefundMethod}" Width="110"/>

                <DataGridTextColumn Header="Total Refund Rs." Binding="{Binding TotalRefundAmount, StringFormat=N2}" Width="120" FontWeight="Bold" Foreground="#8B0000">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Right"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                            <Setter Property="Padding" Value="0,0,4,0"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
            </DataGrid.Columns>
        </DataGrid>

        <Border Grid.Row="2" Style="{StaticResource ClassicGroupBox}" VerticalAlignment="Stretch" Padding="0">
            <Grid IsEnabled="{Binding IsReturnSelected}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="280"/>
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0" Margin="0,0,5,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="#E0E0E0" BorderBrush="#A0A0A0" BorderThickness="0,0,1,1" Padding="8,4">
                        <TextBlock Text="RETURNED ITEMS BREAKDOWN &amp; ROUTING" Style="{StaticResource HeaderLabel}" Margin="0"/>
                    </Border>

                    <DataGrid Grid.Row="1" ItemsSource="{Binding SelectedReturnLines}" 
                              AutoGenerateColumns="False" CanUserAddRows="False" GridLinesVisibility="All" 
                              HorizontalGridLinesBrush="#E0E0E0" VerticalGridLinesBrush="#E0E0E0" 
                              RowHeight="26" HeadersVisibility="Column" Background="White" BorderThickness="0,0,1,0" BorderBrush="#A0A0A0"
                              SelectionMode="Single" IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Qty" Binding="{Binding QuantityReturned}" Width="45">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn Header="Item Description" Binding="{Binding ItemDescription}" Width="*" FontWeight="SemiBold"/>
                            <DataGridTextColumn Header="Reason Code" Binding="{Binding ReturnReason}" Width="120" Foreground="#666"/>

                            <DataGridTextColumn Header="Inventory Action Taken" Binding="{Binding InventoryAction}" Width="180" FontWeight="Bold">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="Padding" Value="4,0"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding InventoryAction}" Value="Restocked">
                                                <Setter Property="Foreground" Value="#005500"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding InventoryAction}" Value="Write-Off / Damaged Bin">
                                                <Setter Property="Foreground" Value="#8B0000"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn Header="Refund Total" Binding="{Binding LineTotalRefund, StringFormat=N2}" Width="100" FontWeight="Bold">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Right"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>

                <Border Grid.Column="1" Background="#E8E8E8" Padding="15">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="INVENTORY CORRECTION" Style="{StaticResource HeaderLabel}" Foreground="#333" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                        <TextBlock Text="Use these actions to manually correct where the physical items were routed after the refund." TextWrapping="Wrap" Foreground="#555" FontStyle="Italic" TextAlignment="Center" Margin="0,0,0,20"/>

                        <Button Command="{Binding RerouteToSupplierCommand}" Content="📦 RE-ROUTE TO SUPPLIER (RTV)" 
                                Style="{StaticResource ClassicBtn}" Height="40" Margin="0,0,0,15" Background="#005555" Foreground="White" BorderBrush="#003333"/>

                        <Button Command="{Binding PrintReturnVoucherCommand}" Content="🖨️ PRINT RETURN VOUCHER" 
                                Style="{StaticResource ClassicBtn}" Height="40" Margin="0,0,0,15" Background="#D0E4F5" BorderBrush="#003366"/>

                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>