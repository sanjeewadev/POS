<UserControl x:Class="POS.BackOffice.UI.Views.Pages.Sales.WholesaleInvoiceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="900" d:DesignWidth="1250"
             Background="#F5F5F5">

    <UserControl.Resources>
        <!-- Standard Button Style -->
        <Style TargetType="Button" x:Key="StandardBtn">
            <Setter Property="Background" Value="#2B3C38"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#3B524E"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Post Action Button (Green for Revenue) -->
        <Style TargetType="Button" x:Key="PostBtn" BasedOn="{StaticResource StandardBtn}">
            <Setter Property="Background" Value="#28A745"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#218838"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Standard Input Style -->
        <Style TargetType="Control" x:Key="StandardInput">
            <Setter Property="Padding" Value="5"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="BorderBrush" Value="#CCCCCC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Height" Value="30"/>
        </Style>

        <!-- Group Box Border Style -->
        <Style TargetType="Border" x:Key="GroupBoxBorder">
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="15"/>
            <Setter Property="Background" Value="White"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Header (Master Data) -->
            <RowDefinition Height="Auto"/>
            <!-- Product Entry Bar -->
            <RowDefinition Height="*"/>
            <!-- Data Grid (Details) -->
            <RowDefinition Height="Auto"/>
            <!-- Footer (Financials & Actions) -->
        </Grid.RowDefinitions>

        <!-- ========================================== -->
        <!-- ZONE 1: DOCUMENT HEADER (MASTER)           -->
        <!-- ========================================== -->
        <Border Grid.Row="0" Style="{StaticResource GroupBoxBorder}" Margin="0,0,0,15">
            <StackPanel>
                <Grid Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal" Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="Wholesale Tax Invoice (B2B Sales)" FontSize="20" FontWeight="SemiBold" Foreground="#28A745" Margin="0,0,15,0"/>
                        <!-- Load from Quote Option -->
                        <TextBlock Text="Load from Quote:" Foreground="#666666" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <ComboBox x:Name="cmbQuoteReference" Width="200" Padding="5" BorderBrush="#CCCCCC" ToolTip="Select an approved quotation to auto-fill this invoice"/>
                    </StackPanel>

                    <!-- Status Badge -->
                    <Border Grid.Column="1" Background="#FFF3CD" BorderBrush="#FFEEBA" BorderThickness="1" CornerRadius="4" Padding="10,5">
                        <TextBlock Text="Status: DRAFT" FontWeight="Bold" Foreground="#856404"/>
                    </Border>
                </Grid>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="1.5*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="1.5*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Row 1: Identity & Credit Check -->
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Registered Customer (Debtor) *" Foreground="#2B5B84" FontWeight="SemiBold" Margin="0,0,0,5"/>
                        <ComboBox x:Name="cmbCustomer" Style="{StaticResource StandardInput}" IsEditable="True" Margin="0,0,0,5"/>
                        <!-- CRITICAL B2B FEATURE: Credit Limit Indicator -->
                        <Border Background="#FDF3F3" BorderBrush="#F5C6CB" BorderThickness="1" CornerRadius="2" Padding="5">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <TextBlock Text="Credit Limit: Rs. 500,000" Foreground="#A94044" FontSize="11" Margin="0,0,15,0"/>
                                <TextBlock Text="Available Credit: Rs. 150,000" Foreground="#A94044" FontSize="11" FontWeight="Bold"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Payment Terms *" Foreground="#666666" Margin="0,0,0,5"/>
                        <ComboBox x:Name="cmbPaymentTerms" Style="{StaticResource StandardInput}">
                            <ComboBoxItem Content="Cash on Delivery (COD)"/>
                            <ComboBoxItem Content="Net 15 Days"/>
                            <ComboBoxItem Content="Net 30 Days" IsSelected="True"/>
                            <ComboBoxItem Content="Net 60 Days"/>
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Grid.Column="4">
                        <TextBlock Text="Sales Rep *" Foreground="#666666" Margin="0,0,0,5"/>
                        <ComboBox x:Name="cmbSalesRep" Style="{StaticResource StandardInput}" DisplayMemberPath="Name" SelectedValuePath="Id"/>
                    </StackPanel>

                    <StackPanel Grid.Column="6">
                        <TextBlock Text="Invoice No." Foreground="#666666" Margin="0,0,0,5"/>
                        <TextBox x:Name="txtInvoiceNo" Style="{StaticResource StandardInput}" Background="#EEEEEE" IsReadOnly="True" Text="[Auto-Generated]"/>
                    </StackPanel>
                </Grid>

                <Grid Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="3*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Invoice Date *" Foreground="#666666" Margin="0,0,0,5"/>
                        <DatePicker x:Name="dpInvoiceDate" Style="{StaticResource StandardInput}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Due Date *" Foreground="#A94044" FontWeight="SemiBold" Margin="0,0,0,5"/>
                        <DatePicker x:Name="dpDueDate" Style="{StaticResource StandardInput}" Background="#FFFFE0" ToolTip="Auto-calculated from Payment Terms"/>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>

        <!-- ========================================== -->
        <!-- ZONE 2: PRODUCT ENTRY BAR                  -->
        <!-- ========================================== -->
        <Border Grid.Row="1" Background="#E2F0CB" BorderBrush="#C3E6CB" BorderThickness="1" CornerRadius="4" Padding="15" Margin="0,0,0,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2.5*"/>
                    <!-- Product Search -->
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="1*"/>
                    <!-- Available Stock -->
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="1*"/>
                    <!-- Unit Price -->
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="1*"/>
                    <!-- Discount -->
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="1*"/>
                    <!-- Quantity -->
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="Auto"/>
                    <!-- Add Button -->
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Scan / Search Product" Foreground="#333333" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <ComboBox x:Name="cmbProductSearch" Style="{StaticResource StandardInput}" IsEditable="True" Margin="0"/>
                </StackPanel>

                <!-- CRITICAL BLOCKER: Stock Verification -->
                <StackPanel Grid.Column="2">
                    <TextBlock Text="Available Stock *" Foreground="#A94044" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <TextBox x:Name="txtAvailableStock" Style="{StaticResource StandardInput}" HorizontalContentAlignment="Center" Background="#EEEEEE" IsReadOnly="True" Margin="0" ToolTip="You cannot invoice stock you do not have"/>
                </StackPanel>

                <StackPanel Grid.Column="4">
                    <TextBlock Text="Unit Price (Rs.)" Foreground="#666666" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <TextBox x:Name="txtUnitPrice" Style="{StaticResource StandardInput}" HorizontalContentAlignment="Right" Margin="0"/>
                </StackPanel>

                <StackPanel Grid.Column="6">
                    <TextBlock Text="Discount (Rs.)" Foreground="#28A745" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <TextBox x:Name="txtItemDiscount" Style="{StaticResource StandardInput}" HorizontalContentAlignment="Right" Margin="0" Text="0.00"/>
                </StackPanel>

                <StackPanel Grid.Column="8">
                    <TextBlock Text="Invoice Qty *" Foreground="#333333" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <TextBox x:Name="txtQty" Style="{StaticResource StandardInput}" HorizontalContentAlignment="Center" Background="#FFFFE0" Margin="0"/>
                </StackPanel>

                <Button Grid.Column="10" x:Name="btnAddItem" Content="Add to Invoice" Style="{StaticResource StandardBtn}" Background="#28A745" Margin="0" VerticalAlignment="Bottom" Height="30" Width="110"/>
            </Grid>
        </Border>

        <!-- ========================================== -->
        <!-- ZONE 3: INVOICE GRID (DETAILS)             -->
        <!-- ========================================== -->
        <Border Grid.Row="2" Style="{StaticResource GroupBoxBorder}" Padding="0" Margin="0,0,0,15">
            <DataGrid x:Name="dgInvoiceLines" 
                      AutoGenerateColumns="False" 
                      CanUserAddRows="False" 
                      CanUserDeleteRows="False" 
                      HeadersVisibility="Column" 
                      GridLinesVisibility="Horizontal"
                      HorizontalGridLinesBrush="#EEEEEE"
                      BorderThickness="0"
                      RowHeight="40"
                      Background="Transparent">

                <DataGrid.Resources>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#F8F8F8"/>
                        <Setter Property="Foreground" Value="#333333"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="Padding" Value="15,10"/>
                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                        <Setter Property="BorderBrush" Value="#DDDDDD"/>
                    </Style>
                    <Style TargetType="DataGridCell">
                        <Setter Property="Padding" Value="15,0"/>
                        <Setter Property="VerticalContentAlignment" Value="Center"/>
                    </Style>
                </DataGrid.Resources>

                <DataGrid.Columns>
                    <DataGridTextColumn Header="Item Code" Binding="{Binding ItemCode}" Width="110" IsReadOnly="True"/>
                    <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="*" IsReadOnly="True"/>

                    <DataGridTextColumn Header="Invoice Qty" Binding="{Binding Qty}" Width="100">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="Foreground" Value="#28A745"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="Unit Price" Binding="{Binding UnitPrice, StringFormat=N2}" Width="120">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Right"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="Discount" Binding="{Binding ItemDiscount, StringFormat=N2}" Width="100">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                <Setter Property="Foreground" Value="#28A745"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="Line Total" Binding="{Binding LineTotal, StringFormat=N2}" Width="140" IsReadOnly="True">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <!-- Remove Row Button -->
                    <DataGridTemplateColumn Header="Del" Width="60">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="X" Background="#A94044" Foreground="White" BorderThickness="0" Cursor="Hand" Width="25" Height="25" FontWeight="Bold"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- ========================================== -->
        <!-- ZONE 4: FOOTER (FINANCIALS & ACTIONS)      -->
        <!-- ========================================== -->
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Legal Terms & Financial Accounting Block -->
            <Border Grid.Column="0" Background="#F8F8F8" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="4" Padding="15" Margin="0,0,20,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Logistics & Remarks -->
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Dispatch / Transport Remarks:" Foreground="#666666" FontSize="12" Margin="0,0,0,5"/>
                        <TextBox x:Name="txtRemarks" Height="40" TextWrapping="Wrap" AcceptsReturn="True" BorderBrush="#CCCCCC" BorderThickness="1" Padding="5" Margin="0,0,0,10" ToolTip="e.g., Lorry number or courier service"/>

                        <!-- Tax Checkbox -->
                        <CheckBox x:Name="chkApplyTax" Content="Apply Statutory Taxes (VAT/SSCL)" IsChecked="True" Foreground="#333333" FontWeight="SemiBold" Cursor="Hand"/>
                    </StackPanel>

                    <!-- Strict Accounting Ledger -->
                    <Grid Grid.Column="2" HorizontalAlignment="Right" MinWidth="300">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <DockPanel Grid.Row="0" Margin="0,0,0,5">
                            <TextBlock Text="Subtotal:" Foreground="#666666"/>
                            <TextBlock x:Name="txtSubtotal" Text="Rs. 0.00" FontWeight="SemiBold" HorizontalAlignment="Right" Foreground="#333333"/>
                        </DockPanel>

                        <DockPanel Grid.Row="1" Margin="0,0,0,5">
                            <TextBlock Text="Tax Amount:" Foreground="#A94044"/>
                            <TextBlock x:Name="txtTaxAmount" Text="Rs. 0.00" HorizontalAlignment="Right" Foreground="#A94044"/>
                        </DockPanel>

                        <DockPanel Grid.Row="2" Margin="0,0,0,10">
                            <TextBlock Text="Bill Discount (Rs.):" Foreground="#28A745" VerticalAlignment="Center"/>
                            <TextBox x:Name="txtBillDiscount" Width="100" Text="0.00" HorizontalAlignment="Right" HorizontalContentAlignment="Right" Padding="2" BorderBrush="#CCCCCC" BorderThickness="1"/>
                        </DockPanel>

                        <!-- GRAND TOTAL -->
                        <Border Grid.Row="3" BorderBrush="#CCCCCC" BorderThickness="0,1,0,0" Padding="0,5">
                            <DockPanel>
                                <TextBlock Text="NET PAYABLE (GRAND TOTAL):" Foreground="#2B3C38" FontWeight="Bold" FontSize="14" VerticalAlignment="Center"/>
                                <TextBlock x:Name="txtGrandTotal" Text="Rs. 0.00" FontWeight="Bold" FontSize="20" Foreground="#2B3C38" HorizontalAlignment="Right"/>
                            </DockPanel>
                        </Border>

                        <!-- Advance Payment -->
                        <DockPanel Grid.Row="4" Margin="0,10,0,5">
                            <TextBlock Text="Advance Paid Today (Rs.):" Foreground="#2B5B84" VerticalAlignment="Center"/>
                            <TextBox x:Name="txtAdvancePayment" Width="120" Text="0.00" Background="#E2EDF8" FontWeight="Bold" HorizontalAlignment="Right" HorizontalContentAlignment="Right" Padding="2" BorderBrush="#B6D4FE" BorderThickness="1" ToolTip="Enter any cash or card payment received right now"/>
                        </DockPanel>

                        <!-- FINAL BALANCE (DEBT) -->
                        <Border Grid.Row="5" Background="#FFF3CD" BorderBrush="#FFEEBA" BorderThickness="1" Padding="5,2" CornerRadius="2">
                            <DockPanel>
                                <TextBlock Text="BALANCE DUE:" Foreground="#856404" FontWeight="Bold" VerticalAlignment="Center"/>
                                <TextBlock x:Name="txtBalanceDue" Text="Rs. 0.00" FontWeight="Bold" FontSize="18" Foreground="#856404" HorizontalAlignment="Right"/>
                            </DockPanel>
                        </Border>
                    </Grid>
                </Grid>
            </Border>

            <!-- Action Buttons -->
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Bottom">
                <Button Content="Clear Form" Style="{StaticResource StandardBtn}" Background="#777777" Width="100"/>
                <Button Content="Save Draft" Style="{StaticResource StandardBtn}" Width="110"/>
                <Button Content="POST INVOICE" Style="{StaticResource PostBtn}" Width="160" Margin="0" ToolTip="Deducts stock and creates Accounts Receivable debt"/>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>