<UserControl x:Class="POS.BackOffice.UI.Views.Pages.Sales.ItemSalesAnalyticsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
             mc:Ignorable="d" 
             d:DesignHeight="850" d:DesignWidth="1400"
             Background="#D4D0C8" FontFamily="Segoe UI" FontSize="12">

    <UserControl.Resources>
        <Style TargetType="TextBlock" x:Key="HeaderLabel">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#003366"/>
            <Setter Property="Margin" Value="0,5,0,10"/>
        </Style>

        <Style TargetType="TextBlock" x:Key="InlineLabel">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,5,0"/>
        </Style>

        <Style TargetType="TextBox" x:Key="ClassicInput">
            <Setter Property="Height" Value="26"/>
            <Setter Property="Padding" Value="4,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="#808080"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
        </Style>

        <Style TargetType="DatePicker" x:Key="ClassicDate">
            <Setter Property="Height" Value="26"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="#808080"/>
            <Setter Property="Width" Value="130"/>
        </Style>

        <Style TargetType="Button" x:Key="ClassicBtn">
            <Setter Property="Height" Value="28"/>
            <Setter Property="Background" Value="#E0E0E0"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="15,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderBrush" Value="#808080"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#CCCCCC"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="Button" x:Key="ActionBtn" BasedOn="{StaticResource ClassicBtn}">
            <Setter Property="Background" Value="#005555"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#003333"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#007777"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="Border" x:Key="ClassicGroupBox">
            <Setter Property="BorderBrush" Value="#A0A0A0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="#F0F0F0"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <Style TargetType="Border" x:Key="KpiCard">
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="15,10"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#A0A0A0"/>
        </Style>

        <Style TargetType="DataGridCell" x:Key="BaseCell">
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="5,0"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="Background" Value="Transparent"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#005555"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="TextBlock" x:Key="RightElement">
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="Margin" Value="0,0,5,0"/>
        </Style>
        <Style TargetType="TextBlock" x:Key="RightBoldElement" BasedOn="{StaticResource RightElement}">
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>
        <Style TargetType="TextBlock" x:Key="ProfitElement" BasedOn="{StaticResource RightBoldElement}">
            <Setter Property="Foreground" Value="#005500"/>
        </Style>
        <Style TargetType="TextBlock" x:Key="DangerElement" BasedOn="{StaticResource RightBoldElement}">
            <Setter Property="Foreground" Value="#A94044"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource ClassicGroupBox}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="SALES FILTER:" Style="{StaticResource HeaderLabel}" Margin="0,0,20,0" VerticalAlignment="Center"/>

                <TextBlock Grid.Column="1" Text="From:" Style="{StaticResource InlineLabel}"/>
                <DatePicker Grid.Column="2" SelectedDate="{Binding StartDate}" Style="{StaticResource ClassicDate}" Margin="0,0,15,0"/>

                <TextBlock Grid.Column="3" Text="To:" Style="{StaticResource InlineLabel}"/>
                <DatePicker Grid.Column="4" SelectedDate="{Binding EndDate}" Style="{StaticResource ClassicDate}" Margin="0,0,20,0"/>

                <TextBox Grid.Column="5" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" Width="250" Style="{StaticResource ClassicInput}" Margin="0,0,10,0" ToolTip="Search Item Code, Name, or Category"/>

                <Button Grid.Column="6" Content="⚡ GENERATE ANALYTICS" Command="{Binding GenerateAnalyticsCommand}" Style="{StaticResource ActionBtn}" HorizontalAlignment="Left" Padding="20,0" FontSize="13"/>

                <Button Grid.Column="7" Content="Clear Filters" Command="{Binding ClearFiltersCommand}" Style="{StaticResource ClassicBtn}" Margin="0,0,10,0"/>
                <Button Grid.Column="8" Content="📊 Export Grid" Command="{Binding ExportToExcelCommand}" Style="{StaticResource ClassicBtn}"/>
            </Grid>
        </Border>

        <UniformGrid Grid.Row="1" Columns="6" Margin="0,0,0,8">
            <Border Style="{StaticResource KpiCard}" BorderBrush="#005555">
                <StackPanel>
                    <TextBlock Text="TOTAL REVENUE" FontSize="11" FontWeight="Bold" Foreground="#666"/>
                    <TextBlock Text="{Binding TotalRevenue, StringFormat=Rs. \{0:N2\}}" FontSize="20" FontWeight="Bold" Foreground="#003366" Margin="0,5,0,0"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource KpiCard}">
                <StackPanel>
                    <TextBlock Text="TOTAL COST OF GOODS" FontSize="11" FontWeight="Bold" Foreground="#666"/>
                    <TextBlock Text="{Binding TotalCost, StringFormat=Rs. \{0:N2\}}" FontSize="20" FontWeight="Bold" Foreground="#555" Margin="0,5,0,0"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource KpiCard}" BorderBrush="#28A745" Background="#F0FFF4">
                <StackPanel>
                    <TextBlock Text="GROSS PROFIT" FontSize="11" FontWeight="Bold" Foreground="#1E7E34"/>
                    <TextBlock Text="{Binding GrossProfit, StringFormat=Rs. \{0:N2\}}" FontSize="20" FontWeight="Bold" Foreground="#28A745" Margin="0,5,0,0"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource KpiCard}">
                <StackPanel>
                    <TextBlock Text="AVERAGE MARGIN %" FontSize="11" FontWeight="Bold" Foreground="#666"/>
                    <TextBlock Text="{Binding AverageMargin, StringFormat=\{0:N2\}%}" FontSize="20" FontWeight="Bold" Foreground="#003366" Margin="0,5,0,0"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource KpiCard}">
                <StackPanel>
                    <TextBlock Text="UNITS SOLD (VELOCITY)" FontSize="11" FontWeight="Bold" Foreground="#666"/>
                    <TextBlock Text="{Binding TotalUnitsSold, StringFormat=N2}" FontSize="20" FontWeight="Bold" Foreground="#003366" Margin="0,5,0,0"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource KpiCard}" BorderBrush="#A94044" Margin="0">
                <StackPanel>
                    <TextBlock Text="DEAD STOCK ITEMS" FontSize="11" FontWeight="Bold" Foreground="#A94044"/>
                    <TextBlock Text="{Binding DeadStockItems}" FontSize="20" FontWeight="Bold" Foreground="#A94044" Margin="0,5,0,0" ToolTip="Items with physical stock that haven't sold in 90+ days"/>
                </StackPanel>
            </Border>
        </UniformGrid>

        <Border Grid.Row="2" Background="White" BorderBrush="#A0A0A0" BorderThickness="1">
            <TabControl Background="#F0F0F0" BorderThickness="0,0,0,1" BorderBrush="#A0A0A0">
                <TabControl.Resources>
                    <Style TargetType="TabItem">
                        <Setter Property="Padding" Value="15,8"/>
                        <Setter Property="FontWeight" Value="Bold"/>
                        <Setter Property="FontSize" Value="13"/>
                        <Setter Property="Foreground" Value="#555"/>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Foreground" Value="#003366"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </TabControl.Resources>

                <TabItem Header="Master Item Performance (Ranked by Revenue)">
                    <DataGrid ItemsSource="{Binding ItemPerformances}" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True"
                              HeadersVisibility="Column" GridLinesVisibility="All" HorizontalGridLinesBrush="#E0E0E0" VerticalGridLinesBrush="#E0E0E0" 
                              RowHeight="28" Background="White" BorderThickness="0" SelectionMode="Single" AlternatingRowBackground="#F9F9F9"
                              FrozenColumnCount="3">

                        <DataGrid.InputBindings>
                            <MouseBinding Gesture="LeftDoubleClick" Command="{Binding OpenDrillDownCommand}" CommandParameter="{Binding SelectedItem, RelativeSource={RelativeSource AncestorType=DataGrid}}" />
                        </DataGrid.InputBindings>

                        <DataGrid.Resources>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="#E0E0E0"/>
                                <Setter Property="Foreground" Value="Black"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="Padding" Value="6"/>
                                <Setter Property="BorderThickness" Value="0,0,1,1"/>
                                <Setter Property="BorderBrush" Value="#A0A0A0"/>
                            </Style>
                            <Style TargetType="DataGridCell" BasedOn="{StaticResource BaseCell}"/>
                        </DataGrid.Resources>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="#" Binding="{Binding Rank}" Width="50" ElementStyle="{StaticResource RightBoldElement}" Foreground="#005555"/>
                            <DataGridTextColumn Header="Item Code" Binding="{Binding ItemCode}" Width="100" FontWeight="SemiBold"/>
                            <DataGridTextColumn Header="Item Description" Binding="{Binding ItemName}" Width="250" FontWeight="Bold"/>
                            <DataGridTextColumn Header="Category" Binding="{Binding CategoryName}" Width="150" Foreground="#555"/>

                            <DataGridTextColumn Header="Stock (SOH)" Binding="{Binding CurrentStock, StringFormat=N2}" Width="90" ElementStyle="{StaticResource RightBoldElement}" Foreground="#003366"/>
                            <DataGridTextColumn Header="Qty Sold" Binding="{Binding QtySold, StringFormat=N2}" Width="90" ElementStyle="{StaticResource RightBoldElement}" Foreground="#005500"/>

                            <DataGridTextColumn Header="Revenue" Binding="{Binding Revenue, StringFormat=N2}" Width="110" ElementStyle="{StaticResource RightElement}"/>
                            <DataGridTextColumn Header="Cost" Binding="{Binding Cost, StringFormat=N2}" Width="100" ElementStyle="{StaticResource RightElement}" Foreground="#666"/>

                            <DataGridTextColumn Header="Gross Profit" Binding="{Binding Profit, StringFormat=N2}" Width="110" ElementStyle="{StaticResource ProfitElement}"/>
                            <DataGridTextColumn Header="Margin %" Binding="{Binding Margin, StringFormat=\{0:N2\}%}" Width="90" ElementStyle="{StaticResource ProfitElement}"/>

                            <DataGridTextColumn Binding="{Binding AverageDailySales, StringFormat=N2}" Width="110" ElementStyle="{StaticResource RightElement}">
                                <DataGridTextColumn.Header>
                                    <TextBlock Text="Velocity (Daily)" ToolTip="Average items sold per day"/>
                                </DataGridTextColumn.Header>
                            </DataGridTextColumn>

                            <DataGridTextColumn Binding="{Binding DaysSinceLastSale}" Width="90" ElementStyle="{StaticResource DangerElement}">
                                <DataGridTextColumn.Header>
                                    <TextBlock Text="Idle Days" ToolTip="Days since this item was last sold"/>
                                </DataGridTextColumn.Header>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </TabItem>

                <TabItem Header="Winners &amp; Losers (Volume)">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" BorderBrush="#28A745" BorderThickness="1" Background="White">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Text="🏆 TOP 20 FASTEST MOVERS" Background="#E8F5E9" Foreground="#1E7E34" FontWeight="Bold" Padding="10,8" FontSize="13"/>

                                <DataGrid Grid.Row="1" ItemsSource="{Binding TopSellingItems}" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True"
                                          HeadersVisibility="Column" GridLinesVisibility="All" HorizontalGridLinesBrush="#E0E0E0" VerticalGridLinesBrush="#E0E0E0" 
                                          RowHeight="28" BorderThickness="0" SelectionMode="Single" AlternatingRowBackground="#F9F9F9">
                                    <DataGrid.Resources>
                                        <Style TargetType="DataGridColumnHeader">
                                            <Setter Property="Background" Value="#E0E0E0"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                            <Setter Property="Padding" Value="5"/>
                                            <Setter Property="BorderThickness" Value="0,0,1,1"/>
                                            <Setter Property="BorderBrush" Value="#A0A0A0"/>
                                        </Style>
                                        <Style TargetType="DataGridCell" BasedOn="{StaticResource BaseCell}"/>
                                    </DataGrid.Resources>
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Item Description" Binding="{Binding ItemName}" Width="*" FontWeight="Bold"/>
                                        <DataGridTextColumn Binding="{Binding QtySold, StringFormat=N2}" Width="90" ElementStyle="{StaticResource RightBoldElement}" Foreground="#005500">
                                            <DataGridTextColumn.Header>
                                                <TextBlock Text="Qty Sold" ToolTip="Total volume moved in this period"/>
                                            </DataGridTextColumn.Header>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Binding="{Binding AverageDailySales, StringFormat=N2}" Width="90" ElementStyle="{StaticResource RightElement}">
                                            <DataGridTextColumn.Header>
                                                <TextBlock Text="Daily Avg" ToolTip="Velocity: Items sold per day"/>
                                            </DataGridTextColumn.Header>
                                        </DataGridTextColumn>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </Border>

                        <Border Grid.Column="2" BorderBrush="#A94044" BorderThickness="1" Background="White">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Text="⚠️ BOTTOM 20 SLOWEST MOVERS" Background="#FEF2F2" Foreground="#A94044" FontWeight="Bold" Padding="10,8" FontSize="13"/>

                                <DataGrid Grid.Row="1" ItemsSource="{Binding WorstSellingItems}" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True"
                                          HeadersVisibility="Column" GridLinesVisibility="All" HorizontalGridLinesBrush="#E0E0E0" VerticalGridLinesBrush="#E0E0E0" 
                                          RowHeight="28" BorderThickness="0" SelectionMode="Single" AlternatingRowBackground="#F9F9F9">
                                    <DataGrid.Resources>
                                        <Style TargetType="DataGridColumnHeader">
                                            <Setter Property="Background" Value="#E0E0E0"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                            <Setter Property="Padding" Value="5"/>
                                            <Setter Property="BorderThickness" Value="0,0,1,1"/>
                                            <Setter Property="BorderBrush" Value="#A0A0A0"/>
                                        </Style>
                                        <Style TargetType="DataGridCell" BasedOn="{StaticResource BaseCell}"/>
                                    </DataGrid.Resources>
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Item Description" Binding="{Binding ItemName}" Width="*" FontWeight="Bold"/>
                                        <DataGridTextColumn Binding="{Binding QtySold, StringFormat=N2}" Width="90" ElementStyle="{StaticResource RightBoldElement}" Foreground="#A94044">
                                            <DataGridTextColumn.Header>
                                                <TextBlock Text="Qty Sold" ToolTip="Total volume moved in this period"/>
                                            </DataGridTextColumn.Header>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Binding="{Binding CurrentStock, StringFormat=N2}" Width="90" ElementStyle="{StaticResource RightElement}" Foreground="#003366">
                                            <DataGridTextColumn.Header>
                                                <TextBlock Text="Current SOH" ToolTip="Stock currently sitting on shelves"/>
                                            </DataGridTextColumn.Header>
                                        </DataGridTextColumn>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </Border>
                    </Grid>
                </TabItem>

                <TabItem Header="Dead Stock &amp; Liquidations">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Background="#FFF3CD" BorderBrush="#FFEEBA" BorderThickness="1" Padding="10" Margin="0,0,0,5">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🛑 DEAD STOCK WARNING:" FontWeight="Bold" Foreground="#856404" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                <TextBlock Text="These items have physical stock but have not recorded a single sale in over 90 days. Consider marking down or returning to supplier." Foreground="#856404" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <DataGrid Grid.Row="1" ItemsSource="{Binding DeadStockList}" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True"
                                  HeadersVisibility="Column" GridLinesVisibility="All" HorizontalGridLinesBrush="#E0E0E0" VerticalGridLinesBrush="#E0E0E0" 
                                  RowHeight="30" Background="White" BorderThickness="1" BorderBrush="#A0A0A0" SelectionMode="Single" AlternatingRowBackground="#F9F9F9">
                            <DataGrid.Resources>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="Background" Value="#E0E0E0"/>
                                    <Setter Property="Foreground" Value="Black"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                    <Setter Property="Padding" Value="6"/>
                                    <Setter Property="BorderThickness" Value="0,0,1,1"/>
                                    <Setter Property="BorderBrush" Value="#A0A0A0"/>
                                </Style>
                                <Style TargetType="DataGridCell" BasedOn="{StaticResource BaseCell}"/>
                            </DataGrid.Resources>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Item Code" Binding="{Binding ItemCode}" Width="120" FontWeight="SemiBold"/>
                                <DataGridTextColumn Header="Item Description" Binding="{Binding ItemName}" Width="350" FontWeight="Bold"/>
                                <DataGridTextColumn Header="Category" Binding="{Binding CategoryName}" Width="200" Foreground="#555"/>

                                <DataGridTextColumn Binding="{Binding CurrentStock, StringFormat=N2}" Width="120" ElementStyle="{StaticResource RightBoldElement}" Foreground="#003366">
                                    <DataGridTextColumn.Header>
                                        <TextBlock Text="Trapped Stock" ToolTip="Physical units sitting idle"/>
                                    </DataGridTextColumn.Header>
                                </DataGridTextColumn>

                                <DataGridTextColumn Binding="{Binding LastSoldDate, StringFormat=dd-MMM-yyyy}" Width="130" ElementStyle="{StaticResource RightElement}" Foreground="#666">
                                    <DataGridTextColumn.Header>
                                        <TextBlock Text="Last Sale Date" ToolTip="The last time a customer bought this"/>
                                    </DataGridTextColumn.Header>
                                </DataGridTextColumn>

                                <DataGridTextColumn Binding="{Binding DaysSinceLastSale}" Width="*" ElementStyle="{StaticResource DangerElement}">
                                    <DataGridTextColumn.Header>
                                        <TextBlock Text="Days Idle" ToolTip="Total days without a sale"/>
                                    </DataGridTextColumn.Header>
                                </DataGridTextColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </TabItem>

                <TabItem Header="Group Analytics (Charts)">
                    <TextBlock Text="Group Analytics Module in Next Update..." HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="16" Foreground="#888"/>
                </TabItem>

                <TabItem Header="Profitability &amp; Trends">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="10"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" BorderBrush="#003366" BorderThickness="1" Background="White">
                                <Grid>
                                    <TextBlock Text="📈 REVENUE VS PROFIT TREND" Background="#E6F0FA" Foreground="#003366" FontWeight="Bold" Padding="10,8" FontSize="13" VerticalAlignment="Top"/>
                                    <Border Background="#F8F8F8" BorderBrush="#DDDDDD" BorderThickness="1" Margin="15,40,15,15" Padding="10">
                                        <lvc:CartesianChart Series="{Binding TrendSeries}" LegendLocation="Top">
                                            <lvc:CartesianChart.AxisX>
                                                <lvc:Axis Labels="{Binding TrendLabels}" />
                                            </lvc:CartesianChart.AxisX>
                                            <lvc:CartesianChart.AxisY>
                                                <lvc:Axis LabelFormatter="{Binding CurrencyFormatter}" />
                                            </lvc:CartesianChart.AxisY>
                                        </lvc:CartesianChart>
                                    </Border>
                                </Grid>
                            </Border>

                            <Border Grid.Column="2" BorderBrush="#A0A0A0" BorderThickness="1" Background="White">
                                <DataGrid ItemsSource="{Binding SalesTrendData}" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True"
                                          HeadersVisibility="Column" GridLinesVisibility="All" HorizontalGridLinesBrush="#E0E0E0" VerticalGridLinesBrush="#E0E0E0" 
                                          RowHeight="26" BorderThickness="0" AlternatingRowBackground="#F9F9F9">
                                    <DataGrid.Resources>
                                        <Style TargetType="DataGridColumnHeader">
                                            <Setter Property="Background" Value="#E0E0E0"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                            <Setter Property="Padding" Value="5"/>
                                            <Setter Property="BorderThickness" Value="0,0,1,1"/>
                                            <Setter Property="BorderBrush" Value="#A0A0A0"/>
                                        </Style>
                                        <Style TargetType="DataGridCell" BasedOn="{StaticResource BaseCell}"/>
                                    </DataGrid.Resources>
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Date" Binding="{Binding DateLabel}" Width="*" FontWeight="SemiBold"/>
                                        <DataGridTextColumn Header="Revenue" Binding="{Binding Revenue, StringFormat=N2}" Width="90" ElementStyle="{StaticResource RightElement}"/>
                                        <DataGridTextColumn Header="Profit" Binding="{Binding Profit, StringFormat=N2}" Width="90" ElementStyle="{StaticResource ProfitElement}"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Border>
                        </Grid>

                        <Grid Grid.Row="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" BorderBrush="#28A745" BorderThickness="1" Background="White">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Text="💰 HIGHEST PROFIT GENERATORS" Background="#E8F5E9" Foreground="#1E7E34" FontWeight="Bold" Padding="10,8" FontSize="13"/>

                                    <DataGrid Grid.Row="1" ItemsSource="{Binding HighestProfitItems}" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True"
                                              HeadersVisibility="Column" GridLinesVisibility="All" HorizontalGridLinesBrush="#E0E0E0" VerticalGridLinesBrush="#E0E0E0" 
                                              RowHeight="28" BorderThickness="0" SelectionMode="Single" AlternatingRowBackground="#F9F9F9">
                                        <DataGrid.Resources>
                                            <Style TargetType="DataGridColumnHeader">
                                                <Setter Property="Background" Value="#E0E0E0"/>
                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                                <Setter Property="Padding" Value="5"/>
                                                <Setter Property="BorderThickness" Value="0,0,1,1"/>
                                                <Setter Property="BorderBrush" Value="#A0A0A0"/>
                                            </Style>
                                            <Style TargetType="DataGridCell" BasedOn="{StaticResource BaseCell}"/>
                                        </DataGrid.Resources>
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Item Description" Binding="{Binding ItemName}" Width="*" FontWeight="Bold"/>
                                            <DataGridTextColumn Header="Profit (Rs.)" Binding="{Binding Profit, StringFormat=N2}" Width="100" ElementStyle="{StaticResource ProfitElement}"/>
                                            <DataGridTextColumn Header="Margin" Binding="{Binding Margin, StringFormat=\{0:N2\}%}" Width="80" ElementStyle="{StaticResource ProfitElement}"/>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </Grid>
                            </Border>

                            <Border Grid.Column="2" BorderBrush="#A94044" BorderThickness="1" Background="White">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Text="🚨 NEGATIVE MARGIN ITEMS (LOSING MONEY)" Background="#FEF2F2" Foreground="#A94044" FontWeight="Bold" Padding="10,8" FontSize="13"/>

                                    <DataGrid Grid.Row="1" ItemsSource="{Binding NegativeMarginItems}" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True"
                                              HeadersVisibility="Column" GridLinesVisibility="All" HorizontalGridLinesBrush="#E0E0E0" VerticalGridLinesBrush="#E0E0E0" 
                                              RowHeight="28" BorderThickness="0" SelectionMode="Single" AlternatingRowBackground="#F9F9F9">
                                        <DataGrid.Resources>
                                            <Style TargetType="DataGridColumnHeader">
                                                <Setter Property="Background" Value="#E0E0E0"/>
                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                                <Setter Property="Padding" Value="5"/>
                                                <Setter Property="BorderThickness" Value="0,0,1,1"/>
                                                <Setter Property="BorderBrush" Value="#A0A0A0"/>
                                            </Style>
                                            <Style TargetType="DataGridCell" BasedOn="{StaticResource BaseCell}"/>
                                        </DataGrid.Resources>
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Item Description" Binding="{Binding ItemName}" Width="*" FontWeight="Bold"/>
                                            <DataGridTextColumn Header="Avg Cost" Binding="{Binding Cost, StringFormat=N2}" Width="90" ElementStyle="{StaticResource RightElement}"/>
                                            <DataGridTextColumn Header="Revenue" Binding="{Binding Revenue, StringFormat=N2}" Width="90" ElementStyle="{StaticResource RightElement}"/>
                                            <DataGridTextColumn Header="Loss" Binding="{Binding Profit, StringFormat=N2}" Width="90" ElementStyle="{StaticResource DangerElement}"/>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </Grid>
                            </Border>
                        </Grid>
                    </Grid>
                </TabItem>
            </TabControl>
        </Border>

        <Grid Grid.RowSpan="3" Background="#AA000000" Panel.ZIndex="999">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsDrillDownOpen}" Value="True">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>

            <Border Background="#D4D0C8" BorderBrush="#003366" BorderThickness="2" Width="900" Height="600" VerticalAlignment="Center" HorizontalAlignment="Center">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="20" Opacity="0.5" ShadowDepth="5"/>
                </Border.Effect>
                <Grid Margin="15">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,15">
                        <TextBlock Text="🔍 ITEM STOCK &amp; SALES DNA" Style="{StaticResource HeaderLabel}" FontSize="16" Margin="0"/>
                        <Button Content="X" Command="{Binding CloseDrillDownCommand}" Width="30" Height="30" HorizontalAlignment="Right" Background="#A94044" Foreground="White" FontWeight="Bold" BorderThickness="0" Cursor="Hand"/>
                    </Grid>

                    <Border Grid.Row="1" Background="White" BorderBrush="#A0A0A0" BorderThickness="1" Padding="15" Margin="0,0,0,10">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding SelectedItem.ItemCode}" FontWeight="Bold" FontSize="18" Foreground="#005555" Margin="0,0,15,0"/>
                            <TextBlock Text="{Binding SelectedItem.ItemName}" FontWeight="Bold" FontSize="18" Foreground="#333" Margin="0,0,30,0"/>
                            <TextBlock Text="Current Physical SOH: " FontSize="14" Foreground="#666" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding SelectedItem.CurrentStock}" FontWeight="Bold" FontSize="16" Foreground="#003366" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <DataGrid Grid.Row="2" ItemsSource="{Binding ItemHistory}" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True"
                              HeadersVisibility="Column" GridLinesVisibility="All" HorizontalGridLinesBrush="#E0E0E0" VerticalGridLinesBrush="#E0E0E0" 
                              RowHeight="28" Background="White" BorderThickness="1" BorderBrush="#A0A0A0" AlternatingRowBackground="#F9F9F9">
                        <DataGrid.Resources>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="#E0E0E0"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="Padding" Value="5"/>
                                <Setter Property="BorderThickness" Value="0,0,1,1"/>
                                <Setter Property="BorderBrush" Value="#A0A0A0"/>
                            </Style>
                            <Style TargetType="DataGridCell" BasedOn="{StaticResource BaseCell}"/>
                        </DataGrid.Resources>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Date" Binding="{Binding TransactionDate, StringFormat=dd-MMM-yyyy HH:mm}" Width="140" Foreground="#555"/>
                            <DataGridTextColumn Header="Type" Binding="{Binding TransactionType}" Width="130" FontWeight="Bold"/>
                            <DataGridTextColumn Header="Reference No." Binding="{Binding DocumentNo}" Width="140"/>
                            <DataGridTextColumn Header="Party (Supplier / Customer)" Binding="{Binding PartyName}" Width="*" />
                            <DataGridTextColumn Header="Qty IN (+)" Binding="{Binding QtyIn, StringFormat=N2}" Width="90" ElementStyle="{StaticResource ProfitElement}"/>
                            <DataGridTextColumn Header="Qty OUT (-)" Binding="{Binding QtyOut, StringFormat=N2}" Width="90" ElementStyle="{StaticResource DangerElement}"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>

    </Grid>
</UserControl>