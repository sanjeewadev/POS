<UserControl x:Class="POS.BackOffice.UI.Views.Pages.Sales.QuotationView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="850" d:DesignWidth="1250"
             Background="#F5F5F5">

    <UserControl.Resources>
        <!-- Standard Button Style -->
        <Style TargetType="Button" x:Key="StandardBtn">
            <Setter Property="Background" Value="#2B3C38"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#3B524E"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Print Action Button (Blue) -->
        <Style TargetType="Button" x:Key="PrintBtn" BasedOn="{StaticResource StandardBtn}">
            <Setter Property="Background" Value="#2B5B84"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1C3F5E"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Standard Input Style -->
        <Style TargetType="Control" x:Key="StandardInput">
            <Setter Property="Padding" Value="5"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="BorderBrush" Value="#CCCCCC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Height" Value="30"/>
        </Style>

        <!-- Group Box Border Style -->
        <Style TargetType="Border" x:Key="GroupBoxBorder">
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="15"/>
            <Setter Property="Background" Value="White"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Header (Master Data) -->
            <RowDefinition Height="Auto"/>
            <!-- Product Quoting Bar -->
            <RowDefinition Height="*"/>
            <!-- Data Grid (Details) -->
            <RowDefinition Height="Auto"/>
            <!-- Footer (Totals & Actions) -->
        </Grid.RowDefinitions>

        <!-- ========================================== -->
        <!-- ZONE 1: DOCUMENT HEADER (MASTER)           -->
        <!-- ========================================== -->
        <Border Grid.Row="0" Style="{StaticResource GroupBoxBorder}" Margin="0,0,0,15">
            <StackPanel>
                <Grid Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Customer Quotation / Estimate" FontSize="20" FontWeight="SemiBold" Foreground="#2B5B84"/>

                    <!-- Status Badge -->
                    <Border Grid.Column="1" Background="#E2EDF8" BorderBrush="#B6D4FE" BorderThickness="1" CornerRadius="4" Padding="10,5">
                        <TextBlock Text="Status: DRAFT" FontWeight="Bold" Foreground="#2B5B84"/>
                    </Border>
                </Grid>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.5*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="1.5*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Row 1: Identity -->
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Registered Customer Link" Foreground="#2B5B84" Margin="0,0,0,5"/>
                        <ComboBox x:Name="cmbCustomer" Style="{StaticResource StandardInput}" IsEditable="True" ToolTip="Search from CRM (Optional)"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Customer / Company Name *" Foreground="#333333" FontWeight="SemiBold" Margin="0,0,0,5"/>
                        <TextBox x:Name="txtCustomerName" Style="{StaticResource StandardInput}" ToolTip="Editable for walk-in or unregistered clients"/>
                    </StackPanel>

                    <StackPanel Grid.Column="4">
                        <TextBlock Text="Quotation No." Foreground="#666666" Margin="0,0,0,5"/>
                        <TextBox x:Name="txtQuotationNo" Style="{StaticResource StandardInput}" Background="#EEEEEE" IsReadOnly="True" Text="[Auto-Generated]"/>
                    </StackPanel>
                </Grid>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.5*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="1.5*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Row 2: Timing & Responsibility -->
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Quotation Date *" Foreground="#666666" Margin="0,0,0,5"/>
                        <DatePicker x:Name="dpQuotationDate" Style="{StaticResource StandardInput}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Valid Until (Expiry) *" Foreground="#A94044" FontWeight="SemiBold" Margin="0,0,0,5"/>
                        <DatePicker x:Name="dpValidUntil" Style="{StaticResource StandardInput}" ToolTip="Crucial: Prevents honoring old prices"/>
                    </StackPanel>

                    <StackPanel Grid.Column="4">
                        <TextBlock Text="Sales Rep *" Foreground="#666666" Margin="0,0,0,5"/>
                        <ComboBox x:Name="cmbSalesRep" Style="{StaticResource StandardInput}" DisplayMemberPath="Name" SelectedValuePath="Id"/>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>

        <!-- ========================================== -->
        <!-- ZONE 2: PRODUCT QUOTING BAR                -->
        <!-- ========================================== -->
        <Border Grid.Row="1" Background="#F0F8FF" BorderBrush="#B6D4FE" BorderThickness="1" CornerRadius="4" Padding="15" Margin="0,0,0,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2.5*"/>
                    <!-- Product Search -->
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="0.8*"/>
                    <!-- Current Stock -->
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="1*"/>
                    <!-- Retail Price -->
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="1*"/>
                    <!-- Item Discount -->
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="1*"/>
                    <!-- Quoted Price -->
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="0.8*"/>
                    <!-- Quantity -->
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="Auto"/>
                    <!-- Add Button -->
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Search Product" Foreground="#333333" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <ComboBox x:Name="cmbProductSearch" Style="{StaticResource StandardInput}" IsEditable="True" Margin="0"/>
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock Text="Stock" Foreground="#666666" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <TextBox x:Name="txtCurrentStock" Style="{StaticResource StandardInput}" HorizontalContentAlignment="Center" Background="#EEEEEE" IsReadOnly="True" Margin="0" ToolTip="Information only. Quote does not deduct stock."/>
                </StackPanel>

                <StackPanel Grid.Column="4">
                    <TextBlock Text="Standard (Rs.)" Foreground="#666666" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <TextBox x:Name="txtRetailPrice" Style="{StaticResource StandardInput}" HorizontalContentAlignment="Right" Background="#EEEEEE" IsReadOnly="True" Margin="0"/>
                </StackPanel>

                <!-- ITEM LEVEL DISCOUNT -->
                <StackPanel Grid.Column="6">
                    <TextBlock Text="Discount (Rs.)" Foreground="#28A745" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <TextBox x:Name="txtItemDiscount" Style="{StaticResource StandardInput}" HorizontalContentAlignment="Right" Margin="0" Text="0.00"/>
                </StackPanel>

                <!-- NEGOTIATED PRICE -->
                <StackPanel Grid.Column="8">
                    <TextBlock Text="Quoted (Rs.) *" Foreground="#2B5B84" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <TextBox x:Name="txtQuotedPrice" Style="{StaticResource StandardInput}" HorizontalContentAlignment="Right" Background="#FFFFE0" Margin="0" FontWeight="Bold"/>
                </StackPanel>

                <StackPanel Grid.Column="10">
                    <TextBlock Text="Qty *" Foreground="#333333" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <TextBox x:Name="txtQty" Style="{StaticResource StandardInput}" HorizontalContentAlignment="Center" Margin="0"/>
                </StackPanel>

                <Button Grid.Column="12" x:Name="btnAddItem" Content="Add to Quote" Style="{StaticResource StandardBtn}" Background="#2B5B84" Margin="0" VerticalAlignment="Bottom" Height="30" Width="110"/>
            </Grid>
        </Border>

        <!-- ========================================== -->
        <!-- ZONE 3: QUOTATION GRID (DETAILS)           -->
        <!-- ========================================== -->
        <Border Grid.Row="2" Style="{StaticResource GroupBoxBorder}" Padding="0" Margin="0,0,0,15">
            <DataGrid x:Name="dgQuoteLines" 
                      AutoGenerateColumns="False" 
                      CanUserAddRows="False" 
                      CanUserDeleteRows="False" 
                      HeadersVisibility="Column" 
                      GridLinesVisibility="Horizontal"
                      HorizontalGridLinesBrush="#EEEEEE"
                      BorderThickness="0"
                      RowHeight="40"
                      Background="Transparent">

                <DataGrid.Resources>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#F8F8F8"/>
                        <Setter Property="Foreground" Value="#333333"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="Padding" Value="15,10"/>
                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                        <Setter Property="BorderBrush" Value="#DDDDDD"/>
                    </Style>
                    <Style TargetType="DataGridCell">
                        <Setter Property="Padding" Value="15,0"/>
                        <Setter Property="VerticalContentAlignment" Value="Center"/>
                    </Style>
                </DataGrid.Resources>

                <DataGrid.Columns>
                    <DataGridTextColumn Header="Item Code" Binding="{Binding ItemCode}" Width="110" IsReadOnly="True"/>
                    <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="*" IsReadOnly="True"/>

                    <DataGridTextColumn Header="Qty" Binding="{Binding Qty}" Width="80">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="Standard Price" Binding="{Binding RetailPrice, StringFormat=N2}" Width="120">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                <Setter Property="Foreground" Value="#666666"/>
                                <Setter Property="TextDecorations" Value="Strikethrough"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="Discount" Binding="{Binding ItemDiscount, StringFormat=N2}" Width="100">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                <Setter Property="Foreground" Value="#28A745"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="Quoted Price" Binding="{Binding QuotedPrice, StringFormat=N2}" Width="120">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="Foreground" Value="#2B5B84"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="Line Total" Binding="{Binding LineTotal, StringFormat=N2}" Width="140" IsReadOnly="True">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <!-- Remove Row Button -->
                    <DataGridTemplateColumn Header="Del" Width="60">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="X" Background="#A94044" Foreground="White" BorderThickness="0" Cursor="Hand" Width="25" Height="25" FontWeight="Bold"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- ========================================== -->
        <!-- ZONE 4: FOOTER (FINANCIALS & ACTIONS)      -->
        <!-- ========================================== -->
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Legal Terms & Financial Totals Block -->
            <Border Grid.Column="0" Background="#F8F8F8" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="4" Padding="15" Margin="0,0,20,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.5*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Terms &amp; Conditions / Remarks:" Foreground="#666666" FontSize="12" Margin="0,0,0,5"/>
                        <TextBox x:Name="txtTerms" Height="50" TextWrapping="Wrap" AcceptsReturn="True" BorderBrush="#CCCCCC" BorderThickness="1" Padding="5" Text="Prices subject to change after validity period. 50% advance required upon confirmation."/>
                    </StackPanel>

                    <Grid Grid.Column="2" HorizontalAlignment="Right" MinWidth="250">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <DockPanel Grid.Row="0" Margin="0,0,0,5">
                            <TextBlock Text="Subtotal:" Foreground="#666666"/>
                            <TextBlock x:Name="txtSubtotal" Text="Rs. 0.00" FontWeight="SemiBold" HorizontalAlignment="Right" Foreground="#333333"/>
                        </DockPanel>

                        <!-- BOTTOM LINE DISCOUNT -->
                        <DockPanel Grid.Row="1" Margin="0,0,0,10">
                            <TextBlock Text="Overall Bill Discount (Rs.):" Foreground="#28A745" VerticalAlignment="Center"/>
                            <TextBox x:Name="txtBillDiscount" Width="90" Text="0.00" HorizontalAlignment="Right" HorizontalContentAlignment="Right" Padding="2" BorderBrush="#CCCCCC" BorderThickness="1"/>
                        </DockPanel>

                        <DockPanel Grid.Row="2">
                            <TextBlock Text="GRAND TOTAL:" Foreground="#2B5B84" FontWeight="Bold" FontSize="16" VerticalAlignment="Center"/>
                            <TextBlock x:Name="txtGrandTotal" Text="Rs. 0.00" FontWeight="Bold" FontSize="24" Foreground="#2B5B84" HorizontalAlignment="Right"/>
                        </DockPanel>
                    </Grid>
                </Grid>
            </Border>

            <!-- Action Buttons -->
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Bottom">
                <Button Content="Clear Form" Style="{StaticResource StandardBtn}" Background="#777777" Width="100"/>
                <Button Content="Save Draft" Style="{StaticResource StandardBtn}" Width="110"/>
                <Button Content="Save &amp; Print Quote" Style="{StaticResource PrintBtn}" Width="170" Margin="0" ToolTip="Generates professional PDF document for the customer"/>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>