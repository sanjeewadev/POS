<UserControl x:Class="POS.BackOffice.UI.Views.Pages.Sales.ReceiptLedgerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#D4D0C8" FontFamily="Segoe UI" FontSize="12">

    <UserControl.Resources>
        <Style TargetType="TextBlock" x:Key="HeaderLabel">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#003366"/>
            <Setter Property="Margin" Value="0,5,0,5"/>
        </Style>

        <Style TargetType="TextBlock" x:Key="InlineLabel">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,5,0"/>
        </Style>

        <Style TargetType="TextBox" x:Key="ClassicInput">
            <Setter Property="Height" Value="24"/>
            <Setter Property="Padding" Value="4,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="#808080"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
        </Style>

        <Style TargetType="ComboBox" x:Key="ClassicCombo">
            <Setter Property="Height" Value="24"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="#808080"/>
            <Setter Property="Background" Value="White"/>
        </Style>

        <Style TargetType="DatePicker" x:Key="ClassicDate">
            <Setter Property="Height" Value="24"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="#808080"/>
        </Style>

        <Style TargetType="Button" x:Key="ClassicBtn">
            <Setter Property="Height" Value="26"/>
            <Setter Property="Background" Value="#E0E0E0"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="15,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderBrush" Value="#808080"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#CCCCCC"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="Border" x:Key="ClassicGroupBox">
            <Setter Property="BorderBrush" Value="#A0A0A0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="#F0F0F0"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="5">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="3*"/>
            <RowDefinition Height="2*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#003366" Padding="10" BorderBrush="#002244" BorderThickness="1" Margin="0,0,0,5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="RECEIPT LEDGER (SALES HISTORY)" Foreground="White" FontSize="14" FontWeight="Bold" Margin="0,0,20,0" VerticalAlignment="Center"/>

                <WrapPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Date From:" Foreground="#A0C0E0" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,5,0"/>
                    <DatePicker SelectedDate="{Binding FilterStartDate}" Style="{StaticResource ClassicDate}" Width="110" Margin="0,0,10,0"/>

                    <TextBlock Text="To:" Foreground="#A0C0E0" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,5,0"/>
                    <DatePicker SelectedDate="{Binding FilterEndDate}" Style="{StaticResource ClassicDate}" Width="110" Margin="0,0,15,0"/>

                    <TextBlock Text="Status:" Foreground="#A0C0E0" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,5,0"/>
                    <ComboBox SelectedItem="{Binding SelectedStatusFilter}" Style="{StaticResource ClassicCombo}" Width="120" Margin="0,0,15,0">
                        <System:String xmlns:System="clr-namespace:System;assembly=mscorlib">Active</System:String>
                        <System:String xmlns:System="clr-namespace:System;assembly=mscorlib">Voided</System:String>
                        <System:String xmlns:System="clr-namespace:System;assembly=mscorlib">All</System:String>
                    </ComboBox>

                    <TextBlock Text="Search (Invoice/Cashier):" Foreground="#A0C0E0" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,5,0"/>
                    <TextBox Text="{Binding SearchKeyword, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ClassicInput}" Width="180" Margin="0,0,15,0"/>

                    <Button Content="[ F5 - REFRESH ]" Command="{Binding RefreshDataCommand}" Style="{StaticResource ClassicBtn}" Background="#D0E4F5" BorderBrush="#003366" Foreground="#003366" Height="24" Padding="10,0"/>
                </WrapPanel>
            </Grid>
        </Border>

        <DataGrid Grid.Row="1" ItemsSource="{Binding ReceiptsList}" SelectedItem="{Binding SelectedReceipt}" 
                  AutoGenerateColumns="False" CanUserAddRows="False" GridLinesVisibility="All" 
                  HorizontalGridLinesBrush="#C0C0C0" VerticalGridLinesBrush="#D0D0D0" 
                  RowHeight="26" HeadersVisibility="Column" Background="White" BorderBrush="#A0A0A0" BorderThickness="1" 
                  SelectionMode="Single" AlternatingRowBackground="#F9F9F9" IsReadOnly="True" Margin="0,0,0,5">
            <DataGrid.Resources>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="#E0E0E0"/>
                    <Setter Property="Foreground" Value="Black"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                    <Setter Property="Padding" Value="5"/>
                    <Setter Property="BorderThickness" Value="0,0,1,1"/>
                    <Setter Property="BorderBrush" Value="#A0A0A0"/>
                </Style>
            </DataGrid.Resources>
            <DataGrid.Columns>
                <DataGridTextColumn Header="Invoice No." Binding="{Binding InvoiceNo}" Width="140" FontWeight="Bold"/>
                <DataGridTextColumn Header="Date &amp; Time" Binding="{Binding Timestamp, StringFormat=yyyy-MM-dd HH:mm}" Width="130"/>
                <DataGridTextColumn Header="Terminal" Binding="{Binding TerminalNo}" Width="80"/>
                <DataGridTextColumn Header="Cashier" Binding="{Binding CashierName}" Width="120"/>

                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="90" FontWeight="Bold">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="VerticalAlignment" Value="Center"/>
                            <Setter Property="Padding" Value="4,0"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsVoided}" Value="True">
                                    <Setter Property="Foreground" Value="#8B0000"/>
                                    <Setter Property="TextDecorations" Value="Strikethrough"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsVoided}" Value="False">
                                    <Setter Property="Foreground" Value="#005500"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn Header="Customer" Binding="{Binding CustomerName}" Width="130"/>
                <DataGridTextColumn Header="Pay Mode" Binding="{Binding PaymentMethod}" Width="80"/>

                <DataGridTextColumn Header="Net Total" Binding="{Binding NetTotal, StringFormat=N2}" Width="120" FontWeight="Bold">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Right"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                            <Setter Property="Padding" Value="0,0,4,0"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsVoided}" Value="True">
                                    <Setter Property="Foreground" Value="#8B0000"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
            </DataGrid.Columns>
        </DataGrid>

        <Border Grid.Row="2" Style="{StaticResource ClassicGroupBox}" VerticalAlignment="Stretch" Padding="0">
            <Grid IsEnabled="{Binding IsReceiptSelected}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="3*"/>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0" Margin="0,0,5,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="#E0E0E0" BorderBrush="#A0A0A0" BorderThickness="0,0,1,1" Padding="8,4">
                        <TextBlock Text="ITEMIZED LINE BREAKDOWN" Style="{StaticResource HeaderLabel}" Margin="0"/>
                    </Border>
                    <DataGrid Grid.Row="1" ItemsSource="{Binding SelectedReceiptLines}" 
                              AutoGenerateColumns="False" CanUserAddRows="False" GridLinesVisibility="All" 
                              HorizontalGridLinesBrush="#E0E0E0" VerticalGridLinesBrush="#E0E0E0" 
                              RowHeight="24" HeadersVisibility="Column" Background="White" BorderThickness="0,0,1,0" BorderBrush="#A0A0A0"
                              SelectionMode="Single" IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Qty" Binding="{Binding Quantity}" Width="45">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Item Description" Binding="{Binding ItemDescription}" Width="*" FontWeight="SemiBold"/>
                            <DataGridTextColumn Header="Unit Price" Binding="{Binding UnitPrice, StringFormat=N2}" Width="80">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Right"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Discount" Binding="{Binding DiscountAmount, StringFormat=N2}" Width="70" Foreground="DarkRed">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Right"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Line Total" Binding="{Binding LineTotal, StringFormat=N2}" Width="90" FontWeight="Bold">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Right"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>

                <Border Grid.Column="1" Background="#F8F8F8" BorderBrush="#A0A0A0" BorderThickness="0,0,1,0" Padding="15">
                    <StackPanel>
                        <TextBlock Text="FINANCIAL SUMMARY" Style="{StaticResource HeaderLabel}" HorizontalAlignment="Center" Margin="0,0,0,15"/>

                        <Grid Margin="0,0,0,5">
                            <TextBlock Text="Gross Total:" FontWeight="Bold" Foreground="#555"/>
                            <TextBlock Text="{Binding SelectedReceipt.GrossTotal, StringFormat=Rs. \{0:N2\}}" FontWeight="Bold" HorizontalAlignment="Right"/>
                        </Grid>
                        <Grid Margin="0,0,0,5">
                            <TextBlock Text="Total Discount:" FontWeight="Bold" Foreground="DarkRed"/>
                            <TextBlock Text="{Binding SelectedReceipt.TotalDiscount, StringFormat=- Rs. \{0:N2\}}" FontWeight="Bold" Foreground="DarkRed" HorizontalAlignment="Right"/>
                        </Grid>
                        <Rectangle Height="2" Fill="#003366" Margin="0,5,0,10"/>
                        <Grid Margin="0,0,0,15">
                            <TextBlock Text="NET TOTAL:" FontWeight="Heavy" FontSize="16" Foreground="#003366"/>
                            <TextBlock Text="{Binding SelectedReceipt.NetTotal, StringFormat=Rs. \{0:N2\}}" FontWeight="Heavy" FontSize="18" Foreground="#005500" HorizontalAlignment="Right"/>
                        </Grid>

                        <Grid Margin="0,0,0,5">
                            <TextBlock Text="Amount Tendered:" Style="{StaticResource InlineLabel}"/>
                            <TextBlock Text="{Binding SelectedReceipt.AmountTendered, StringFormat=Rs. \{0:N2\}}" FontWeight="SemiBold" HorizontalAlignment="Right"/>
                        </Grid>
                        <Grid>
                            <TextBlock Text="Balance Returned:" Style="{StaticResource InlineLabel}"/>
                            <TextBlock Text="{Binding SelectedReceipt.BalanceReturned, StringFormat=Rs. \{0:N2\}}" FontWeight="SemiBold" HorizontalAlignment="Right"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Background="#E8E8E8" Padding="15">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="ADMIN ACTIONS" Style="{StaticResource HeaderLabel}" Foreground="#333" HorizontalAlignment="Center" Margin="0,0,0,15"/>

                        <Button Command="{Binding DuplicatePrintCommand}" Content="🖨️ DUPLICATE RECEIPT" Style="{StaticResource ClassicBtn}" Height="40" Margin="0,0,0,15" Background="#D0E4F5" BorderBrush="#003366"/>

                        <Button Command="{Binding VoidTransactionCommand}" IsEnabled="{Binding CanVoidTransaction}" 
                                Content="🚨 VOID TRANSACTION" Background="#8B0000" Foreground="White" 
                                FontWeight="Heavy" FontSize="12" BorderBrush="#4A0000" BorderThickness="2" Height="50" Cursor="Hand">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Style.Triggers>
                                        <Trigger Property="IsEnabled" Value="False">
                                            <Setter Property="Opacity" Value="0.4"/>
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#A50000"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <TextBlock Text="Manager authorization required." FontSize="10" Foreground="#888" FontStyle="Italic" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>