<UserControl x:Class="POS.BackOffice.UI.Views.Pages.InventoryOperations.StockBalanceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="850"
             d:DesignWidth="1400"
             Background="#D4D0C8"
             FontFamily="Segoe UI"
             FontSize="12">

    <UserControl.Resources>

        <Style TargetType="TextBlock" x:Key="HeaderLabel">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#003366"/>
            <Setter Property="Margin" Value="0,5,0,8"/>
        </Style>

        <Style TargetType="TextBlock" x:Key="InlineLabel">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,5,0"/>
        </Style>

        <Style TargetType="TextBox" x:Key="ClassicInput">
            <Setter Property="Height" Value="24"/>
            <Setter Property="Padding" Value="4,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="#808080"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
        </Style>

        <Style TargetType="ComboBox" x:Key="ClassicCombo">
            <Setter Property="Height" Value="24"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="#808080"/>
            <Setter Property="Background" Value="White"/>
        </Style>

        <Style TargetType="Button" x:Key="ClassicBtn">
            <Setter Property="Height" Value="26"/>
            <Setter Property="Background" Value="#E0E0E0"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="15,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderBrush" Value="#808080"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#CCCCCC"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.55"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="Button" x:Key="ExcelBtn" BasedOn="{StaticResource ClassicBtn}">
            <Setter Property="Background" Value="#28A745"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#1E7E34"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#218838"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="Border" x:Key="ClassicGroupBox">
            <Setter Property="BorderBrush" Value="#A0A0A0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="#F0F0F0"/>
            <Setter Property="Padding" Value="10"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#E0E0E0"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="BorderBrush" Value="#A0A0A0"/>
        </Style>

        <Style TargetType="DataGridCell" x:Key="BaseCell">
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="4,0"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="Background" Value="Transparent"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#005555"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridCell" x:Key="FrozenCell" BasedOn="{StaticResource BaseCell}">
            <Setter Property="Background" Value="#F5F5F5"/>
        </Style>

        <Style TargetType="DataGridCell" x:Key="FinancialCell" BasedOn="{StaticResource BaseCell}">
            <Setter Property="Background" Value="#F8F8F8"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>

        <Style TargetType="DataGridCell" x:Key="WarningCell" BasedOn="{StaticResource BaseCell}">
            <Setter Property="Background" Value="#FFF7ED"/>
            <Setter Property="Foreground" Value="#B45309"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>

        <Style TargetType="DataGridCell" x:Key="DangerCell" BasedOn="{StaticResource BaseCell}">
            <Setter Property="Background" Value="#FEF2F2"/>
            <Setter Property="Foreground" Value="#991B1B"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>

        <Style TargetType="TextBlock" x:Key="RightText">
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style TargetType="TextBlock" x:Key="CenterText">
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style TargetType="TextBlock" x:Key="CenterBoldGreenText" BasedOn="{StaticResource CenterText}">
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#005500"/>
        </Style>

        <Style TargetType="TextBlock" x:Key="RightBoldText" BasedOn="{StaticResource RightText}">
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>

    </UserControl.Resources>

    <Grid Margin="5">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- FILTER BAR -->
        <Border Grid.Row="0"
                Style="{StaticResource ClassicGroupBox}"
                Margin="0,0,0,5">

            <StackPanel>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="STOCK BALANCE, BATCH INVENTORY &amp; VALUATION"
                               Style="{StaticResource HeaderLabel}"/>

                    <TextBlock Grid.Column="1"
                               Text="{Binding StatusMessage}"
                               VerticalAlignment="Center"
                               Foreground="#666"
                               FontSize="11"
                               Margin="15,0"/>

                    <Border Grid.Column="2"
                            Background="#E0FFFF"
                            BorderBrush="#005555"
                            BorderThickness="1"
                            Padding="10,3"
                            VerticalAlignment="Center">

                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Busy: "
                                       Foreground="#003366"
                                       FontWeight="Bold"/>

                            <TextBlock Text="{Binding IsBusy}"
                                       Foreground="#003366"
                                       FontWeight="Bold"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <Grid Margin="0,2,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2.3*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="1.7*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="1.7*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Search Item Code / SKU / Barcode / Name:"
                                   Style="{StaticResource InlineLabel}"/>

                        <TextBox Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource ClassicInput}">
                            <TextBox.InputBindings>
                                <KeyBinding Key="Enter"
                                            Command="{Binding RefreshCommand}"/>
                            </TextBox.InputBindings>
                        </TextBox>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Category:"
                                   Style="{StaticResource InlineLabel}"/>

                        <ComboBox ItemsSource="{Binding Categories}"
                                  SelectedItem="{Binding SelectedCategory, Mode=TwoWay}"
                                  DisplayMemberPath="CategoryName"
                                  IsTextSearchEnabled="True"
                                  Style="{StaticResource ClassicCombo}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="4">
                        <TextBlock Text="Supplier:"
                                   Style="{StaticResource InlineLabel}"/>

                        <ComboBox ItemsSource="{Binding Suppliers}"
                                  SelectedItem="{Binding SelectedSupplier, Mode=TwoWay}"
                                  DisplayMemberPath="SupplierName"
                                  IsTextSearchEnabled="True"
                                  Style="{StaticResource ClassicCombo}"/>
                    </StackPanel>

                    <Button Grid.Column="6"
                            Content="SEARCH / REFRESH"
                            Command="{Binding RefreshCommand}"
                            Style="{StaticResource ClassicBtn}"
                            Height="24"
                            VerticalAlignment="Bottom"/>
                </Grid>

                <WrapPanel Orientation="Horizontal">
                    <CheckBox Content="Hide Zero Stock Items"
                              IsChecked="{Binding HideZeroStock, Mode=TwoWay}"
                              Foreground="#333"
                              FontWeight="SemiBold"
                              Margin="0,0,25,0"
                              ToolTip="Removes out-of-stock items from the view."/>

                    <CheckBox Content="Show Negative Stock Only"
                              IsChecked="{Binding ShowNegativeOnly, Mode=TwoWay}"
                              Foreground="DarkRed"
                              FontWeight="Bold"
                              Margin="0,0,25,0"
                              ToolTip="Audit tool to find stock below zero."/>

                    <TextBlock Text="Tip: Select a row to view batch-level details."
                               Foreground="#666"
                               VerticalAlignment="Center"
                               FontStyle="Italic"/>
                </WrapPanel>
            </StackPanel>
        </Border>

        <!-- MAIN STOCK GRID -->
        <Border Grid.Row="1"
                Background="White"
                BorderBrush="#A0A0A0"
                BorderThickness="1"
                Margin="0,0,0,5">

            <DataGrid x:Name="dgStockBalance"
                      ItemsSource="{Binding StockBalances}"
                      SelectedItem="{Binding SelectedItem, Mode=TwoWay}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      IsReadOnly="True"
                      HeadersVisibility="Column"
                      GridLinesVisibility="All"
                      HorizontalGridLinesBrush="#C0C0C0"
                      VerticalGridLinesBrush="#D0D0D0"
                      RowHeight="27"
                      Background="White"
                      BorderThickness="0"
                      SelectionMode="Single"
                      AlternatingRowBackground="#F9F9F9"
                      RowDetailsVisibilityMode="VisibleWhenSelected"
                      ScrollViewer.HorizontalScrollBarVisibility="Auto"
                      ScrollViewer.VerticalScrollBarVisibility="Auto">

                <DataGrid.Resources>
                    <Style TargetType="DataGridCell" BasedOn="{StaticResource BaseCell}"/>
                </DataGrid.Resources>

                <DataGrid.Columns>
                    <DataGridTextColumn Header="..."
                                        Binding="{Binding BatchCount}"
                                        Width="42"
                                        FontWeight="Bold"
                                        Foreground="#005555"
                                        ElementStyle="{StaticResource CenterText}"
                                        CellStyle="{StaticResource FrozenCell}"/>

                    <DataGridTextColumn Header="Status"
                                        Binding="{Binding StockStatus}"
                                        Width="105"
                                        FontWeight="Bold"
                                        CellStyle="{StaticResource WarningCell}"/>

                    <DataGridTextColumn Header="Item Code"
                                        Binding="{Binding ItemCode}"
                                        Width="90"
                                        Foreground="#666"
                                        CellStyle="{StaticResource FrozenCell}"/>

                    <DataGridTextColumn Header="SKU"
                                        Binding="{Binding SkuCode}"
                                        Width="120"
                                        Foreground="#444"/>

                    <DataGridTextColumn Header="Barcode"
                                        Binding="{Binding Barcode}"
                                        Width="120"
                                        Foreground="#444"/>

                    <DataGridTextColumn Header="Description"
                                        Binding="{Binding Description}"
                                        Width="220"
                                        FontWeight="SemiBold"
                                        CellStyle="{StaticResource FrozenCell}"/>

                    <DataGridTextColumn Header="Variant"
                                        Binding="{Binding VariantDescription}"
                                        Width="130"
                                        Foreground="#444"/>

                    <DataGridTextColumn Header="UOM"
                                        Binding="{Binding Uom}"
                                        Width="55"
                                        ElementStyle="{StaticResource CenterText}"/>

                    <DataGridTextColumn Header="Category"
                                        Binding="{Binding CategoryName}"
                                        Width="120"/>

                    <DataGridTextColumn Header="Supplier"
                                        Binding="{Binding PrimarySupplierName}"
                                        Width="150"/>

                    <DataGridTextColumn Header="Qty On Hand"
                                        Binding="{Binding TotalQtyOnHand, StringFormat=N3}"
                                        Width="105"
                                        ElementStyle="{StaticResource CenterBoldGreenText}"/>

                    <DataGridTextColumn Header="Batches"
                                        Binding="{Binding BatchCount}"
                                        Width="65"
                                        ElementStyle="{StaticResource CenterText}"/>

                    <DataGridTextColumn Header="Avg Cost"
                                        Binding="{Binding UnitCost, StringFormat=N2}"
                                        Width="85"
                                        CellStyle="{StaticResource FinancialCell}"
                                        ElementStyle="{StaticResource RightText}"/>

                    <DataGridTextColumn Header="Retail"
                                        Binding="{Binding UnitRetail, StringFormat=N2}"
                                        Width="85"
                                        CellStyle="{StaticResource FinancialCell}"
                                        ElementStyle="{StaticResource RightText}"/>

                    <DataGridTextColumn Header="Wholesale"
                                        Binding="{Binding UnitWholesale, StringFormat=N2}"
                                        Width="90"
                                        CellStyle="{StaticResource FinancialCell}"
                                        ElementStyle="{StaticResource RightText}"/>

                    <DataGridTextColumn Header="Cost Value"
                                        Binding="{Binding TotalCostValue, StringFormat=N2}"
                                        Width="110"
                                        FontWeight="Bold"
                                        CellStyle="{StaticResource FinancialCell}"
                                        ElementStyle="{StaticResource RightBoldText}"/>

                    <DataGridTextColumn Header="Retail Value"
                                        Binding="{Binding TotalRetailValue, StringFormat=N2}"
                                        Width="110"
                                        Foreground="#005500"
                                        FontWeight="Bold"
                                        CellStyle="{StaticResource FinancialCell}"
                                        ElementStyle="{StaticResource RightBoldText}"/>

                    <DataGridTextColumn Header="Wholesale Value"
                                        Binding="{Binding TotalWholesaleValue, StringFormat=N2}"
                                        Width="120"
                                        CellStyle="{StaticResource FinancialCell}"
                                        ElementStyle="{StaticResource RightText}"/>

                    <DataGridTextColumn Header="Gross Profit"
                                        Binding="{Binding PotentialGrossProfit, StringFormat=N2}"
                                        Width="105"
                                        Foreground="#003366"
                                        FontWeight="Bold"
                                        CellStyle="{StaticResource FinancialCell}"
                                        ElementStyle="{StaticResource RightBoldText}"/>

                    <DataGridTextColumn Header="Markup %"
                                        Binding="{Binding MarkupPercent, StringFormat=N2}"
                                        Width="80"
                                        ElementStyle="{StaticResource RightText}"/>

                    <DataGridTextColumn Header="Earliest Expiry"
                                        Binding="{Binding EarliestExpiryDate, StringFormat=d}"
                                        Width="105"
                                        CellStyle="{StaticResource WarningCell}"/>

                    <DataGridTextColumn Header="Last Received"
                                        Binding="{Binding LastReceivedDate, StringFormat=d}"
                                        Width="105"/>
                </DataGrid.Columns>

                <DataGrid.RowDetailsTemplate>
                    <DataTemplate>
                        <Border Background="#F1F5F9"
                                BorderBrush="#005555"
                                BorderThickness="0,1,0,1"
                                Padding="35,10,10,10">

                            <StackPanel>
                                <Grid Margin="0,0,0,5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0"
                                               Text="ACTIVE BATCH BREAKDOWN"
                                               FontWeight="Bold"
                                               Foreground="#003366"
                                               FontSize="11"/>

                                    <TextBlock Grid.Column="1"
                                               Text="{Binding Description}"
                                               Foreground="#666"
                                               FontStyle="Italic"
                                               Margin="15,0,0,0"/>
                                </Grid>

                                <DataGrid ItemsSource="{Binding Batches}"
                                          AutoGenerateColumns="False"
                                          IsReadOnly="True"
                                          CanUserAddRows="False"
                                          CanUserDeleteRows="False"
                                          HeadersVisibility="Column"
                                          Background="White"
                                          BorderBrush="#CBD5E1"
                                          BorderThickness="1"
                                          HorizontalGridLinesBrush="#E2E8F0"
                                          VerticalGridLinesBrush="#E2E8F0"
                                          RowHeight="24">

                                    <DataGrid.Resources>
                                        <Style TargetType="DataGridColumnHeader">
                                            <Setter Property="Background" Value="#334155"/>
                                            <Setter Property="Foreground" Value="White"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                            <Setter Property="Padding" Value="4"/>
                                        </Style>

                                        <Style TargetType="DataGridCell" BasedOn="{StaticResource BaseCell}"/>
                                    </DataGrid.Resources>

                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Batch No"
                                                            Binding="{Binding BatchNo}"
                                                            Width="130"
                                                            FontWeight="Bold"
                                                            Foreground="#003366"/>

                                        <DataGridTextColumn Header="Stock"
                                                            Binding="{Binding CurrentStock, StringFormat=N3}"
                                                            Width="75"
                                                            Foreground="#005500"
                                                            FontWeight="Bold"
                                                            ElementStyle="{StaticResource CenterBoldGreenText}"/>

                                        <DataGridTextColumn Header="Stock Status"
                                                            Binding="{Binding StockStatus}"
                                                            Width="90"/>

                                        <DataGridTextColumn Header="Received"
                                                            Binding="{Binding ReceivedDate, StringFormat=d}"
                                                            Width="90"/>

                                        <DataGridTextColumn Header="Expiry"
                                                            Binding="{Binding ExpiryDate, StringFormat=d}"
                                                            Width="90"/>

                                        <DataGridTextColumn Header="Expiry Status"
                                                            Binding="{Binding ExpiryStatus}"
                                                            Width="105"
                                                            Foreground="#B45309"
                                                            FontWeight="Bold"/>

                                        <DataGridTextColumn Header="Days"
                                                            Binding="{Binding DaysToExpire}"
                                                            Width="55"
                                                            ElementStyle="{StaticResource CenterText}"/>

                                        <DataGridTextColumn Header="Cost"
                                                            Binding="{Binding CostPrice, StringFormat=N2}"
                                                            Width="80"
                                                            ElementStyle="{StaticResource RightText}"/>

                                        <DataGridTextColumn Header="Retail"
                                                            Binding="{Binding RetailPrice, StringFormat=N2}"
                                                            Width="80"
                                                            ElementStyle="{StaticResource RightText}"/>

                                        <DataGridTextColumn Header="Wholesale"
                                                            Binding="{Binding WholesalePrice, StringFormat=N2}"
                                                            Width="85"
                                                            ElementStyle="{StaticResource RightText}"/>

                                        <DataGridTextColumn Header="Cost Value"
                                                            Binding="{Binding TotalBatchCost, StringFormat=N2}"
                                                            Width="105"
                                                            Foreground="#003366"
                                                            FontWeight="Bold"
                                                            ElementStyle="{StaticResource RightBoldText}"/>

                                        <DataGridTextColumn Header="Retail Value"
                                                            Binding="{Binding TotalBatchRetail, StringFormat=N2}"
                                                            Width="105"
                                                            Foreground="#005500"
                                                            FontWeight="Bold"
                                                            ElementStyle="{StaticResource RightBoldText}"/>

                                        <DataGridTextColumn Header="Wholesale Value"
                                                            Binding="{Binding TotalBatchWholesale, StringFormat=N2}"
                                                            Width="115"
                                                            ElementStyle="{StaticResource RightText}"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </DataGrid.RowDetailsTemplate>
            </DataGrid>
        </Border>

        <!-- FOOTER TOTALS -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Style="{StaticResource ClassicGroupBox}"
                    Margin="0,0,5,0"
                    Padding="15,10">

                <StackPanel VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBlock Text="Total Line Items: "
                                   Foreground="#555"
                                   FontSize="12"
                                   FontWeight="SemiBold"/>

                        <TextBlock Text="{Binding TotalLineItems}"
                                   FontWeight="Bold"
                                   Foreground="#000"
                                   FontSize="13"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBlock Text="Total Batches: "
                                   Foreground="#555"
                                   FontSize="12"
                                   FontWeight="SemiBold"/>

                        <TextBlock Text="{Binding TotalBatchCount}"
                                   FontWeight="Bold"
                                   Foreground="#000"
                                   FontSize="13"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Total Physical Qty: "
                                   Foreground="#555"
                                   FontSize="12"
                                   FontWeight="SemiBold"/>

                        <TextBlock Text="{Binding TotalPhysicalQty, StringFormat=N3}"
                                   FontWeight="Bold"
                                   Foreground="#005500"
                                   FontSize="13"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Grid.Column="1"
                    Background="#E0FFFF"
                    BorderBrush="#005555"
                    BorderThickness="1"
                    Padding="15,8"
                    Margin="0,0,5,0">

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="1"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="1"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Center">

                        <TextBlock Text="TOTAL INVENTORY ASSET VALUE"
                                   Foreground="#003366"
                                   FontSize="11"
                                   FontWeight="Bold"/>

                        <TextBlock Text="{Binding TotalAssetValue, StringFormat=Rs. \{0:N2\}}"
                                   FontWeight="Bold"
                                   FontSize="22"
                                   Foreground="#003366"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>

                    <Rectangle Grid.Column="1"
                               Fill="#005555"
                               Margin="0,5"/>

                    <StackPanel Grid.Column="2"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Center">

                        <TextBlock Text="PROJECTED RETAIL VALUE"
                                   Foreground="#005500"
                                   FontSize="11"
                                   FontWeight="Bold"/>

                        <TextBlock Text="{Binding ProjectedRevenue, StringFormat=Rs. \{0:N2\}}"
                                   FontWeight="Bold"
                                   FontSize="22"
                                   Foreground="#005500"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>

                    <Rectangle Grid.Column="3"
                               Fill="#005555"
                               Margin="0,5"/>

                    <StackPanel Grid.Column="4"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Center">

                        <TextBlock Text="PROJECTED GROSS PROFIT"
                                   Foreground="#B45309"
                                   FontSize="11"
                                   FontWeight="Bold"/>

                        <TextBlock Text="{Binding ProjectedGrossProfit, StringFormat=Rs. \{0:N2\}}"
                                   FontWeight="Bold"
                                   FontSize="22"
                                   Foreground="#B45309"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Column="2"
                    Style="{StaticResource ClassicGroupBox}"
                    Margin="0"
                    Padding="10">

                <StackPanel Orientation="Horizontal"
                            VerticalAlignment="Center">

                    <StackPanel Margin="0,0,15,0">
                        <TextBlock Text="{Binding NegativeLineCount, StringFormat=Negative: \{0\}}"
                                   Foreground="DarkRed"
                                   FontWeight="Bold"
                                   FontSize="11"/>

                        <TextBlock Text="{Binding ExpiredBatchCount, StringFormat=Expired: \{0\}}"
                                   Foreground="DarkRed"
                                   FontWeight="Bold"
                                   FontSize="11"/>

                        <TextBlock Text="{Binding ExpiringSoonBatchCount, StringFormat=Expiring Soon: \{0\}}"
                                   Foreground="#B45309"
                                   FontWeight="Bold"
                                   FontSize="11"/>
                    </StackPanel>

                    <Button Content="Clear Filters"
                            Command="{Binding ClearFiltersCommand}"
                            Style="{StaticResource ClassicBtn}"
                            Height="34"
                            Margin="0,0,10,0"/>

                    <Button Content="Export CSV"
                            Command="{Binding ExportExcelCommand}"
                            Style="{StaticResource ExcelBtn}"
                            Height="34"
                            Padding="20,0"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>