<UserControl x:Class="POS.BackOffice.UI.Views.Pages.InventoryOperations.BarcodeManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="850" d:DesignWidth="1400"
             Background="#D4D0C8" FontFamily="Segoe UI" FontSize="12">

    <UserControl.Resources>
        <!-- Core Purified Styles -->
        <Style TargetType="TextBlock" x:Key="HeaderLabel">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#003366"/>
            <Setter Property="Margin" Value="0,5,0,10"/>
        </Style>
        <Style TargetType="TextBlock" x:Key="InlineLabel">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,5,0"/>
        </Style>
        <Style TargetType="TextBox" x:Key="ClassicInput">
            <Setter Property="Height" Value="26"/>
            <Setter Property="Padding" Value="4,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="#808080"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
        </Style>
        <Style TargetType="ComboBox" x:Key="ClassicCombo">
            <Setter Property="Height" Value="26"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="#808080"/>
            <Setter Property="Background" Value="White"/>
        </Style>
        <Style TargetType="Button" x:Key="ClassicBtn">
            <Setter Property="Height" Value="28"/>
            <Setter Property="Background" Value="#E0E0E0"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="15,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderBrush" Value="#808080"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#CCCCCC"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="Button" x:Key="ActionBtn" BasedOn="{StaticResource ClassicBtn}">
            <Setter Property="Background" Value="#005555"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#003333"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#007777"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="Border" x:Key="ClassicGroupBox">
            <Setter Property="BorderBrush" Value="#A0A0A0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="#F0F0F0"/>
            <Setter Property="Padding" Value="10"/>
        </Style>
        <Style TargetType="DataGridCell" x:Key="BaseCell">
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="6,0"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="Background" Value="Transparent"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#005555"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- TOP BAND: Filters -->
        <Border Grid.Row="0" Style="{StaticResource ClassicGroupBox}" Margin="0,0,0,5">
            <StackPanel>
                <TextBlock Text="BARCODE DATA ADMINISTRATION" Style="{StaticResource HeaderLabel}"/>

                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2.5*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Search (Item Code / Name / Barcode):" Style="{StaticResource InlineLabel}"/>
                        <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ClassicInput}">
                            <TextBox.InputBindings>
                                <KeyBinding Key="Enter" Command="{Binding LoadDataCommand}" />
                            </TextBox.InputBindings>
                        </TextBox>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Category Filter:" Style="{StaticResource InlineLabel}"/>
                        <ComboBox ItemsSource="{Binding Categories}" SelectedItem="{Binding SelectedCategory}" DisplayMemberPath="CategoryName" Style="{StaticResource ClassicCombo}"/>
                    </StackPanel>

                    <Button Grid.Column="4" Content="SEARCH DATA" Command="{Binding LoadDataCommand}" Style="{StaticResource ClassicBtn}" Height="26" VerticalAlignment="Bottom"/>
                </Grid>

                <WrapPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <CheckBox Content="Show Active Items Only" IsChecked="{Binding ShowActiveOnly}" Foreground="#333" FontWeight="SemiBold" Margin="0,0,15,0"/>
                    <Button Content="Clear Filters" Command="{Binding ClearFiltersCommand}" Style="{StaticResource ClassicBtn}" Height="24" Padding="10,0"/>
                </WrapPanel>
            </StackPanel>
        </Border>

        <!-- ACTION BAND: Auto-Generate controls -->
        <Border Grid.Row="1" Background="#E5E5E5" Padding="10" BorderBrush="#A0A0A0" BorderThickness="1,1,1,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Items Selected:" FontWeight="Bold" Foreground="#666" Margin="0,0,5,0"/>
                    <TextBlock Text="{Binding SelectedItemsCount}" FontWeight="Bold" FontSize="14" Foreground="#005555" Margin="0,0,15,0"/>
                    <TextBlock Text="Total Results:" FontWeight="Bold" Foreground="#666" Margin="0,0,5,0"/>
                    <TextBlock Text="{Binding TotalItemsCount}" FontWeight="Bold" FontSize="14" Foreground="#000"/>
                </StackPanel>

                <Button Grid.Column="1" Content="⚡ AUTO-GENERATE SYSTEM SKUs FOR SELECTED" Command="{Binding AutoGenerateBarcodesCommand}" Style="{StaticResource ActionBtn}" Height="30" ToolTip="Assigns unique internal barcodes to selected items that are currently blank."/>
            </Grid>
        </Border>

        <!-- DATA GRID: The Management Interface -->
        <DataGrid Grid.Row="2" ItemsSource="{Binding BarcodeItems}" 
                  AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False" IsReadOnly="False"
                  HeadersVisibility="Column" GridLinesVisibility="All" 
                  HorizontalGridLinesBrush="#C0C0C0" VerticalGridLinesBrush="#D0D0D0" 
                  RowHeight="34" Background="White" BorderBrush="#A0A0A0" BorderThickness="1" 
                  SelectionMode="Single" AlternatingRowBackground="#F9F9F9">

            <DataGrid.Resources>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="#003366"/>
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                    <Setter Property="Padding" Value="8,5"/>
                    <Setter Property="BorderThickness" Value="0,0,1,1"/>
                </Style>
                <Style TargetType="DataGridCell" BasedOn="{StaticResource BaseCell}"/>
            </DataGrid.Resources>

            <DataGrid.Columns>
                <!-- Bulk Selection Column -->
                <DataGridTemplateColumn Width="45">
                    <DataGridTemplateColumn.Header>
                        <CheckBox IsChecked="{Binding DataContext.IsSelectAllChecked, RelativeSource={RelativeSource AncestorType=UserControl}, UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Center"/>
                    </DataGridTemplateColumn.Header>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <CheckBox IsChecked="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}" 
                                      Command="{Binding DataContext.UpdateSelectedCountCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                      HorizontalAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTextColumn Header="Item Code" Binding="{Binding ItemCode}" Width="100" IsReadOnly="True" Foreground="#666"/>
                <DataGridTextColumn Header="Item Name" Binding="{Binding ItemName}" Width="2*" IsReadOnly="True" FontWeight="SemiBold"/>
                <DataGridTextColumn Header="Variant/Size" Binding="{Binding VariantDescription}" Width="*" IsReadOnly="True" Foreground="#555"/>
                <DataGridTextColumn Header="Category" Binding="{Binding CategoryName}" Width="*" IsReadOnly="True"/>

                <!-- Inline Editing Barcode Column -->
                <DataGridTemplateColumn Header="Master Barcode (Edit &amp; Save)" Width="220">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Grid Margin="2,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" Text="{Binding Barcode, UpdateSourceTrigger=PropertyChanged}" Background="#E0FFFF" BorderBrush="#A0A0A0" BorderThickness="1" VerticalContentAlignment="Center" FontWeight="Bold" Padding="5,0"/>
                                <Button Grid.Column="1" Content="💾 Save" 
                                        Command="{Binding DataContext.UpdateSingleBarcodeCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" 
                                        CommandParameter="{Binding}" 
                                        Background="#E0E0E0" BorderBrush="#A0A0A0" BorderThickness="1" Cursor="Hand" Margin="2,0,0,0" Padding="8,0" FontSize="11" FontWeight="Bold"/>
                            </Grid>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>