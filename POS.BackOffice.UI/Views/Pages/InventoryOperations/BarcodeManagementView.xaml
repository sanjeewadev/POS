<UserControl x:Class="POS.BackOffice.UI.Views.Pages.InventoryOperations.BarcodeManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="850"
             d:DesignWidth="1400"
             Background="#D4D0C8"
             FontFamily="Segoe UI"
             FontSize="12">

    <UserControl.Resources>
        <Style TargetType="TextBlock" x:Key="HeaderLabel">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#003366"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <Style TargetType="TextBlock" x:Key="InlineLabel">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,5,0"/>
        </Style>

        <Style TargetType="TextBox" x:Key="ClassicInput">
            <Setter Property="Height" Value="27"/>
            <Setter Property="Padding" Value="5,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="#808080"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
        </Style>

        <Style TargetType="ComboBox" x:Key="ClassicCombo">
            <Setter Property="Height" Value="27"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="#808080"/>
            <Setter Property="Background" Value="White"/>
        </Style>

        <Style TargetType="Button" x:Key="ClassicBtn">
            <Setter Property="Height" Value="30"/>
            <Setter Property="Background" Value="#E0E0E0"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderBrush" Value="#808080"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style TargetType="Button" x:Key="ActionBtn" BasedOn="{StaticResource ClassicBtn}">
            <Setter Property="Background" Value="#005555"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#003333"/>
        </Style>

        <Style TargetType="Button" x:Key="SaveBtn" BasedOn="{StaticResource ClassicBtn}">
            <Setter Property="Background" Value="#005500"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#003300"/>
        </Style>

        <Style TargetType="Button" x:Key="GenerateBtn" BasedOn="{StaticResource ClassicBtn}">
            <Setter Property="Background" Value="#F59E0B"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="BorderBrush" Value="#B45309"/>
        </Style>

        <Style TargetType="Border" x:Key="ClassicGroupBox">
            <Setter Property="BorderBrush" Value="#A0A0A0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="#F0F0F0"/>
            <Setter Property="Padding" Value="10"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#003366"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="6"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="BorderBrush" Value="#A0A0A0"/>
        </Style>

        <Style TargetType="DataGridCell" x:Key="BaseCell">
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="5,0"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="Background" Value="Transparent"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#005555"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridCell" x:Key="FrozenCell" BasedOn="{StaticResource BaseCell}">
            <Setter Property="Background" Value="#F5F5F5"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style TargetType="DataGridCell" x:Key="EditableCell" BasedOn="{StaticResource BaseCell}">
            <Setter Property="Background" Value="#E0FFFF"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>

        <Style TargetType="TextBox" x:Key="GridBarcodeBox">
            <Setter Property="Padding" Value="5,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="#808080"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="#E0FFFF"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>

        <Style TargetType="TextBlock" x:Key="CenterText">
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- FILTER BAND -->
        <Border Grid.Row="0"
                Style="{StaticResource ClassicGroupBox}">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="1. BARCODE DATA ADMINISTRATION"
                           Style="{StaticResource HeaderLabel}"/>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="260"/>
                        <ColumnDefinition Width="220"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,15,0">
                        <TextBlock Text="Search Item / SKU / Barcode:" Style="{StaticResource InlineLabel}"/>
                        <TextBox Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource ClassicInput}">
                            <TextBox.InputBindings>
                                <KeyBinding Key="Enter" Command="{Binding LoadDataCommand}"/>
                            </TextBox.InputBindings>
                        </TextBox>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="0,0,15,0">
                        <TextBlock Text="Category:" Style="{StaticResource InlineLabel}"/>
                        <ComboBox ItemsSource="{Binding Categories}"
                                  SelectedItem="{Binding SelectedCategory, Mode=TwoWay}"
                                  DisplayMemberPath="CategoryName"
                                  Style="{StaticResource ClassicCombo}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2" VerticalAlignment="Bottom" Margin="0,0,15,2">
                        <CheckBox Content="Show active items only"
                                  IsChecked="{Binding ShowActiveOnly, Mode=TwoWay}"
                                  FontWeight="SemiBold"
                                  Foreground="#333333"/>
                    </StackPanel>

                    <StackPanel Grid.Column="3"
                                Orientation="Horizontal"
                                VerticalAlignment="Bottom"
                                Margin="0,0,15,0">

                        <Button Content="Refresh"
                                Command="{Binding LoadDataCommand}"
                                Style="{StaticResource ActionBtn}"
                                Width="85"
                                Margin="0,0,6,0"/>

                        <Button Content="Clear Filters"
                                Command="{Binding ClearFiltersCommand}"
                                Style="{StaticResource ClassicBtn}"
                                Width="105"/>
                    </StackPanel>

                    <Border Grid.Column="4"
                            Background="#E0FFFF"
                            BorderBrush="#005555"
                            BorderThickness="1"
                            Padding="8,4"
                            VerticalAlignment="Bottom">

                        <TextBlock Text="{Binding StatusMessage}"
                                   Foreground="#003366"
                                   FontWeight="SemiBold"
                                   TextTrimming="CharacterEllipsis"/>
                    </Border>
                </Grid>
            </Grid>
        </Border>

        <!-- ACTION BAND -->
        <Border Grid.Row="2"
                Background="#E5E5E5"
                BorderBrush="#A0A0A0"
                BorderThickness="1"
                Padding="10">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Background="White"
                        BorderBrush="#A0A0A0"
                        BorderThickness="1"
                        Padding="8,4"
                        Margin="0,0,6,0">

                    <TextBlock>
                        <Run Text="Total Results: "/>
                        <Run Text="{Binding TotalItemsCount}" FontWeight="Bold"/>
                    </TextBlock>
                </Border>

                <Border Grid.Column="1"
                        Background="White"
                        BorderBrush="#A0A0A0"
                        BorderThickness="1"
                        Padding="8,4"
                        Margin="0,0,6,0">

                    <TextBlock>
                        <Run Text="Selected: "/>
                        <Run Text="{Binding SelectedItemsCount}" FontWeight="Bold"/>
                    </TextBlock>
                </Border>

                <Border Grid.Column="2"
                        Background="#FFFFE0"
                        BorderBrush="#A0A0A0"
                        BorderThickness="1"
                        Padding="8,4">

                    <TextBlock>
                        <Run Text="Unsaved: "/>
                        <Run Text="{Binding DirtyItemsCount}" FontWeight="Bold"/>
                    </TextBlock>
                </Border>

                <TextBlock Grid.Column="3"
                           Text="Internal generated barcodes use valid EAN-13 format with prefix 29 and calculated check digit."
                           Foreground="#555555"
                           FontStyle="Italic"
                           VerticalAlignment="Center"
                           Margin="15,0,15,0"/>

                <Button Grid.Column="4"
                        Content="Generate EAN-13 for Selected Missing"
                        Command="{Binding AutoGenerateBarcodesCommand}"
                        Style="{StaticResource GenerateBtn}"
                        Width="245"
                        Margin="0,0,8,0"/>

                <Button Grid.Column="5"
                        Content="Save All Changed"
                        Command="{Binding SaveAllDirtyBarcodesCommand}"
                        Style="{StaticResource SaveBtn}"
                        Width="135"/>
            </Grid>
        </Border>

        <!-- GRID -->
        <DataGrid Grid.Row="3"
                  ItemsSource="{Binding BarcodeItems}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  IsReadOnly="False"
                  HeadersVisibility="Column"
                  GridLinesVisibility="All"
                  HorizontalGridLinesBrush="#C0C0C0"
                  VerticalGridLinesBrush="#D0D0D0"
                  RowHeight="34"
                  Background="White"
                  BorderBrush="#A0A0A0"
                  BorderThickness="1"
                  SelectionMode="Single"
                  AlternatingRowBackground="#F9F9F9"
                  ScrollViewer.HorizontalScrollBarVisibility="Auto"
                  ScrollViewer.VerticalScrollBarVisibility="Auto">

            <DataGrid.Resources>
                <Style TargetType="DataGridCell" BasedOn="{StaticResource BaseCell}"/>
            </DataGrid.Resources>

            <DataGrid.Columns>
                <DataGridTemplateColumn Width="45">
                    <DataGridTemplateColumn.Header>
                        <CheckBox IsChecked="{Binding DataContext.IsSelectAllChecked,
                                                      RelativeSource={RelativeSource AncestorType=UserControl},
                                                      Mode=TwoWay,
                                                      UpdateSourceTrigger=PropertyChanged}"
                                  HorizontalAlignment="Center"/>
                    </DataGridTemplateColumn.Header>

                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      Command="{Binding DataContext.UpdateSelectedCountCommand,
                                                        RelativeSource={RelativeSource AncestorType=UserControl}}"
                                      HorizontalAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTextColumn Header="Item Code"
                                    Binding="{Binding ItemCode}"
                                    Width="95"
                                    IsReadOnly="True"
                                    CellStyle="{StaticResource FrozenCell}"/>

                <DataGridTextColumn Header="SKU"
                                    Binding="{Binding SkuCode}"
                                    Width="120"
                                    IsReadOnly="True"
                                    CellStyle="{StaticResource FrozenCell}"/>

                <DataGridTextColumn Header="Item / Variant"
                                    Binding="{Binding DisplayName}"
                                    Width="260"
                                    IsReadOnly="True"
                                    FontWeight="SemiBold"/>

                <DataGridTextColumn Header="Category"
                                    Binding="{Binding CategoryName}"
                                    Width="150"
                                    IsReadOnly="True"/>

                <DataGridTextColumn Header="Status"
                                    Binding="{Binding StatusText}"
                                    Width="80"
                                    IsReadOnly="True"
                                    ElementStyle="{StaticResource CenterText}"/>

                <DataGridTemplateColumn Header="Barcode"
                                        Width="230"
                                        CellStyle="{StaticResource EditableCell}">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBox Text="{Binding Barcode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource GridBarcodeBox}"
                                     Margin="2"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTextColumn Header="Barcode Type"
                                    Binding="{Binding BarcodeType}"
                                    Width="130"
                                    IsReadOnly="True"/>

                <DataGridCheckBoxColumn Header="Has Barcode"
                        Binding="{Binding HasBarcode, Mode=OneWay}"
                        Width="90"
                        IsReadOnly="True"/>

                <DataGridCheckBoxColumn Header="Changed"
                        Binding="{Binding IsDirty, Mode=OneWay}"
                        Width="80"
                        IsReadOnly="True"/>

                <DataGridTemplateColumn Header="Save"
                                        Width="80">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="Save"
                                    Command="{Binding DataContext.UpdateSingleBarcodeCommand,
                                                      RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                    CommandParameter="{Binding}"
                                    Background="#E0E0E0"
                                    BorderBrush="#A0A0A0"
                                    BorderThickness="1"
                                    Cursor="Hand"
                                    Width="55"
                                    Height="24"
                                    FontWeight="Bold"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>