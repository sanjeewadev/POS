<UserControl x:Class="POS.BackOffice.UI.Views.Pages.InventoryOperations.GrnView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="850"
             d:DesignWidth="1400"
             Background="#D4D0C8"
             FontFamily="Segoe UI"
             FontSize="12">

    <UserControl.Resources>

        <Style TargetType="TextBlock" x:Key="HeaderLabel">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#003366"/>
            <Setter Property="Margin" Value="0,5,0,5"/>
        </Style>

        <Style TargetType="TextBlock" x:Key="InlineLabel">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,5,0"/>
        </Style>

        <Style TargetType="TextBox" x:Key="ClassicInput">
            <Setter Property="Height" Value="24"/>
            <Setter Property="Padding" Value="4,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="#808080"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Style.Triggers>
                <Trigger Property="IsReadOnly" Value="True">
                    <Setter Property="Background" Value="#E5E5E5"/>
                    <Setter Property="Foreground" Value="#555"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#E5E5E5"/>
                    <Setter Property="Foreground" Value="#555"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="ComboBox" x:Key="ClassicCombo">
            <Setter Property="Height" Value="24"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="#808080"/>
            <Setter Property="Background" Value="White"/>
        </Style>

        <Style TargetType="DatePicker" x:Key="ClassicDate">
            <Setter Property="Height" Value="24"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="#808080"/>
        </Style>

        <Style TargetType="Button" x:Key="ClassicBtn">
            <Setter Property="Height" Value="26"/>
            <Setter Property="Background" Value="#E0E0E0"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderBrush" Value="#808080"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#CCCCCC"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.55"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="Button" x:Key="ActionBtn" BasedOn="{StaticResource ClassicBtn}">
            <Setter Property="Background" Value="#005555"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#003333"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#007777"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="Border" x:Key="ClassicGroupBox">
            <Setter Property="BorderBrush" Value="#A0A0A0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="#F0F0F0"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#E0E0E0"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="BorderBrush" Value="#A0A0A0"/>
        </Style>

        <Style TargetType="DataGridCell" x:Key="BaseCell">
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="4,0"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="Background" Value="Transparent"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#005555"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridCell" x:Key="FrozenCell" BasedOn="{StaticResource BaseCell}">
            <Setter Property="Background" Value="#F5F5F5"/>
        </Style>

        <Style TargetType="DataGridCell" x:Key="EditableCell" BasedOn="{StaticResource BaseCell}">
            <Setter Property="Background" Value="#FFFFE0"/>
        </Style>

        <Style TargetType="DataGridCell" x:Key="HighlightCell" BasedOn="{StaticResource BaseCell}">
            <Setter Property="Background" Value="#FFF7ED"/>
        </Style>

    </UserControl.Resources>

    <Grid Margin="5">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="550"/>
            <ColumnDefinition Width="5"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- HEADER SETUP -->
        <Border Grid.Row="0"
                Grid.ColumnSpan="3"
                Style="{StaticResource ClassicGroupBox}">

            <StackPanel>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="1. GRN &amp; SUPPLIER INVOICE SETUP"
                               Style="{StaticResource HeaderLabel}"/>

                    <TextBlock Grid.Column="1"
                               Text="{Binding StatusMessage}"
                               VerticalAlignment="Center"
                               Foreground="#666"
                               FontSize="11"
                               Margin="15,0"/>

                    <Border Grid.Column="2"
                            Background="#DEFF9A"
                            Padding="12,3"
                            BorderBrush="#A0A0A0"
                            BorderThickness="1">

                        <TextBlock Text="{Binding DocumentStatus}"
                                   Foreground="Black"
                                   FontWeight="Bold"/>
                    </Border>
                </Grid>

                <WrapPanel Orientation="Horizontal" Margin="0,5,0,0">

                    <!-- PO LINK -->
                    <Border Margin="0,0,30,5"
                            Background="#E6F2F2"
                            BorderBrush="#A0A0A0"
                            BorderThickness="1"
                            Padding="5">

                        <StackPanel>
                            <TextBlock Text="Link Approved PO"
                                       Style="{StaticResource InlineLabel}"
                                       Foreground="#005555"/>

                            <Grid Margin="0,4,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="220"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="75"/>
                                </Grid.ColumnDefinitions>

                                <ComboBox Grid.Column="0"
                                          ItemsSource="{Binding OpenPurchaseOrders}"
                                          SelectedItem="{Binding SelectedPO, Mode=TwoWay}"
                                          DisplayMemberPath="PoNumber"
                                          IsEditable="True"
                                          IsTextSearchEnabled="True"
                                          Style="{StaticResource ClassicCombo}"
                                          ToolTip="Leave blank for Direct GRN."/>

                                <Button Grid.Column="2"
                                        Content="LOAD"
                                        Command="{Binding LoadPoCommand}"
                                        Style="{StaticResource ActionBtn}"
                                        Height="24"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- SUPPLIER + INVOICE -->
                    <StackPanel Margin="0,0,30,5">
                        <TextBlock Text="Supplier &amp; Invoice No *"
                                   Style="{StaticResource InlineLabel}"/>

                        <Grid Margin="0,4,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="200"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="130"/>
                            </Grid.ColumnDefinitions>

                            <ComboBox Grid.Column="0"
                                      ItemsSource="{Binding Suppliers}"
                                      SelectedItem="{Binding SelectedSupplier, Mode=TwoWay}"
                                      DisplayMemberPath="SupplierName"
                                      IsEnabled="{Binding IsSupplierSelectionEnabled}"
                                      IsEditable="True"
                                      IsTextSearchEnabled="True"
                                      Style="{StaticResource ClassicCombo}"/>

                            <TextBox Grid.Column="2"
                                     Text="{Binding SupplierInvoiceNo, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource ClassicInput}"
                                     Background="#FFFFE0"
                                     FontWeight="Bold"
                                     ToolTip="Supplier invoice number. Duplicate invoice number is blocked per supplier."/>
                        </Grid>
                    </StackPanel>

                    <!-- DATES -->
                    <StackPanel Margin="0,0,30,5">
                        <TextBlock Text="Invoice / Received / Due Dates"
                                   Style="{StaticResource InlineLabel}"/>

                        <Grid Margin="0,4,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="115"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="115"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="115"/>
                            </Grid.ColumnDefinitions>

                            <DatePicker Grid.Column="0"
                                        SelectedDate="{Binding InvoiceDate, Mode=TwoWay}"
                                        Style="{StaticResource ClassicDate}"
                                        ToolTip="Date on supplier invoice."/>

                            <DatePicker Grid.Column="2"
                                        SelectedDate="{Binding ReceivedDate, Mode=TwoWay}"
                                        Style="{StaticResource ClassicDate}"
                                        ToolTip="Actual goods received date."/>

                            <DatePicker Grid.Column="4"
                                        SelectedDate="{Binding DueDate, Mode=TwoWay}"
                                        Style="{StaticResource ClassicDate}"
                                        ToolTip="Supplier payment due date."/>
                        </Grid>
                    </StackPanel>

                </WrapPanel>
            </StackPanel>
        </Border>

        <!-- LEFT SIDE: ITEM ENTRY -->
        <Border Grid.Row="1"
                Grid.Column="0"
                Style="{StaticResource ClassicGroupBox}"
                VerticalAlignment="Stretch">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="2. ITEM ENTRY CONSOLE"
                           Style="{StaticResource HeaderLabel}"
                           Foreground="#005555"
                           Margin="0,0,0,5"/>

                <!-- BARCODE / ITEM SEARCH -->
                <Border Grid.Row="1"
                        Background="#334155"
                        Padding="8"
                        BorderBrush="#1E293B"
                        BorderThickness="1"
                        Margin="0,0,0,10">

                    <StackPanel>
                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="65"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       Text="Barcode:"
                                       Foreground="#DEFF9A"
                                       Style="{StaticResource InlineLabel}"/>

                            <TextBox Grid.Column="1"
                                     Text="{Binding ScanBarcode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Height="26"
                                     FontSize="13"
                                     FontWeight="Bold"
                                     ToolTip="Scan barcode or type SKU and press Enter.">
                                <TextBox.InputBindings>
                                    <KeyBinding Key="Enter"
                                                Command="{Binding AddItemCommand}"/>
                                </TextBox.InputBindings>
                            </TextBox>
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="65"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="40"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       Text="Code:"
                                       Foreground="White"
                                       Style="{StaticResource InlineLabel}"/>

                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding AvailableItems}"
                                      SelectedItem="{Binding SelectedItem, Mode=TwoWay}"
                                      DisplayMemberPath="ItemCode"
                                      IsEditable="True"
                                      IsTextSearchEnabled="True"
                                      TextSearch.TextPath="ItemCode"
                                      Height="26"
                                      Margin="0,0,10,0"/>

                            <TextBlock Grid.Column="2"
                                       Text="Name:"
                                       Foreground="White"
                                       Style="{StaticResource InlineLabel}"/>

                            <ComboBox Grid.Column="3"
                                      ItemsSource="{Binding AvailableItems}"
                                      SelectedItem="{Binding SelectedItem, Mode=TwoWay}"
                                      DisplayMemberPath="ItemName"
                                      IsEditable="True"
                                      IsTextSearchEnabled="True"
                                      TextSearch.TextPath="ItemName"
                                      Height="26"
                                      ToolTip="Select standard item or matrix parent."/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- MATRIX ENTRY -->
                <Border Grid.Row="2"
                        Background="#F0F8FF"
                        BorderBrush="#005555"
                        BorderThickness="1"
                        Padding="8">

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       Text="MATRIX RAPID RECEIVING"
                                       FontWeight="Bold"
                                       Foreground="#003366"
                                       VerticalAlignment="Center"/>

                            <TextBox Grid.Column="1"
                                     Text="{Binding MatrixFilterText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Width="180"
                                     Height="24"
                                     Padding="4,0"
                                     Background="White"
                                     BorderBrush="#A0A0A0"
                                     BorderThickness="1"
                                     ToolTip="Search loaded variants by item, attributes, or barcode."/>
                        </Grid>

                        <Grid Grid.Row="1" Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="125"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       Text="Batch No:"
                                       Style="{StaticResource InlineLabel}"/>

                            <TextBox Grid.Column="1"
                                     Text="{Binding MatrixBatchNo, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource ClassicInput}"
                                     ToolTip="Leave blank for system generated batch number."/>

                            <TextBlock Grid.Column="3"
                                       Text="Expiry:"
                                       Style="{StaticResource InlineLabel}"/>

                            <DatePicker Grid.Column="4"
                                        SelectedDate="{Binding MatrixExpiryDate, Mode=TwoWay}"
                                        Style="{StaticResource ClassicDate}"/>
                        </Grid>

                        <DataGrid Grid.Row="2"
                                  ItemsSource="{Binding ActiveMatrixVariants}"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  IsReadOnly="False"
                                  HeadersVisibility="Column"
                                  Background="White"
                                  BorderBrush="#A0A0A0"
                                  BorderThickness="1"
                                  RowHeight="28"
                                  GridLinesVisibility="All"
                                  HorizontalGridLinesBrush="#E0E0E0"
                                  VerticalGridLinesBrush="#E0E0E0"
                                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                                  FrozenColumnCount="1"
                                  SelectionMode="Single">

                            <DataGrid.Resources>
                                <Style TargetType="DataGridCell" BasedOn="{StaticResource BaseCell}"/>
                            </DataGrid.Resources>

                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Attributes"
                                                    Binding="{Binding VariantDescription}"
                                                    Width="*"
                                                    IsReadOnly="True"
                                                    CellStyle="{StaticResource FrozenCell}"/>

                                <DataGridTemplateColumn Header="Rec'd Qty" Width="80">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBox Text="{Binding ReceivedQty, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                     TextAlignment="Center"
                                                     FontWeight="Bold"
                                                     Background="#FFFFE0"
                                                     BorderThickness="0"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTemplateColumn Header="Unit Cost" Width="90">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBox Text="{Binding UnitCost, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                                     TextAlignment="Right"
                                                     Background="#FFFFE0"
                                                     BorderThickness="0"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTemplateColumn Header="Disc Rs." Width="75">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBox Text="{Binding LineDiscount, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                                     TextAlignment="Right"
                                                     Foreground="DarkRed"
                                                     Background="#FFFFE0"
                                                     BorderThickness="0"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>

                <Button Grid.Row="3"
                        Content="ADD ACTIVE MATRIX TO GRN"
                        Command="{Binding AddMatrixCommand}"
                        Style="{StaticResource ActionBtn}"
                        Background="#0066CC"
                        BorderBrush="#004C99"
                        Height="36"
                        Margin="0,10,0,0"
                        FontSize="13"/>
            </Grid>
        </Border>

        <!-- RIGHT SIDE: GRN CART -->
        <Grid Grid.Row="1"
              Grid.Column="2">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- GRN NUMBER BAR -->
            <Border Grid.Row="0"
                    Background="#003366"
                    Padding="10"
                    BorderBrush="#002244"
                    BorderThickness="1">

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">

                        <TextBlock Text="GRN NO:"
                                   Foreground="#A0C0E0"
                                   FontSize="14"
                                   FontWeight="Bold"
                                   Margin="0,0,10,0"/>

                        <TextBlock Text="[ AUTO GENERATED ON POST ]"
                                   Foreground="White"
                                   FontSize="14"
                                   FontWeight="SemiBold"/>
                    </StackPanel>

                    <TextBlock Grid.Column="1"
                               Text="Posting updates inventory, batches, PO received qty, and supplier ledger"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Center"
                               Foreground="#DEFF9A"
                               FontWeight="SemiBold"/>
                </Grid>
            </Border>

            <!-- ROW ACTIONS -->
            <Border Grid.Row="1"
                    Background="#E5E5E5"
                    Padding="8"
                    BorderBrush="#A0A0A0"
                    BorderThickness="1,0,1,0">

                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Selected Row Actions:"
                               VerticalAlignment="Center"
                               FontWeight="Bold"
                               Foreground="#666"
                               Margin="0,0,10,0"/>

                    <Button Content="Remove Item"
                            Command="{Binding RemoveLineCommand}"
                            CommandParameter="{Binding SelectedLine}"
                            Style="{StaticResource ClassicBtn}"
                            Foreground="DarkRed"
                            Height="26"/>

                    <TextBlock Text="Edit highlighted cells before posting."
                               VerticalAlignment="Center"
                               Foreground="#888"
                               FontStyle="Italic"
                               Margin="20,0,0,0"/>
                </StackPanel>
            </Border>

            <!-- GRN LINES -->
            <DataGrid Grid.Row="2"
                      x:Name="dgGrnLines"
                      ItemsSource="{Binding GrnLines}"
                      SelectedItem="{Binding SelectedLine, Mode=TwoWay}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      GridLinesVisibility="All"
                      IsReadOnly="False"
                      HorizontalGridLinesBrush="#C0C0C0"
                      VerticalGridLinesBrush="#D0D0D0"
                      RowHeight="28"
                      HeadersVisibility="Column"
                      Background="White"
                      BorderBrush="#A0A0A0"
                      BorderThickness="1"
                      SelectionMode="Single"
                      AlternatingRowBackground="#F9F9F9"
                      CellEditEnding="DgGrnLines_CellEditEnding">

                <DataGrid.Resources>
                    <Style TargetType="DataGridCell" BasedOn="{StaticResource BaseCell}"/>
                </DataGrid.Resources>

                <DataGrid.Columns>
                    <DataGridTextColumn Header="Code"
                                        Binding="{Binding ItemCode}"
                                        Width="85"
                                        IsReadOnly="True"
                                        Foreground="#666"
                                        CellStyle="{StaticResource FrozenCell}"/>

                    <DataGridTextColumn Header="Description"
                                        Binding="{Binding Description}"
                                        Width="*"
                                        IsReadOnly="True"
                                        FontWeight="SemiBold"
                                        CellStyle="{StaticResource FrozenCell}"/>

                    <DataGridTextColumn Header="Variant"
                                        Binding="{Binding VariantDescription}"
                                        Width="120"
                                        IsReadOnly="True"
                                        CellStyle="{StaticResource FrozenCell}"/>

                    <DataGridTextColumn Header="Batch"
                                        Binding="{Binding BatchNo, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                        Width="90"
                                        CellStyle="{StaticResource EditableCell}"/>

                    <DataGridTextColumn Header="Expiry"
                                        Binding="{Binding ExpiryDate, Mode=TwoWay, StringFormat=d, UpdateSourceTrigger=LostFocus}"
                                        Width="90"
                                        CellStyle="{StaticResource EditableCell}"/>

                    <DataGridTextColumn Header="PO Qty"
                                        Binding="{Binding OrderedQty, StringFormat=N3}"
                                        Width="75"
                                        IsReadOnly="True"
                                        Foreground="#003366"
                                        FontWeight="Bold"
                                        CellStyle="{StaticResource FrozenCell}">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="Rec'd"
                                        Binding="{Binding ReceivedQty, Mode=TwoWay, UpdateSourceTrigger=LostFocus, StringFormat=N3}"
                                        Width="75"
                                        CellStyle="{StaticResource EditableCell}"
                                        FontWeight="Bold"
                                        Foreground="#005555">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="Unit Cost"
                                        Binding="{Binding UnitCost, Mode=TwoWay, UpdateSourceTrigger=LostFocus, StringFormat=N2}"
                                        Width="90"
                                        CellStyle="{StaticResource EditableCell}">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="Disc"
                                        Binding="{Binding LineDiscount, Mode=TwoWay, UpdateSourceTrigger=LostFocus, StringFormat=N2}"
                                        Width="75"
                                        Foreground="DarkRed"
                                        CellStyle="{StaticResource EditableCell}">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="Landed Cost"
                                        Binding="{Binding LandedCost, StringFormat=N2}"
                                        Width="95"
                                        IsReadOnly="True"
                                        Foreground="#D97706"
                                        CellStyle="{StaticResource HighlightCell}">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="Line Total"
                                        Binding="{Binding LineTotal, StringFormat=N2}"
                                        Width="100"
                                        IsReadOnly="True"
                                        FontWeight="Bold"
                                        CellStyle="{StaticResource FrozenCell}">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                </DataGrid.Columns>
            </DataGrid>

            <!-- FOOTER -->
            <Border Grid.Row="3"
                    Background="#D4D0C8"
                    BorderBrush="#A0A0A0"
                    BorderThickness="1"
                    Margin="0,5,0,0"
                    Padding="10">

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="15"/>
                        <ColumnDefinition Width="230"/>
                        <ColumnDefinition Width="15"/>
                        <ColumnDefinition Width="310"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Remarks / Internal Notes:"
                                   Style="{StaticResource InlineLabel}"
                                   Margin="0,0,0,5"/>

                        <TextBox Text="{Binding Remarks, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 Height="75"
                                 Style="{StaticResource ClassicInput}"/>
                    </StackPanel>

                    <Rectangle Grid.Column="1"
                               Width="1"
                               Fill="#A0A0A0"
                               Margin="7,0"/>

                    <StackPanel Grid.Column="2"
                                VerticalAlignment="Center">

                        <TextBlock Text="GLOBAL MODIFIERS"
                                   FontWeight="Bold"
                                   Foreground="#003366"
                                   Margin="0,0,0,10"/>

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       Text="Bill Disc (-)"
                                       Style="{StaticResource InlineLabel}"
                                       Foreground="DarkRed"/>

                            <TextBox Grid.Column="1"
                                     Text="{Binding GlobalBillDiscount, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                     Style="{StaticResource ClassicInput}"
                                     HorizontalContentAlignment="Right"
                                     Background="#FEF2F2"/>
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       Text="Freight (+)"
                                       Style="{StaticResource InlineLabel}"
                                       Foreground="#D97706"/>

                            <TextBox Grid.Column="1"
                                     Text="{Binding FreightAmount, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                     Style="{StaticResource ClassicInput}"
                                     HorizontalContentAlignment="Right"
                                     Background="#FFF7ED"
                                     ToolTip="Freight is proportionally allocated to landed cost."/>
                        </Grid>
                    </StackPanel>

                    <Rectangle Grid.Column="3"
                               Width="1"
                               Fill="#A0A0A0"
                               Margin="7,0"/>

                    <StackPanel Grid.Column="4"
                                VerticalAlignment="Center">

                        <Grid Margin="0,0,0,4">
                            <TextBlock Text="SUBTOTAL:"
                                       Foreground="#555"
                                       FontSize="13"
                                       FontWeight="Bold"/>

                            <TextBlock Text="{Binding Subtotal, StringFormat=Rs. \{0:N2\}}"
                                       HorizontalAlignment="Right"
                                       FontSize="13"
                                       FontWeight="Bold"/>
                        </Grid>

                        <Grid Margin="0,0,0,4">
                            <TextBlock Text="DISCOUNTS:"
                                       Foreground="DarkRed"
                                       FontSize="13"
                                       FontWeight="Bold"/>

                            <TextBlock Text="{Binding TotalDiscountAmount, StringFormat=- Rs. \{0:N2\}}"
                                       HorizontalAlignment="Right"
                                       Foreground="DarkRed"
                                       FontSize="13"
                                       FontWeight="Bold"/>
                        </Grid>

                        <Grid Margin="0,0,0,8">
                            <TextBlock Text="FREIGHT:"
                                       Foreground="#D97706"
                                       FontSize="13"
                                       FontWeight="Bold"/>

                            <TextBlock Text="{Binding FreightAmount, StringFormat=+ Rs. \{0:N2\}}"
                                       HorizontalAlignment="Right"
                                       Foreground="#D97706"
                                       FontSize="13"
                                       FontWeight="Bold"/>
                        </Grid>

                        <Rectangle Height="2"
                                   Fill="#333"
                                   Margin="0,0,0,8"/>

                        <Grid Margin="0,0,0,10">
                            <TextBlock Text="NET PAYABLE:"
                                       Foreground="#003366"
                                       FontSize="14"
                                       FontWeight="Bold"
                                       VerticalAlignment="Center"/>

                            <TextBlock Text="{Binding NetPayable, StringFormat=Rs. \{0:N2\}}"
                                       Foreground="#005500"
                                       FontSize="26"
                                       FontWeight="Bold"
                                       HorizontalAlignment="Right"/>
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Button Grid.Column="0"
                                    Content="Clear Form"
                                    Command="{Binding ClearCommand}"
                                    Style="{StaticResource ClassicBtn}"
                                    Height="40"/>

                            <Button Grid.Column="2"
                                    Content="POST GRN"
                                    Command="{Binding PostGrnCommand}"
                                    Height="40"
                                    Background="#005500"
                                    Foreground="White"
                                    FontSize="14"
                                    FontWeight="Bold"
                                    BorderBrush="#003300"
                                    BorderThickness="1"
                                    Cursor="Hand"
                                    ToolTip="Finalizes inventory, batches, supplier ledger, and PO receiving."/>
                        </Grid>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>