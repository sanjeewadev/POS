<UserControl x:Class="POS.BackOffice.UI.Views.Pages.InventoryOperations.GrnView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="850" d:DesignWidth="1400"
             Background="#D4D0C8" FontFamily="Segoe UI" FontSize="12">
    <UserControl.Resources>
        <Style TargetType="TextBlock" x:Key="HeaderLabel">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#003366"/>
            <Setter Property="Margin" Value="0,10,0,5"/>
        </Style>

        <Style TargetType="TextBlock" x:Key="InlineLabel">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,5,0"/>
        </Style>

        <Style TargetType="TextBox" x:Key="ClassicInput">
            <Setter Property="Height" Value="24"/>
            <Setter Property="Padding" Value="4,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="#808080"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
        </Style>

        <Style TargetType="ComboBox" x:Key="ClassicCombo">
            <Setter Property="Height" Value="24"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="#808080"/>
            <Setter Property="Background" Value="White"/>
        </Style>

        <Style TargetType="DatePicker" x:Key="ClassicDate">
            <Setter Property="Height" Value="24"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="#808080"/>
        </Style>

        <Style TargetType="Button" x:Key="ClassicBtn">
            <Setter Property="Height" Value="26"/>
            <Setter Property="Background" Value="#E0E0E0"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderBrush" Value="#808080"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#CCCCCC"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="Button" x:Key="ActionBtn" BasedOn="{StaticResource ClassicBtn}">
            <Setter Property="Background" Value="#005555"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#003333"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#007777"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="Border" x:Key="ClassicGroupBox">
            <Setter Property="BorderBrush" Value="#A0A0A0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="#F0F0F0"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <Style TargetType="DataGridCell" x:Key="BaseCell">
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="4,0"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="Background" Value="Transparent"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#005555"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="DataGridCell" x:Key="FrozenCell" BasedOn="{StaticResource BaseCell}">
            <Setter Property="Background" Value="#F5F5F5"/>
        </Style>
        <Style TargetType="DataGridCell" x:Key="RetailCell" BasedOn="{StaticResource BaseCell}">
            <Setter Property="Background" Value="#F0FFF0"/>
        </Style>
        <Style TargetType="DataGridCell" x:Key="WarningCell" BasedOn="{StaticResource BaseCell}">
            <Setter Property="Background" Value="#FFF7ED"/>
        </Style>
        <Style TargetType="DataGridCell" x:Key="EditableCell" BasedOn="{StaticResource BaseCell}">
            <Setter Property="Background" Value="#FFFFE0"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="5">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="480"/>
            <ColumnDefinition Width="5"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Style="{StaticResource ClassicGroupBox}">
                <StackPanel>
                    <TextBlock Text="1. PURCHASE ORDER" Style="{StaticResource HeaderLabel}" Margin="0,0,0,5"/>
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="70"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Link PO:" Style="{StaticResource InlineLabel}"/>
                        <ComboBox Grid.Column="1" IsEditable="True" ItemsSource="{Binding OpenPurchaseOrders}" SelectedItem="{Binding SelectedPO}" DisplayMemberPath="PONumber" Style="{StaticResource ClassicCombo}" Margin="0,0,5,0"/>
                        <Button Grid.Column="2" Content="LOAD" Command="{Binding LoadPoCommand}" Style="{StaticResource ActionBtn}" Height="24"/>
                    </Grid>
                </StackPanel>
            </Border>

            <Border Grid.Row="1" Style="{StaticResource ClassicGroupBox}">
                <StackPanel>
                    <TextBlock Text="2. INVOICE LEVEL SETUP" Style="{StaticResource HeaderLabel}" Margin="0,0,0,5"/>
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Supplier *" Style="{StaticResource InlineLabel}"/>
                        <ComboBox Grid.Column="1" IsEditable="True" ItemsSource="{Binding Suppliers}" SelectedItem="{Binding SelectedSupplier}" DisplayMemberPath="CompanyName" Style="{StaticResource ClassicCombo}"/>
                    </Grid>

                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="65"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Inv No *" Style="{StaticResource InlineLabel}" Foreground="DarkRed"/>
                        <TextBox Grid.Column="1" Text="{Binding SupplierInvoiceNo}" Style="{StaticResource ClassicInput}" Background="#FFFFE0" Margin="0,0,10,0"/>

                        <TextBlock Grid.Column="2" Text="Inv Date *" Style="{StaticResource InlineLabel}"/>
                        <DatePicker Grid.Column="3" SelectedDate="{Binding InvoiceDate}" Style="{StaticResource ClassicDate}"/>
                    </Grid>

                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="65"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Rec Date *" Style="{StaticResource InlineLabel}"/>
                        <DatePicker Grid.Column="1" SelectedDate="{Binding ReceivedDate}" Style="{StaticResource ClassicDate}" Margin="0,0,10,0"/>

                        <TextBlock Grid.Column="2" Text="Terms" Style="{StaticResource InlineLabel}"/>
                        <ComboBox Grid.Column="3" Style="{StaticResource ClassicCombo}">
                            <ComboBoxItem Content="30 Days" IsSelected="True"/>
                            <ComboBoxItem Content="Cash"/>
                        </ComboBox>
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="65"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Cr. Days" Style="{StaticResource InlineLabel}"/>
                        <TextBox Grid.Column="1" Text="30" Style="{StaticResource ClassicInput}" HorizontalContentAlignment="Center" Margin="0,0,10,0"/>

                        <TextBlock Grid.Column="2" Text="Due Date" Style="{StaticResource InlineLabel}" Foreground="#005500"/>
                        <TextBox Grid.Column="3" Text="{Binding DueDate, StringFormat=d}" IsReadOnly="True" Background="#E5E5E5" Foreground="#005500" FontWeight="Bold" Style="{StaticResource ClassicInput}"/>
                    </Grid>
                </StackPanel>
            </Border>

            <Border Grid.Row="2" Style="{StaticResource ClassicGroupBox}" VerticalAlignment="Stretch">
                <StackPanel>
                    <TextBlock Text="3. ITEM ENTRY &amp; PRICING" Style="{StaticResource HeaderLabel}" Foreground="#005555" Margin="0,0,0,5"/>

                    <Border Background="#334155" Padding="8" BorderBrush="#1E293B" BorderThickness="1" Margin="0,0,0,8">
                        <StackPanel>
                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="60"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Barcode:" Foreground="#DEFF9A" Style="{StaticResource InlineLabel}"/>

                                <TextBox Grid.Column="1" Text="{Binding ScanBarcode, UpdateSourceTrigger=PropertyChanged}" Height="24" FontSize="12" FontWeight="Bold" ToolTip="Scan direct variant or standard item here">
                                    <TextBox.InputBindings>
                                        <KeyBinding Key="Enter" Command="{Binding AddItemCommand}" />
                                    </TextBox.InputBindings>
                                </TextBox>
                            </Grid>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="60"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="45"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Code:" Foreground="White" Style="{StaticResource InlineLabel}"/>

                                <ComboBox Grid.Column="1" ItemsSource="{Binding AvailableItems}" SelectedItem="{Binding SelectedItem}" 
                                          DisplayMemberPath="ItemCode" IsEditable="True" IsTextSearchEnabled="True" TextSearch.TextPath="ItemCode" 
                                          Height="24" Margin="0,0,10,0"/>

                                <TextBlock Grid.Column="2" Text="Name:" Foreground="White" Style="{StaticResource InlineLabel}"/>

                                <ComboBox Grid.Column="3" ItemsSource="{Binding AvailableItems}" SelectedItem="{Binding SelectedItem}" 
                                          DisplayMemberPath="ItemName" IsEditable="True" IsTextSearchEnabled="True" TextSearch.TextPath="ItemName" 
                                          Height="24"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Background="#F0F8FF" BorderBrush="#005555" BorderThickness="1" Padding="8" Margin="0,0,0,8" Visibility="Visible">
                        <StackPanel>
                            <Grid Margin="0,0,5,5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="⚡ MATRIX RAPID ENTRY (Tab to navigate)" FontWeight="Bold" Foreground="#003366" VerticalAlignment="Center"/>
                                <TextBox Grid.Column="1" Text="{Binding MatrixFilterText, UpdateSourceTrigger=PropertyChanged}" Width="150" Height="22" Padding="4,0" ToolTip="Filter variants..." Background="White" BorderBrush="#A0A0A0" BorderThickness="1"/>
                            </Grid>

                            <DataGrid Height="140" ItemsSource="{Binding ActiveMatrixVariants}" AutoGenerateColumns="False" CanUserAddRows="False" 
                                      HeadersVisibility="Column" Background="White" BorderBrush="#A0A0A0" BorderThickness="1" 
                                      RowHeight="26" GridLinesVisibility="All" HorizontalGridLinesBrush="#E0E0E0" VerticalGridLinesBrush="#E0E0E0"
                                      ScrollViewer.HorizontalScrollBarVisibility="Auto" ScrollViewer.VerticalScrollBarVisibility="Auto"
                                      FrozenColumnCount="2" IsReadOnly="False">
                                <DataGrid.Resources>
                                    <Style TargetType="DataGridColumnHeader">
                                        <Setter Property="Background" Value="#E5E5E5"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                        <Setter Property="Padding" Value="4"/>
                                        <Setter Property="BorderThickness" Value="0,0,1,1"/>
                                        <Setter Property="BorderBrush" Value="#A0A0A0"/>
                                    </Style>
                                </DataGrid.Resources>
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Variant Name" Binding="{Binding VariantDescription}" Width="120" IsReadOnly="True" Foreground="#444" CellStyle="{StaticResource FrozenCell}"/>

                                    <DataGridTemplateColumn Header="Rec'd Qty" Width="70">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBox Text="{Binding ReceivedQty, UpdateSourceTrigger=PropertyChanged}" TextAlignment="Center" FontWeight="Bold" Background="#E0FFFF" BorderThickness="0"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>

                                    <DataGridTextColumn Header="New Barcode" Binding="{Binding Barcode}" Width="100" IsReadOnly="True"/>
                                    <DataGridTextColumn Header="Cost Rs." Binding="{Binding CostPrice, StringFormat=N2}" Width="80" IsReadOnly="True">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="Retail Rs." Binding="{Binding RetailPrice, StringFormat=N2}" Width="80" FontWeight="Bold" Foreground="#005500" CellStyle="{StaticResource RetailCell}" IsReadOnly="True">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="Whsale Rs." Binding="{Binding WholesalePrice, StringFormat=N2}" Width="80" IsReadOnly="True">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="Min Price" Binding="{Binding MinimumPrice, StringFormat=N2}" Width="80" IsReadOnly="True">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                </DataGrid.Columns>
                            </DataGrid>

                            <Grid Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="60"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="60"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Batch No:" Style="{StaticResource InlineLabel}"/>
                                <TextBox Grid.Column="1" Text="{Binding MatrixBatchNo}" Style="{StaticResource ClassicInput}"/>

                                <TextBlock Grid.Column="3" Text="Expiry:" Style="{StaticResource InlineLabel}"/>
                                <DatePicker Grid.Column="4" SelectedDate="{Binding MatrixExpiryDate}" Style="{StaticResource ClassicDate}"/>
                            </Grid>

                            <Button Content="⚡ ADD ACTIVE MATRIX TO GRN" Command="{Binding AddMatrixCommand}" Style="{StaticResource ActionBtn}" Background="#0066CC" BorderBrush="#004C99" Height="30" Margin="0,8,0,0" FontSize="13"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <Grid Grid.Row="3" Margin="0,0,0,5" VerticalAlignment="Bottom">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Content="Clear Form" Command="{Binding ClearCommand}" Style="{StaticResource ClassicBtn}"/>
                <Button Grid.Column="2" Content="Save Draft" Command="{Binding SaveDraftCommand}" Style="{StaticResource ClassicBtn}"/>
            </Grid>
        </Grid>

        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#003366" Padding="10" BorderBrush="#002244" BorderThickness="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="GRN NO:" Foreground="#A0C0E0" FontSize="14" FontWeight="Bold" Margin="0,0,10,0"/>
                        <TextBlock Text="[ AUTO GENERATED ON POST ]" Foreground="White" FontSize="14" FontWeight="SemiBold"/>
                    </StackPanel>
                    <Border Grid.Column="2" Background="#DEFF9A" Padding="15,4">
                        <TextBlock Text="{Binding DocumentStatus}" FontWeight="Bold" Foreground="Black" FontSize="12"/>
                    </Border>
                </Grid>
            </Border>

            <Border Grid.Row="1" Background="#E5E5E5" Padding="5" BorderBrush="#A0A0A0" BorderThickness="1,0,1,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Selected Row Actions:" VerticalAlignment="Center" FontWeight="Bold" Foreground="#666" Margin="0,0,10,0"/>
                    <Button Grid.Column="1" Content="🖨️ Print Labels" Command="{Binding PrintLabelsCommand}" Style="{StaticResource ClassicBtn}" Height="24" Margin="0,0,5,0" ToolTip="Prints barcode labels for the received quantity of the selected row"/>
                    <Button Grid.Column="2" Content="🗑️ Remove" Command="{Binding RemoveLineCommand}" CommandParameter="{Binding SelectedLine}" Style="{StaticResource ClassicBtn}" Foreground="DarkRed" Height="24"/>

                    <TextBlock Grid.Column="4" Text="(Double-click highlighted cells below to quick-edit)" VerticalAlignment="Center" Foreground="#888" FontStyle="Italic" Margin="20,0,0,0"/>
                </Grid>
            </Border>

            <DataGrid Grid.Row="2" x:Name="dgGrnLines" ItemsSource="{Binding GrnLines}" SelectedItem="{Binding SelectedLine}" 
                      AutoGenerateColumns="False" CanUserAddRows="False" GridLinesVisibility="All" 
                      HorizontalGridLinesBrush="#C0C0C0" VerticalGridLinesBrush="#D0D0D0" 
                      RowHeight="26" HeadersVisibility="Column" Background="White" BorderBrush="#A0A0A0" BorderThickness="1" 
                      SelectionMode="Single" AlternatingRowBackground="#F9F9F9"
                      IsReadOnly="False" CellEditEnding="DgGrnLines_CellEditEnding">

                <DataGrid.Resources>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#E0E0E0"/>
                        <Setter Property="Foreground" Value="Black"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="Padding" Value="5"/>
                        <Setter Property="BorderThickness" Value="0,0,1,1"/>
                        <Setter Property="BorderBrush" Value="#A0A0A0"/>
                    </Style>
                    <Style TargetType="DataGridCell" BasedOn="{StaticResource BaseCell}"/>
                </DataGrid.Resources>

                <DataGrid.Columns>
                    <DataGridTextColumn Header="Item Code" Binding="{Binding ItemCode}" Width="75" IsReadOnly="True" Foreground="#666"/>
                    <DataGridTextColumn Header="Variant Attributes" Binding="{Binding VariantDescription}" Width="100" IsReadOnly="True" Foreground="#444"/>
                    <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="*" IsReadOnly="True" FontWeight="SemiBold"/>

                    <DataGridTextColumn Header="Batch" Binding="{Binding BatchNo}" Width="70" CellStyle="{StaticResource EditableCell}"/>
                    <DataGridTextColumn Header="Expiry" Binding="{Binding ExpiryDate, StringFormat=d}" Width="70" CellStyle="{StaticResource EditableCell}"/>
                    <DataGridTextColumn Header="UOM" Binding="{Binding Uom}" Width="45" IsReadOnly="True"/>

                    <DataGridTextColumn Header="Ord" Binding="{Binding OrderedQty}" Width="40" IsReadOnly="True" Foreground="#666"/>

                    <DataGridTextColumn Header="Rec Qty" Binding="{Binding ReceivedQty}" Width="55" CellStyle="{StaticResource EditableCell}" FontWeight="Bold" Foreground="#005555">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="FOC" Binding="{Binding FocQty}" Width="40" CellStyle="{StaticResource EditableCell}"/>

                    <DataGridTextColumn Header="Cost Price" Binding="{Binding UnitCost, StringFormat=N2}" Width="75" CellStyle="{StaticResource EditableCell}">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Right"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="Landed" Binding="{Binding LandedCost, StringFormat=N2}" Width="70" IsReadOnly="True" Foreground="#D97706" CellStyle="{StaticResource WarningCell}">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Right"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="Retail" Binding="{Binding RetailPrice, StringFormat=N2}" Width="70" FontWeight="Bold" Foreground="#005500" CellStyle="{StaticResource EditableCell}">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Right"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="Whsale" Binding="{Binding WholesalePrice, StringFormat=N2}" Width="70" CellStyle="{StaticResource EditableCell}">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Right"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="Min Price" Binding="{Binding MinimumPrice, StringFormat=N2}" Width="70" CellStyle="{StaticResource EditableCell}">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Right"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="Disc" Binding="{Binding LineDiscount}" Width="40" Foreground="DarkRed" CellStyle="{StaticResource EditableCell}">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Right"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="Tax Code" Binding="{Binding TaxCode}" Width="65" IsReadOnly="True"/>

                    <DataGridTextColumn Header="Line Total" Binding="{Binding LineTotal, StringFormat=N2}" Width="90" IsReadOnly="True" FontWeight="Bold">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Right"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                </DataGrid.Columns>
            </DataGrid>

            <Border Grid.Row="3" Background="#D4D0C8" BorderBrush="#A0A0A0" BorderThickness="1" Margin="0,5,0,0" Padding="10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="15"/>
                        <ColumnDefinition Width="220"/>
                        <ColumnDefinition Width="15"/>
                        <ColumnDefinition Width="300"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Remarks / Delivery Notes:" Style="{StaticResource InlineLabel}" Margin="0,0,0,5"/>
                        <TextBox Text="{Binding Remarks}" TextWrapping="Wrap" AcceptsReturn="True" Height="75" Style="{StaticResource ClassicInput}"/>
                    </StackPanel>

                    <Rectangle Grid.Column="1" Width="1" Fill="#A0A0A0" Margin="7,0"/>

                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                        <TextBlock Text="GLOBAL MODIFIERS" FontWeight="Bold" Foreground="#003366" Margin="0,0,0,10"/>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Bill Disc (-)" Style="{StaticResource InlineLabel}" Foreground="DarkRed"/>
                            <TextBox Grid.Column="1" Text="{Binding GlobalBillDiscount, StringFormat=N2, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ClassicInput}" HorizontalContentAlignment="Right" Background="#FEF2F2"/>
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Freight (+)" Style="{StaticResource InlineLabel}" Foreground="#D97706"/>
                            <TextBox Grid.Column="1" Text="{Binding FreightAmount, StringFormat=N2, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ClassicInput}" HorizontalContentAlignment="Right" Background="#FFF7ED"/>
                        </Grid>
                    </StackPanel>

                    <Rectangle Grid.Column="3" Width="1" Fill="#A0A0A0" Margin="7,0"/>

                    <StackPanel Grid.Column="4" VerticalAlignment="Center">
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <CheckBox Grid.Column="0" Content="Tax Inclusive Prices" IsChecked="{Binding IsTaxInclusive}" Foreground="#333" ToolTip="Check this if the Unit Cost you typed already includes VAT"/>
                            <CheckBox Grid.Column="1" Content="Amortize FOC" IsChecked="{Binding AmortizeFoc}" Foreground="#333" ToolTip="Dilutes the Landed Cost across Free of Charge items"/>
                        </Grid>
                        <Rectangle Height="1" Fill="#A0A0A0" Margin="0,0,0,8"/>

                        <Grid Margin="0,0,0,4">
                            <TextBlock Text="SUBTOTAL:" Foreground="#555" FontSize="13" FontWeight="Bold"/>
                            <TextBlock Text="{Binding Subtotal, StringFormat=Rs. \{0:N2\}}" HorizontalAlignment="Right" FontSize="13" FontWeight="Bold"/>
                        </Grid>
                        <Grid Margin="0,0,0,4">
                            <TextBlock Text="DISCOUNTS:" Foreground="DarkRed" FontSize="13" FontWeight="Bold"/>
                            <TextBlock Text="{Binding TotalDiscountAmount, StringFormat=- Rs. \{0:N2\}}" HorizontalAlignment="Right" Foreground="DarkRed" FontSize="13" FontWeight="Bold"/>
                        </Grid>
                        <Grid Margin="0,0,0,8">
                            <TextBlock Text="FREIGHT:" Foreground="#D97706" FontSize="13" FontWeight="Bold"/>
                            <TextBlock Text="{Binding FreightAmount, StringFormat=+ Rs. \{0:N2\}}" HorizontalAlignment="Right" Foreground="#D97706" FontSize="13" FontWeight="Bold"/>
                        </Grid>
                        <Rectangle Height="2" Fill="#333" Margin="0,0,0,8"/>
                        <Grid Margin="0,0,0,10">
                            <TextBlock Text="NET PAYABLE:" Foreground="#003366" FontSize="14" FontWeight="Bold" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding NetPayable, StringFormat=Rs. \{0:N2\}}" Foreground="#005500" FontSize="26" FontWeight="Bold" HorizontalAlignment="Right"/>
                        </Grid>

                        <Button Content="POST GRN &amp; UPDATE STOCK" Command="{Binding PostGrnCommand}" Height="40" Background="#005500" Foreground="White" FontSize="14" FontWeight="Bold" BorderBrush="#003300" BorderThickness="1" Cursor="Hand"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>