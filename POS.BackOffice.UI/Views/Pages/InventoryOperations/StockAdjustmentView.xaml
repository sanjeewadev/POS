<UserControl x:Class="POS.BackOffice.UI.Views.Pages.InventoryOperations.StockAdjustmentView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="850" d:DesignWidth="1400"
             Background="#D4D0C8" FontFamily="Segoe UI" FontSize="12">
    <UserControl.Resources>

        <Style TargetType="TextBlock" x:Key="HeaderLabel">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#003366"/>
            <Setter Property="Margin" Value="0,10,0,5"/>
        </Style>

        <Style TargetType="TextBlock" x:Key="InlineLabel">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,5,0"/>
        </Style>

        <Style TargetType="TextBox" x:Key="ClassicInput">
            <Setter Property="Height" Value="24"/>
            <Setter Property="Padding" Value="4,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="#808080"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
        </Style>

        <Style TargetType="ComboBox" x:Key="ClassicCombo">
            <Setter Property="Height" Value="24"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="#808080"/>
            <Setter Property="Background" Value="White"/>
        </Style>

        <Style TargetType="DatePicker" x:Key="ClassicDate">
            <Setter Property="Height" Value="24"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="#808080"/>
        </Style>

        <Style TargetType="Button" x:Key="ClassicBtn">
            <Setter Property="Height" Value="26"/>
            <Setter Property="Background" Value="#E0E0E0"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderBrush" Value="#808080"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#CCCCCC"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="Button" x:Key="ActionBtn" BasedOn="{StaticResource ClassicBtn}">
            <Setter Property="Background" Value="#005555"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#003333"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#007777"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="Button" x:Key="PostBtn" BasedOn="{StaticResource ClassicBtn}">
            <Setter Property="Background" Value="#D97706"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#B45309"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#B45309"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="Border" x:Key="ClassicGroupBox">
            <Setter Property="BorderBrush" Value="#A0A0A0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="#F0F0F0"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <Style TargetType="DataGridCell" x:Key="BaseCell">
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="4,0"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="Background" Value="Transparent"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#005555"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="DataGridCell" x:Key="FrozenCell" BasedOn="{StaticResource BaseCell}">
            <Setter Property="Background" Value="#F5F5F5"/>
        </Style>
        <Style TargetType="DataGridCell" x:Key="ImpactCell" BasedOn="{StaticResource BaseCell}">
            <Setter Property="Background" Value="#FFF7ED"/>
            <Setter Property="Foreground" Value="#D97706"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="5">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="480"/>
            <ColumnDefinition Width="5"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Style="{StaticResource ClassicGroupBox}">
                <StackPanel>
                    <TextBlock Text="1. ADJUSTMENT DETAILS" Style="{StaticResource HeaderLabel}" Margin="0,0,0,5"/>

                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="65"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Adj Date *" Style="{StaticResource InlineLabel}" Foreground="DarkRed"/>
                        <DatePicker Grid.Column="1" SelectedDate="{Binding AdjustmentDate}" Style="{StaticResource ClassicDate}" Margin="0,0,10,0"/>

                        <TextBlock Grid.Column="2" Text="Auth By *" Style="{StaticResource InlineLabel}"/>
                        <TextBox Grid.Column="3" Text="{Binding AuthorizedBy}" Style="{StaticResource ClassicInput}"/>
                    </Grid>

                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Reference:" Style="{StaticResource InlineLabel}"/>
                        <TextBox Grid.Column="1" Text="{Binding Reference}" Style="{StaticResource ClassicInput}" ToolTip="e.g., Monthly Store Audit, Roof Leak Damage"/>
                    </Grid>

                </StackPanel>
            </Border>

            <Border Grid.Row="1" Style="{StaticResource ClassicGroupBox}" VerticalAlignment="Stretch">
                <StackPanel>
                    <TextBlock Text="2. ITEM AUDIT CONSOLE" Style="{StaticResource HeaderLabel}" Foreground="#005555" Margin="0,0,0,5"/>

                    <Border Background="#334155" Padding="8" BorderBrush="#1E293B" BorderThickness="1" Margin="0,0,0,10">
                        <StackPanel>
                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="65"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Barcode:" Foreground="#DEFF9A" Style="{StaticResource InlineLabel}"/>
                                <TextBox Grid.Column="1" Text="{Binding ScanBarcode}" Height="24" FontSize="12" FontWeight="Bold" ToolTip="Scan direct variant or standard item here"/>
                            </Grid>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="65"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="40"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Code:" Foreground="White" Style="{StaticResource InlineLabel}"/>
                                <ComboBox Grid.Column="1" IsEditable="True" Height="24" Margin="0,0,10,0"/>

                                <TextBlock Grid.Column="2" Text="Name:" Foreground="White" Style="{StaticResource InlineLabel}"/>
                                <ComboBox Grid.Column="3" IsEditable="True" Height="24" ToolTip="Select a standard item OR a Matrix Parent"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="AUDIT PARAMETERS" FontSize="10" FontWeight="Bold" Foreground="#666" Margin="0,0,0,5"/>

                    <Border Background="#F0F8FF" BorderBrush="#005555" BorderThickness="1" Padding="8" Margin="0,0,0,8" Visibility="Visible">
                        <StackPanel>
                            <TextBlock Text="⚡ MATRIX STOCK TAKE" FontWeight="Bold" Foreground="#003366" Margin="0,0,0,5"/>

                            <DataGrid Height="160" ItemsSource="{Binding ActiveMatrixVariants}" AutoGenerateColumns="False" CanUserAddRows="False" 
                                      HeadersVisibility="Column" Background="White" BorderBrush="#A0A0A0" BorderThickness="1" 
                                      RowHeight="26" GridLinesVisibility="All" HorizontalGridLinesBrush="#E0E0E0" VerticalGridLinesBrush="#E0E0E0"
                                      ScrollViewer.HorizontalScrollBarVisibility="Auto" ScrollViewer.VerticalScrollBarVisibility="Auto"
                                      FrozenColumnCount="2">
                                <DataGrid.Resources>
                                    <Style TargetType="DataGridColumnHeader">
                                        <Setter Property="Background" Value="#E5E5E5"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                        <Setter Property="Padding" Value="4"/>
                                        <Setter Property="BorderThickness" Value="0,0,1,1"/>
                                        <Setter Property="BorderBrush" Value="#A0A0A0"/>
                                    </Style>
                                </DataGrid.Resources>
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Variant Attributes" Binding="{Binding VariantDescription}" Width="130" IsReadOnly="True" Foreground="#444" CellStyle="{StaticResource FrozenCell}"/>

                                    <DataGridTextColumn Header="Sys Qty" Binding="{Binding SystemQty}" Width="60" IsReadOnly="True" FontWeight="Bold" Foreground="#666">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>

                                    <DataGridTemplateColumn Header="Actual Qty" Width="80">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBox Text="{Binding ActualQty, UpdateSourceTrigger=PropertyChanged}" TextAlignment="Center" FontWeight="Bold" Background="#E0FFFF" BorderThickness="0"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>

                                    <DataGridTextColumn Header="Variance" Binding="{Binding Variance}" Width="70" IsReadOnly="True" FontWeight="Bold" Foreground="#A94044">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                </DataGrid.Columns>
                            </DataGrid>

                            <Grid Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="90"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Reason Code:" Style="{StaticResource InlineLabel}"/>
                                <ComboBox Grid.Column="1" Style="{StaticResource ClassicCombo}">
                                    <ComboBoxItem Content="Damaged / Broken" IsSelected="True"/>
                                    <ComboBoxItem Content="Expired / Spoiled"/>
                                    <ComboBoxItem Content="Stolen / Missing"/>
                                    <ComboBoxItem Content="Found Stock (+ve)"/>
                                    <ComboBoxItem Content="Data Entry Error"/>
                                </ComboBox>
                            </Grid>

                            <Button Content="⚡ QUEUE MATRIX ADJUSTMENT" Command="{Binding AddMatrixCommand}" Style="{StaticResource ActionBtn}" Background="#0066CC" BorderBrush="#004C99" Height="30" Margin="0,10,0,0" FontSize="13"/>
                        </StackPanel>
                    </Border>

                    <StackPanel Visibility="Collapsed">
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="70"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="70"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="System Qty:" Style="{StaticResource InlineLabel}"/>
                            <TextBox Grid.Column="1" Text="10" Style="{StaticResource ClassicInput}" HorizontalContentAlignment="Center" Background="#EEEEEE" IsReadOnly="True"/>

                            <TextBlock Grid.Column="3" Text="Actual Qty *" Style="{StaticResource InlineLabel}" Foreground="#005555"/>
                            <TextBox Grid.Column="4" Text="8" Style="{StaticResource ClassicInput}" HorizontalContentAlignment="Center" FontWeight="Bold" Background="#E0FFFF"/>
                        </Grid>

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="70"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="70"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Variance:" Style="{StaticResource InlineLabel}" Foreground="#A94044"/>
                            <TextBox Grid.Column="1" Text="-2" Style="{StaticResource ClassicInput}" HorizontalContentAlignment="Center" Background="#F8F8F8" IsReadOnly="True" FontWeight="Bold" Foreground="#A94044"/>

                            <TextBlock Grid.Column="3" Text="Reason:" Style="{StaticResource InlineLabel}"/>
                            <ComboBox Grid.Column="4" Style="{StaticResource ClassicCombo}">
                                <ComboBoxItem Content="Damaged / Broken"/>
                                <ComboBoxItem Content="Stolen / Missing" IsSelected="True"/>
                            </ComboBox>
                        </Grid>

                        <Button Content="QUEUE ADJUSTMENT" Command="{Binding AddItemCommand}" Style="{StaticResource ActionBtn}" Height="34" FontSize="13"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#003366" Padding="10" BorderBrush="#002244" BorderThickness="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="ADJ NO:" Foreground="#A0C0E0" FontSize="14" FontWeight="Bold" Margin="0,0,10,0"/>
                        <TextBlock Text="ADJ-2026-0012" Foreground="White" FontSize="18" FontWeight="Bold"/>
                    </StackPanel>
                    <Border Grid.Column="2" Background="#FFD700" Padding="15,4">
                        <TextBlock Text="DRAFT / PENDING" FontWeight="Bold" Foreground="Black" FontSize="12"/>
                    </Border>
                </Grid>
            </Border>

            <Border Grid.Row="1" Background="#E5E5E5" Padding="5" BorderBrush="#A0A0A0" BorderThickness="1,0,1,0">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Selected Row Actions:" VerticalAlignment="Center" FontWeight="Bold" Foreground="#666" Margin="0,0,10,0"/>
                    <Button Content="🗑️ Remove Row" Command="{Binding RemoveLineCommand}" CommandParameter="{Binding SelectedLine}" Style="{StaticResource ClassicBtn}" Foreground="DarkRed" Height="24"/>
                </StackPanel>
            </Border>

            <DataGrid Grid.Row="2" x:Name="dgAdjustmentLines" ItemsSource="{Binding AdjustmentLines}" SelectedItem="{Binding SelectedLine}" 
                      AutoGenerateColumns="False" CanUserAddRows="False" GridLinesVisibility="All" IsReadOnly="True"
                      HorizontalGridLinesBrush="#C0C0C0" VerticalGridLinesBrush="#D0D0D0" 
                      RowHeight="26" HeadersVisibility="Column" Background="White" BorderBrush="#A0A0A0" BorderThickness="1,0,1,0" 
                      SelectionMode="Single" AlternatingRowBackground="#F9F9F9">

                <DataGrid.Resources>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#E0E0E0"/>
                        <Setter Property="Foreground" Value="Black"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="Padding" Value="5"/>
                        <Setter Property="BorderThickness" Value="0,0,1,1"/>
                        <Setter Property="BorderBrush" Value="#A0A0A0"/>
                    </Style>
                    <Style TargetType="DataGridCell" BasedOn="{StaticResource BaseCell}"/>
                </DataGrid.Resources>

                <DataGrid.Columns>
                    <DataGridTextColumn Header="Item Code" Binding="{Binding ItemCode}" Width="85" Foreground="#666"/>
                    <DataGridTextColumn Header="Variant Attributes" Binding="{Binding VariantDescription}" Width="110" Foreground="#444"/>
                    <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="*" FontWeight="SemiBold"/>
                    <DataGridTextColumn Header="Reason" Binding="{Binding ReasonCode}" Width="120"/>

                    <DataGridTextColumn Header="Sys Qty" Binding="{Binding SystemQty}" Width="60">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="Actual Qty" Binding="{Binding ActualQty}" Width="70" FontWeight="Bold" Foreground="#005500">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="Variance" Binding="{Binding VarianceQty}" Width="70" FontWeight="Bold" Foreground="#A94044">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="Unit Cost" Binding="{Binding UnitCost, StringFormat=N2}" Width="80" Foreground="#666">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Right"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="Cost Impact" Binding="{Binding CostImpact, StringFormat=N2}" Width="100" FontWeight="Bold" CellStyle="{StaticResource ImpactCell}">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Right"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                </DataGrid.Columns>
            </DataGrid>

            <Border Grid.Row="3" Background="#E0FFFF" BorderBrush="#005555" BorderThickness="1,1,1,1" Padding="6">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="✏️ EDIT SELECTED LINE:" FontWeight="Bold" Foreground="#005555" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBlock Grid.Column="1" Text="{Binding SelectedLine.Description}" VerticalAlignment="Center" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>

                    <TextBlock Grid.Column="2" Text="Actual Qty:" VerticalAlignment="Center" Margin="10,0,5,0" FontSize="11"/>
                    <TextBox Grid.Column="3" Text="{Binding SelectedLine.ActualQty}" Width="60" Style="{StaticResource ClassicInput}" FontWeight="Bold" HorizontalContentAlignment="Center"/>

                    <TextBlock Grid.Column="4" Text="Reason:" VerticalAlignment="Center" Margin="10,0,5,0" FontSize="11"/>
                    <ComboBox Grid.Column="5" Width="130" Style="{StaticResource ClassicCombo}">
                        <ComboBoxItem Content="Damaged / Broken"/>
                        <ComboBoxItem Content="Stolen / Missing"/>
                    </ComboBox>

                    <Button Grid.Column="6" Content="UPDATE LINE" Command="{Binding UpdateLineCommand}" Style="{StaticResource ActionBtn}" Height="24" Padding="15,0" Margin="10,0,0,0"/>
                </Grid>
            </Border>

            <Border Grid.Row="4" Background="#D4D0C8" BorderBrush="#A0A0A0" BorderThickness="1" Margin="0,5,0,0" Padding="10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="15"/>
                        <ColumnDefinition Width="380"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Audit Notes / Final Remarks:" Style="{StaticResource InlineLabel}" Margin="0,0,0,5"/>
                        <TextBox Text="{Binding Remarks}" TextWrapping="Wrap" AcceptsReturn="True" Height="75" Style="{StaticResource ClassicInput}"/>
                    </StackPanel>

                    <Rectangle Grid.Column="1" Width="1" Fill="#A0A0A0" Margin="7,0"/>

                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                        <Grid Margin="0,0,0,10">
                            <TextBlock Text="TOTAL NET IMPACT:" Foreground="#003366" FontSize="14" FontWeight="Bold" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding TotalImpact, StringFormat=Rs. \{0:N2\}}" Foreground="#A94044" FontSize="26" FontWeight="Bold" HorizontalAlignment="Right" ToolTip="Negative value indicates a loss hitting the P&amp;L"/>
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="5"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="5"/>
                                <ColumnDefinition Width="1.5*"/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" Content="Clear Form" Style="{StaticResource ClassicBtn}" Height="36"/>
                            <Button Grid.Column="2" Content="Save Draft" Style="{StaticResource ClassicBtn}" Height="36"/>
                            <Button Grid.Column="4" Content="POST ADJUSTMENT" Style="{StaticResource PostBtn}" Height="36" Cursor="Hand" ToolTip="Warning: This instantly updates physical stock levels and posts to P&amp;L"/>
                        </Grid>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>