<UserControl x:Class="POS.BackOffice.UI.Views.Pages.InventoryOperations.StockAdjustmentView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:conv="clr-namespace:POS.BackOffice.UI.Converters"
             mc:Ignorable="d"
             d:DesignHeight="850"
             d:DesignWidth="1400"
             Background="#D4D0C8"
             FontFamily="Segoe UI"
             FontSize="12">

    <UserControl.Resources>

        <conv:InverseBooleanConverter x:Key="InverseBooleanConverter"/>

        <Style TargetType="TextBlock" x:Key="HeaderLabel">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#003366"/>
            <Setter Property="Margin" Value="0,5,0,5"/>
        </Style>

        <Style TargetType="TextBlock" x:Key="InlineLabel">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,5,0"/>
        </Style>

        <Style TargetType="TextBox" x:Key="ClassicInput">
            <Setter Property="Height" Value="26"/>
            <Setter Property="Padding" Value="6,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="#808080"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Style.Triggers>
                <Trigger Property="IsReadOnly" Value="True">
                    <Setter Property="Background" Value="#E5E5E5"/>
                    <Setter Property="Foreground" Value="#555"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#E5E5E5"/>
                    <Setter Property="Foreground" Value="#555"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="ComboBox" x:Key="ClassicCombo">
            <Setter Property="Height" Value="26"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="#808080"/>
            <Setter Property="Background" Value="White"/>
        </Style>

        <Style TargetType="DatePicker" x:Key="ClassicDate">
            <Setter Property="Height" Value="26"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="#808080"/>
        </Style>

        <Style TargetType="Button" x:Key="ClassicBtn">
            <Setter Property="Height" Value="28"/>
            <Setter Property="Background" Value="#E0E0E0"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="15,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderBrush" Value="#808080"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#CCCCCC"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.55"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="Button" x:Key="ActionBtn" BasedOn="{StaticResource ClassicBtn}">
            <Setter Property="Background" Value="#005555"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#003333"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#007777"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="Button" x:Key="PostBtn" BasedOn="{StaticResource ClassicBtn}">
            <Setter Property="Background" Value="#D97706"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#B45309"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F59E0B"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="Border" x:Key="ClassicGroupBox">
            <Setter Property="BorderBrush" Value="#A0A0A0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="#F0F0F0"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#E0E0E0"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="BorderBrush" Value="#A0A0A0"/>
        </Style>

        <Style TargetType="DataGridCell" x:Key="BaseCell">
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="6,0"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="Background" Value="Transparent"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#005555"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridCell" x:Key="FrozenCell" BasedOn="{StaticResource BaseCell}">
            <Setter Property="Background" Value="#F5F5F5"/>
        </Style>

        <Style TargetType="DataGridCell" x:Key="EditableCell" BasedOn="{StaticResource BaseCell}">
            <Setter Property="Background" Value="#E0FFFF"/>
        </Style>

        <Style TargetType="DataGridCell" x:Key="ImpactCell" BasedOn="{StaticResource BaseCell}">
            <Setter Property="Background" Value="#FEF2F2"/>
            <Setter Property="Foreground" Value="#991B1B"/>
        </Style>

    </UserControl.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="500"/>
            <ColumnDefinition Width="10"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- TOP BAND -->
        <Border Grid.Row="0"
                Grid.ColumnSpan="3"
                Style="{StaticResource ClassicGroupBox}">

            <StackPanel>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="1. STOCK ADJUSTMENT INITIATION"
                               Style="{StaticResource HeaderLabel}"/>

                    <TextBlock Grid.Column="1"
                               Text="{Binding StatusMessage}"
                               VerticalAlignment="Center"
                               Foreground="#666"
                               FontSize="11"
                               Margin="15,0"/>

                    <Border Grid.Column="2"
                            Background="#003366"
                            Padding="15,4"
                            CornerRadius="4"
                            VerticalAlignment="Center">

                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="STATUS: "
                                       Foreground="#A0C0E0"
                                       FontWeight="Bold"/>

                            <TextBlock Text="{Binding DocumentStatus}"
                                       Foreground="White"
                                       FontWeight="Bold"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <WrapPanel Orientation="Horizontal"
                           Margin="0,8,0,0"
                           IsEnabled="{Binding IsDocumentLocked, Converter={StaticResource InverseBooleanConverter}}">

                    <StackPanel Margin="0,0,25,5">
                        <TextBlock Text="Adjustment Mode *"
                                   Style="{StaticResource InlineLabel}"
                                   Foreground="#003366"/>

                        <ComboBox ItemsSource="{Binding AdjustmentModes}"
                                  SelectedItem="{Binding AdjustmentMode, Mode=TwoWay}"
                                  Width="190"
                                  Style="{StaticResource ClassicCombo}"
                                  Margin="0,4,0,0"/>
                    </StackPanel>

                    <StackPanel Margin="0,0,25,5">
                        <TextBlock Text="Adjustment Date *"
                                   Style="{StaticResource InlineLabel}"
                                   Foreground="DarkRed"/>

                        <DatePicker SelectedDate="{Binding AdjustmentDate, Mode=TwoWay}"
                                    Style="{StaticResource ClassicDate}"
                                    Width="140"
                                    Margin="0,4,0,0"/>
                    </StackPanel>

                    <StackPanel Margin="0,0,25,5">
                        <TextBlock Text="Authorized By *"
                                   Style="{StaticResource InlineLabel}"/>

                        <TextBox Text="{Binding AuthorizedBy, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource ClassicInput}"
                                 Width="150"
                                 Margin="0,4,0,0"/>
                    </StackPanel>

                    <StackPanel Margin="0,0,25,5">
                        <TextBlock Text="Reference / Reason Document *"
                                   Style="{StaticResource InlineLabel}"/>

                        <TextBox Text="{Binding Reference, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource ClassicInput}"
                                 Width="280"
                                 Margin="0,4,0,0"
                                 ToolTip="Example: Monthly stock audit, damage report, opening balance, manager approval note."/>
                    </StackPanel>
                </WrapPanel>
            </StackPanel>
        </Border>

        <!-- LEFT COLUMN -->
        <Border Grid.Row="1"
                Grid.Column="0"
                Style="{StaticResource ClassicGroupBox}"
                VerticalAlignment="Stretch"
                IsEnabled="{Binding IsDocumentLocked, Converter={StaticResource InverseBooleanConverter}}">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="2. ITEM BATCH AUDIT CONSOLE"
                           Style="{StaticResource HeaderLabel}"
                           Foreground="#005555"
                           Margin="0,0,0,5"/>

                <!-- BARCODE -->
                <Border Grid.Row="1"
                        Background="#334155"
                        Padding="10"
                        BorderBrush="#1E293B"
                        BorderThickness="1"
                        Margin="0,0,0,10"
                        CornerRadius="4">

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="75"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   Text="Barcode:"
                                   Foreground="#DEFF9A"
                                   Style="{StaticResource InlineLabel}"
                                   FontSize="13"/>

                        <TextBox Grid.Column="1"
                                 Text="{Binding ScanBarcode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Height="28"
                                 FontSize="14"
                                 FontWeight="Bold"
                                 ToolTip="Scan barcode, SKU, or item code to load active batches.">
                            <TextBox.InputBindings>
                                <KeyBinding Key="Enter"
                                            Command="{Binding AddItemCommand}"/>
                            </TextBox.InputBindings>
                        </TextBox>
                    </Grid>
                </Border>

                <!-- ACTIVE BATCH COUNT ENTRY -->
                <Border Grid.Row="2"
                        Background="#F0F8FF"
                        BorderBrush="#005555"
                        BorderThickness="1"
                        Padding="8">

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"
                                   Text="LOG PHYSICAL COUNT"
                                   FontWeight="Bold"
                                   Foreground="#003366"
                                   Margin="0,0,0,8"/>

                        <DataGrid Grid.Row="1"
                                  ItemsSource="{Binding ActiveMatrixVariants}"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  HeadersVisibility="Column"
                                  Background="White"
                                  BorderBrush="#A0A0A0"
                                  BorderThickness="1"
                                  RowHeight="30"
                                  GridLinesVisibility="All"
                                  HorizontalGridLinesBrush="#E0E0E0"
                                  VerticalGridLinesBrush="#E0E0E0"
                                  SelectionMode="Single"
                                  IsReadOnly="False">

                            <DataGrid.Resources>
                                <Style TargetType="DataGridCell" BasedOn="{StaticResource BaseCell}"/>
                            </DataGrid.Resources>

                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Batch No"
                                                    Binding="{Binding BatchNo}"
                                                    Width="*"
                                                    IsReadOnly="True"
                                                    Foreground="#003366"
                                                    FontWeight="Bold"
                                                    CellStyle="{StaticResource FrozenCell}"/>

                                <DataGridTextColumn Header="System"
                                                    Binding="{Binding SystemQty, StringFormat=N3}"
                                                    Width="70"
                                                    IsReadOnly="True"
                                                    Foreground="#666"
                                                    FontWeight="Bold">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Center"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <DataGridTemplateColumn Header="Actual" Width="80">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBox Text="{Binding ActualQty, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                     TextAlignment="Center"
                                                     FontWeight="Bold"
                                                     Background="#E0FFFF"
                                                     BorderThickness="0"
                                                     FontSize="14"
                                                     Foreground="#005500"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTextColumn Header="Variance"
                                                    Binding="{Binding Variance, StringFormat=N3}"
                                                    Width="75"
                                                    IsReadOnly="True"
                                                    FontWeight="Bold"
                                                    Foreground="#A94044">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Center"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <DataGridTextColumn Header="Impact"
                                                    Binding="{Binding CostImpact, StringFormat=N2}"
                                                    Width="85"
                                                    IsReadOnly="True"
                                                    Foreground="#991B1B">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Right"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>

                <Button Grid.Row="3"
                        Content="QUEUE VARIANCE"
                        Command="{Binding AddMatrixCommand}"
                        Style="{StaticResource ActionBtn}"
                        Background="#0066CC"
                        BorderBrush="#004C99"
                        Height="38"
                        Margin="0,10,0,0"
                        FontSize="13"/>
            </Grid>
        </Border>

        <!-- RIGHT COLUMN -->
        <Grid Grid.Row="1"
              Grid.Column="2">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Text="3. STOCK ADJUSTMENT QUEUE"
                       Style="{StaticResource HeaderLabel}"
                       Foreground="#D97706"
                       Margin="0,0,0,5"/>

            <Border Grid.Row="1"
                    Background="#E5E5E5"
                    Padding="8"
                    BorderBrush="#A0A0A0"
                    BorderThickness="1,1,1,0">

                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Queue Actions:"
                               VerticalAlignment="Center"
                               FontWeight="Bold"
                               Foreground="#666"
                               Margin="0,0,10,0"/>

                    <Button Content="Remove Selected Row"
                            Command="{Binding RemoveLineCommand}"
                            CommandParameter="{Binding SelectedLine}"
                            Style="{StaticResource ClassicBtn}"
                            Foreground="DarkRed"
                            Height="26"
                            IsEnabled="{Binding IsDocumentLocked, Converter={StaticResource InverseBooleanConverter}}"/>

                    <TextBlock Text="Every posted adjustment line requires a reason code."
                               VerticalAlignment="Center"
                               Foreground="#991B1B"
                               FontWeight="Bold"
                               Margin="20,0,0,0"/>
                </StackPanel>
            </Border>

            <!-- ADJUSTMENT QUEUE -->
            <DataGrid Grid.Row="2"
                      x:Name="dgAdjustmentLines"
                      ItemsSource="{Binding AdjustmentLines}"
                      SelectedItem="{Binding SelectedLine, Mode=TwoWay}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      GridLinesVisibility="All"
                      IsReadOnly="False"
                      HorizontalGridLinesBrush="#C0C0C0"
                      VerticalGridLinesBrush="#D0D0D0"
                      RowHeight="32"
                      HeadersVisibility="Column"
                      Background="White"
                      BorderBrush="#A0A0A0"
                      BorderThickness="1"
                      SelectionMode="Single"
                      AlternatingRowBackground="#F9F9F9"
                      CellEditEnding="DgAdjustmentLines_CellEditEnding">

                <DataGrid.Resources>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#003366"/>
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="Padding" Value="8,5"/>
                        <Setter Property="BorderThickness" Value="0,0,1,1"/>
                    </Style>

                    <Style TargetType="DataGridCell" BasedOn="{StaticResource BaseCell}"/>
                </DataGrid.Resources>

                <DataGrid.Columns>
                    <DataGridTextColumn Header="Item Code"
                                        Binding="{Binding ItemCode}"
                                        Width="85"
                                        IsReadOnly="True"
                                        CellStyle="{StaticResource FrozenCell}"
                                        Foreground="#666"/>

                    <DataGridTextColumn Header="Description"
                                        Binding="{Binding Description}"
                                        Width="*"
                                        IsReadOnly="True"
                                        CellStyle="{StaticResource FrozenCell}"
                                        FontWeight="SemiBold"/>

                    <DataGridTextColumn Header="Variant"
                                        Binding="{Binding VariantDescription}"
                                        Width="120"
                                        IsReadOnly="True"
                                        CellStyle="{StaticResource FrozenCell}"/>

                    <DataGridTextColumn Header="Batch"
                                        Binding="{Binding BatchNo}"
                                        Width="95"
                                        IsReadOnly="True"
                                        CellStyle="{StaticResource FrozenCell}"
                                        FontWeight="Bold"
                                        Foreground="#003366"/>

                    <DataGridTextColumn Header="System"
                                        Binding="{Binding SystemQty, StringFormat=N3}"
                                        Width="75"
                                        IsReadOnly="True"
                                        Foreground="#666">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="Actual"
                                        Binding="{Binding ActualQty, Mode=TwoWay, UpdateSourceTrigger=LostFocus, StringFormat=N3}"
                                        Width="75"
                                        CellStyle="{StaticResource EditableCell}"
                                        FontWeight="Bold"
                                        Foreground="#005500">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="Variance"
                                        Binding="{Binding VarianceQty, StringFormat=N3}"
                                        Width="80"
                                        IsReadOnly="True"
                                        FontWeight="Bold"
                                        Foreground="#A94044">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTemplateColumn Header="Reason Code *" Width="170">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <ComboBox ItemsSource="{Binding DataContext.ReasonCodes, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                          SelectedItem="{Binding ReasonCode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          BorderThickness="0"
                                          Background="#FFF7ED"
                                          FontWeight="Bold"
                                          Foreground="#991B1B"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="Line Remarks" Width="150">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBox Text="{Binding LineRemarks, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                         BorderThickness="0"
                                         Background="White"
                                         Padding="4,0"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTextColumn Header="Unit Cost"
                                        Binding="{Binding UnitCost, StringFormat=N2}"
                                        Width="80"
                                        IsReadOnly="True"
                                        Foreground="#666">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="Cost Impact"
                                        Binding="{Binding CostImpact, StringFormat=N2}"
                                        Width="100"
                                        IsReadOnly="True"
                                        FontWeight="Bold"
                                        CellStyle="{StaticResource ImpactCell}">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                </DataGrid.Columns>
            </DataGrid>

            <!-- FOOTER -->
            <Border Grid.Row="3"
                    Background="#D4D0C8"
                    BorderBrush="#A0A0A0"
                    BorderThickness="1"
                    Margin="0,5,0,0"
                    Padding="10">

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="15"/>
                        <ColumnDefinition Width="390"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Final Audit Notes / Board Remarks:"
                                   Style="{StaticResource InlineLabel}"
                                   Margin="0,0,0,5"/>

                        <TextBox Text="{Binding Remarks, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 Height="78"
                                 Style="{StaticResource ClassicInput}"
                                 IsReadOnly="{Binding IsDocumentLocked}"/>
                    </StackPanel>

                    <Rectangle Grid.Column="1"
                               Width="1"
                               Fill="#A0A0A0"
                               Margin="7,0"/>

                    <StackPanel Grid.Column="2"
                                VerticalAlignment="Center">

                        <Grid Margin="0,0,0,4">
                            <TextBlock Text="TOTAL INCREASE QTY:"
                                       Foreground="#005500"
                                       FontSize="12"
                                       FontWeight="Bold"/>

                            <TextBlock Text="{Binding TotalIncreaseQty, StringFormat=N3}"
                                       HorizontalAlignment="Right"
                                       Foreground="#005500"
                                       FontSize="12"
                                       FontWeight="Bold"/>
                        </Grid>

                        <Grid Margin="0,0,0,4">
                            <TextBlock Text="TOTAL DECREASE QTY:"
                                       Foreground="#991B1B"
                                       FontSize="12"
                                       FontWeight="Bold"/>

                            <TextBlock Text="{Binding TotalDecreaseQty, StringFormat=N3}"
                                       HorizontalAlignment="Right"
                                       Foreground="#991B1B"
                                       FontSize="12"
                                       FontWeight="Bold"/>
                        </Grid>

                        <Rectangle Height="2"
                                   Fill="#333"
                                   Margin="0,4,0,8"/>

                        <Grid Margin="0,0,0,12">
                            <TextBlock Text="NET FINANCIAL IMPACT:"
                                       Foreground="#003366"
                                       FontSize="14"
                                       FontWeight="Bold"
                                       VerticalAlignment="Center"/>

                            <TextBlock Text="{Binding TotalImpact, StringFormat=Rs. \{0:N2\}}"
                                       Foreground="#991B1B"
                                       FontSize="26"
                                       FontWeight="Bold"
                                       HorizontalAlignment="Right"
                                       ToolTip="Negative value indicates stock loss. Positive value indicates found stock gain."/>
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="5"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="5"/>
                                <ColumnDefinition Width="1.5*"/>
                            </Grid.ColumnDefinitions>

                            <Button Grid.Column="0"
                                    Content="Clear Form"
                                    Command="{Binding ClearCommand}"
                                    Style="{StaticResource ClassicBtn}"
                                    Height="38"/>

                            <Button Grid.Column="2"
                                    Content="Save Draft"
                                    Command="{Binding SaveDraftCommand}"
                                    Style="{StaticResource ClassicBtn}"
                                    Height="38"
                                    IsEnabled="{Binding IsDocumentLocked, Converter={StaticResource InverseBooleanConverter}}"/>

                            <Button Grid.Column="4"
                                    Content="POST ADJUSTMENT"
                                    Command="{Binding PostAdjustmentCommand}"
                                    Style="{StaticResource PostBtn}"
                                    Height="38"
                                    Cursor="Hand"
                                    ToolTip="Final posting updates item batch stock and inventory transaction ledger."
                                    IsEnabled="{Binding IsDocumentLocked, Converter={StaticResource InverseBooleanConverter}}"/>
                        </Grid>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>