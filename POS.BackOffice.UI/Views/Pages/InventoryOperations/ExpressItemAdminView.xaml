<UserControl x:Class="POS.BackOffice.UI.Views.Pages.InventoryOperations.ExpressItemAdminView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#D4D0C8" FontFamily="Segoe UI" FontSize="12">

    <UserControl.Resources>
        <Style TargetType="TextBlock" x:Key="HeaderLabel">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#003366"/>
            <Setter Property="Margin" Value="0,5,0,5"/>
        </Style>
        <Style TargetType="TextBlock" x:Key="InlineLabel">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,5,0"/>
        </Style>
        <Style TargetType="TextBox" x:Key="ClassicInput">
            <Setter Property="Height" Value="24"/>
            <Setter Property="Padding" Value="4,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="#808080"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
        </Style>
        <Style TargetType="ComboBox" x:Key="ClassicCombo">
            <Setter Property="Height" Value="24"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="#808080"/>
            <Setter Property="Background" Value="White"/>
        </Style>
        <Style TargetType="Button" x:Key="ClassicBtn">
            <Setter Property="Height" Value="26"/>
            <Setter Property="Background" Value="#E0E0E0"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="15,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderBrush" Value="#808080"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#CCCCCC"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="Button" x:Key="ActionBtn" BasedOn="{StaticResource ClassicBtn}">
            <Setter Property="Background" Value="#005555"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#003333"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#007777"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="Border" x:Key="ClassicGroupBox">
            <Setter Property="BorderBrush" Value="#A0A0A0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="#F0F0F0"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="5">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="500"/>
            <ColumnDefinition Width="5"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#003366" Padding="10" BorderBrush="#002244" BorderThickness="1" Margin="0,0,0,5">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="1. SEARCH INVENTORY" Foreground="White" FontSize="14" FontWeight="Bold" Margin="0,0,15,0" VerticalAlignment="Center"/>
                    <TextBox Grid.Column="1" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ClassicInput}" Height="26" Padding="5,0"/>
                    <Button Grid.Column="2" Content="SEARCH" Command="{Binding SearchCommand}" Style="{StaticResource ClassicBtn}" Height="26" Margin="5,0,0,0"/>
                </Grid>
            </Border>

            <DataGrid Grid.Row="1" ItemsSource="{Binding SearchResults}" SelectedItem="{Binding SelectedVariant}" 
                      AutoGenerateColumns="False" CanUserAddRows="False" GridLinesVisibility="All" 
                      HorizontalGridLinesBrush="#C0C0C0" VerticalGridLinesBrush="#D0D0D0" 
                      RowHeight="26" HeadersVisibility="Column" Background="White" BorderBrush="#A0A0A0" BorderThickness="1" 
                      SelectionMode="Single" AlternatingRowBackground="#F9F9F9" IsReadOnly="True">
                <DataGrid.Resources>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#E0E0E0"/>
                        <Setter Property="Foreground" Value="Black"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="Padding" Value="5"/>
                        <Setter Property="BorderThickness" Value="0,0,1,1"/>
                        <Setter Property="BorderBrush" Value="#A0A0A0"/>
                    </Style>
                </DataGrid.Resources>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="SKU Code" Binding="{Binding SkuCode}" Width="100" FontWeight="Bold"/>
                    <DataGridTextColumn Header="Parent Item" Binding="{Binding ItemParent.ItemName}" Width="150" FontWeight="SemiBold"/>
                    <DataGridTextColumn Header="Variant Attributes" Binding="{Binding VariantDescription}" Width="*"/>
                    <DataGridTextColumn Header="Price" Binding="{Binding RetailPrice, StringFormat=N2}" Width="70">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                <Setter Property="Foreground" Value="#005500"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>

        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#003366" Padding="10" BorderBrush="#002244" BorderThickness="1" Margin="0,0,0,5">
                <TextBlock Text="2. POS BUTTON CONFIGURATION" Foreground="White" FontSize="14" FontWeight="Bold" VerticalAlignment="Center"/>
            </Border>

            <Border Grid.Row="1" Style="{StaticResource ClassicGroupBox}">
                <StackPanel>
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="Tab Category *" Style="{StaticResource InlineLabel}"/>
                        <TextBox Grid.Column="1" Text="{Binding CurrentLayout.TabCategory}" Style="{StaticResource ClassicInput}" Background="#FFFFE0" FontWeight="Bold" ToolTip="e.g., Bakery, Drinks, Produce"/>

                        <TextBlock Grid.Column="3" Text="Button Label *" Style="{StaticResource InlineLabel}" Foreground="DarkRed"/>
                        <TextBox Grid.Column="4" Text="{Binding CurrentLayout.DisplayLabel}" Style="{StaticResource ClassicInput}" Background="#FFFFE0" FontWeight="Bold" ToolTip="Keep it short! Max 20 characters." MaxLength="20"/>
                    </Grid>

                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="Button Color *" Style="{StaticResource InlineLabel}"/>
                        <ComboBox Grid.Column="1" ItemsSource="{Binding AvailableColors}" SelectedItem="{Binding CurrentLayout.ButtonColorHex}" Style="{StaticResource ClassicCombo}">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <Rectangle Width="15" Height="15" Fill="{Binding}" Stroke="Black" StrokeThickness="1" Margin="0,0,5,0"/>
                                        <TextBlock Text="{Binding}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>

                        <TextBlock Grid.Column="3" Text="Active:" Style="{StaticResource InlineLabel}"/>
                        <CheckBox Grid.Column="4" IsChecked="{Binding CurrentLayout.IsActive}" VerticalAlignment="Center" FontWeight="Bold" Foreground="#333"/>
                    </Grid>

                    <Rectangle Height="1" Fill="#C0C0C0" Margin="0,5,0,10"/>

                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="Grid Row (Y) *" Style="{StaticResource InlineLabel}"/>
                        <TextBox Grid.Column="1" Text="{Binding CurrentLayout.GridRow}" Style="{StaticResource ClassicInput}" HorizontalContentAlignment="Center"/>

                        <TextBlock Grid.Column="3" Text="Grid Column (X) *" Style="{StaticResource InlineLabel}"/>
                        <TextBox Grid.Column="4" Text="{Binding CurrentLayout.GridColumn}" Style="{StaticResource ClassicInput}" HorizontalContentAlignment="Center"/>
                    </Grid>

                    <Grid Margin="0,5,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Content="🗑️ REMOVE BUTTON" Command="{Binding DeleteCommand}" Style="{StaticResource ClassicBtn}" Foreground="DarkRed" BorderBrush="DarkRed"/>
                        <Button Grid.Column="2" Content="CLEAR" Command="{Binding ClearCommand}" Style="{StaticResource ClassicBtn}" Margin="0,0,10,0"/>
                        <Button Grid.Column="3" Content="💾 SAVE LAYOUT" Command="{Binding SaveCommand}" Style="{StaticResource ActionBtn}"/>
                    </Grid>
                </StackPanel>
            </Border>

            <DataGrid Grid.Row="2" ItemsSource="{Binding Layouts}" SelectedItem="{Binding SelectedLayout}" 
                      AutoGenerateColumns="False" CanUserAddRows="False" GridLinesVisibility="All" 
                      HorizontalGridLinesBrush="#C0C0C0" VerticalGridLinesBrush="#D0D0D0" 
                      RowHeight="28" HeadersVisibility="Column" Background="White" BorderBrush="#A0A0A0" BorderThickness="1" 
                      SelectionMode="Single" AlternatingRowBackground="#F9F9F9" IsReadOnly="True" Margin="0,5,0,0">
                <DataGrid.Resources>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#E0E0E0"/>
                        <Setter Property="Foreground" Value="Black"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="Padding" Value="5"/>
                        <Setter Property="BorderThickness" Value="0,0,1,1"/>
                        <Setter Property="BorderBrush" Value="#A0A0A0"/>
                    </Style>
                </DataGrid.Resources>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Tab Group" Binding="{Binding TabCategory}" Width="120" FontWeight="Bold"/>
                    <DataGridTextColumn Header="Grid [R, C]" Width="80">
                        <DataGridTextColumn.Binding>
                            <MultiBinding StringFormat="[{0}, {1}]">
                                <Binding Path="GridRow"/>
                                <Binding Path="GridColumn"/>
                            </MultiBinding>
                        </DataGridTextColumn.Binding>
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Button Label" Binding="{Binding DisplayLabel}" Width="150" FontWeight="SemiBold"/>
                    <DataGridTextColumn Header="Mapped SKU" Binding="{Binding ItemVariant.SkuCode}" Width="120"/>

                    <DataGridTemplateColumn Header="Color" Width="60">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Rectangle Fill="{Binding ButtonColorHex}" Margin="4" ToolTip="{Binding ButtonColorHex}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </Grid>
</UserControl>