<UserControl x:Class="POS.BackOffice.UI.Views.Pages.InventoryOperations.PriceManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="850" d:DesignWidth="1400"
             Background="#D4D0C8" FontFamily="Segoe UI" FontSize="12">

    <UserControl.Resources>
        <Style TargetType="TextBlock" x:Key="HeaderLabel">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#003366"/>
            <Setter Property="Margin" Value="0,5,0,5"/>
        </Style>

        <Style TargetType="TextBlock" x:Key="InlineLabel">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,5,0"/>
        </Style>

        <Style TargetType="TextBox" x:Key="ClassicInput">
            <Setter Property="Height" Value="26"/>
            <Setter Property="Padding" Value="6,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="#808080"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
        </Style>

        <Style TargetType="ComboBox" x:Key="ClassicCombo">
            <Setter Property="Height" Value="26"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="#808080"/>
            <Setter Property="Background" Value="White"/>
        </Style>

        <Style TargetType="Button" x:Key="ClassicBtn">
            <Setter Property="Height" Value="28"/>
            <Setter Property="Background" Value="#E0E0E0"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="15,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderBrush" Value="#808080"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#CCCCCC"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="Button" x:Key="ActionBtn" BasedOn="{StaticResource ClassicBtn}">
            <Setter Property="Background" Value="#005555"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#003333"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#007777"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="Border" x:Key="ClassicGroupBox">
            <Setter Property="BorderBrush" Value="#A0A0A0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="#F0F0F0"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <Style TargetType="DataGridCell" x:Key="BaseCell">
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="6,0"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="Background" Value="Transparent"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#005555"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridCell" x:Key="FrozenCell" BasedOn="{StaticResource BaseCell}">
            <Setter Property="Background" Value="#F5F5F5"/>
        </Style>

        <Style TargetType="DataGridCell" x:Key="EditableCell" BasedOn="{StaticResource BaseCell}">
            <Setter Property="Background" Value="#FFFFE0"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="10"/>
            <ColumnDefinition Width="450"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Row="0" Grid.ColumnSpan="3" Style="{StaticResource ClassicGroupBox}">
            <StackPanel>
                <TextBlock Text="1. COMMAND CENTER CONTROLS" Style="{StaticResource HeaderLabel}"/>

                <WrapPanel Orientation="Horizontal" Margin="0,5,0,0">
                    <StackPanel Margin="0,0,25,5">
                        <TextBlock Text="Search Item / Barcode:" Style="{StaticResource InlineLabel}"/>
                        <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" Width="200" Style="{StaticResource ClassicInput}"/>
                    </StackPanel>

                    <StackPanel Margin="0,0,25,5">
                        <TextBlock Text="Margin Health Alert:" Style="{StaticResource InlineLabel}" Foreground="DarkRed"/>
                        <ComboBox ItemsSource="{Binding MarginFilters}" SelectedItem="{Binding SelectedMarginFilter}" Width="200" Style="{StaticResource ClassicCombo}" Background="#FEF2F2"/>
                    </StackPanel>

                    <StackPanel Margin="0,0,25,5">
                        <TextBlock Text="Logistics &amp; Expiry:" Style="{StaticResource InlineLabel}"/>
                        <ComboBox ItemsSource="{Binding ExpiryFilters}" SelectedItem="{Binding SelectedExpiryFilter}" Width="150" Style="{StaticResource ClassicCombo}"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom" Margin="0,0,0,5">
                        <Button Content="🧹 Clear Filters" Command="{Binding ClearFiltersCommand}" Style="{StaticResource ClassicBtn}" Foreground="DarkRed" Margin="0,0,10,0"/>
                    </StackPanel>
                </WrapPanel>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource ClassicGroupBox}" VerticalAlignment="Stretch">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                    <TextBlock Text="2. GLOBAL MASTER PRICING" Style="{StaticResource HeaderLabel}" Foreground="#005555" VerticalAlignment="Center"/>
                    <TextBlock Text="(Double-click yellow cells to update master prices. Margins recalculate instantly.)" FontStyle="Italic" Foreground="#666" Margin="15,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>

                <DataGrid Grid.Row="1" ItemsSource="{Binding PricingItems}" SelectedItem="{Binding SelectedItem}"
                          AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="False"
                          HeadersVisibility="Column" Background="White" BorderBrush="#A0A0A0" BorderThickness="1" 
                          RowHeight="32" GridLinesVisibility="All" HorizontalGridLinesBrush="#E0E0E0" VerticalGridLinesBrush="#E0E0E0"
                          SelectionMode="Single" FrozenColumnCount="2" AlternatingRowBackground="#F9F9F9">

                    <DataGrid.Resources>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#003366"/>
                            <Setter Property="Foreground" Value="White"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="Padding" Value="8,5"/>
                            <Setter Property="BorderThickness" Value="0,0,1,1"/>
                        </Style>
                    </DataGrid.Resources>

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Item Code" Binding="{Binding ItemCode}" Width="90" IsReadOnly="True" CellStyle="{StaticResource FrozenCell}" Foreground="#444" FontWeight="SemiBold"/>
                        <DataGridTextColumn Header="Description &amp; Variant" Binding="{Binding Description}" Width="2*" IsReadOnly="True" CellStyle="{StaticResource FrozenCell}" FontWeight="Bold"/>

                        <DataGridTextColumn Header="Total SOH" Binding="{Binding TotalSoh}" Width="80" IsReadOnly="True">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="Active MAC" Binding="{Binding MovingAverageCost, StringFormat=N2}" Width="90" IsReadOnly="True" Foreground="#005500">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Right"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="Last Landed" Binding="{Binding LastLandedCost, StringFormat=N2}" Width="90" IsReadOnly="True" Foreground="#555">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Right"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="Retail Price" Binding="{Binding RetailPrice, StringFormat=N2, UpdateSourceTrigger=PropertyChanged}" Width="100" CellStyle="{StaticResource EditableCell}" FontWeight="Bold">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Right"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="Wholesale" Binding="{Binding WholesalePrice, StringFormat=N2, UpdateSourceTrigger=PropertyChanged}" Width="90" CellStyle="{StaticResource EditableCell}">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Right"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="Margin %" Binding="{Binding GrossMarginPercentage, StringFormat={}{0:N2}%}" Width="80" IsReadOnly="True">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                    <Setter Property="Foreground" Value="#005500"/>
                                    <Style.Triggers>
                                    </Style.Triggers>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Grid.Column="2">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsBatchPanelVisible}" Value="True">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>

            <Border Background="#E6F2F2" BorderBrush="#005555" BorderThickness="1" Padding="15">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="3. BATCH MARKDOWN OVERRIDES" FontSize="14" FontWeight="Bold" Foreground="#005555" VerticalAlignment="Center"/>
                        <Button Grid.Column="1" Content="✖ Close" Command="{Binding CloseBatchPanelCommand}" Style="{StaticResource ClassicBtn}" Height="24" Background="White"/>
                    </Grid>

                    <Border Grid.Row="1" Background="White" BorderBrush="#A0A0A0" BorderThickness="1" Padding="10" Margin="0,0,0,15">
                        <StackPanel>
                            <TextBlock Text="{Binding SelectedItem.ItemCode}" Foreground="#666" FontWeight="Bold" FontSize="11"/>
                            <TextBlock Text="{Binding SelectedItem.Description}" Foreground="#003366" FontWeight="Bold" FontSize="16" Margin="0,2,0,5" TextWrapping="Wrap"/>
                            <TextBlock Text="{Binding SelectedItem.VariantAttributes}" Foreground="#555" FontSize="12"/>
                        </StackPanel>
                    </Border>

                    <DataGrid Grid.Row="2" ItemsSource="{Binding ActiveBatches}"
                              AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="False"
                              HeadersVisibility="Column" Background="White" BorderBrush="#A0A0A0" BorderThickness="1" 
                              RowHeight="30" GridLinesVisibility="All" HorizontalGridLinesBrush="#E0E0E0" VerticalGridLinesBrush="#E0E0E0"
                              SelectionMode="Single">
                        <DataGrid.Resources>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="#E0E0E0"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="Padding" Value="5"/>
                                <Setter Property="BorderThickness" Value="0,0,1,1"/>
                            </Style>
                        </DataGrid.Resources>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Batch No" Binding="{Binding BatchNo}" Width="*" IsReadOnly="True" CellStyle="{StaticResource FrozenCell}" Foreground="#444"/>

                            <DataGridTextColumn Header="Stock" Binding="{Binding CurrentStock}" Width="60" IsReadOnly="True" FontWeight="Bold">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn Header="Expiry" Binding="{Binding ExpiryDate, StringFormat=MMM yyyy}" Width="75" IsReadOnly="True" Foreground="DarkRed" FontWeight="SemiBold"/>

                            <DataGridTextColumn Header="Override Rs." Binding="{Binding RetailPrice, StringFormat=N2, UpdateSourceTrigger=PropertyChanged}" Width="100" CellStyle="{StaticResource EditableCell}" FontWeight="Bold" Foreground="#D97706">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Right"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <Button Grid.Row="3" Content="💾 SAVE PRICING STRATEGY" Command="{Binding SaveAdjustmentsCommand}" Height="45" Background="#005500" Foreground="White" FontSize="14" FontWeight="Bold" BorderBrush="#003300" BorderThickness="1" Margin="0,15,0,0" Cursor="Hand"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>