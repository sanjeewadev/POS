<UserControl x:Class="POS.BackOffice.UI.Views.Pages.InventoryOperations.BarcodePrinterView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="850" d:DesignWidth="1400"
             Background="#D4D0C8" FontFamily="Segoe UI" FontSize="12">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

        <Style TargetType="TextBlock" x:Key="HeaderLabel">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#003366"/>
            <Setter Property="Margin" Value="0,5,0,10"/>
        </Style>
        <Style TargetType="TextBlock" x:Key="InlineLabel">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#333"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>
        <Style TargetType="TextBox" x:Key="ClassicInput">
            <Setter Property="Height" Value="28"/>
            <Setter Property="Padding" Value="6,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="#808080"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
        </Style>
        <Style TargetType="ComboBox" x:Key="ClassicCombo">
            <Setter Property="Height" Value="28"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="#808080"/>
            <Setter Property="Background" Value="White"/>
        </Style>
        <Style TargetType="Button" x:Key="ClassicBtn">
            <Setter Property="Height" Value="30"/>
            <Setter Property="Background" Value="#E0E0E0"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="15,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderBrush" Value="#808080"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style TargetType="Button" x:Key="ActionBtn" BasedOn="{StaticResource ClassicBtn}">
            <Setter Property="Background" Value="#005555"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#003333"/>
        </Style>
        <Style TargetType="Button" x:Key="PrintBtn" BasedOn="{StaticResource ClassicBtn}">
            <Setter Property="Background" Value="#D97706"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#B45309"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>
        <Style TargetType="Border" x:Key="ClassicGroupBox">
            <Setter Property="BorderBrush" Value="#A0A0A0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="#F0F0F0"/>
            <Setter Property="Padding" Value="10"/>
        </Style>
        <Style TargetType="DataGridCell" x:Key="BaseCell">
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="6,0"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="Background" Value="Transparent"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <!-- Left Side: Queue Intake -->
            <ColumnDefinition Width="*"/>
            <!-- Divider -->
            <ColumnDefinition Width="10"/>
            <!-- Right Side: Config & Dispatch -->
            <ColumnDefinition Width="380"/>
        </Grid.ColumnDefinitions>

        <!-- ======================================================== -->
        <!-- LEFT COLUMN: INTAKE & QUEUE MANAGEMENT                   -->
        <!-- ======================================================== -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ZONE 2 & 3: INTAKE MODES -->
            <Border Grid.Row="0" Style="{StaticResource ClassicGroupBox}" Margin="0,0,0,10">
                <StackPanel>
                    <TextBlock Text="1. PRINT QUEUE INTAKE" Style="{StaticResource HeaderLabel}"/>

                    <TabControl Background="White" BorderBrush="#A0A0A0" BorderThickness="1" Padding="10">
                        <TabControl.Resources>
                            <Style TargetType="TabItem">
                                <Setter Property="Padding" Value="15,6"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="Foreground" Value="#555"/>
                            </Style>
                        </TabControl.Resources>

                        <!-- Mode A: GRN Intake -->
                        <TabItem Header="📦 Link to Received Document (GRN)">
                            <Grid Margin="0,10,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="150"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Select Recent Posted GRN (Last 30 Days):" Style="{StaticResource InlineLabel}"/>
                                    <ComboBox ItemsSource="{Binding RecentGrns}" SelectedItem="{Binding SelectedGrn}" Style="{StaticResource ClassicCombo}" Margin="0,0,10,0">
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{Binding GrnNumber}" FontWeight="Bold" Width="130"/>
                                                    <TextBlock Text=" | " Foreground="#A0A0A0"/>
                                                    <TextBlock Text="{Binding SupplierInvoiceNo}" Foreground="#005500"/>
                                                    <TextBlock Text=" | " Foreground="#A0A0A0"/>
                                                    <TextBlock Text="{Binding ReceivedDate, StringFormat=d}" Foreground="#555"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>
                                    <TextBlock Text="* The system will automatically queue the exact number of labels received." FontSize="11" Foreground="#1E7E34" Margin="0,5,0,0" FontStyle="Italic"/>
                                </StackPanel>
                                <Button Grid.Column="1" Content="LOAD GRN ITEMS" Command="{Binding LoadGrnItemsCommand}" Style="{StaticResource ActionBtn}" VerticalAlignment="Center"/>
                            </Grid>
                        </TabItem>

                        <!-- Mode B: Manual Scan Intake -->
                        <TabItem Header="🔍 Manual Item Scan / Override">
                            <Grid Margin="0,10,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="150"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                    <TextBlock Text="Scan Item Barcode:" Style="{StaticResource InlineLabel}"/>
                                    <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ClassicInput}">
                                        <TextBox.InputBindings>
                                            <KeyBinding Key="Enter" Command="{Binding AddManualItemCommand}" />
                                        </TextBox.InputBindings>
                                    </TextBox>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Margin="0,0,10,0">
                                    <TextBlock Text="Qty to Print:" Style="{StaticResource InlineLabel}"/>
                                    <TextBox Text="{Binding ManualQty, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ClassicInput}" HorizontalContentAlignment="Center" FontWeight="Bold"/>
                                </StackPanel>
                                <Button Grid.Column="2" Content="ADD TO QUEUE" Command="{Binding AddManualItemCommand}" Style="{StaticResource ClassicBtn}" Background="#666" Foreground="White" VerticalAlignment="Center"/>
                            </Grid>
                        </TabItem>
                    </TabControl>
                </StackPanel>
            </Border>

            <!-- ZONE 4: THE PRINT QUEUE -->
            <Border Grid.Row="1" Style="{StaticResource ClassicGroupBox}" Padding="0">
                <DockPanel>
                    <Border DockPanel.Dock="Top" Background="#E5E5E5" BorderBrush="#A0A0A0" BorderThickness="0,0,0,1" Padding="10">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="2. ACTIVE PRINT QUEUE" FontWeight="Bold" Foreground="#003366" VerticalAlignment="Center"/>
                            <TextBlock Text="(You can manually edit the print quantities below)" Foreground="#666" FontStyle="Italic" Margin="10,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <DataGrid ItemsSource="{Binding PrintQueue}" 
                              AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False" 
                              HeadersVisibility="Column" GridLinesVisibility="Horizontal" 
                              HorizontalGridLinesBrush="#E0E0E0" BorderThickness="0" RowHeight="36" Background="White" AlternatingRowBackground="#F9F9F9">
                        <DataGrid.Resources>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="#F0F0F0"/>
                                <Setter Property="Foreground" Value="#333"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="Padding" Value="8"/>
                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                <Setter Property="BorderBrush" Value="#A0A0A0"/>
                            </Style>
                        </DataGrid.Resources>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Item Code" Binding="{Binding ItemCode}" Width="100" IsReadOnly="True" Foreground="#666" CellStyle="{StaticResource BaseCell}"/>
                            <DataGridTextColumn Header="Description &amp; Variant" Binding="{Binding ItemName}" Width="*" IsReadOnly="True" FontWeight="SemiBold" CellStyle="{StaticResource BaseCell}"/>

                            <DataGridTextColumn Header="Retail Price (Rs.)" Binding="{Binding Price, StringFormat=N2}" Width="110" IsReadOnly="True" Foreground="#005500" CellStyle="{StaticResource BaseCell}">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Right"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTemplateColumn Header="Labels to Print *" Width="110">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBox Text="{Binding PrintQuantity, UpdateSourceTrigger=PropertyChanged}" 
                                                 Background="#FFFFE0" BorderBrush="#A0A0A0" BorderThickness="1" 
                                                 HorizontalContentAlignment="Center" VerticalContentAlignment="Center" 
                                                 FontWeight="Bold" Padding="0" Height="26" Margin="4,0"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="Drop" Width="60">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="✖" Command="{Binding DataContext.RemoveQueueItemCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" 
                                                CommandParameter="{Binding}" Background="#A94044" Foreground="White" BorderThickness="0" Cursor="Hand" Width="26" Height="26" FontWeight="Bold"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Border>
        </Grid>

        <!-- ======================================================== -->
        <!-- RIGHT COLUMN: CONFIGURATION & DISPATCH                   -->
        <!-- ======================================================== -->
        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- ZONE 1: PRINTER SETTINGS -->
            <Border Grid.Row="0" Style="{StaticResource ClassicGroupBox}" Margin="0,0,0,10">
                <StackPanel>
                    <TextBlock Text="3. HARDWARE &amp; TEMPLATE SETTINGS" Style="{StaticResource HeaderLabel}" Foreground="#6F42C1"/>

                    <TextBlock Text="Target Windows Printer *" Style="{StaticResource InlineLabel}"/>
                    <ComboBox ItemsSource="{Binding AvailablePrinters}" SelectedItem="{Binding SelectedPrinter}" Style="{StaticResource ClassicCombo}" FontWeight="Bold" Margin="0,0,0,15"/>

                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Label Width (mm):" Style="{StaticResource InlineLabel}"/>
                            <TextBox Text="{Binding PrintConfig.WidthMm, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ClassicInput}" HorizontalContentAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Label Height (mm):" Style="{StaticResource InlineLabel}"/>
                            <TextBox Text="{Binding PrintConfig.HeightMm, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ClassicInput}" HorizontalContentAlignment="Center"/>
                        </StackPanel>
                    </Grid>

                    <Border Background="#F9F5FF" BorderBrush="#E5D6FA" BorderThickness="1" CornerRadius="4" Padding="10">
                        <StackPanel>
                            <TextBlock Text="Label Content Toggles:" FontWeight="SemiBold" Foreground="#6F42C1" Margin="0,0,0,8"/>
                            <CheckBox Content="Print Company/Store Name" IsChecked="{Binding PrintConfig.PrintStoreName, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,5"/>
                            <TextBox Text="{Binding PrintConfig.StoreName, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding PrintConfig.PrintStoreName}" Style="{StaticResource ClassicInput}" Margin="20,0,0,10"/>

                            <CheckBox Content="Print Item Name / Variant" IsChecked="{Binding PrintConfig.PrintItemName, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,5"/>
                            <CheckBox Content="Print Global Retail Price (Rs.)" IsChecked="{Binding PrintConfig.PrintPrice, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,5"/>
                            <CheckBox Content="Print Internal Item Code" IsChecked="{Binding PrintConfig.PrintItemCode, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <!-- LIVE PREVIEW BOX -->
            <Border Grid.Row="1" Style="{StaticResource ClassicGroupBox}" Background="#E2EDF8" BorderBrush="#B6D4FE" Margin="0,0,0,10">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="Live Visual Preview" FontWeight="Bold" Foreground="#2B5B84" HorizontalAlignment="Center" Margin="0,0,0,15"/>

                    <Border Background="White" BorderBrush="#A0A0A0" BorderThickness="1" Width="200" Height="100" HorizontalAlignment="Center" VerticalAlignment="Center" Padding="5">
                        <Border.Effect>
                            <DropShadowEffect Color="Black" Direction="320" ShadowDepth="4" BlurRadius="8" Opacity="0.1"/>
                        </Border.Effect>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Text="{Binding PrintConfig.StoreName}" FontSize="9" FontWeight="Bold" HorizontalAlignment="Center" Visibility="{Binding PrintConfig.PrintStoreName, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                            <TextBlock Grid.Row="1" Text="Sample Retail Item Name" FontSize="8" HorizontalAlignment="Center" Margin="0,2" Visibility="{Binding PrintConfig.PrintItemName, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                            <!-- Fake Barcode Representation for Preview Only -->
                            <StackPanel Grid.Row="2" VerticalAlignment="Center" HorizontalAlignment="Center">
                                <TextBlock Text="||| ||||||| | ||||| || ||| ||||" FontFamily="Consolas" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center"/>
                            </StackPanel>

                            <Grid Grid.Row="3">
                                <TextBlock Text="ITM-00100" FontSize="8" VerticalAlignment="Bottom" HorizontalAlignment="Left" Visibility="{Binding PrintConfig.PrintItemCode, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                <TextBlock Text="Rs. 1,500.00" FontSize="11" FontWeight="Bold" VerticalAlignment="Bottom" HorizontalAlignment="Right" Visibility="{Binding PrintConfig.PrintPrice, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                            </Grid>
                        </Grid>
                    </Border>
                </DockPanel>
            </Border>

            <!-- ACTION FOOTER -->
            <Border Grid.Row="2" Background="White" BorderBrush="#A0A0A0" BorderThickness="1" Padding="15">
                <StackPanel>
                    <Grid Margin="0,0,0,15">
                        <TextBlock Text="Total Labels Queued:" VerticalAlignment="Center" FontWeight="Bold" Foreground="#555" FontSize="14"/>
                        <TextBlock Text="{Binding TotalLabelsToGenerate}" FontWeight="Bold" FontSize="24" Foreground="#1E7E34" HorizontalAlignment="Right"/>
                    </Grid>

                    <Button Content="Clear Spooler Queue" Command="{Binding ClearQueueCommand}" Style="{StaticResource ClassicBtn}" Background="#FEF2F2" Foreground="#991B1B" BorderBrush="#FCA5A5" Margin="0,0,0,10"/>
                    <Button Content="🖨️ DISPATCH TO PRINTER" Command="{Binding PrintSelectedLabelsCommand}" Style="{StaticResource PrintBtn}" Height="50" Cursor="Hand" ToolTip="Sends the job directly to the Windows Spooler silently"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>