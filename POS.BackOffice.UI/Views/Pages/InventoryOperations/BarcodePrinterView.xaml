<UserControl x:Class="POS.BackOffice.UI.Views.Pages.InventoryOperations.BarcodePrinterView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="850"
             d:DesignWidth="1400"
             Background="#D4D0C8"
             FontFamily="Segoe UI"
             FontSize="12">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>

        <Style TargetType="TextBlock" x:Key="HeaderLabel">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#003366"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <Style TargetType="TextBlock" x:Key="InlineLabel">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <Style TargetType="TextBox" x:Key="ClassicInput">
            <Setter Property="Height" Value="28"/>
            <Setter Property="Padding" Value="5,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="#808080"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
        </Style>

        <Style TargetType="ComboBox" x:Key="ClassicCombo">
            <Setter Property="Height" Value="28"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="#808080"/>
            <Setter Property="Background" Value="White"/>
        </Style>

        <Style TargetType="Button" x:Key="ClassicBtn">
            <Setter Property="Height" Value="30"/>
            <Setter Property="Background" Value="#E0E0E0"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderBrush" Value="#808080"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style TargetType="Button" x:Key="ActionBtn" BasedOn="{StaticResource ClassicBtn}">
            <Setter Property="Background" Value="#005555"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#003333"/>
        </Style>

        <Style TargetType="Button" x:Key="PrintBtn" BasedOn="{StaticResource ClassicBtn}">
            <Setter Property="Background" Value="#D97706"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#B45309"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>

        <Style TargetType="Border" x:Key="ClassicGroupBox">
            <Setter Property="BorderBrush" Value="#A0A0A0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="#F0F0F0"/>
            <Setter Property="Padding" Value="10"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#003366"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="6"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="BorderBrush" Value="#A0A0A0"/>
        </Style>

        <Style TargetType="DataGridCell" x:Key="BaseCell">
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="5,0"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="Background" Value="Transparent"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#005555"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="TextBox" x:Key="GridQtyBox">
            <Setter Property="Padding" Value="4,0"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="#808080"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="#FFFFE0"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>

        <Style TargetType="TextBlock" x:Key="RightText">
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style TargetType="TextBlock" x:Key="CenterText">
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="8">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="8"/>
            <ColumnDefinition Width="390"/>
        </Grid.ColumnDefinitions>

        <!-- LEFT SIDE -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="8"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- INTAKE -->
            <Border Grid.Row="0"
                    Style="{StaticResource ClassicGroupBox}">

                <StackPanel>
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   Text="1. PRINT QUEUE INTAKE"
                                   Style="{StaticResource HeaderLabel}"/>

                        <Border Grid.Column="1"
                                Background="#E0FFFF"
                                BorderBrush="#005555"
                                BorderThickness="1"
                                Padding="8,3">

                            <TextBlock Text="{Binding StatusMessage}"
                                       Foreground="#003366"
                                       FontWeight="SemiBold"
                                       TextTrimming="CharacterEllipsis"
                                       Width="420"/>
                        </Border>
                    </Grid>

                    <TabControl Background="White"
                                BorderBrush="#A0A0A0"
                                BorderThickness="1">

                        <TabControl.Resources>
                            <Style TargetType="TabItem">
                                <Setter Property="Padding" Value="14,6"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="Foreground" Value="#555555"/>
                            </Style>
                        </TabControl.Resources>

                        <!-- GRN INTAKE -->
                        <TabItem Header="GRN Received Labels">
                            <Grid Margin="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="130"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Recent Posted GRN:" Style="{StaticResource InlineLabel}"/>

                                    <ComboBox ItemsSource="{Binding RecentGrns}"
                                              SelectedItem="{Binding SelectedGrn, Mode=TwoWay}"
                                              DisplayMemberPath="DisplayText"
                                              Style="{StaticResource ClassicCombo}"/>
                                </StackPanel>

                                <Button Grid.Column="2"
                                        Content="Refresh GRNs"
                                        Command="{Binding LoadRecentGrnsCommand}"
                                        Style="{StaticResource ClassicBtn}"
                                        VerticalAlignment="Bottom"/>

                                <Button Grid.Column="4"
                                        Content="Load GRN Items"
                                        Command="{Binding LoadGrnItemsCommand}"
                                        Style="{StaticResource ActionBtn}"
                                        VerticalAlignment="Bottom"/>
                            </Grid>
                        </TabItem>

                        <!-- MANUAL INTAKE -->
                        <TabItem Header="Manual Item / Barcode">
                            <Grid Margin="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="130"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Scan / Type Barcode, SKU, or Item Code:" Style="{StaticResource InlineLabel}"/>

                                    <TextBox Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource ClassicInput}">
                                        <TextBox.InputBindings>
                                            <KeyBinding Key="Enter" Command="{Binding AddManualItemCommand}"/>
                                        </TextBox.InputBindings>
                                    </TextBox>
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Qty:" Style="{StaticResource InlineLabel}"/>

                                    <TextBox Text="{Binding ManualQty, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource ClassicInput}"
                                             HorizontalContentAlignment="Center"
                                             FontWeight="Bold"/>
                                </StackPanel>

                                <Button Grid.Column="4"
                                        Content="Add To Queue"
                                        Command="{Binding AddManualItemCommand}"
                                        Style="{StaticResource ActionBtn}"
                                        VerticalAlignment="Bottom"/>
                            </Grid>
                        </TabItem>
                    </TabControl>
                </StackPanel>
            </Border>

            <!-- PRINT QUEUE -->
            <Border Grid.Row="2"
                    Style="{StaticResource ClassicGroupBox}"
                    Padding="0">

                <DockPanel>
                    <Border DockPanel.Dock="Top"
                            Background="#E5E5E5"
                            BorderBrush="#A0A0A0"
                            BorderThickness="0,0,0,1"
                            Padding="10">

                        <Grid>
                            <TextBlock Text="2. ACTIVE PRINT QUEUE"
                                       FontWeight="Bold"
                                       Foreground="#003366"
                                       VerticalAlignment="Center"/>

                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Center">

                                <TextBlock Text="Items: "
                                           FontWeight="Bold"
                                           Foreground="#666666"/>

                                <TextBlock Text="{Binding QueueItemCount}"
                                           FontWeight="Bold"
                                           Foreground="#005555"
                                           Margin="0,0,15,0"/>

                                <TextBlock Text="Labels: "
                                           FontWeight="Bold"
                                           Foreground="#666666"/>

                                <TextBlock Text="{Binding TotalLabelsToGenerate}"
                                           FontWeight="Bold"
                                           Foreground="#1E7E34"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <DataGrid ItemsSource="{Binding PrintQueue}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              IsReadOnly="False"
                              HeadersVisibility="Column"
                              GridLinesVisibility="All"
                              HorizontalGridLinesBrush="#E0E0E0"
                              VerticalGridLinesBrush="#E0E0E0"
                              BorderThickness="0"
                              RowHeight="34"
                              Background="White"
                              AlternatingRowBackground="#F9F9F9"
                              ScrollViewer.HorizontalScrollBarVisibility="Auto"
                              ScrollViewer.VerticalScrollBarVisibility="Auto">

                        <DataGrid.Resources>
                            <Style TargetType="DataGridCell" BasedOn="{StaticResource BaseCell}"/>
                        </DataGrid.Resources>

                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Source"
                                                Binding="{Binding SourceDocument}"
                                                Width="95"
                                                IsReadOnly="True"/>

                            <DataGridTextColumn Header="Item Code"
                                                Binding="{Binding ItemCode}"
                                                Width="90"
                                                IsReadOnly="True"/>

                            <DataGridTextColumn Header="SKU"
                                                Binding="{Binding SkuCode}"
                                                Width="115"
                                                IsReadOnly="True"/>

                            <DataGridTextColumn Header="Description"
                                                Binding="{Binding DisplayName}"
                                                Width="260"
                                                IsReadOnly="True"
                                                FontWeight="SemiBold"/>

                            <DataGridTextColumn Header="Barcode"
                                                Binding="{Binding Barcode}"
                                                Width="135"
                                                IsReadOnly="True"
                                                FontWeight="Bold"/>

                            <DataGridTextColumn Header="Price"
                                                Binding="{Binding Price, StringFormat={}{0:N2}}"
                                                Width="85"
                                                IsReadOnly="True"
                                                ElementStyle="{StaticResource RightText}"/>

                            <DataGridTemplateColumn Header="Print Qty"
                                                    Width="90">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBox Text="{Binding PrintQuantity, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{StaticResource GridQtyBox}"
                                                 Margin="3"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="Drop"
                                                    Width="60">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="X"
                                                Command="{Binding DataContext.RemoveQueueItemCommand,
                                                                  RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding}"
                                                Background="#A94044"
                                                Foreground="White"
                                                BorderThickness="0"
                                                Cursor="Hand"
                                                Width="28"
                                                Height="24"
                                                FontWeight="Bold"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Border>
        </Grid>

        <!-- RIGHT SIDE -->
        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="8"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="8"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- SETTINGS -->
            <Border Grid.Row="0"
                    Style="{StaticResource ClassicGroupBox}">

                <StackPanel>
                    <TextBlock Text="3. PRINTER AND LABEL SETTINGS"
                               Style="{StaticResource HeaderLabel}"
                               Foreground="#6F42C1"/>

                    <TextBlock Text="Target Windows Printer:"
                               Style="{StaticResource InlineLabel}"/>

                    <ComboBox ItemsSource="{Binding AvailablePrinters}"
                              SelectedItem="{Binding SelectedPrinter, Mode=TwoWay}"
                              Style="{StaticResource ClassicCombo}"
                              FontWeight="Bold"
                              Margin="0,0,0,10"/>

                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Width mm:" Style="{StaticResource InlineLabel}"/>
                            <TextBox Text="{Binding PrintConfig.WidthMm, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource ClassicInput}"
                                     HorizontalContentAlignment="Center"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Height mm:" Style="{StaticResource InlineLabel}"/>
                            <TextBox Text="{Binding PrintConfig.HeightMm, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource ClassicInput}"
                                     HorizontalContentAlignment="Center"/>
                        </StackPanel>
                    </Grid>

                    <Border Background="#F9F5FF"
                            BorderBrush="#E5D6FA"
                            BorderThickness="1"
                            Padding="10">

                        <StackPanel>
                            <TextBlock Text="Label Content:"
                                       FontWeight="SemiBold"
                                       Foreground="#6F42C1"
                                       Margin="0,0,0,8"/>

                            <CheckBox Content="Print Store Name"
                                      IsChecked="{Binding PrintConfig.PrintStoreName, Mode=TwoWay}"
                                      Margin="0,0,0,5"/>

                            <TextBox Text="{Binding PrintConfig.StoreName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     IsEnabled="{Binding PrintConfig.PrintStoreName}"
                                     Style="{StaticResource ClassicInput}"
                                     Margin="20,0,0,8"/>

                            <CheckBox Content="Print Item Name / Variant"
                                      IsChecked="{Binding PrintConfig.PrintItemName, Mode=TwoWay}"
                                      Margin="0,0,0,5"/>

                            <CheckBox Content="Print Retail Price"
                                      IsChecked="{Binding PrintConfig.PrintPrice, Mode=TwoWay}"
                                      Margin="0,0,0,5"/>

                            <CheckBox Content="Print Item Code"
                                      IsChecked="{Binding PrintConfig.PrintItemCode, Mode=TwoWay}"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <!-- PREVIEW -->
            <Border Grid.Row="2"
                    Style="{StaticResource ClassicGroupBox}"
                    Background="#E2EDF8"
                    BorderBrush="#B6D4FE">

                <DockPanel>
                    <TextBlock DockPanel.Dock="Top"
                               Text="Live Label Preview"
                               FontWeight="Bold"
                               Foreground="#2B5B84"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,12"/>

                    <Border Background="White"
                            BorderBrush="#A0A0A0"
                            BorderThickness="1"
                            Width="230"
                            Height="125"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Padding="6">

                        <Border.Effect>
                            <DropShadowEffect Color="Black"
                                              Direction="320"
                                              ShadowDepth="4"
                                              BlurRadius="8"
                                              Opacity="0.15"/>
                        </Border.Effect>

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0"
                                       Text="{Binding PrintConfig.StoreName}"
                                       FontSize="10"
                                       FontWeight="Bold"
                                       HorizontalAlignment="Center"
                                       Visibility="{Binding PrintConfig.PrintStoreName,
                                                            Converter={StaticResource BooleanToVisibilityConverter}}"/>

                            <TextBlock Grid.Row="1"
                                       Text="Sample Retail Item - Standard"
                                       FontSize="9"
                                       HorizontalAlignment="Center"
                                       Margin="0,3,0,0"
                                       TextTrimming="CharacterEllipsis"
                                       Visibility="{Binding PrintConfig.PrintItemName,
                                                            Converter={StaticResource BooleanToVisibilityConverter}}"/>

                            <StackPanel Grid.Row="2"
                                        VerticalAlignment="Center"
                                        HorizontalAlignment="Center">

                                <TextBlock Text="||| ||||||| | ||||| || ||| ||||"
                                           FontFamily="Consolas"
                                           FontSize="18"
                                           FontWeight="Bold"
                                           HorizontalAlignment="Center"/>

                                <TextBlock Text="2900000000018"
                                           FontSize="9"
                                           HorizontalAlignment="Center"
                                           Margin="0,2,0,0"/>
                            </StackPanel>

                            <Grid Grid.Row="3">
                                <TextBlock Text="ITM-00100"
                                           FontSize="8"
                                           VerticalAlignment="Bottom"
                                           HorizontalAlignment="Left"
                                           Visibility="{Binding PrintConfig.PrintItemCode,
                                                                Converter={StaticResource BooleanToVisibilityConverter}}"/>

                                <TextBlock Text="Rs. 1,500.00"
                                           FontSize="11"
                                           FontWeight="Bold"
                                           VerticalAlignment="Bottom"
                                           HorizontalAlignment="Right"
                                           Visibility="{Binding PrintConfig.PrintPrice,
                                                                Converter={StaticResource BooleanToVisibilityConverter}}"/>
                            </Grid>
                        </Grid>
                    </Border>
                </DockPanel>
            </Border>

            <!-- ACTION FOOTER -->
            <Border Grid.Row="4"
                    Background="White"
                    BorderBrush="#A0A0A0"
                    BorderThickness="1"
                    Padding="12">

                <StackPanel>
                    <Grid Margin="0,0,0,10">
                        <TextBlock Text="Total Labels Queued:"
                                   VerticalAlignment="Center"
                                   FontWeight="Bold"
                                   Foreground="#555555"
                                   FontSize="14"/>

                        <TextBlock Text="{Binding TotalLabelsToGenerate}"
                                   FontWeight="Bold"
                                   FontSize="24"
                                   Foreground="#1E7E34"
                                   HorizontalAlignment="Right"/>
                    </Grid>

                    <Button Content="Clear Print Queue"
                            Command="{Binding ClearQueueCommand}"
                            Style="{StaticResource ClassicBtn}"
                            Background="#FEF2F2"
                            Foreground="#991B1B"
                            BorderBrush="#FCA5A5"
                            Margin="0,0,0,8"/>

                    <Button Content="DISPATCH TO PRINTER"
                            Command="{Binding PrintSelectedLabelsCommand}"
                            Style="{StaticResource PrintBtn}"
                            Height="48"
                            ToolTip="Sends the label job to the selected Windows printer."/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>