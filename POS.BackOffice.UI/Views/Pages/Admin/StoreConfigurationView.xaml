<UserControl x:Class="POS.BackOffice.UI.Views.Pages.Admin.StoreConfigurationView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="950" d:DesignWidth="1250"
             Background="#F5F5F5">

    <UserControl.Resources>
        <Style TargetType="Button" x:Key="StandardBtn">
            <Setter Property="Background" Value="#2B3C38"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#3B524E"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="Button" x:Key="SaveBtn" BasedOn="{StaticResource StandardBtn}">
            <Setter Property="Background" Value="#28A745"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#218838"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="Button" x:Key="OutlineBtn" BasedOn="{StaticResource StandardBtn}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#2B5B84"/>
            <Setter Property="BorderBrush" Value="#2B5B84"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E2EDF8"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="Control" x:Key="StandardInput">
            <Setter Property="Padding" Value="5"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="BorderBrush" Value="#CCCCCC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Height" Value="30"/>
        </Style>

        <Style TargetType="Border" x:Key="GroupBoxBorder">
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Margin" Value="0,0,0,15"/>
        </Style>

        <Style TargetType="Border" x:Key="UploaderBox">
            <Setter Property="BorderBrush" Value="#B6D4FE"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Background" Value="#F8FAFC"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="15"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Store Configuration &amp; Business Identity" FontSize="22" FontWeight="Bold" Foreground="#333333" Margin="0,0,0,20"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="0,0,15,0">
            <StackPanel>

                <Border Style="{StaticResource GroupBoxBorder}">
                    <StackPanel>
                        <TextBlock Text="1. Corporate Identity &amp; Branding" FontSize="16" FontWeight="SemiBold" Foreground="#2B5B84" Margin="0,0,0,15"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="2*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Company Legal Name *" Foreground="#333333" Margin="0,0,0,5"/>
                                <TextBox x:Name="txtLegalName" Style="{StaticResource StandardInput}" Text="Apex Retail Solutions Pvt Ltd"/>

                                <TextBlock Text="Trading Name / Display Name *" Foreground="#333333" Margin="0,0,0,5"/>
                                <TextBox x:Name="txtTradingName" Style="{StaticResource StandardInput}" Text="Apex Supermart" ToolTip="The friendly name printed on customer receipts"/>

                                <TextBlock Text="Business Registration Number (BRN)" Foreground="#666666" Margin="0,0,0,5"/>
                                <TextBox x:Name="txtBRN" Style="{StaticResource StandardInput}" Text="PV-123456"/>

                                <TextBlock Text="Primary Tax / VAT Number" Foreground="#666666" Margin="0,0,0,5"/>
                                <TextBox x:Name="txtTaxNo" Style="{StaticResource StandardInput}" Text="VAT-987654321-V" ToolTip="Required for commercial B2B invoices"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Company Logos (Dual Architecture)" Foreground="#333333" FontWeight="SemiBold" Margin="0,0,0,10"/>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="1*"/>
                                        <ColumnDefinition Width="10"/>
                                        <ColumnDefinition Width="1*"/>
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0" Style="{StaticResource UploaderBox}" ToolTip="Click to upload standard full-color logo">
                                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <TextBlock Text="🖼️" FontSize="24" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                                            <TextBlock Text="System &amp; A4 Logo" FontWeight="SemiBold" Foreground="#2B5B84" HorizontalAlignment="Center"/>
                                            <TextBlock Text="Full Color (PNG/JPG)" FontSize="10" Foreground="#666666" HorizontalAlignment="Center"/>
                                            <TextBlock Text="Ideal: 400x150px" FontSize="10" Foreground="#666666" HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Column="2" Style="{StaticResource UploaderBox}" BorderBrush="#CCCCCC" ToolTip="Click to upload high-contrast logo for thermal paper">
                                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <TextBlock Text="🧾" FontSize="24" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                                            <TextBlock Text="Thermal Receipt Logo" FontWeight="SemiBold" Foreground="#333333" HorizontalAlignment="Center"/>
                                            <TextBlock Text="Monochrome (BMP)" FontSize="10" Foreground="#666666" HorizontalAlignment="Center"/>
                                            <TextBlock Text="Max Width: 380px" FontSize="10" Foreground="#A94044" HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource GroupBoxBorder}">
                    <StackPanel>
                        <TextBlock Text="2. Headquarters &amp; Global Contact Data" FontSize="16" FontWeight="SemiBold" Foreground="#2B5B84" Margin="0,0,0,15"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1*"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="1*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Primary Address Line 1 *" Foreground="#333333" Margin="0,0,0,5"/>
                                <TextBox x:Name="txtAddress1" Style="{StaticResource StandardInput}" Text="No. 45, Main Street"/>

                                <TextBlock Text="City &amp; Postal Code *" Foreground="#333333" Margin="0,0,0,5"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="2*"/>
                                        <ColumnDefinition Width="10"/>
                                        <ColumnDefinition Width="1*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox Grid.Column="0" x:Name="txtCity" Style="{StaticResource StandardInput}" Text="Colombo 04"/>
                                    <TextBox Grid.Column="2" x:Name="txtPostal" Style="{StaticResource StandardInput}" Text="00400"/>
                                </Grid>

                                <TextBlock Text="Country" Foreground="#666666" Margin="0,0,0,5"/>
                                <TextBox x:Name="txtCountry" Style="{StaticResource StandardInput}" Text="Sri Lanka"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="General Telephone (Landline) *" Foreground="#333333" Margin="0,0,0,5"/>
                                <TextBox x:Name="txtPhone" Style="{StaticResource StandardInput}" Text="+94 11 234 5678"/>

                                <TextBlock Text="Mobile / WhatsApp Hotline" Foreground="#666666" Margin="0,0,0,5"/>
                                <TextBox x:Name="txtMobile" Style="{StaticResource StandardInput}" Text="+94 77 123 4567"/>

                                <TextBlock Text="Support Email Address" Foreground="#666666" Margin="0,0,0,5"/>
                                <TextBox x:Name="txtEmail" Style="{StaticResource StandardInput}" Text="support@apexsupermart.com"/>

                                <TextBlock Text="Official Website" Foreground="#666666" Margin="0,0,0,5"/>
                                <TextBox x:Name="txtWebsite" Style="{StaticResource StandardInput}" Text="www.apexsupermart.com"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource GroupBoxBorder}">
                    <StackPanel>
                        <TextBlock Text="3. Document &amp; Receipt Formatting" FontSize="16" FontWeight="SemiBold" Foreground="#28A745" Margin="0,0,0,15"/>

                        <Grid Margin="0,0,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1*"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="1*"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="1*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Invoice Prefix" Foreground="#333333" Margin="0,0,0,5"/>
                                <TextBox x:Name="txtInvPrefix" Style="{StaticResource StandardInput}" Text="INV-" ToolTip="E.g., INV-0001"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Quotation Prefix" Foreground="#333333" Margin="0,0,0,5"/>
                                <TextBox x:Name="txtQuotePrefix" Style="{StaticResource StandardInput}" Text="QTN-"/>
                            </StackPanel>

                            <StackPanel Grid.Column="4">
                                <TextBlock Text="Purchase Order Prefix" Foreground="#333333" Margin="0,0,0,5"/>
                                <TextBox x:Name="txtPoPrefix" Style="{StaticResource StandardInput}" Text="PO-"/>
                            </StackPanel>
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1*"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="1*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="POS Receipt Header Message" Foreground="#666666" Margin="0,0,0,5"/>
                                <TextBox x:Name="txtReceiptHeader" TextWrapping="Wrap" AcceptsReturn="True" Height="60" BorderBrush="#CCCCCC" BorderThickness="1" Padding="5" Margin="0,0,0,15" Text="Welcome to Apex Supermart!&#x0a;Serving you since 1995."/>

                                <TextBlock Text="POS Receipt Footer Message" Foreground="#666666" Margin="0,0,0,5"/>
                                <TextBox x:Name="txtReceiptFooter" TextWrapping="Wrap" AcceptsReturn="True" Height="60" BorderBrush="#CCCCCC" BorderThickness="1" Padding="5" Text="Thank you for shopping with us!&#x0a;Goods once sold cannot be returned without this receipt."/>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="B2B Invoice Terms &amp; Conditions (A4 PDF)" Foreground="#2B5B84" FontWeight="SemiBold" Margin="0,0,0,5"/>
                                <TextBox x:Name="txtInvoiceTerms" TextWrapping="Wrap" AcceptsReturn="True" Height="145" BorderBrush="#CCCCCC" BorderThickness="1" Padding="5" ToolTip="Prints at the bottom of wholesale invoices" Text="1. Payment is due within 30 days from the invoice date.&#x0a;2. All cheques must be drawn in favor of 'Apex Retail Solutions Pvt Ltd'.&#x0a;3. Late payments will incur a 2% monthly interest charge.&#x0a;4. Direct bank transfers to: BOC A/C 12345678, Colombo Fort Branch."/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource GroupBoxBorder}" Margin="0">
                    <StackPanel>
                        <TextBlock Text="4. System Localization" FontSize="16" FontWeight="SemiBold" Foreground="#D97706" Margin="0,0,0,15"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1*"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="1*"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="1*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="System Time Zone *" Foreground="#333333" Margin="0,0,0,5"/>
                                <ComboBox x:Name="cmbTimeZone" Style="{StaticResource StandardInput}">
                                    <ComboBoxItem Content="(UTC+05:30) Sri Jayawardenepura" IsSelected="True"/>
                                    <ComboBoxItem Content="(UTC+00:00) London / GMT"/>
                                    <ComboBoxItem Content="(UTC-05:00) Eastern Time (US)"/>
                                </ComboBox>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Date Format Preference" Foreground="#333333" Margin="0,0,0,5"/>
                                <ComboBox x:Name="cmbDateFormat" Style="{StaticResource StandardInput}">
                                    <ComboBoxItem Content="DD/MM/YYYY (UK/Asia Default)" IsSelected="True"/>
                                    <ComboBoxItem Content="MM/DD/YYYY (US Default)"/>
                                    <ComboBoxItem Content="YYYY-MM-DD (ISO Standard)"/>
                                </ComboBox>
                            </StackPanel>

                            <StackPanel Grid.Column="4">
                                <TextBlock Text="Financial Year Start Month *" Foreground="#A94044" FontWeight="SemiBold" Margin="0,0,0,5"/>
                                <ComboBox x:Name="cmbFinYear" Style="{StaticResource StandardInput}" Background="#FDF3F3" ToolTip="Crucial for calculating Annual P&amp;L Reports">
                                    <ComboBoxItem Content="January (Jan-Dec)"/>
                                    <ComboBoxItem Content="April (Apr-Mar)" IsSelected="True"/>
                                    <ComboBoxItem Content="July (Jul-Jun)"/>
                                </ComboBox>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="2" Background="White" BorderBrush="#DDDDDD" BorderThickness="0,1,0,0" Padding="20" Margin="-20,15,-20,-20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="Changes to Company Identity will instantly reflect on all newly generated documents." Foreground="#333333" FontWeight="SemiBold"/>
                    <TextBlock Text="Historically generated PDF documents and closed audit logs will not be altered." Foreground="#666666" FontSize="11" Margin="0,2,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="Discard Changes" Style="{StaticResource OutlineBtn}" Background="White" Width="140"/>
                    <Button Content="SAVE CONFIGURATION" Style="{StaticResource SaveBtn}" Width="200" Margin="0"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>