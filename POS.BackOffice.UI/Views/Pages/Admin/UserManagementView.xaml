<UserControl x:Class="POS.BackOffice.UI.Views.Pages.Admin.UserManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="850" d:DesignWidth="1250"
             Background="#F5F5F5">

    <UserControl.Resources>
        <!-- Standard Button Style -->
        <Style TargetType="Button" x:Key="StandardBtn">
            <Setter Property="Background" Value="#2B3C38"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#3B524E"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Save/Update Button (Green) -->
        <Style TargetType="Button" x:Key="SaveBtn" BasedOn="{StaticResource StandardBtn}">
            <Setter Property="Background" Value="#28A745"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#218838"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Generate Key Action Button (Blue) -->
        <Style TargetType="Button" x:Key="ActionBtn" BasedOn="{StaticResource StandardBtn}">
            <Setter Property="Background" Value="#2B5B84"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1C3F5E"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Standard Input Style -->
        <Style TargetType="Control" x:Key="StandardInput">
            <Setter Property="Padding" Value="5"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="BorderBrush" Value="#CCCCCC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Height" Value="30"/>
        </Style>

        <!-- Group Box Border Style -->
        <Style TargetType="Border" x:Key="GroupBoxBorder">
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="15"/>
            <Setter Property="Background" Value="White"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="20">
        <!-- Main Layout: Master (Left) and Detail Form (Right) -->
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.2*"/>
            <!-- Staff Directory -->
            <ColumnDefinition Width="20"/>
            <!-- Spacer -->
            <ColumnDefinition Width="1.5*"/>
            <!-- User Profile Form -->
        </Grid.ColumnDefinitions>

        <!-- ========================================== -->
        <!-- ZONE 1: STAFF DIRECTORY (LEFT PANEL)       -->
        <!-- ========================================== -->
        <Border Grid.Column="0" Style="{StaticResource GroupBoxBorder}" Padding="0">
            <DockPanel>
                <!-- Directory Header & Filters -->
                <Border DockPanel.Dock="Top" Background="#F8F8F8" BorderBrush="#DDDDDD" BorderThickness="0,0,0,1" Padding="15">
                    <StackPanel>
                        <TextBlock Text="Staff Directory" FontSize="18" FontWeight="SemiBold" Foreground="#333333" Margin="0,0,0,15"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Search Users" Foreground="#666666" Margin="0,0,0,5"/>
                                <TextBox x:Name="txtSearch" Style="{StaticResource StandardInput}" ToolTip="Search by Name or Emp ID" Margin="0"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Filter by Role" Foreground="#666666" Margin="0,0,0,5"/>
                                <ComboBox x:Name="cmbFilterRole" Style="{StaticResource StandardInput}" Margin="0">
                                    <ComboBoxItem Content="All Roles" IsSelected="True"/>
                                    <ComboBoxItem Content="Store Manager"/>
                                    <ComboBoxItem Content="Cashier"/>
                                    <ComboBoxItem Content="Accountant"/>
                                </ComboBox>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Directory Grid -->
                <DataGrid x:Name="dgUsers" 
                          AutoGenerateColumns="False" 
                          CanUserAddRows="False" 
                          CanUserDeleteRows="False" 
                          IsReadOnly="True"
                          HeadersVisibility="Column" 
                          GridLinesVisibility="Horizontal"
                          HorizontalGridLinesBrush="#EEEEEE"
                          BorderThickness="0"
                          RowHeight="40"
                          Background="Transparent"
                          SelectionMode="Single">

                    <DataGrid.Resources>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#FFFFFF"/>
                            <Setter Property="Foreground" Value="#666666"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="Padding" Value="10"/>
                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                            <Setter Property="BorderBrush" Value="#DDDDDD"/>
                        </Style>
                        <Style TargetType="DataGridCell">
                            <Setter Property="Padding" Value="10,0"/>
                            <Setter Property="VerticalContentAlignment" Value="Center"/>
                        </Style>
                    </DataGrid.Resources>

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Employee Name" Binding="{Binding FullName}" Width="*" FontWeight="SemiBold"/>
                        <DataGridTextColumn Header="Role" Binding="{Binding RoleName}" Width="120" Foreground="#2B5B84"/>

                        <!-- Status Indicator Column -->
                        <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="90">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <!-- Converters would handle making 'Suspended' red, 'Active' green in C# -->
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </DockPanel>
        </Border>

        <!-- ========================================== -->
        <!-- ZONES 2-5: USER MANAGEMENT FORM (RIGHT)    -->
        <!-- ========================================== -->
        <Border Grid.Column="2" Style="{StaticResource GroupBoxBorder}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <!-- Header -->
                    <RowDefinition Height="*"/>
                    <!-- Scrollable Form Area -->
                    <RowDefinition Height="Auto"/>
                    <!-- Footer Actions -->
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Identity &amp; Access Control Form" FontSize="18" FontWeight="SemiBold" Foreground="#333333" Margin="0,0,0,20"/>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="0,0,10,0">
                    <StackPanel>

                        <!-- ZONE 2: Identity & Contact -->
                        <Border Background="#F8F8F8" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="4" Padding="15" Margin="0,0,0,15">
                            <StackPanel>
                                <TextBlock Text="1. Human Resources Data" FontWeight="SemiBold" Foreground="#2B5B84" Margin="0,0,0,10"/>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="10"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="10"/>
                                        <ColumnDefinition Width="120"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="First Name *" Foreground="#333333" Margin="0,0,0,5"/>
                                        <TextBox x:Name="txtFirstName" Style="{StaticResource StandardInput}"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Last Name *" Foreground="#333333" Margin="0,0,0,5"/>
                                        <TextBox x:Name="txtLastName" Style="{StaticResource StandardInput}"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="4">
                                        <TextBlock Text="Employee ID" Foreground="#666666" Margin="0,0,0,5"/>
                                        <TextBox x:Name="txtEmpId" Style="{StaticResource StandardInput}" Background="#EEEEEE"/>
                                    </StackPanel>
                                </Grid>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="10"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Email Address (For Alerts/Recovery) *" Foreground="#333333" Margin="0,0,0,5"/>
                                        <TextBox x:Name="txtEmail" Style="{StaticResource StandardInput}"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Mobile Number" Foreground="#666666" Margin="0,0,0,5"/>
                                        <TextBox x:Name="txtMobile" Style="{StaticResource StandardInput}"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- ZONE 3: Authentication & Security -->
                        <Border Background="#FFF8EB" BorderBrush="#FDE0A6" BorderThickness="1" CornerRadius="4" Padding="15" Margin="0,0,0,15">
                            <StackPanel>
                                <TextBlock Text="2. System Authentication Keys" FontWeight="SemiBold" Foreground="#D97706" Margin="0,0,0,10"/>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="10"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="10"/>
                                        <ColumnDefinition Width="140"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="System Username *" Foreground="#333333" Margin="0,0,0,5"/>
                                        <TextBox x:Name="txtUsername" Style="{StaticResource StandardInput}"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Login Password" Foreground="#333333" Margin="0,0,0,5"/>
                                        <PasswordBox x:Name="pwdLogin" Style="{StaticResource StandardInput}" ToolTip="Leave blank to keep existing password"/>
                                    </StackPanel>

                                    <Button Grid.Column="4" Content="Auto-Generate" Style="{StaticResource ActionBtn}" Margin="0,0,0,10" VerticalAlignment="Bottom" Height="30" ToolTip="Generates a secure password and emails it to the user"/>
                                </Grid>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="20"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- ENTERPRISE FEATURE: POS PIN -->
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Retail POS PIN *" Foreground="#A94044" FontWeight="SemiBold" Margin="0,0,0,5"/>
                                        <PasswordBox x:Name="pwdPosPin" Style="{StaticResource StandardInput}" Width="120" HorizontalContentAlignment="Center" Background="#FDF3F3" MaxLength="6" ToolTip="4 or 6-digit PIN used for rapid till unlocking at the front counter"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="0,10,0,0">
                                        <CheckBox x:Name="chkForcePasswordReset" Content="Force password reset on next login" FontWeight="SemiBold" Foreground="#666666" Margin="0,0,0,5"/>
                                        <TextBlock Text="User will be required to choose a new password immediately upon their next successful login." Foreground="#888888" FontSize="11" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- ZONE 4 & 5: Authorization & Lifecycle -->
                        <Border Background="#F4FAF6" BorderBrush="#C3E6CB" BorderThickness="1" CornerRadius="4" Padding="15">
                            <StackPanel>
                                <TextBlock Text="3. Authorization &amp; Lifecycle" FontWeight="SemiBold" Foreground="#28A745" Margin="0,0,0,10"/>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="10"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="10"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Security Role *" Foreground="#333333" Margin="0,0,0,5"/>
                                        <ComboBox x:Name="cmbAssignRole" Style="{StaticResource StandardInput}">
                                            <ComboBoxItem Content="Super Admin"/>
                                            <ComboBoxItem Content="Store Manager"/>
                                            <ComboBoxItem Content="Junior Cashier" IsSelected="True"/>
                                            <ComboBoxItem Content="Accountant"/>
                                        </ComboBox>
                                    </StackPanel>

                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Branch Assignment *" Foreground="#333333" Margin="0,0,0,5"/>
                                        <ComboBox x:Name="cmbAssignBranch" Style="{StaticResource StandardInput}">
                                            <ComboBoxItem Content="All Branches (Global)"/>
                                            <ComboBoxItem Content="Main Store" IsSelected="True"/>
                                            <ComboBoxItem Content="Warehouse"/>
                                        </ComboBox>
                                    </StackPanel>

                                    <!-- CRITICAL ARCHITECTURE: No Delete Button, Only Status Suspension -->
                                    <StackPanel Grid.Column="4">
                                        <TextBlock Text="Account Status *" Foreground="#A94044" FontWeight="SemiBold" Margin="0,0,0,5"/>
                                        <ComboBox x:Name="cmbAccountStatus" Style="{StaticResource StandardInput}" Background="#FFFFE0" ToolTip="Select 'Suspended' to revoke access while preserving their historical audit data">
                                            <ComboBoxItem Content="ACTIVE (Can Login)" IsSelected="True"/>
                                            <ComboBoxItem Content="SUSPENDED (Revoked)"/>
                                        </ComboBox>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <!-- Footer Actions -->
                <Border Grid.Row="2" BorderBrush="#DDDDDD" BorderThickness="0,1,0,0" Padding="0,15,0,0" Margin="0,10,0,0">
                    <Grid>
                        <TextBlock Text="Changes apply immediately." Foreground="#666666" VerticalAlignment="Center" FontStyle="Italic"/>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button x:Name="btnClear" Content="Clear Form" Style="{StaticResource StandardBtn}" Background="#777777" Width="100"/>
                            <Button x:Name="btnSaveUser" Content="SAVE / UPDATE USER" Style="{StaticResource SaveBtn}" Width="200" Margin="0"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>