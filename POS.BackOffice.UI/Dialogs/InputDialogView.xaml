<Window x:Class="POS.BackOffice.UI.Dialogs.InputDialogView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Input Required" Height="180" Width="350"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        Background="#F3F4F6" FontFamily="Segoe UI" FontSize="13">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="lblPrompt" Text="Please enter value:" FontWeight="SemiBold" Foreground="#333333" Margin="0,0,0,10"/>

        <TextBox x:Name="txtInput" Grid.Row="1" Height="28" Padding="5,0" VerticalContentAlignment="Center" BorderBrush="#A0A0A0"/>

        <TextBlock x:Name="lblError" Grid.Row="2" Text="* Value cannot be empty." Foreground="#DC2626" FontSize="11" Visibility="Hidden" Margin="0,5,0,0"/>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="Cancel" Width="80" Height="28" Margin="0,0,10,0" Background="#E0E0E0" Click="BtnCancel_Click" IsCancel="True"/>
            <Button Content="Save" Width="80" Height="28" Background="#005555" Foreground="White" FontWeight="Bold" Click="BtnSave_Click" IsDefault="True"/>
        </StackPanel>
    </Grid>
</Window>