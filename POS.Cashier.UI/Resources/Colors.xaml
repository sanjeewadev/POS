<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Background Brushes -->
    <SolidColorBrush x:Key="MainBgBrush" Color="#F3F4F6" />
    <SolidColorBrush x:Key="HeaderBgBrush" Color="#1E293B" />
    <SolidColorBrush x:Key="InfoPanelBgBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="TotalsPanelBgBrush" Color="#0F172A" />
    <SolidColorBrush x:Key="LoyaltyBgBrush" Color="#1E293B" />
    <SolidColorBrush x:Key="PopupBgBrush" Color="#F8FAFC" />
    <SolidColorBrush x:Key="DisabledBgBrush" Color="#E2E8F0" />

    <!-- Button Brushes -->
    <SolidColorBrush x:Key="SystemBtnBrush" Color="#94A3B8" />
    <SolidColorBrush x:Key="ActionBtnBrush" Color="#3B82F6" />
    <SolidColorBrush x:Key="NumpadBtnBrush" Color="#334155" />
    <SolidColorBrush x:Key="CancelBtnBrush" Color="#EF4444" />
    <SolidColorBrush x:Key="CashBtnBrush" Color="#10B981" />
    <SolidColorBrush x:Key="ExpressBtnBrush" Color="#059669" />
    <SolidColorBrush x:Key="SubTotalBtnBrush" Color="#F59E0B" />
    <SolidColorBrush x:Key="PluBtnBrush" Color="#6366F1" />

    <!-- Payment Brushes -->
    <SolidColorBrush x:Key="PaymentOrangeBrush" Color="#F59E0B" />
    <SolidColorBrush x:Key="PaymentDarkOrangeBrush" Color="#D97706" />

    <!-- Border Brushes -->
    <SolidColorBrush x:Key="ControlBorderBrush" Color="#CBD5E1" />

    <!-- Text Brushes -->
    <SolidColorBrush x:Key="TextLightBrush" Color="#F8FAFC" />
    <SolidColorBrush x:Key="TextDarkBrush" Color="#334155" />
    <SolidColorBrush x:Key="TextBlackBrush" Color="#0F172A" />
    <SolidColorBrush x:Key="TextDangerBrush" Color="#DC2626" />
    <SolidColorBrush x:Key="TextHighlightBrush" Color="#2563EB" />
    <SolidColorBrush x:Key="TextBalanceBrush" Color="#DC2626" />
    <SolidColorBrush x:Key="TextInactiveBrush" Color="#94A3B8" />

</ResourceDictionary>