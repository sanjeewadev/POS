<Window x:Class="POS.Cashier.UI.Dialogs.DiscountDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Apply Discount" Height="500" Width="600"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="{StaticResource MainBgBrush}"
        BorderBrush="{StaticResource HeaderBgBrush}"
        BorderThickness="3"
        FontFamily="Arial">

    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource TextLightBrush}"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="5" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="45"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="70"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource HeaderBgBrush}">
            <TextBlock Text="APPLY GLOBAL DISCOUNT" Foreground="{StaticResource TextLightBrush}" FontSize="20" FontWeight="Heavy" HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Border>

        <Grid Grid.Row="1" Margin="15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="250"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Margin="0,0,20,0">
                <UniformGrid Columns="2" Height="60" Margin="0,0,0,20">
                    <RadioButton Content="PERCENTAGE (%)" IsChecked="{Binding IsPercentage}" Style="{StaticResource {x:Type ToggleButton}}" FontSize="14" FontWeight="Bold" Margin="0,0,5,0"/>
                    <RadioButton Content="AMOUNT (Rs.)" Style="{StaticResource {x:Type ToggleButton}}" FontSize="14" FontWeight="Bold" Margin="5,0,0,0"/>
                </UniformGrid>

                <TextBlock Text="Discount Value:" FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextDarkBrush}"/>
                <TextBox x:Name="txtDiscountValue" Text="{Binding DiscountValue}" FontSize="42" FontWeight="Heavy" TextAlignment="Right" Foreground="{StaticResource TextDangerBrush}" Margin="0,5,0,20" Background="White" Padding="10"/>

                <TextBlock Text="Authorized PIN (Manager):" FontSize="14" FontWeight="Bold" Foreground="{StaticResource TextDarkBrush}"/>
                <PasswordBox x:Name="txtPin" FontSize="24" Background="White" Margin="0,5,0,0" Padding="10"/>
            </StackPanel>

            <UniformGrid Grid.Column="1" Columns="3" Rows="4">
                <Button Background="{StaticResource NumpadBtnBrush}" Content="7" FontSize="26"/>
                <Button Background="{StaticResource NumpadBtnBrush}" Content="8" FontSize="26"/>
                <Button Background="{StaticResource NumpadBtnBrush}" Content="9" FontSize="26"/>
                <Button Background="{StaticResource NumpadBtnBrush}" Content="4" FontSize="26"/>
                <Button Background="{StaticResource NumpadBtnBrush}" Content="5" FontSize="26"/>
                <Button Background="{StaticResource NumpadBtnBrush}" Content="6" FontSize="26"/>
                <Button Background="{StaticResource NumpadBtnBrush}" Content="1" FontSize="26"/>
                <Button Background="{StaticResource NumpadBtnBrush}" Content="2" FontSize="26"/>
                <Button Background="{StaticResource NumpadBtnBrush}" Content="3" FontSize="26"/>
                <Button Background="{StaticResource NumpadBtnBrush}" Content="C" FontSize="22"/>
                <Button Background="{StaticResource NumpadBtnBrush}" Content="0" FontSize="26"/>
                <Button Background="{StaticResource NumpadBtnBrush}" Content="." FontSize="26"/>
            </UniformGrid>
        </Grid>

        <Grid Grid.Row="2" Background="{StaticResource HeaderBgBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Button Click="CancelBtn_Click" Grid.Column="0" Background="{StaticResource CancelBtnBrush}" Content="CANCEL" FontSize="20" Margin="10,10,5,10"/>
            <Button Click="ConfirmBtn_Click" Grid.Column="1" Background="{StaticResource ExpressBtnBrush}" Content="APPLY DISCOUNT" FontSize="20" Margin="5,10,10,10"/>
        </Grid>
    </Grid>
</Window>