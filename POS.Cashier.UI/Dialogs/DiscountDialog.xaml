<Window x:Class="POS.Cashier.UI.Dialogs.DiscountDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Apply Discount" Height="450" Width="450"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="{StaticResource MainBgBrush}"
        BorderBrush="{StaticResource HeaderBgBrush}"
        BorderThickness="3"
        FontFamily="Arial">

    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource TextLightBrush}"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="5" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DiscountModeToggleStyle" TargetType="RadioButton" BasedOn="{StaticResource {x:Type ToggleButton}}">
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{StaticResource TextDarkBrush}"/>
            <Setter Property="Background" Value="#E0E0E0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="ButtonBorder" Background="{TemplateBinding Background}" CornerRadius="4" BorderBrush="#B0B0B0" BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{StaticResource HeaderBgBrush}"/>
                                <Setter Property="Foreground" Value="{StaticResource TextLightBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="45"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="70"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource HeaderBgBrush}">
            <TextBlock Text="APPLY GLOBAL DISCOUNT" Foreground="{StaticResource TextLightBrush}" FontSize="20" FontWeight="Heavy" HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Border>

        <Grid Grid.Row="1" Margin="25,20,25,20">
            <StackPanel VerticalAlignment="Center">

                <UniformGrid Columns="2" Height="50" Margin="0,0,0,25">
                    <RadioButton x:Name="radPercentage" Content="PERCENTAGE (%)" GroupName="DiscountType" IsChecked="True" Style="{StaticResource DiscountModeToggleStyle}" Margin="0,0,8,0"/>
                    <RadioButton x:Name="radAmount" Content="AMOUNT (Rs.)" GroupName="DiscountType" Style="{StaticResource DiscountModeToggleStyle}" Margin="8,0,0,0"/>
                </UniformGrid>

                <TextBlock Text="Discount Value:" FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextDarkBrush}"/>
                <TextBox x:Name="txtDiscountValue" FontSize="36" FontWeight="Heavy" TextAlignment="Right" Foreground="{StaticResource TextDangerBrush}" Margin="0,6,0,20" Background="White" Padding="8,6"/>

                <TextBlock Text="Authorized PIN (Manager):" FontSize="14" FontWeight="Bold" Foreground="{StaticResource TextDarkBrush}"/>
                <PasswordBox x:Name="txtPin" FontSize="24" Background="White" Margin="0,6,0,0" Padding="8,6"/>

            </StackPanel>
        </Grid>

        <Grid Grid.Row="2" Background="{StaticResource HeaderBgBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Button Click="CancelBtn_Click" Grid.Column="0" Background="{StaticResource CancelBtnBrush}" Content="CANCEL" FontSize="18" Margin="12,12,6,12"/>
            <Button Click="ConfirmBtn_Click" Grid.Column="1" Background="{StaticResource ExpressBtnBrush}" Content="APPLY" FontSize="18" Margin="6,12,12,12"/>
        </Grid>
    </Grid>
</Window>