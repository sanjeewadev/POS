<Window x:Class="POS.Cashier.UI.Dialogs.ReturnInvoiceDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Process Return Exchange" Height="650" Width="1000"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="{StaticResource MainBgBrush}"
        BorderBrush="{StaticResource HeaderBgBrush}"
        BorderThickness="3"
        FontFamily="Arial">

    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource TextLightBrush}"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="5" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="45"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="80"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource HeaderBgBrush}">
            <TextBlock Text="ITEM RETURN &amp; EXCHANGE DESK" Foreground="{StaticResource TextLightBrush}" FontSize="18" FontWeight="Heavy" HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Border>

        <Border Grid.Row="1" Background="#E2E8F0" Padding="10,8" BorderBrush="#CBD5E1" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <RadioButton x:Name="RadWithInvoice" Content="SCAN/ENTER INVOICE" IsChecked="True" GroupName="ReturnMode" FontSize="13" FontWeight="Bold" Margin="0,0,40,0" VerticalAlignment="Center"/>
                <RadioButton x:Name="RadWithoutInvoice" Content="DIRECT TAG SCAN (NO INVOICE)" GroupName="ReturnMode" FontSize="13" FontWeight="Bold" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="2" Background="{StaticResource InfoPanelBgBrush}" Padding="15" BorderBrush="{StaticResource HeaderBgBrush}" BorderThickness="0,0,0,2">
            <Grid>
                <Grid Visibility="{Binding IsChecked, ElementName=RadWithInvoice, Converter={StaticResource BoolToVis}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="150"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Text="{Binding InvoiceSearchText, UpdateSourceTrigger=PropertyChanged}" FontSize="24" FontWeight="Bold" Padding="10" Background="#F1F5F9" BorderBrush="{StaticResource ControlBorderBrush}" BorderThickness="2" />
                    <Button x:Name="BtnSearchInvoice" Grid.Column="1" Content="FIND INVOICE" Background="{StaticResource ActionBtnBrush}" Margin="10,0,0,0" FontSize="16"/>
                </Grid>

                <Grid Visibility="{Binding IsChecked, ElementName=RadWithoutInvoice, Converter={StaticResource BoolToVis}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="150"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="TxtDirectTagScan" FontSize="24" FontWeight="Bold" Padding="10" Background="#FFF7ED" BorderBrush="{StaticResource ControlBorderBrush}" BorderThickness="2"/>
                    <Button x:Name="BtnAddDirectItem" Grid.Column="1" Content="SCAN TAG" Background="#4CAF50" Margin="10,0,0,0" FontSize="16"/>
                </Grid>
            </Grid>
        </Border>

        <DataGrid x:Name="dgReturnItems" Grid.Row="3" ItemsSource="{Binding InvoiceLines}" 
                  AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="False"
                  HeadersVisibility="Column" Background="White" RowHeight="50" FontSize="16" 
                  BorderThickness="0" SelectionMode="Single" AlternatingRowBackground="#F8FAFC" Margin="15">
            <DataGrid.Resources>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="{StaticResource HeaderBgBrush}"/>
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="FontWeight" Value="Bold"/>
                    <Setter Property="Padding" Value="10"/>
                </Style>
            </DataGrid.Resources>
            <DataGrid.Columns>
                <DataGridCheckBoxColumn Header="Select" Binding="{Binding IsReturning, UpdateSourceTrigger=PropertyChanged}" Width="70"/>
                <DataGridTextColumn Header="Item Description" Binding="{Binding Description}" Width="*" IsReadOnly="True" FontWeight="Bold"/>
                <DataGridTextColumn Header="Sold Price" Binding="{Binding SoldPrice, StringFormat=N2}" Width="130" IsReadOnly="True"/>
                <DataGridTextColumn Header="Bill Qty" Binding="{Binding SoldQty}" Width="90" IsReadOnly="True" Foreground="{StaticResource TextInactiveBrush}"/>

                <DataGridTemplateColumn Header="Exchange Qty" Width="130">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBox Text="{Binding ReturnQty, UpdateSourceTrigger=PropertyChanged}" Background="#FFF7ED" FontSize="20" FontWeight="Bold" TextAlignment="Center" BorderThickness="0"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <Grid Grid.Row="4" Background="{StaticResource HeaderBgBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="320"/>
            </Grid.ColumnDefinitions>

            <Button x:Name="BtnCancelReturn" Click="CancelBtn_Click" Grid.Column="0" Background="{StaticResource CancelBtnBrush}" Content="CANCEL (ESC)" FontSize="16" Margin="15,15,5,15"/>

            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="TOTAL EXCHANGE CREDIT:" Foreground="{StaticResource TextLightBrush}" FontSize="15" FontWeight="Bold" VerticalAlignment="Center"/>
                <TextBlock x:Name="LblExchangeCredit" Text="LKR 0.00" Foreground="#FFD700" FontSize="24" FontWeight="Black" Margin="10,0,0,0" VerticalAlignment="Center"/>
            </StackPanel>

            <Button x:Name="BtnGenerateExchangeSlip" Click="ConfirmBtn_Click" Grid.Column="2" Background="#10B981" Content="🖨️ GENERATE EXCHANGE BILL" FontSize="18" FontWeight="Black" Margin="5,15,15,15"/>
        </Grid>
    </Grid>
</Window>