<Window x:Class="POS.Cashier.UI.Dialogs.ReturnInvoiceDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Process Return" Height="650" Width="1000"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="{StaticResource MainBgBrush}"
        BorderBrush="{StaticResource HeaderBgBrush}"
        BorderThickness="3"
        FontFamily="Arial">

    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource TextLightBrush}"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="5" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="45"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="70"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource HeaderBgBrush}">
            <TextBlock Text="VERIFY INVOICE &amp; PROCESS RETURN" Foreground="{StaticResource TextLightBrush}" FontSize="20" FontWeight="Heavy" HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Border>

        <Border Grid.Row="1" Background="{StaticResource InfoPanelBgBrush}" Padding="15" BorderBrush="{StaticResource HeaderBgBrush}" BorderThickness="0,0,0,2">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="150"/>
                </Grid.ColumnDefinitions>
                <TextBox Text="{Binding InvoiceSearchText}" FontSize="24" FontWeight="Bold" Padding="10" Background="#F1F5F9" BorderBrush="{StaticResource ControlBorderBrush}" BorderThickness="2" />
                <Button Grid.Column="1" Content="FIND INVOICE" Background="{StaticResource ActionBtnBrush}" Margin="10,0,0,0" FontSize="18"/>
            </Grid>
        </Border>

        <DataGrid x:Name="dgReturnItems" Grid.Row="2" ItemsSource="{Binding InvoiceLines}" 
                  AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="False"
                  HeadersVisibility="Column" Background="White" RowHeight="50" FontSize="16" 
                  BorderThickness="0" SelectionMode="Single" AlternatingRowBackground="#F8FAFC" Margin="15">
            <DataGrid.Resources>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="{StaticResource HeaderBgBrush}"/>
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="FontWeight" Value="Bold"/>
                    <Setter Property="Padding" Value="10"/>
                </Style>
            </DataGrid.Resources>
            <DataGrid.Columns>
                <DataGridCheckBoxColumn Header="Return" Binding="{Binding IsReturning, UpdateSourceTrigger=PropertyChanged}" Width="80"/>
                <DataGridTextColumn Header="Item Description" Binding="{Binding Description}" Width="*" IsReadOnly="True" FontWeight="Bold"/>
                <DataGridTextColumn Header="Price" Binding="{Binding SoldPrice, StringFormat=N2}" Width="120" IsReadOnly="True"/>
                <DataGridTextColumn Header="Sold Qty" Binding="{Binding SoldQty}" Width="100" IsReadOnly="True" Foreground="{StaticResource TextInactiveBrush}"/>

                <DataGridTemplateColumn Header="Return Qty" Width="120">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBox Text="{Binding ReturnQty, UpdateSourceTrigger=PropertyChanged}" Background="#FFF7ED" FontSize="20" FontWeight="Bold" TextAlignment="Center" BorderThickness="0"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <Grid Grid.Row="3" Background="{StaticResource HeaderBgBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="2*"/>
            </Grid.ColumnDefinitions>
            <Button Click="CancelBtn_Click" Grid.Column="0" Background="{StaticResource CancelBtnBrush}" Content="CANCEL" FontSize="20" Margin="10,10,5,10"/>
            <Button Click="ConfirmBtn_Click" Grid.Column="1" Background="{StaticResource ExpressBtnBrush}" Content="ISSUE REFUND (CREDIT NOTE)" FontSize="20" Margin="5,10,10,10"/>
        </Grid>
    </Grid>
</Window>