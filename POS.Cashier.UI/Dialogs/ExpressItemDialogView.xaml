<Window x:Class="POS.Cashier.UI.Dialogs.ExpressItemDialogView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Express Items" Height="700" Width="1050"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None" AllowsTransparency="True" Background="#A0000000"
        FontFamily="Segoe UI, Arial">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

        <Style TargetType="Button" x:Key="ExpressGridButtonStyle">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Heavy"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Margin" Value="6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="#222" BorderThickness="1" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="10"/>
                            <Border.Effect>
                                <DropShadowEffect Color="Black" Direction="270" ShadowDepth="3" BlurRadius="6" Opacity="0.4"/>
                            </Border.Effect>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Opacity" Value="0.7"/>
                                <Setter Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.95" ScaleY="0.95" CenterX="50" CenterY="50"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <!-- Main Dark Modal Box -->
        <Border Background="#1E293B" CornerRadius="12" Margin="30" BorderBrush="#334155" BorderThickness="2">
            <Border.Effect>
                <DropShadowEffect Color="Black" BlurRadius="20" ShadowDepth="5" Opacity="0.6"/>
            </Border.Effect>

            <Grid Margin="15">
                <Grid.RowDefinitions>
                    <!-- ROW 0: Button grid fills all available space -->
                    <RowDefinition Height="*"/>
                    <!-- ROW 1: Fixed-height close bar at the bottom -->
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- ROW 0: Express Button Grid -->
                <Grid Grid.Row="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Loading Indicator -->
                    <TextBlock Text="Loading items..."
                               Foreground="#94A3B8" FontSize="18"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                    <!-- The Buttons -->
                    <ItemsControl ItemsSource="{Binding CurrentTabButtons}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="5"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Background="{Binding ButtonColorHex}"
                                        Style="{StaticResource ExpressGridButtonStyle}"
                                        Command="{Binding DataContext.ButtonClickedCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding}">
                                    <TextBlock Text="{Binding DisplayLabel}" TextWrapping="Wrap" TextAlignment="Center"/>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>

                <!-- ROW 1: Close Button Bar -->
                <Border Grid.Row="1" BorderBrush="#334155" BorderThickness="0,1,0,0" Padding="0,10,0,0">
                    <Button Content="CLOSE MENU"
                            Click="CloseBtn_Click"
                            Height="65"
                            Background="#EF4444"
                            Foreground="White"
                            FontSize="16"
                            FontWeight="Heavy"
                            Cursor="Hand"
                            BorderThickness="0">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="6"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </Border>

            </Grid>
        </Border>
    </Grid>
</Window>