<Window x:Class="POS.Cashier.UI.Dialogs.ExpressItemDialogView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Express Items"
        Height="680"
        Width="1050"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="#D4D0C8"
        FontFamily="Segoe UI, Arial"
        PreviewKeyDown="Window_PreviewKeyDown">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>

        <Style TargetType="Button" x:Key="TerminalButton">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#222222"/>
            <Setter Property="MinHeight" Value="78"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="4"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="DataGridCell" x:Key="BaseCell">
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="5,0"/>
            <Setter Property="Foreground" Value="Black"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#0A246A"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Border BorderBrush="#222222"
            BorderThickness="2"
            Background="#D4D0C8"
            Margin="4">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="48"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="58"/>
            </Grid.RowDefinitions>

            <!-- HEADER -->
            <Border Grid.Row="0"
                    Background="#003366"
                    BorderBrush="#222222"
                    BorderThickness="0,0,0,1">

                <Grid>
                    <TextBlock Text="EXPRESS ITEMS"
                               Foreground="White"
                               FontSize="20"
                               FontWeight="Heavy"
                               VerticalAlignment="Center"
                               Margin="18,0,0,0"/>

                    <TextBlock Text="{Binding StatusMessage}"
                               Foreground="#FFB84D"
                               FontSize="14"
                               FontWeight="Bold"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center"/>

                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                Margin="0,0,8,0">

                        <TextBlock Text="Buttons: "
                                   Foreground="White"
                                   FontWeight="Bold"
                                   VerticalAlignment="Center"/>

                        <TextBlock Text="{Binding ButtonCount}"
                                   Foreground="#DEFF9A"
                                   FontWeight="Bold"
                                   VerticalAlignment="Center"
                                   Margin="0,0,15,0"/>

                        <Button Content="REFRESH"
                                Command="{Binding LoadButtonsCommand}"
                                Background="#005555"
                                Style="{StaticResource TerminalButton}"
                                MinHeight="32"
                                Height="32"
                                Width="90"
                                FontSize="13"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- BODY -->
            <Grid Grid.Row="1"
                  Margin="6">

                <TextBlock Text="Loading express buttons..."
                           Foreground="#003366"
                           FontSize="20"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                <ItemsControl ItemsSource="{Binding ExpressButtons}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="5"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>

                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Background="{Binding ButtonColorHex}"
                                    Foreground="{Binding TextColorHex}"
                                    Style="{StaticResource TerminalButton}"
                                    Command="{Binding DataContext.ButtonClickedCommand,
                                                      RelativeSource={RelativeSource AncestorType=Window}}"
                                    CommandParameter="{Binding}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0"
                                               Text="{Binding DisplayLabel}"
                                               TextWrapping="Wrap"
                                               TextAlignment="Center"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               FontSize="18"
                                               FontWeight="Heavy"/>

                                    <TextBlock Grid.Row="1"
                                               Text="{Binding RetailPrice, StringFormat=Rs. {0:N2}}"
                                               TextAlignment="Center"
                                               HorizontalAlignment="Center"
                                               FontSize="13"
                                               FontWeight="Bold"
                                               Opacity="0.9"
                                               Margin="0,4,0,0"/>
                                </Grid>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>

            <!-- FOOTER -->
            <Border Grid.Row="2"
                    Background="#E5E5E5"
                    BorderBrush="#A0A0A0"
                    BorderThickness="0,1,0,0"
                    Padding="6">

                <Grid>
                    <TextBlock Text="Click an item to add it to the current sale. Press ESC to close."
                               Foreground="#333333"
                               FontWeight="Bold"
                               VerticalAlignment="Center"
                               Margin="10,0,0,0"/>

                    <Button Content="CLOSE MENU"
                            Click="CloseBtn_Click"
                            Background="#A94044"
                            Style="{StaticResource TerminalButton}"
                            HorizontalAlignment="Right"
                            Width="170"
                            MinHeight="42"
                            Height="42"
                            FontSize="15"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>