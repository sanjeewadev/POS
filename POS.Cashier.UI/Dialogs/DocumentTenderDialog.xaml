<Window x:Class="POS.Cashier.UI.Views.Dialogs.DocumentTenderDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Document Tender" Height="650" Width="950"
        WindowStartupLocation="CenterOwner" WindowStyle="None" ResizeMode="NoResize"
        Background="#1E1E1E" FontFamily="Segoe UI, Arial">

    <!-- Insert exact same Button Resource Style here -->
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#444444"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="5"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0" Background="#D97706" BorderBrush="#111111" BorderThickness="0,0,0,2">
            <TextBlock Text="{Binding DocumentType, FallbackValue='CHEQUE PAYMENT'}" Foreground="White" FontSize="32" FontWeight="Heavy" HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Border>

        <Grid Grid.Row="1" Margin="15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="4.5*"/>
                <ColumnDefinition Width="5.5*"/>
            </Grid.ColumnDefinitions>

            <!-- Inputs -->
            <Border Grid.Column="0" Background="#2B2B2B" BorderBrush="#444444" BorderThickness="1" Margin="0,0,10,0" Padding="20">
                <StackPanel>
                    <TextBlock Text="AMOUNT" Foreground="#AAAAAA" FontSize="16" FontWeight="Bold"/>
                    <TextBox Background="White" Foreground="#8B0000" FontSize="36" FontWeight="Heavy" TextAlignment="Right" Height="55" Margin="0,5,0,15" Text="{Binding TotalDue, StringFormat=N2}"/>

                    <TextBlock Text="BANK NAME" Foreground="#AAAAAA" FontSize="16" FontWeight="Bold"/>
                    <TextBox Background="White" Foreground="Black" FontSize="24" FontWeight="Bold" Height="45" Margin="0,5,0,15"/>

                    <TextBlock Text="BRANCH CODE" Foreground="#AAAAAA" FontSize="16" FontWeight="Bold"/>
                    <TextBox Background="White" Foreground="Black" FontSize="24" FontWeight="Bold" Height="45" Margin="0,5,0,15"/>

                    <TextBlock Text="CHEQUE / REF NUMBER" Foreground="#AAAAAA" FontSize="16" FontWeight="Bold"/>
                    <TextBox Background="White" Foreground="Black" FontSize="24" FontWeight="Bold" Height="45" Margin="0,5,0,30"/>

                    <Grid Height="70">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Background="#DC3545" Content="CANCEL" FontSize="20" Margin="0,0,5,0"/>
                        <Button Grid.Column="1" Background="#D97706" Content="APPLY" FontSize="24" FontWeight="Heavy" Margin="5,0,0,0"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Full QWERTY + Numpad -->
            <Grid Grid.Column="1" Margin="10,0,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- This mimics the On-Screen Keyboard layout of POS machines -->
                <UniformGrid Grid.Row="0" Columns="10" Rows="4">
                    <Button Background="#444444" Content="1" FontSize="20"/>
                    <Button Background="#444444" Content="2" FontSize="20"/>
                    <Button Background="#444444" Content="3" FontSize="20"/>
                    <Button Background="#444444" Content="4" FontSize="20"/>
                    <Button Background="#444444" Content="5" FontSize="20"/>
                    <Button Background="#444444" Content="6" FontSize="20"/>
                    <Button Background="#444444" Content="7" FontSize="20"/>
                    <Button Background="#444444" Content="8" FontSize="20"/>
                    <Button Background="#444444" Content="9" FontSize="20"/>
                    <Button Background="#444444" Content="0" FontSize="20"/>
                    <Button Background="#444444" Content="Q" FontSize="20"/>
                    <Button Background="#444444" Content="W" FontSize="20"/>
                    <Button Background="#444444" Content="E" FontSize="20"/>
                    <Button Background="#444444" Content="R" FontSize="20"/>
                    <Button Background="#444444" Content="T" FontSize="20"/>
                    <Button Background="#444444" Content="Y" FontSize="20"/>
                    <Button Background="#444444" Content="U" FontSize="20"/>
                    <Button Background="#444444" Content="I" FontSize="20"/>
                    <Button Background="#444444" Content="O" FontSize="20"/>
                    <Button Background="#444444" Content="P" FontSize="20"/>
                    <Button Background="#444444" Content="A" FontSize="20"/>
                    <Button Background="#444444" Content="S" FontSize="20"/>
                    <Button Background="#444444" Content="D" FontSize="20"/>
                    <Button Background="#444444" Content="F" FontSize="20"/>
                    <Button Background="#444444" Content="G" FontSize="20"/>
                    <Button Background="#444444" Content="H" FontSize="20"/>
                    <Button Background="#444444" Content="J" FontSize="20"/>
                    <Button Background="#444444" Content="K" FontSize="20"/>
                    <Button Background="#444444" Content="L" FontSize="20"/>
                    <Button Background="#DC3545" Content="CLR" FontSize="18"/>
                    <Button Background="#444444" Content="Z" FontSize="20"/>
                    <Button Background="#444444" Content="X" FontSize="20"/>
                    <Button Background="#444444" Content="C" FontSize="20"/>
                    <Button Background="#444444" Content="V" FontSize="20"/>
                    <Button Background="#444444" Content="B" FontSize="20"/>
                    <Button Background="#444444" Content="N" FontSize="20"/>
                    <Button Background="#444444" Content="M" FontSize="20"/>
                    <Button Background="#444444" Content="-" FontSize="20"/>
                    <Button Background="#444444" Content="/" FontSize="20"/>
                    <Button Background="#0056B3" Content="&lt;&lt;" FontSize="20"/>
                </UniformGrid>

                <Button Grid.Row="1" Height="60" Margin="3,10,3,3" Background="#444444" Content="SPACE" FontSize="22"/>
            </Grid>
        </Grid>
    </Grid>
</Window>