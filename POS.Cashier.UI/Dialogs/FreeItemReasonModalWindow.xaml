<Window x:Class="POS.Cashier.UI.Dialogs.FreeItemReasonModalWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Apply Free Item Comp"
        SizeToContent="WidthAndHeight" 
        WindowStartupLocation="CenterOwner" 
        WindowStyle="None" 
        AllowsTransparency="True" 
        Background="Transparent"
        FontFamily="Segoe UI">

    <Border Background="White" BorderBrush="#007BFF" BorderThickness="3" CornerRadius="8" 
            Width="500" Height="420" Margin="20">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" Opacity="0.4" ShadowDepth="5"/>
        </Border.Effect>

        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="🎁 Apply 100% Comp (Free Item)" FontSize="22" FontWeight="Bold" Foreground="#333" Margin="0,0,0,10"/>
            <Separator Grid.Row="1" Margin="0,0,0,15" Background="#E0E0E0"/>

            <StackPanel Grid.Row="2">
                <Border Background="#F8F9FA" BorderBrush="#DEE2E6" BorderThickness="1" CornerRadius="4" Padding="15" Margin="0,0,0,15">
                    <StackPanel>
                        <TextBlock Text="Selected Item:" FontSize="12" Foreground="#666"/>
                        <TextBlock Text="{Binding ItemName}" FontSize="18" FontWeight="Bold" Foreground="#333" TextWrapping="Wrap" Margin="0,0,0,5"/>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Dropping Price from: " FontSize="14" Foreground="#666" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding OriginalPrice, StringFormat=Rs. \{0:N2\}}" FontSize="16" FontWeight="Bold" Foreground="#A94044" VerticalAlignment="Center" TextDecorations="Strikethrough"/>
                            <TextBlock Text=" ➔ Rs. 0.00" FontSize="16" FontWeight="Heavy" Foreground="#1E7E34" VerticalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <TextBlock Text="Select Authorization Reason:" FontSize="14" FontWeight="SemiBold" Foreground="#555" Margin="0,0,0,10"/>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="55"/>
                        <RowDefinition Height="55"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Row="0" Grid.Column="0" Content="Supplier Promo (Recoverable)" Background="#1E7E34" Foreground="White" FontWeight="Bold" FontSize="13" Command="{Binding SelectReasonCommand}" CommandParameter="SupplierPromo"/>
                    <Button Grid.Row="0" Grid.Column="2" Content="Manager Comp (Loss)" Background="#007BFF" Foreground="White" FontWeight="Bold" FontSize="13" Command="{Binding SelectReasonCommand}" CommandParameter="ManagerComp"/>

                    <Button Grid.Row="1" Grid.Column="0" Content="Damaged Goods (Loss)" Background="#E0A800" Foreground="White" FontWeight="Bold" FontSize="13" Margin="0,10,0,0" Command="{Binding SelectReasonCommand}" CommandParameter="DamagedGoods"/>
                    <Button Grid.Row="1" Grid.Column="2" Content="Customer Apology (Loss)" Background="#6F42C1" Foreground="White" FontWeight="Bold" FontSize="13" Margin="0,10,0,0" Command="{Binding SelectReasonCommand}" CommandParameter="CustomerApology"/>
                </Grid>
            </StackPanel>

            <Button Grid.Row="3" Content="Cancel" Command="{Binding CancelCommand}" 
                    Background="#F5F5F5" Foreground="#333" BorderBrush="#CCC" BorderThickness="1" Height="45" FontSize="14" FontWeight="Bold" Cursor="Hand" Margin="0,15,0,0"/>
        </Grid>
    </Border>
</Window>