<Window x:Class="POS.Cashier.UI.Dialogs.FreeItemReasonModalWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Free Item Authorization"
        Width="920"
        Height="620"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#D7DCE2"
        FontFamily="Segoe UI"
        FontSize="14"
        Loaded="Window_Loaded"
        PreviewKeyDown="Window_PreviewKeyDown">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>

        <Style TargetType="Button" x:Key="DialogButton">
            <Setter Property="Height" Value="44"/>
            <Setter Property="FontWeight" Value="Heavy"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderBrush" Value="#222"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <Style TargetType="TextBlock" x:Key="FieldLabel">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#111827"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style TargetType="TextBox" x:Key="InputBox">
            <Setter Property="Height" Value="36"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#111827"/>
            <Setter Property="BorderBrush" Value="#555"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#2B3C38"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="8,7"/>
            <Setter Property="BorderBrush" Value="#1F2937"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
        </Style>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="58"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="56"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0"
                Background="#0B3A53"
                BorderBrush="#1F2937"
                BorderThickness="1"
                Padding="14,0">

            <Grid>
                <TextBlock Text="FREE ITEM AUTHORIZATION"
                           Foreground="White"
                           FontSize="24"
                           FontWeight="Heavy"
                           VerticalAlignment="Center"/>

                <TextBlock Text="Admin rule required   |   Enter = Confirm   |   Esc = Cancel"
                           Foreground="#BFEAFF"
                           FontSize="13"
                           FontWeight="Bold"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- BODY -->
        <Grid Grid.Row="1" Margin="0,10,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.05*"/>
                <ColumnDefinition Width="1.15*"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT -->
            <Border Grid.Column="0"
                    Background="White"
                    BorderBrush="#6B7280"
                    BorderThickness="1"
                    Padding="14"
                    Margin="0,0,10,0">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="48"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Background="{Binding StatusColorHex}"
                            BorderBrush="#222"
                            BorderThickness="1"
                            Padding="8,0">

                        <TextBlock Text="{Binding StatusText}"
                                   Foreground="White"
                                   FontSize="13"
                                   FontWeight="Heavy"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap"
                                   VerticalAlignment="Center"/>
                    </Border>

                    <!-- ITEM DETAILS -->
                    <GroupBox Grid.Row="1"
                              Header="Selected Item"
                              FontWeight="Bold"
                              Margin="0,10,0,10">

                        <Grid Margin="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="115"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Grid.RowDefinitions>
                                <RowDefinition Height="34"/>
                                <RowDefinition Height="34"/>
                                <RowDefinition Height="34"/>
                                <RowDefinition Height="34"/>
                                <RowDefinition Height="34"/>
                                <RowDefinition Height="34"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Item:" Style="{StaticResource FieldLabel}"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding ItemDescription}" FontWeight="Heavy" TextTrimming="CharacterEllipsis"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Barcode:" Style="{StaticResource FieldLabel}"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Barcode}" FontWeight="Bold"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="SKU:" Style="{StaticResource FieldLabel}"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding SkuCode}" FontWeight="Bold"/>

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Batch:" Style="{StaticResource FieldLabel}"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding BatchNo}" FontWeight="Bold"/>

                            <TextBlock Grid.Row="4" Grid.Column="0" Text="Qty:" Style="{StaticResource FieldLabel}"/>
                            <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding Quantity, StringFormat={}{0:N3}}" FontWeight="Bold"/>

                            <TextBlock Grid.Row="5" Grid.Column="0" Text="Price / Cost:" Style="{StaticResource FieldLabel}"/>
                            <TextBlock Grid.Row="5" Grid.Column="1"
                                       Text="{Binding OriginalUnitPrice, StringFormat=Selling Rs. {0:N2}}"
                                       FontWeight="Bold"/>
                        </Grid>
                    </GroupBox>

                    <!-- VALUES -->
                    <GroupBox Grid.Row="2"
                              Header="Free Issue Values"
                              FontWeight="Bold">

                        <Grid Margin="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Grid.RowDefinitions>
                                <RowDefinition Height="44"/>
                                <RowDefinition Height="44"/>
                                <RowDefinition Height="44"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Shop Cost Value:" Style="{StaticResource FieldLabel}"/>

                            <Border Grid.Row="0" Grid.Column="1"
                                    Background="#FFF7ED"
                                    BorderBrush="#D97706"
                                    BorderThickness="2"
                                    Padding="10,0">

                                <TextBlock Text="{Binding FreeIssueCostValue, StringFormat={}{0:N2}}"
                                           Foreground="#9A3412"
                                           FontSize="22"
                                           FontWeight="Heavy"
                                           TextAlignment="Right"
                                           VerticalAlignment="Center"/>
                            </Border>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Selling Value Lost:" Style="{StaticResource FieldLabel}"/>

                            <Border Grid.Row="1" Grid.Column="1"
                                    Background="#FEE2E2"
                                    BorderBrush="#EF4444"
                                    BorderThickness="2"
                                    Padding="10,0">

                                <TextBlock Text="{Binding FreeIssueSellingValue, StringFormat={}{0:N2}}"
                                           Foreground="#991B1B"
                                           FontSize="22"
                                           FontWeight="Heavy"
                                           TextAlignment="Right"
                                           VerticalAlignment="Center"/>
                            </Border>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Supplier Claim:" Style="{StaticResource FieldLabel}"/>

                            <Border Grid.Row="2" Grid.Column="1"
                                    Background="#E8F5E9"
                                    BorderBrush="#10B981"
                                    BorderThickness="2"
                                    Padding="10,0">

                                <TextBlock Text="{Binding ClaimValue, StringFormat={}{0:N2}}"
                                           Foreground="#065F46"
                                           FontSize="22"
                                           FontWeight="Heavy"
                                           TextAlignment="Right"
                                           VerticalAlignment="Center"/>
                            </Border>
                        </Grid>
                    </GroupBox>
                </Grid>
            </Border>

            <!-- RIGHT -->
            <Border Grid.Column="1"
                    Background="White"
                    BorderBrush="#6B7280"
                    BorderThickness="1"
                    Padding="14">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="230"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="Available Free Issue Rules"
                               FontSize="15"
                               FontWeight="Heavy"
                               Foreground="#003366"
                               Margin="0,0,0,8"/>

                    <DataGrid Grid.Row="0"
                              Margin="0,28,0,0"
                              ItemsSource="{Binding ApplicableRules}"
                              SelectedItem="{Binding SelectedRule, Mode=TwoWay}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              IsReadOnly="True"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              HorizontalGridLinesBrush="#D1D5DB"
                              BorderBrush="#808080"
                              BorderThickness="1"
                              Background="White"
                              RowHeight="34">

                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Rule"
                                                Binding="{Binding RuleName}"
                                                Width="180"
                                                FontWeight="Bold"/>

                            <DataGridTextColumn Header="Type"
                                                Binding="{Binding DisplayFreeIssueType}"
                                                Width="140"/>

                            <DataGridTextColumn Header="Reason"
                                                Binding="{Binding ReasonName}"
                                                Width="135"/>

                            <DataGridCheckBoxColumn Header="Mgr"
                                                    Binding="{Binding RequiresManagerApproval}"
                                                    Width="55"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <GroupBox Grid.Row="1"
                              Header="Selected Rule Details"
                              FontWeight="Bold"
                              Margin="0,10,0,8">

                        <Grid Margin="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="130"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Grid.RowDefinitions>
                                <RowDefinition Height="32"/>
                                <RowDefinition Height="32"/>
                                <RowDefinition Height="32"/>
                                <RowDefinition Height="32"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Rule:" Style="{StaticResource FieldLabel}"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SelectedRule.RuleName}" FontWeight="Bold"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Free Type:" Style="{StaticResource FieldLabel}"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SelectedRule.DisplayFreeIssueType}" FontWeight="Bold"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Supplier:" Style="{StaticResource FieldLabel}"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding SelectedRule.SupplierName}" FontWeight="Bold"/>

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Claim Mode:" Style="{StaticResource FieldLabel}"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding SelectedRule.ClaimValueMode}" FontWeight="Bold"/>
                        </Grid>
                    </GroupBox>

                    <GroupBox Grid.Row="2"
                              Header="Approval / Claim Reference"
                              FontWeight="Bold"
                              Margin="0,0,0,8">

                        <Grid Margin="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="155"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Grid.RowDefinitions>
                                <RowDefinition Height="40"/>
                                <RowDefinition Height="40"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Manager Approved By:" Style="{StaticResource FieldLabel}"/>
                            <TextBox Grid.Row="0" Grid.Column="1"
                                     Text="{Binding ApprovedBy, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource InputBox}"
                                     ToolTip="Required only when selected rule requires manager approval."/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Claim Reference:" Style="{StaticResource FieldLabel}"/>
                            <TextBox Grid.Row="1" Grid.Column="1"
                                     Text="{Binding ClaimReferenceNo, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource InputBox}"
                                     ToolTip="Optional. Used for supplier recoverable claims."/>
                        </Grid>
                    </GroupBox>

                    <Border Grid.Row="3"
                            Background="#FFF7ED"
                            BorderBrush="#D97706"
                            BorderThickness="1"
                            Padding="10"
                            Visibility="{Binding RequiresManagerApproval, Converter={StaticResource BooleanToVisibilityConverter}}">

                        <TextBlock Text="Manager approval is required for this free issue rule. Enter manager name/code before confirming. Later this should be replaced with a real manager PIN authorization dialog."
                                   Foreground="#9A3412"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap"/>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <!-- FOOTER -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="135"/>
                <ColumnDefinition Width="190"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Text="Free item can only be applied using an active BackOffice rule."
                       Foreground="#374151"
                       FontWeight="Bold"
                       VerticalAlignment="Center"/>

            <Button Grid.Column="1"
                    Content="CANCEL"
                    Command="{Binding CancelCommand}"
                    Style="{StaticResource DialogButton}"
                    Background="#6B7280"
                    Margin="0,0,8,0"/>

            <Button Grid.Column="2"
                    Content="CONFIRM FREE ITEM"
                    Command="{Binding ConfirmCommand}"
                    Style="{StaticResource DialogButton}"
                    Background="#10B981"/>
        </Grid>
    </Grid>
</Window>