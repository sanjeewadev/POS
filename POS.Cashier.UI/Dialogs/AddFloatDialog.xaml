<Window x:Class="POS.Cashier.UI.Views.Dialogs.AddFloatDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add Till Float" Height="700" Width="850"
        WindowStartupLocation="CenterOwner" WindowStyle="None" ResizeMode="NoResize"
        Background="#1E1E1E" FontFamily="Segoe UI, Arial">

    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="3"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#444444"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="5"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TextBox" x:Key="FlatTextBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="FontWeight" Value="Heavy"/>
            <Setter Property="FontSize" Value="36"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="60"/>
        </Style>

        <Style TargetType="TextBlock" x:Key="FormLabel">
            <Setter Property="Foreground" Value="#AAAAAA"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#0D6EFD" BorderBrush="#111111" BorderThickness="0,0,0,2">
            <TextBlock Text="ADD TILL FLOAT / STARTING CASH" Foreground="White" FontSize="32" FontWeight="Heavy" HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Border>

        <Grid Grid.Row="1" Margin="15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="5.5*"/>
                <ColumnDefinition Width="4.5*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#2B2B2B" BorderBrush="#444444" BorderThickness="1" Margin="0,0,10,0" Padding="20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="75"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#111111" Padding="15" Margin="0,0,0,25">
                        <Grid>
                            <StackPanel HorizontalAlignment="Left">
                                <TextBlock Text="CURRENT EXPECTED CASH:" Foreground="#777777" FontSize="14" FontWeight="Bold"/>
                                <TextBlock Text="{Binding CurrentExpectedCash, StringFormat=Rs. \{0:N2\}, FallbackValue='Rs. 0.00'}" Foreground="#A9C6E2" FontSize="28" FontWeight="Heavy"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <StackPanel Grid.Row="1" Margin="0,0,0,20">
                        <TextBlock Text="ENTER FLOAT AMOUNT (Rs.)" Style="{StaticResource FormLabel}"/>
                        <TextBox Style="{StaticResource FlatTextBox}" Text="{Binding FloatAmount, FallbackValue='10,000.00'}" TextAlignment="Right" Foreground="#28A745"/>
                    </StackPanel>

                    <StackPanel Grid.Row="2" Margin="0,0,0,20">
                        <TextBlock Text="REFERENCE NOTE" Style="{StaticResource FormLabel}"/>
                        <TextBox Style="{StaticResource FlatTextBox}" FontSize="20" FontWeight="Bold" Height="50" Text="{Binding ReferenceNote, FallbackValue='Morning Shift Float'}"/>
                    </StackPanel>

                    <Grid Grid.Row="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="2*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Background="#DC3545" Content="CANCEL" FontSize="22" Margin="0,0,5,0" Command="{Binding CancelCommand}"/>
                        <Button Grid.Column="1" Background="#0D6EFD" Content="SAVE &amp; OPEN DRAWER" FontSize="22" FontWeight="Heavy" Margin="5,0,0,0" Command="{Binding SaveFloatCommand}"/>
                    </Grid>
                </Grid>
            </Border>

            <Grid Grid.Column="1" Margin="10,0,0,0">
                <UniformGrid Columns="3" Rows="4">
                    <Button Background="#444444" Content="7" FontSize="45"/>
                    <Button Background="#444444" Content="8" FontSize="45"/>
                    <Button Background="#444444" Content="9" FontSize="45"/>
                    <Button Background="#444444" Content="4" FontSize="45"/>
                    <Button Background="#444444" Content="5" FontSize="45"/>
                    <Button Background="#444444" Content="6" FontSize="45"/>
                    <Button Background="#444444" Content="1" FontSize="45"/>
                    <Button Background="#444444" Content="2" FontSize="45"/>
                    <Button Background="#444444" Content="3" FontSize="45"/>
                    <Button Background="#DC3545" Content="CLR" FontSize="35"/>
                    <Button Background="#444444" Content="0" FontSize="45"/>
                    <Button Background="#0D6EFD" Content="00" FontSize="35"/>
                </UniformGrid>
            </Grid>
        </Grid>
    </Grid>
</Window>