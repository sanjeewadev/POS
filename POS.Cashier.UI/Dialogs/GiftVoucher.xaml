<Window x:Class="POS.Cashier.UI.Views.Dialogs.GiftVoucherPaymentWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add Gift Voucher" Height="340" Width="480"
        WindowStartupLocation="CenterScreen" 
        WindowStyle="None" 
        ResizeMode="NoResize"
        Background="{StaticResource MainBgBrush}" 
        BorderBrush="{StaticResource HeaderBgBrush}"
        BorderThickness="3"
        FontFamily="Arial, Segoe UI">

    <Window.Resources>
        <!-- Custom Button Style to handle the Disabled State look properly -->
        <Style x:Key="SolidActionButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <!-- We bind the background here, but control what happens when disabled via triggers below -->
                        <Border x:Name="ButtonBorder" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="5"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <!-- This trigger prevents it from turning white/gray like in image_c7800d.png -->
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#1E5E2F"/>
                                <!-- Darker muted green when disabled -->
                                <Setter Property="Foreground" Value="#A0A0A0"/>
                                <!-- Muted gray text when disabled -->
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Standard Button Style for other basic buttons -->
        <Style TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="5"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="45"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="70"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0" Background="{StaticResource HeaderBgBrush}">
            <TextBlock Text="ADD GIFT VOUCHER TO BILL" Foreground="{StaticResource TextLightBrush}" FontSize="18" FontWeight="Heavy" HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Border>

        <!-- MAIN FORM -->
        <Grid Grid.Row="1" Margin="25,20,25,15">
            <StackPanel VerticalAlignment="Center">

                <!-- VOUCHER INPUT -->
                <TextBlock Text="Scan Voucher Barcode or Type Code:" FontSize="14" FontWeight="Bold" Foreground="{StaticResource TextDarkBrush}"/>
                <Grid Margin="0,5,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="90"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="txtVoucherInput" Background="White" Foreground="Black" FontSize="18" FontWeight="Bold" Padding="8,5" VerticalContentAlignment="Center" KeyDown="TxtVoucherInput_KeyDown"/>
                    <Button Grid.Column="1" Click="ValidateVoucherBtn_Click" Background="#0056B3" Foreground="White" FontWeight="Bold" Content="CHECK" Margin="5,0,0,0" Cursor="Hand"/>
                </Grid>

                <!-- LIVE VALUE CARD -->
                <Border x:Name="brdVoucherStatus" Background="#E9ECEF" BorderThickness="1" CornerRadius="4" Padding="15">
                    <StackPanel>
                        <Grid Margin="0,0,0,8">
                            <TextBlock Text="Voucher Number:" FontSize="13" Foreground="#6C757D"/>
                            <TextBlock x:Name="lblVoucherCode" Text="---" FontSize="14" FontWeight="Bold" Foreground="Black" HorizontalAlignment="Right"/>
                        </Grid>
                        <Grid>
                            <TextBlock Text="Voucher Value (Rs.):" FontSize="14" FontWeight="Bold" Foreground="Black" VerticalAlignment="Center"/>
                            <TextBlock x:Name="lblVoucherValue" Text="0.00" FontSize="26" FontWeight="Heavy" Foreground="#28A745" HorizontalAlignment="Right"/>
                        </Grid>
                    </StackPanel>
                </Border>

            </StackPanel>
        </Grid>

        <!-- FOOTER ACTIONS -->
        <Grid Grid.Row="2" Background="{StaticResource HeaderBgBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Button Click="CancelBtn_Click" Grid.Column="0" Background="{StaticResource CancelBtnBrush}" Content="CANCEL" FontSize="16" Margin="15,12,7,12" Cursor="Hand"/>

            <!-- FIXED: Added Style="{StaticResource SolidActionButtonStyle}" to preserve the dark green color states -->
            <Button x:Name="btnApplyToBill" 
                    Style="{StaticResource SolidActionButtonStyle}"
                    Click="ApplyToBillBtn_Click" 
                    Grid.Column="1" 
                    Background="#28A745" 
                    Content="ADD TO BILL" 
                    FontSize="16" 
                    Margin="7,12,15,12" 
                    IsEnabled="False"/>
        </Grid>
    </Grid>
</Window>