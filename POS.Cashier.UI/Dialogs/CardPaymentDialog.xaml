<Window x:Class="POS.Cashier.UI.Dialogs.CardPaymentDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Process Card Payment" Height="340" Width="550"
        WindowStartupLocation="CenterScreen" WindowStyle="None" ResizeMode="NoResize"
        Background="#111827" FontFamily="Segoe UI, Arial">

    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.9"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="TextBlock" x:Key="FieldLabel">
            <Setter Property="Foreground" Value="#9CA3AF"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <Style x:Key="WatermarkTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#D1D5DB"/>
            <Setter Property="FontSize" Value="22"/>
            <Setter Property="FontWeight" Value="Heavy"/>
            <Setter Property="Padding" Value="15,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Grid>
                            <Border Background="{TemplateBinding Background}" 
                                    BorderBrush="{TemplateBinding BorderBrush}" 
                                    BorderThickness="{TemplateBinding BorderThickness}" 
                                    CornerRadius="4"/>

                            <TextBlock x:Name="WatermarkPrompt" 
                                       Text="XXXX - XXXX - XXXX - XXXX" 
                                       Foreground="#9CA3AF" 
                                       FontSize="20" 
                                       FontWeight="Bold"
                                       Visibility="Collapsed"
                                       Margin="15,0,0,0"
                                       VerticalAlignment="Center" 
                                       IsHitTestVisible="False"/>

                            <ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="Center"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Text" Value="">
                                <Setter TargetName="WatermarkPrompt" Property="Visibility" Value="Visible"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="80"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#3B82F6">
            <TextBlock Text="💳 CARD PAYMENT PROCESSING" Foreground="White" FontSize="20" FontWeight="Black" HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Border>

        <StackPanel Grid.Row="1" Margin="30,0,30,0" VerticalAlignment="Center">

            <TextBlock Text="SELECT CARD NETWORK / TYPE" Style="{StaticResource FieldLabel}"/>
            <ComboBox x:Name="CboCardType" Height="45" FontSize="16" FontWeight="Bold" VerticalContentAlignment="Center" Margin="0,0,0,20" SelectedIndex="0">
                <ComboBoxItem Content="VISA (Credit / Debit)"/>
                <ComboBoxItem Content="Mastercard (Credit / Debit)"/>
                <ComboBoxItem Content="LankaPay / JustPay (Local Cards)"/>
                <ComboBoxItem Content="AMEX (American Express)"/>
                <ComboBoxItem Content="Diners Club / Discover"/>
            </ComboBox>

            <TextBlock Text="ENTER CARD NUMBER (16 DIGITS)" Style="{StaticResource FieldLabel}"/>
            <TextBox x:Name="TxtCardNumber" Height="50" Style="{StaticResource WatermarkTextBoxStyle}" InputScope="Number" TextChanged="TxtCardNumber_TextChanged" MaxLength="19"/>
            <TextBlock Text="The system automatically secures and masks your audit trail entries." FontSize="11" Foreground="#6B7280" FontWeight="SemiBold" Margin="2,5,0,0"/>

        </StackPanel>

        <Border Grid.Row="2" Background="#1F2937">
            <Grid Margin="20,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="2*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" Content="CANCEL" Background="#EF4444" Height="50" Margin="0,0,10,0" Click="Cancel_Click"/>
                <Button Grid.Column="1" Content="✔ CONFIRM PAYMENT" Background="#10B981" Height="50" Click="Confirm_Click"/>
            </Grid>
        </Border>
    </Grid>
</Window>