<Window x:Class="POS.Cashier.UI.Dialogs.PrintOptionsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Print Options"
        Width="390"
        Height="270"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="#D9E2EC"
        PreviewKeyDown="Window_PreviewKeyDown">

    <Border Margin="10"
            Background="#F8FAFC"
            BorderBrush="#334155"
            BorderThickness="1">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="46"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="44"/>
            </Grid.RowDefinitions>

            <!-- HEADER -->
            <Border Grid.Row="0"
                    Background="#0F3D5E"
                    BorderBrush="#082F49"
                    BorderThickness="0,0,0,1">

                <DockPanel LastChildFill="True">
                    <TextBlock Text="PRINT OPTIONS"
                               Foreground="White"
                               FontWeight="Bold"
                               FontSize="17"
                               VerticalAlignment="Center"
                               Margin="14,0,0,0"/>

                    <TextBlock Text="Esc = Close"
                               Foreground="#DDEAF3"
                               FontSize="11"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Right"
                               Margin="0,0,12,0"/>
                </DockPanel>
            </Border>

            <!-- BODY -->
            <Grid Grid.Row="1"
                  Margin="14">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Content="Print Last Bill"
                        FontSize="18"
                        FontWeight="SemiBold"
                        Background="#E2E8F0"
                        BorderBrush="#64748B"
                        BorderThickness="1"
                        Height="105"
                        Click="PrintLastBill_Click"/>

                <Button Grid.Column="2"
                        Content="Print Quotation"
                        FontSize="18"
                        FontWeight="SemiBold"
                        Background="#DBEAFE"
                        BorderBrush="#2563EB"
                        BorderThickness="1"
                        Height="105"
                        Click="PrintQuotation_Click"/>
            </Grid>

            <!-- FOOTER -->
            <Border Grid.Row="2"
                    Background="#E5E7EB"
                    BorderBrush="#CBD5E1"
                    BorderThickness="0,1,0,0">

                <Button Content="Cancel"
                        Width="95"
                        Height="30"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Margin="0,0,12,0"
                        IsCancel="True"
                        Click="Cancel_Click"/>
            </Border>
        </Grid>
    </Border>
</Window>