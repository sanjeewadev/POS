<Window x:Class="POS.Cashier.UI.Dialogs.DiscountRuleDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Discount Rule"
        Width="920"
        Height="620"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F3F4F6"
        FontFamily="Segoe UI"
        PreviewKeyDown="Window_PreviewKeyDown">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>

        <Style TargetType="Button">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="8,0"/>
        </Style>

        <Style TargetType="TextBlock" x:Key="LabelText">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#374151"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="4,2"/>
        </Style>

        <Style TargetType="TextBlock" x:Key="ValueText">
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Foreground" Value="#111827"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="4,2"/>
        </Style>
    </Window.Resources>

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0"
                Background="#111827"
                CornerRadius="6"
                Padding="14"
                Margin="0,0,0,10">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Discount Rule"
                               Foreground="White"
                               FontSize="24"
                               FontWeight="Bold"/>

                    <TextBlock Text="Select an approved BackOffice discount rule for the selected item."
                               Foreground="#D1D5DB"
                               FontSize="13"
                               Margin="0,4,0,0"/>
                </StackPanel>

                <Button Grid.Column="1"
                        Content="X"
                        Width="44"
                        Height="34"
                        Background="#DC2626"
                        Foreground="White"
                        BorderThickness="0"
                        Click="CloseBtn_Click"/>
            </Grid>
        </Border>

        <!-- ITEM SNAPSHOT -->
        <Border Grid.Row="1"
                Background="White"
                BorderBrush="#D1D5DB"
                BorderThickness="1"
                CornerRadius="6"
                Padding="10"
                Margin="0,0,0,10">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="{Binding SelectedItemText}"
                           FontSize="17"
                           FontWeight="Bold"
                           Foreground="#111827"
                           TextTrimming="CharacterEllipsis"/>

                <UniformGrid Grid.Row="1"
                             Columns="4"
                             Margin="0,8,0,0">

                    <StackPanel>
                        <TextBlock Text="Unit Price" Style="{StaticResource LabelText}"/>
                        <TextBlock Text="{Binding SelectedUnitPrice, StringFormat=N2}" Style="{StaticResource ValueText}"/>
                    </StackPanel>

                    <StackPanel>
                        <TextBlock Text="Quantity" Style="{StaticResource LabelText}"/>
                        <TextBlock Text="{Binding SelectedQuantity, StringFormat=N3}" Style="{StaticResource ValueText}"/>
                    </StackPanel>

                    <StackPanel>
                        <TextBlock Text="Gross" Style="{StaticResource LabelText}"/>
                        <TextBlock Text="{Binding SelectedGrossAmount, StringFormat=N2}" Style="{StaticResource ValueText}"/>
                    </StackPanel>

                    <StackPanel>
                        <TextBlock Text="Minimum Price" Style="{StaticResource LabelText}"/>
                        <TextBlock Text="{Binding SelectedMinimumPrice, StringFormat=N2}" Style="{StaticResource ValueText}"/>
                    </StackPanel>
                </UniformGrid>
            </Grid>
        </Border>

        <!-- RULE LIST + SUMMARY -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2.2*"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <!-- RULE LIST -->
            <Border Grid.Column="0"
                    Background="White"
                    BorderBrush="#D1D5DB"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="8"
                    Margin="0,0,10,0">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0"
                               Margin="0,0,0,8">

                        <TextBlock Text="Applicable Rules"
                                   FontSize="16"
                                   FontWeight="Bold"
                                   Foreground="#111827"
                                   DockPanel.Dock="Left"
                                   VerticalAlignment="Center"/>

                        <Button Content="Reload"
                                Width="90"
                                DockPanel.Dock="Right"
                                Background="#2563EB"
                                Foreground="White"
                                BorderThickness="0"
                                Command="{Binding RefreshRulesCommand}"/>
                    </DockPanel>

                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding ApplicableRules}"
                              SelectedItem="{Binding SelectedRule, Mode=TwoWay}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              IsReadOnly="True"
                              SelectionMode="Single"
                              RowHeight="36"
                              HeadersVisibility="Column"
                              GridLinesVisibility="All"
                              BorderBrush="#E5E7EB"
                              BorderThickness="1">

                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Rule"
                                                Binding="{Binding RuleName}"
                                                Width="*"/>

                            <DataGridTextColumn Header="Type"
                                                Binding="{Binding DisplayDiscountType}"
                                                Width="90"/>

                            <DataGridTextColumn Header="Value"
                                                Binding="{Binding DisplayDiscountValue}"
                                                Width="100"/>

                            <DataGridTextColumn Header="Reason"
                                                Binding="{Binding ReasonName}"
                                                Width="160"/>

                            <DataGridTextColumn Header="Applies To"
                                                Binding="{Binding DisplayAppliesTo}"
                                                Width="160"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <!-- SUMMARY -->
            <Border Grid.Column="1"
                    Background="White"
                    BorderBrush="#D1D5DB"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="12">

                <StackPanel>
                    <TextBlock Text="Calculated Discount"
                               FontSize="16"
                               FontWeight="Bold"
                               Foreground="#111827"
                               Margin="0,0,0,10"/>

                    <TextBlock Text="Discount Amount" Style="{StaticResource LabelText}"/>
                    <TextBlock Text="{Binding CalculatedDiscountAmount, StringFormat=N2}"
                               FontSize="28"
                               FontWeight="Heavy"
                               Foreground="#DC2626"
                               TextAlignment="Right"
                               Margin="0,0,0,10"/>

                    <TextBlock Text="Line Total After Discount" Style="{StaticResource LabelText}"/>
                    <TextBlock Text="{Binding LineTotalAfterDiscount, StringFormat=N2}"
                               FontSize="28"
                               FontWeight="Heavy"
                               Foreground="#047857"
                               TextAlignment="Right"
                               Margin="0,0,0,14"/>

                    <Border Background="#FEF3C7"
                            BorderBrush="#F59E0B"
                            BorderThickness="1"
                            CornerRadius="5"
                            Padding="8"
                            Margin="0,0,0,10"
                            Visibility="{Binding ApprovalRequired, Converter={StaticResource BoolToVisibility}}">

                        <StackPanel>
                            <TextBlock Text="Approval Required"
                                       FontWeight="Bold"
                                       Foreground="#92400E"
                                       FontSize="14"/>

                            <TextBlock Text="Manager/Admin mode must be active before confirming this discount."
                                       TextWrapping="Wrap"
                                       Foreground="#92400E"
                                       FontSize="12"
                                       Margin="0,4,0,0"/>

                            <TextBlock Text="Approved By" Style="{StaticResource LabelText}" Margin="0,8,0,0"/>
                            <TextBox Text="{Binding ApprovedBy, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="Remarks" Style="{StaticResource LabelText}"/>
                    <TextBox Text="{Binding Remarks, UpdateSourceTrigger=PropertyChanged}"
                             Height="70"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- STATUS -->
        <Border Grid.Row="3"
                Background="{Binding StatusColor}"
                CornerRadius="5"
                Padding="10"
                Margin="0,10,0,10">

            <TextBlock Text="{Binding StatusMessage}"
                       Foreground="White"
                       FontSize="14"
                       FontWeight="Bold"
                       TextWrapping="Wrap"/>
        </Border>

        <!-- ACTIONS -->
        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Text="Enter = Confirm, Esc = Cancel"
                       Foreground="#6B7280"
                       VerticalAlignment="Center"
                       FontWeight="SemiBold"/>

            <Button Grid.Column="1"
                    Content="Cancel"
                    Width="130"
                    Background="#6B7280"
                    Foreground="White"
                    BorderThickness="0"
                    Command="{Binding CancelCommand}"/>

            <Button Grid.Column="2"
                    Content="Apply Discount"
                    Width="160"
                    Background="#16A34A"
                    Foreground="White"
                    BorderThickness="0"
                    IsEnabled="{Binding CanConfirm}"
                    Command="{Binding ConfirmCommand}"/>
        </Grid>
    </Grid>
</Window>