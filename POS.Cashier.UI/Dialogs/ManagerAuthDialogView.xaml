<Window x:Class="POS.Cashier.UI.Dialogs.ManagerAuthDialogView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Manager Override" Height="360" Width="400"
        WindowStartupLocation="CenterOwner" WindowStyle="None" ResizeMode="NoResize"
        AllowsTransparency="True" Background="Transparent" FontFamily="Segoe UI, Arial">

    <Window.Resources>
        <!-- Native Clean Button Style -->
        <Style TargetType="Button" x:Key="NativeBtnStyle">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.85"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.5"/>
                    <Setter Property="Cursor" Value="No"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Clean Input Style -->
        <Style TargetType="Control" x:Key="CleanInputStyle">
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="#F8FAFC"/>
            <Setter Property="Foreground" Value="#0F172A"/>
        </Style>
    </Window.Resources>

    <Border Background="White" CornerRadius="8" BorderBrush="#94A3B8" BorderThickness="1" Margin="10">
        <Border.Effect>
            <DropShadowEffect BlurRadius="15" Opacity="0.3" ShadowDepth="4" Direction="270"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header (Using your HeaderBgBrush Color) -->
            <Border Background="#1E293B" CornerRadius="7,7,0,0" Padding="15">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock Text="🔒" Foreground="#F59E0B" FontSize="20" Margin="0,0,10,0"/>
                    <TextBlock Text="MANAGER AUTHORIZATION" Foreground="White" FontSize="16" FontWeight="Heavy" VerticalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- Body -->
            <StackPanel Grid.Row="1" Margin="30,20,30,10">
                <TextBlock Text="This action requires security clearance." Foreground="#64748B" FontSize="13" TextAlignment="Center" Margin="0,0,0,20" FontWeight="SemiBold"/>

                <TextBlock Text="Username" FontWeight="Bold" Foreground="#334155" Margin="0,0,0,5"/>
                <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}" Height="40" Style="{StaticResource CleanInputStyle}" Margin="0,0,0,15"/>

                <TextBlock Text="Password / PIN" FontWeight="Bold" Foreground="#334155" Margin="0,0,0,5"/>
                <PasswordBox x:Name="PwdBox" Height="40" Style="{StaticResource CleanInputStyle}" Margin="0,0,0,15"/>

                <!-- Error Message Banner -->
                <TextBlock Text="{Binding ErrorMessage}" Foreground="#EF4444" FontWeight="Bold" TextAlignment="Center" TextWrapping="Wrap" MinHeight="20"/>
            </StackPanel>

            <!-- Footer -->
            <Grid Grid.Row="2" Margin="30,10,30,25">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="15"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Cancel Button -->
                <Button Grid.Column="0" Content="CANCEL" Click="CancelBtn_Click" 
                        Height="45" Background="#E2E8F0" Foreground="#334155" Style="{StaticResource NativeBtnStyle}"/>

                <!-- Authorize Button (Using your ActionBtnBrush Color) -->
                <Button Grid.Column="2" Content="AUTHORIZE" 
                        Command="{Binding AuthenticateCommand}" CommandParameter="{Binding ElementName=PwdBox}" 
                        Height="45" Background="#3B82F6" Style="{StaticResource NativeBtnStyle}"/>
            </Grid>
        </Grid>
    </Border>
</Window>