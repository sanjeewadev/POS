<Window x:Class="POS.Cashier.UI.Dialogs.CashTenderDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:components="clr-namespace:POS.Cashier.UI.Components"
        Title="Cash Tender"
        Width="820"
        Height="455"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#D7DCE2"
        FontFamily="Segoe UI"
        FontSize="14"
        Loaded="Window_Loaded"
        PreviewKeyDown="Window_PreviewKeyDown">

    <Window.Resources>
        <Style TargetType="Button" x:Key="DialogButton">
            <Setter Property="Height" Value="44"/>
            <Setter Property="FontWeight" Value="Heavy"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderBrush" Value="#222"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <Style TargetType="TextBlock" x:Key="FieldLabel">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#111827"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style TargetType="TextBox" x:Key="MoneyInputBox">
            <Setter Property="Height" Value="48"/>
            <Setter Property="FontSize" Value="27"/>
            <Setter Property="FontWeight" Value="Heavy"/>
            <Setter Property="TextAlignment" Value="Right"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Background" Value="#FFFFCC"/>
            <Setter Property="Foreground" Value="#8B0000"/>
            <Setter Property="BorderBrush" Value="#555"/>
            <Setter Property="BorderThickness" Value="2"/>
        </Style>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="58"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="54"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0"
                Background="#0B3A53"
                BorderBrush="#1F2937"
                BorderThickness="1"
                Padding="14,0">

            <Grid>
                <TextBlock Text="CASH PAYMENT"
                           Foreground="White"
                           FontSize="25"
                           FontWeight="Heavy"
                           VerticalAlignment="Center"/>

                <TextBlock Text="Enter = Confirm   |   Esc = Cancel"
                           Foreground="#BFEAFF"
                           FontSize="13"
                           FontWeight="Bold"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- BODY -->
        <Grid Grid.Row="1" Margin="0,10,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="300"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT DETAILS -->
            <Border Grid.Column="0"
                    Background="White"
                    BorderBrush="#6B7280"
                    BorderThickness="1"
                    Padding="16"
                    Margin="0,0,10,0">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="48"/>
                        <RowDefinition Height="64"/>
                        <RowDefinition Height="64"/>
                        <RowDefinition Height="64"/>
                        <RowDefinition Height="64"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- STATUS -->
                    <Border Grid.Row="0"
                            Background="{Binding StatusColorHex}"
                            BorderBrush="#222"
                            BorderThickness="1"
                            Padding="8,0">

                        <TextBlock Text="{Binding StatusText}"
                                   Foreground="White"
                                   FontSize="14"
                                   FontWeight="Heavy"
                                   TextAlignment="Center"
                                   VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis"/>
                    </Border>

                    <!-- BALANCE DUE -->
                    <Grid Grid.Row="1" Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="165"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   Text="BALANCE DUE"
                                   Style="{StaticResource FieldLabel}"/>

                        <Border Grid.Column="1"
                                Background="#111827"
                                BorderBrush="#030712"
                                BorderThickness="2"
                                Padding="10,0">

                            <TextBlock Text="{Binding BalanceDue, StringFormat={}{0:N2}}"
                                       Foreground="#FBBF24"
                                       FontSize="30"
                                       FontWeight="Heavy"
                                       TextAlignment="Right"
                                       VerticalAlignment="Center"/>
                        </Border>
                    </Grid>

                    <!-- CASH TENDERED -->
                    <Grid Grid.Row="2" Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="165"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   Text="CASH TENDERED"
                                   Style="{StaticResource FieldLabel}"/>

                        <TextBox x:Name="TenderedAmountTextBox"
                                 Grid.Column="1"
                                 Text="{Binding TenderedAmountText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource MoneyInputBox}"
                                 GotKeyboardFocus="TenderedAmountTextBox_GotKeyboardFocus"
                                 PreviewMouseLeftButtonDown="TenderedAmountTextBox_PreviewMouseLeftButtonDown"/>
                    </Grid>

                    <!-- APPLY TO BILL -->
                    <Grid Grid.Row="3" Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="165"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   Text="APPLY TO BILL"
                                   Style="{StaticResource FieldLabel}"/>

                        <Border Grid.Column="1"
                                Background="#E8F5E9"
                                BorderBrush="#10B981"
                                BorderThickness="2"
                                Padding="10,0">

                            <TextBlock Text="{Binding AppliedAmount, StringFormat={}{0:N2}}"
                                       Foreground="#065F46"
                                       FontSize="26"
                                       FontWeight="Heavy"
                                       TextAlignment="Right"
                                       VerticalAlignment="Center"/>
                        </Border>
                    </Grid>

                    <!-- CHANGE / REMAINING -->
                    <Grid Grid.Row="4" Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="165"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   Text="CHANGE / BAL"
                                   Style="{StaticResource FieldLabel}"/>

                        <Border Grid.Column="1"
                                Background="#FFF7ED"
                                BorderBrush="#D97706"
                                BorderThickness="2"
                                Padding="10,0">

                            <TextBlock Text="{Binding ChangeOrRemainingText}"
                                       Foreground="#9A3412"
                                       FontSize="25"
                                       FontWeight="Heavy"
                                       TextAlignment="Right"
                                       VerticalAlignment="Center"/>
                        </Border>
                    </Grid>

                    <Border Grid.Row="5"
                            Background="#F3F4F6"
                            BorderBrush="#D1D5DB"
                            BorderThickness="1"
                            Padding="10"
                            Margin="0,16,0,0">

                        <TextBlock Text="Cash rules: exact cash completes the bill. Higher cash calculates change. Lower cash records partial payment and leaves the remaining balance for another payment method."
                                   Foreground="#374151"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap"/>
                    </Border>
                </Grid>
            </Border>

            <!-- RIGHT NUMPAD -->
            <components:TenderNumpadControl x:Name="TenderNumpad"
                                            Grid.Column="1"
                                            TargetText="{Binding TenderedAmountText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                            HeaderText="C A S H   E N T R Y"
                                            TargetLabel="CASH TENDERED"
                                            ModeText="AMOUNT"
                                            ShowDecimal="True"
                                            ShowDoubleZero="True"
                                            MaxLength="12"
                                            ClearValue=""
                                            SelectAllOnFirstKey="True"
                                            EnterPressed="TenderNumpad_EnterPressed"/>
        </Grid>

        <!-- FOOTER BUTTONS -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="135"/>
                <ColumnDefinition Width="165"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Text="Type amount using keyboard or touch numpad. Press Enter to confirm."
                       Foreground="#374151"
                       FontWeight="Bold"
                       VerticalAlignment="Center"/>

            <Button Grid.Column="1"
                    Content="CANCEL"
                    Style="{StaticResource DialogButton}"
                    Background="#6B7280"
                    Margin="0,0,8,0"
                    Click="CancelBtn_Click"/>

            <Button Grid.Column="2"
                    Content="CONFIRM CASH"
                    Style="{StaticResource DialogButton}"
                    Background="#10B981"
                    Click="ConfirmBtn_Click"/>
        </Grid>
    </Grid>
</Window>