<Window x:Class="POS.Cashier.UI.Dialogs.ChequeTenderDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:components="clr-namespace:POS.Cashier.UI.Components"
        Title="Cheque Tender"
        Width="890"
        Height="560"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#D7DCE2"
        FontFamily="Segoe UI"
        FontSize="14"
        Loaded="Window_Loaded"
        PreviewKeyDown="Window_PreviewKeyDown">

    <Window.Resources>
        <Style TargetType="Button" x:Key="DialogButton">
            <Setter Property="Height" Value="44"/>
            <Setter Property="FontWeight" Value="Heavy"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderBrush" Value="#222"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <Style TargetType="TextBlock" x:Key="FieldLabel">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#111827"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style TargetType="TextBox" x:Key="TenderInputBox">
            <Setter Property="Height" Value="45"/>
            <Setter Property="FontSize" Value="23"/>
            <Setter Property="FontWeight" Value="Heavy"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Background" Value="#FFFFCC"/>
            <Setter Property="Foreground" Value="#8B0000"/>
            <Setter Property="BorderBrush" Value="#555"/>
            <Setter Property="BorderThickness" Value="2"/>
        </Style>

        <Style TargetType="DatePicker" x:Key="TenderDatePicker">
            <Setter Property="Height" Value="45"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="8,0"/>
        </Style>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="58"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="54"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0"
                Background="#92400E"
                BorderBrush="#1F2937"
                BorderThickness="1"
                Padding="14,0">

            <Grid>
                <TextBlock Text="CHEQUE PAYMENT"
                           Foreground="White"
                           FontSize="25"
                           FontWeight="Heavy"
                           VerticalAlignment="Center"/>

                <TextBlock Text="Enter = Next / Confirm   |   Esc = Cancel"
                           Foreground="#FFE7C2"
                           FontSize="13"
                           FontWeight="Bold"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- BODY -->
        <Grid Grid.Row="1" Margin="0,10,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="300"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT DETAILS -->
            <Border Grid.Column="0"
                    Background="White"
                    BorderBrush="#6B7280"
                    BorderThickness="1"
                    Padding="16"
                    Margin="0,0,10,0">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="48"/>
                        <RowDefinition Height="56"/>
                        <RowDefinition Height="56"/>
                        <RowDefinition Height="56"/>
                        <RowDefinition Height="56"/>
                        <RowDefinition Height="56"/>
                        <RowDefinition Height="56"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- STATUS -->
                    <Border Grid.Row="0"
                            Background="{Binding StatusColorHex}"
                            BorderBrush="#222"
                            BorderThickness="1"
                            Padding="8,0">

                        <TextBlock Text="{Binding StatusText}"
                                   Foreground="White"
                                   FontSize="14"
                                   FontWeight="Heavy"
                                   TextAlignment="Center"
                                   VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis"/>
                    </Border>

                    <!-- BALANCE DUE -->
                    <Grid Grid.Row="1" Margin="0,9,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="165"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   Text="BALANCE DUE"
                                   Style="{StaticResource FieldLabel}"/>

                        <Border Grid.Column="1"
                                Background="#111827"
                                BorderBrush="#030712"
                                BorderThickness="2"
                                Padding="10,0">

                            <TextBlock Text="{Binding BalanceDue, StringFormat={}{0:N2}}"
                                       Foreground="#FBBF24"
                                       FontSize="25"
                                       FontWeight="Heavy"
                                       TextAlignment="Right"
                                       VerticalAlignment="Center"/>
                        </Border>
                    </Grid>

                    <!-- CHEQUE AMOUNT -->
                    <Grid Grid.Row="2" Margin="0,9,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="165"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   Text="CHEQUE AMOUNT"
                                   Style="{StaticResource FieldLabel}"/>

                        <TextBox x:Name="ChequeAmountTextBox"
                                 Grid.Column="1"
                                 Text="{Binding ChequeAmountText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource TenderInputBox}"
                                 TextAlignment="Right"
                                 GotKeyboardFocus="ChequeAmountTextBox_GotKeyboardFocus"
                                 PreviewMouseLeftButtonDown="ChequeAmountTextBox_PreviewMouseLeftButtonDown"/>
                    </Grid>

                    <!-- CHEQUE NO -->
                    <Grid Grid.Row="3" Margin="0,9,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="165"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   Text="CHEQUE NO"
                                   Style="{StaticResource FieldLabel}"/>

                        <TextBox x:Name="ChequeNoTextBox"
                                 Grid.Column="1"
                                 Text="{Binding ChequeNo, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource TenderInputBox}"
                                 Background="White"
                                 Foreground="#111827"
                                 TextAlignment="Center"
                                 MaxLength="20"
                                 GotKeyboardFocus="ChequeNoTextBox_GotKeyboardFocus"
                                 PreviewMouseLeftButtonDown="ChequeNoTextBox_PreviewMouseLeftButtonDown"/>
                    </Grid>

                    <!-- BANK NAME -->
                    <Grid Grid.Row="4" Margin="0,9,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="165"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   Text="BANK NAME"
                                   Style="{StaticResource FieldLabel}"/>

                        <TextBox x:Name="BankNameTextBox"
                                 Grid.Column="1"
                                 Text="{Binding BankName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource TenderInputBox}"
                                 Background="White"
                                 Foreground="#111827"
                                 FontSize="18"
                                 FontWeight="Bold"
                                 TextAlignment="Left"
                                 CharacterCasing="Upper"
                                 GotKeyboardFocus="BankNameTextBox_GotKeyboardFocus"
                                 PreviewMouseLeftButtonDown="BankNameTextBox_PreviewMouseLeftButtonDown"/>
                    </Grid>

                    <!-- BRANCH -->
                    <Grid Grid.Row="5" Margin="0,9,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="165"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   Text="BRANCH"
                                   Style="{StaticResource FieldLabel}"/>

                        <TextBox x:Name="BranchNameTextBox"
                                 Grid.Column="1"
                                 Text="{Binding BranchName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource TenderInputBox}"
                                 Background="White"
                                 Foreground="#111827"
                                 FontSize="18"
                                 FontWeight="Bold"
                                 TextAlignment="Left"
                                 CharacterCasing="Upper"
                                 GotKeyboardFocus="BranchNameTextBox_GotKeyboardFocus"
                                 PreviewMouseLeftButtonDown="BranchNameTextBox_PreviewMouseLeftButtonDown"/>
                    </Grid>

                    <!-- CHEQUE DATE / REMAINING -->
                    <Grid Grid.Row="6" Margin="0,9,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="165"/>
                            <ColumnDefinition Width="1.2*"/>
                            <ColumnDefinition Width="110"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   Text="CHEQUE DATE"
                                   Style="{StaticResource FieldLabel}"/>

                        <DatePicker x:Name="ChequeDatePicker"
                                    Grid.Column="1"
                                    SelectedDate="{Binding ChequeDate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    Style="{StaticResource TenderDatePicker}"
                                    GotKeyboardFocus="ChequeDatePicker_GotKeyboardFocus"/>

                        <TextBlock Grid.Column="2"
                                   Text="REMAINING"
                                   Style="{StaticResource FieldLabel}"
                                   Margin="12,0,8,0"/>

                        <Border Grid.Column="3"
                                Background="#FFF7ED"
                                BorderBrush="#D97706"
                                BorderThickness="2"
                                Padding="8,0">

                            <TextBlock Text="{Binding RemainingAfterCheque, StringFormat={}{0:N2}}"
                                       Foreground="#9A3412"
                                       FontSize="20"
                                       FontWeight="Heavy"
                                       TextAlignment="Right"
                                       VerticalAlignment="Center"/>
                        </Border>
                    </Grid>

                    <Border Grid.Row="7"
                            Background="#F3F4F6"
                            BorderBrush="#D1D5DB"
                            BorderThickness="1"
                            Padding="10"
                            Margin="0,14,0,0">

                        <TextBlock Text="Cheque rules: cheque number and bank name are required. Post-dated cheques are allowed for now. Cheque payment completes the invoice but does not count as physical cash in drawer."
                                   Foreground="#374151"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap"/>
                    </Border>
                </Grid>
            </Border>

            <!-- RIGHT NUMPAD -->
            <components:TenderNumpadControl x:Name="TenderNumpad"
                                            Grid.Column="1"
                                            TargetText="{Binding ActiveInputText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                            HeaderText="{Binding ActiveNumpadHeader}"
                                            TargetLabel="{Binding ActiveTargetLabel}"
                                            ModeText="{Binding ActiveModeText}"
                                            ShowDecimal="{Binding ActiveShowDecimal}"
                                            ShowDoubleZero="{Binding ActiveShowDoubleZero}"
                                            MaxLength="{Binding ActiveMaxLength}"
                                            ClearValue=""
                                            SelectAllOnFirstKey="True"
                                            EnterPressed="TenderNumpad_EnterPressed"/>
        </Grid>

        <!-- FOOTER BUTTONS -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="135"/>
                <ColumnDefinition Width="175"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Text="Keyboard and touch numpad both work for amount and cheque number."
                       Foreground="#374151"
                       FontWeight="Bold"
                       VerticalAlignment="Center"/>

            <Button Grid.Column="1"
                    Content="CANCEL"
                    Style="{StaticResource DialogButton}"
                    Background="#6B7280"
                    Margin="0,0,8,0"
                    Click="CancelBtn_Click"/>

            <Button Grid.Column="2"
                    Content="CONFIRM CHEQUE"
                    Style="{StaticResource DialogButton}"
                    Background="#92400E"
                    Click="ConfirmBtn_Click"/>
        </Grid>
    </Grid>
</Window>