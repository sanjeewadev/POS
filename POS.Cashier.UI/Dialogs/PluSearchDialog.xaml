<Window x:Class="POS.Cashier.UI.Dialogs.PluSearchDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Item Search" Height="600" Width="900"
        WindowStartupLocation="CenterScreen" WindowStyle="None" ResizeMode="NoResize"
        Background="#F3F4F6" BorderBrush="#1F2937" BorderThickness="3" FontFamily="Segoe UI, Arial">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="80"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="80"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#111827">
            <TextBlock Text="ITEM SEARCH (SEEK)" Foreground="White" FontSize="24" FontWeight="Heavy" HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Border>

        <Border Grid.Row="1" Background="White" BorderBrush="#E5E7EB" BorderThickness="0,0,0,2">
            <Grid Margin="15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Search Keyword:" FontSize="18" FontWeight="Bold" Foreground="#374151" VerticalAlignment="Center" Margin="0,0,15,0"/>
                <TextBox Grid.Column="1" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" FontSize="22" FontWeight="Bold" Padding="10,5" VerticalContentAlignment="Center" BorderBrush="#9CA3AF" BorderThickness="2" Margin="0,0,15,0"/>
                <Button Grid.Column="2" Command="{Binding SearchCommand}" Background="#3B82F6" Foreground="White" FontWeight="Bold" Content="SEARCH" Margin="0,0,10,0" Width="120"/>
                <Button Grid.Column="3" Command="{Binding ClearSearchCommand}" Background="#6B7280" Foreground="White" FontWeight="Bold" Content="CLEAR" Width="100"/>
            </Grid>
        </Border>

        <DataGrid x:Name="ResultsGrid" Grid.Row="2" ItemsSource="{Binding SearchResults}" MouseDoubleClick="ResultsGrid_MouseDoubleClick"
                  AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Single" SelectionUnit="FullRow"
                  Background="White" RowHeight="50" FontSize="18" Margin="15">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Barcode" Binding="{Binding Barcode}" Width="150"/>
                <DataGridTextColumn Header="Short Code" Binding="{Binding SkuCode}" Width="120"/>
                <DataGridTextColumn Header="Item Description" Binding="{Binding ItemParent.ItemName}" Width="*"/>
                <DataGridTextColumn Header="Price (Rs.)" Binding="{Binding RetailPrice, StringFormat=N2}" Width="150" />
            </DataGrid.Columns>
        </DataGrid>

        <Border Grid.Row="3" Background="#F9FAFB" BorderBrush="#E5E7EB" BorderThickness="0,2,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,20,0">
                <Button Click="CloseBtn_Click" Background="#EF4444" Foreground="White" FontWeight="Bold" Content="CANCEL" Width="120" Height="40" Margin="0,0,15,0"/>
                <Button Click="SelectBtn_Click" Background="#10B981" Foreground="White" FontWeight="Bold" Content="SELECT &amp; ADD" Width="180" Height="40"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>