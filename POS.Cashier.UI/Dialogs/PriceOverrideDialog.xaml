<Window x:Class="POS.Cashier.UI.Dialogs.PriceOverrideDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Manager Override" Height="500" Width="600"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="{StaticResource MainBgBrush}"
        BorderBrush="{StaticResource HeaderBgBrush}"
        BorderThickness="3"
        FontFamily="Arial">

    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource TextLightBrush}"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="5" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="45"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="70"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource CancelBtnBrush}">
            <TextBlock Text="AUTHORIZATION REQUIRED" Foreground="{StaticResource TextLightBrush}" FontSize="20" FontWeight="Heavy" HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Border>

        <Grid Grid.Row="1" Margin="15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="250"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Margin="0,0,20,0" VerticalAlignment="Center">
                <TextBlock Text="Target Item:" FontSize="14" FontWeight="Bold" Foreground="{StaticResource TextInactiveBrush}"/>
                <TextBlock Text="{Binding SelectedItemName, FallbackValue='Selected Item Name'}" FontSize="16" FontWeight="Heavy" Foreground="{StaticResource TextDarkBrush}" Margin="0,5,0,20" TextWrapping="Wrap"/>

                <TextBlock Text="New Price (Rs.):" FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextDarkBrush}"/>
                <TextBox x:Name="txtNewPrice" Text="{Binding NewPrice, StringFormat=N2}" FontSize="36" FontWeight="Heavy" TextAlignment="Right" Foreground="{StaticResource TextHighlightBrush}" Margin="0,5,0,20" Background="White" Padding="10" BorderBrush="{StaticResource ControlBorderBrush}" BorderThickness="2"/>

                <TextBlock Text="Manager PIN:" FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextDangerBrush}"/>
                <PasswordBox x:Name="txtPin" FontSize="36" Background="#FFF7ED" BorderBrush="{StaticResource PaymentOrangeBrush}" BorderThickness="2" Margin="0,5,0,0" Padding="10" HorizontalContentAlignment="Center"/>
            </StackPanel>

            <UniformGrid Grid.Column="1" Columns="3" Rows="4">
                <Button Background="{StaticResource NumpadBtnBrush}" Content="7" FontSize="26"/>
                <Button Background="{StaticResource NumpadBtnBrush}" Content="8" FontSize="26"/>
                <Button Background="{StaticResource NumpadBtnBrush}" Content="9" FontSize="26"/>
                <Button Background="{StaticResource NumpadBtnBrush}" Content="4" FontSize="26"/>
                <Button Background="{StaticResource NumpadBtnBrush}" Content="5" FontSize="26"/>
                <Button Background="{StaticResource NumpadBtnBrush}" Content="6" FontSize="26"/>
                <Button Background="{StaticResource NumpadBtnBrush}" Content="1" FontSize="26"/>
                <Button Background="{StaticResource NumpadBtnBrush}" Content="2" FontSize="26"/>
                <Button Background="{StaticResource NumpadBtnBrush}" Content="3" FontSize="26"/>
                <Button Background="{StaticResource NumpadBtnBrush}" Content="C" FontSize="22"/>
                <Button Background="{StaticResource NumpadBtnBrush}" Content="0" FontSize="26"/>
                <Button Background="{StaticResource NumpadBtnBrush}" Content="." FontSize="26"/>
            </UniformGrid>
        </Grid>

        <Grid Grid.Row="2" Background="{StaticResource HeaderBgBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Button Click="CancelBtn_Click" Grid.Column="0" Background="{StaticResource NumpadBtnBrush}" Content="CANCEL" FontSize="20" Margin="10,10,5,10"/>
            <Button Click="ConfirmBtn_Click" Grid.Column="1" Background="{StaticResource ActionBtnBrush}" Content="AUTHORIZE OVERRIDE" FontSize="20" Margin="5,10,10,10"/>
        </Grid>
    </Grid>
</Window>