<Window x:Class="POS.Cashier.UI.Views.Dialogs.ManagerAuthDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Manager Authorization" Height="550" Width="400"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None" ResizeMode="NoResize"
        Background="#1E1E1E"
        BorderBrush="#DC3545" BorderThickness="3"
        FontFamily="Segoe UI, Arial">

    <Window.Resources>
        <Style TargetType="Button" x:Key="NumpadBtn">
            <Setter Property="Background" Value="#2B2B2B"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="28"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderBrush" Value="#444444"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="100"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="70"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#DC3545">
            <TextBlock Text="MANAGER AUTHORIZATION" Foreground="White" FontSize="20" FontWeight="Heavy" HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Border>

        <StackPanel Grid.Row="1" VerticalAlignment="Center" Margin="20,0">
            <TextBlock Text="ENTER PIN TO CONTINUE" Foreground="#AAAAAA" FontSize="14" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,10"/>
            <PasswordBox x:Name="PinBox" PasswordChar="●" FontSize="36" Height="50" Background="#111111" Foreground="#FFD700" HorizontalContentAlignment="Center" BorderBrush="#444444" BorderThickness="2" IsEnabled="False"/>
        </StackPanel>

        <UniformGrid Grid.Row="2" Columns="3" Rows="4" Margin="15,0,15,10">
            <Button Style="{StaticResource NumpadBtn}" Content="7" Click="NumpadBtn_Click"/>
            <Button Style="{StaticResource NumpadBtn}" Content="8" Click="NumpadBtn_Click"/>
            <Button Style="{StaticResource NumpadBtn}" Content="9" Click="NumpadBtn_Click"/>

            <Button Style="{StaticResource NumpadBtn}" Content="4" Click="NumpadBtn_Click"/>
            <Button Style="{StaticResource NumpadBtn}" Content="5" Click="NumpadBtn_Click"/>
            <Button Style="{StaticResource NumpadBtn}" Content="6" Click="NumpadBtn_Click"/>

            <Button Style="{StaticResource NumpadBtn}" Content="1" Click="NumpadBtn_Click"/>
            <Button Style="{StaticResource NumpadBtn}" Content="2" Click="NumpadBtn_Click"/>
            <Button Style="{StaticResource NumpadBtn}" Content="3" Click="NumpadBtn_Click"/>

            <Button Style="{StaticResource NumpadBtn}" Content="C" Background="#DC3545" Click="ClearBtn_Click"/>
            <Button Style="{StaticResource NumpadBtn}" Content="0" Click="NumpadBtn_Click"/>
            <Button Style="{StaticResource NumpadBtn}" Content="OK" Background="#28A745" Click="ConfirmBtn_Click"/>
        </UniformGrid>

        <Button Grid.Row="3" Background="#111111" Foreground="#AAAAAA" Content="CANCEL &amp; RETURN" FontSize="16" FontWeight="Bold" BorderThickness="0" Cursor="Hand" Click="CancelBtn_Click"/>
    </Grid>
</Window>