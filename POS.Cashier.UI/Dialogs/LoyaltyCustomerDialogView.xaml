<Window x:Class="POS.Cashier.UI.Dialogs.LoyaltyCustomerDialogView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding DialogTitle}"
        Height="680"
        Width="1080"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#D4D0C8"
        FontFamily="Segoe UI"
        FontSize="13"
        Loaded="Window_Loaded">

    <Window.InputBindings>
        <KeyBinding Key="Escape" Command="{Binding CancelCommand}" />
    </Window.InputBindings>

    <Window.Resources>
        <Style TargetType="Button" x:Key="ClassicBtn">
            <Setter Property="Height" Value="42"/>
            <Setter Property="Background" Value="#E0E0E0"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderBrush" Value="#808080"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style TargetType="Button" x:Key="AttachBtn" BasedOn="{StaticResource ClassicBtn}">
            <Setter Property="Background" Value="#005500"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#003300"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Height" Value="45"/>
        </Style>

        <Style TargetType="TextBox" x:Key="SearchInput">
            <Setter Property="Height" Value="38"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Background" Value="#FFFFE0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="6,0"/>
            <Setter Property="BorderBrush" Value="#808080"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style TargetType="TextBlock" x:Key="InfoLabel">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <Grid Margin="5">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0"
                Background="#005500"
                Padding="9"
                Margin="0,0,0,5"
                BorderBrush="#003300"
                BorderThickness="1">

            <Grid>
                <TextBlock Text="LOYALTY CUSTOMER LOOKUP"
                           Foreground="White"
                           FontSize="19"
                           FontWeight="Heavy"
                           HorizontalAlignment="Center"/>

                <TextBlock Text="Retail customers with Loyalty enabled only"
                           Foreground="#D1FAE5"
                           FontSize="12"
                           FontWeight="Bold"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- BODY -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="350"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT DIRECTORY -->
            <GroupBox Grid.Column="0"
                      Header="Retail Loyalty Customers"
                      FontSize="15"
                      FontWeight="Bold"
                      Foreground="#005500"
                      BorderBrush="#808080"
                      Background="#F0F0F0">

                <Grid Margin="5">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- SEARCH -->
                    <Grid Grid.Row="0" Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="115"/>
                            <ColumnDefinition Width="115"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   Text="{Binding SearchLabel}"
                                   FontWeight="SemiBold"
                                   Foreground="Black"
                                   FontSize="14"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0"/>

                        <TextBox x:Name="SearchTxt"
                                 Grid.Column="1"
                                 Text="{Binding SearchTerm, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource SearchInput}">
                            <TextBox.InputBindings>
                                <KeyBinding Key="Enter" Command="{Binding SearchCommand}" />
                            </TextBox.InputBindings>
                        </TextBox>

                        <Button Grid.Column="2"
        Content="SEARCH"
        Command="{Binding SearchCommand}"
        Style="{StaticResource ClassicBtn}"
        Height="38"
        Margin="8,0,0,0"/>

                        <Button Grid.Column="3"
        Content="REFRESH"
        Click="RefreshBtn_Click"
        Style="{StaticResource ClassicBtn}"
        Height="38"
        Margin="8,0,0,0"/>
                    </Grid>

                    <!-- GRID -->
                    <DataGrid Grid.Row="1"
                              x:Name="CustomerDataGrid"
                              ItemsSource="{Binding Customers}"
                              SelectedItem="{Binding SelectedCustomer}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              IsReadOnly="True"
                              HeadersVisibility="Column"
                              GridLinesVisibility="All"
                              HorizontalGridLinesBrush="#C0C0C0"
                              VerticalGridLinesBrush="#D0D0D0"
                              RowHeight="36"
                              FontSize="14"
                              Background="White"
                              SelectionMode="Single"
                              BorderBrush="#808080"
                              BorderThickness="1"
                              Foreground="Black"
                              MouseDoubleClick="CustomerDataGrid_MouseDoubleClick">

                        <DataGrid.Resources>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="#E0E0E0"/>
                                <Setter Property="Foreground" Value="Black"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="Padding" Value="5"/>
                                <Setter Property="BorderBrush" Value="#A0A0A0"/>
                                <Setter Property="BorderThickness" Value="0,0,1,1"/>
                            </Style>

                            <Style TargetType="DataGridCell">
                                <Setter Property="VerticalContentAlignment" Value="Center"/>
                                <Setter Property="Padding" Value="5,0"/>
                            </Style>
                        </DataGrid.Resources>

                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Code"
                                                Binding="{Binding CustomerCode}"
                                                Width="110"
                                                FontWeight="Bold"/>

                            <DataGridTextColumn Header="Customer Name"
                                                Binding="{Binding FullName}"
                                                Width="*"
                                                FontWeight="Bold"
                                                Foreground="#003366"/>

                            <DataGridTextColumn Header="Phone"
                                                Binding="{Binding Phone}"
                                                Width="130"/>

                            <DataGridTextColumn Header="Birthday"
                                                Binding="{Binding Birthday, StringFormat=MMM dd}"
                                                Width="90"/>

                            <DataGridTextColumn Header="Loyalty"
                                                Binding="{Binding DiscountLabel}"
                                                Width="120"
                                                FontWeight="Bold"
                                                Foreground="#005500"/>

                            <DataGridTextColumn Header="Credit"
                                                Binding="{Binding CreditStatusText}"
                                                Width="140"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </GroupBox>

            <!-- RIGHT DETAILS -->
            <GroupBox Grid.Column="2"
                      Header="Selected Loyalty Customer"
                      FontSize="15"
                      FontWeight="Bold"
                      Foreground="#005500"
                      BorderBrush="#808080"
                      Background="#F0F0F0">

                <Border Background="#E8E8E8"
                        BorderBrush="#C0C0C0"
                        BorderThickness="1"
                        Padding="12"
                        Margin="5">

                    <Grid>
                        <TextBlock Text="Select a loyalty customer."
                                   Foreground="#777"
                                   FontStyle="Italic"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsCustomerSelected}" Value="False">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <StackPanel>
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsCustomerSelected}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>

                            <TextBlock Text="{Binding DisplayCompanyName}"
                                       FontSize="20"
                                       FontWeight="Heavy"
                                       Foreground="#003366"
                                       HorizontalAlignment="Center"
                                       TextWrapping="Wrap"
                                       TextAlignment="Center"
                                       Margin="0,0,0,8"/>

                            <TextBlock Text="{Binding DisplayContactName}"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="#333333"
                                       HorizontalAlignment="Center"
                                       TextWrapping="Wrap"
                                       TextAlignment="Center"
                                       Margin="0,0,0,15"/>

                            <Border Background="White"
                                    BorderBrush="#A0A0A0"
                                    BorderThickness="1"
                                    Padding="10"
                                    Margin="0,0,0,12">

                                <StackPanel>
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="130"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Text="Type:" Style="{StaticResource InfoLabel}"/>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding DisplayCustomerType}"
                                                   FontWeight="Heavy"
                                                   Foreground="#003366"
                                                   HorizontalAlignment="Right"/>
                                    </Grid>

                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="130"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Text="Loyalty:" Style="{StaticResource InfoLabel}"/>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding DisplayDiscountStatus}"
                                                   FontWeight="Heavy"
                                                   Foreground="#005500"
                                                   HorizontalAlignment="Right"/>
                                    </Grid>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="130"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Text="Credit:" Style="{StaticResource InfoLabel}"/>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding DisplayCreditStatus}"
                                                   FontWeight="Heavy"
                                                   Foreground="#8B0000"
                                                   HorizontalAlignment="Right"
                                                   TextWrapping="Wrap"
                                                   TextAlignment="Right"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <Border Background="#F0FFF4"
                                    BorderBrush="#4CAF50"
                                    BorderThickness="1"
                                    Padding="10"
                                    Margin="0,0,0,12">

                                <TextBlock Text="This button is only a shortcut. It attaches the same CustomerMaster record to the sale. Manual discount rules will be applied later from the discount engine."
                                           Foreground="#064E3B"
                                           TextWrapping="Wrap"
                                           FontSize="12"
                                           FontWeight="SemiBold"/>
                            </Border>

                            <Border Background="#FFCCCC"
                                    BorderBrush="#8B0000"
                                    BorderThickness="2"
                                    Padding="10">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsAccountLocked}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>

                                <TextBlock Text="{Binding LockReasonText}"
                                           Foreground="#8B0000"
                                           FontWeight="Heavy"
                                           FontSize="14"
                                           HorizontalAlignment="Center"
                                           TextAlignment="Center"
                                           TextWrapping="Wrap"/>
                            </Border>
                        </StackPanel>
                    </Grid>
                </Border>
            </GroupBox>
        </Grid>

        <!-- FOOTER -->
        <Grid Grid.Row="2" Margin="0,5,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="150"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="300"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0"
                    Content="CLOSE"
                    Command="{Binding CancelCommand}"
                    Style="{StaticResource ClassicBtn}"/>

            <TextBlock Grid.Column="1"
                       Text="Double-click a customer row or press Attach."
                       Foreground="#333333"
                       FontWeight="SemiBold"
                       VerticalAlignment="Center"
                       Margin="10,0"/>

            <Button Grid.Column="2"
                    Content="{Binding AttachButtonText}"
                    Command="{Binding AttachCommand}"
                    IsEnabled="{Binding CanAttachToInvoice}"
                    Style="{StaticResource AttachBtn}"/>
        </Grid>
    </Grid>
</Window>