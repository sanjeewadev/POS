<Window x:Class="POS.Cashier.UI.Views.Dialogs.CustomerManagementDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Customer Management" Height="650" Width="700"
        WindowStartupLocation="CenterOwner" WindowStyle="None" ResizeMode="NoResize"
        Background="#1E1E1E" FontFamily="Segoe UI, Arial">

    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="3"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#444444"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="5"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TextBox" x:Key="FlatTextBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="22"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="50"/>
        </Style>

        <Style TargetType="ComboBox" x:Key="FlatComboBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="22"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="50"/>
        </Style>

        <Style TargetType="TextBlock" x:Key="FormLabel">
            <Setter Property="Foreground" Value="#AAAAAA"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#0056B3" BorderBrush="#111111" BorderThickness="0,0,0,2">
            <TextBlock Text="CUSTOMER REGISTRATION" Foreground="White" FontSize="28" FontWeight="Heavy" HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Border>

        <Border Grid.Row="1" Background="#2B2B2B" BorderBrush="#444444" BorderThickness="1" Margin="15" Padding="25">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="70"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,20">
                    <TextBlock Text="PRIMARY PHONE NUMBER" Style="{StaticResource FormLabel}"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="120"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Style="{StaticResource FlatTextBox}" Text="{Binding PhoneNumber}" MaxLength="15"/>
                        <Button Grid.Column="1" Background="#444444" Content="SEARCH" FontSize="18" Margin="10,0,0,0"/>
                    </Grid>
                </StackPanel>

                <StackPanel Grid.Row="1" Margin="0,0,0,20">
                    <TextBlock Text="FULL NAME / COMPANY NAME" Style="{StaticResource FormLabel}"/>
                    <TextBox Style="{StaticResource FlatTextBox}" Text="{Binding CustomerName}"/>
                </StackPanel>

                <StackPanel Grid.Row="2" Margin="0,0,0,20">
                    <TextBlock Text="ADDRESS / CITY" Style="{StaticResource FormLabel}"/>
                    <TextBox Style="{StaticResource FlatTextBox}" Text="{Binding Address}"/>
                </StackPanel>

                <Grid Grid.Row="3" Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="CUSTOMER TYPE" Style="{StaticResource FormLabel}"/>
                        <ComboBox Style="{StaticResource FlatComboBox}" SelectedValue="{Binding CustomerType}">
                            <ComboBoxItem Content="Retail"/>
                            <ComboBoxItem Content="Wholesale"/>
                            <ComboBoxItem Content="VIP"/>
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="CREDIT LIMIT (Rs.)" Style="{StaticResource FormLabel}"/>
                        <TextBox Style="{StaticResource FlatTextBox}" Foreground="#8B0000" TextAlignment="Right" Text="{Binding CreditLimit, StringFormat=N2}"/>
                    </StackPanel>
                </Grid>

                <Border Grid.Row="4" Background="#111111" BorderBrush="#444444" BorderThickness="1" Padding="15" Margin="0,10,0,20" VerticalAlignment="Top">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="CURRENT OUTSTANDING:" Foreground="#777777" FontSize="14" FontWeight="Bold"/>
                            <TextBlock Text="{Binding OutstandingBalance, StringFormat=Rs. \{0:N2\}, FallbackValue='Rs. 0.00'}" Foreground="#DC3545" FontSize="24" FontWeight="Heavy"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                            <TextBlock Text="AVAILABLE CREDIT:" Foreground="#777777" FontSize="14" FontWeight="Bold" TextAlignment="Right"/>
                            <TextBlock Text="{Binding AvailableCredit, StringFormat=Rs. \{0:N2\}, FallbackValue='Rs. 0.00'}" Foreground="#28A745" FontSize="24" FontWeight="Heavy" TextAlignment="Right"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <Grid Grid.Row="5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Background="#DC3545" Content="CANCEL" FontSize="22" Margin="0,0,5,0" Command="{Binding CancelCommand}"/>
                    <Button Grid.Column="1" Background="#28A745" Content="SAVE CUSTOMER" FontSize="24" FontWeight="Heavy" Margin="5,0,0,0" Command="{Binding SaveCustomerCommand}"/>
                </Grid>

            </Grid>
        </Border>
    </Grid>
</Window>