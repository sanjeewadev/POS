<Window x:Class="POS.Cashier.UI.Dialogs.DocumentTenderDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Document Tender" Height="480" Width="480"
        WindowStartupLocation="CenterScreen" 
        WindowStyle="None" 
        ResizeMode="NoResize"
        Background="{StaticResource MainBgBrush}" 
        BorderBrush="{StaticResource HeaderBgBrush}"
        BorderThickness="3"
        FontFamily="Arial, Segoe UI">

    <Window.Resources>
        <!-- Standard Button Style Match -->
        <Style TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource TextLightBrush}"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="5"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="45"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="70"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0" Background="{StaticResource HeaderBgBrush}">
            <TextBlock Text="CHEQUE PAYMENT" Foreground="{StaticResource TextLightBrush}" FontSize="20" FontWeight="Heavy" HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Border>

        <!-- INPUT FORM -->
        <Grid Grid.Row="1" Margin="25,20,25,20">
            <StackPanel VerticalAlignment="Center">

                <!-- AMOUNT DISPLAY -->
                <TextBlock Text="Total Amount (Rs.):" FontSize="15" FontWeight="Bold" Foreground="{StaticResource TextDarkBrush}"/>
                <TextBox x:Name="txtAmount" Background="White" Foreground="{StaticResource TextDangerBrush}" FontSize="32" FontWeight="Heavy" TextAlignment="Right" Padding="8,4" Margin="0,5,0,15" IsReadOnly="True" Text="{Binding TotalDue, StringFormat=N2, FallbackValue='0.00'}"/>

                <!-- BANK SELECT DROPDOWN -->
                <TextBlock Text="Select Bank:" FontSize="15" FontWeight="Bold" Foreground="{StaticResource TextDarkBrush}"/>
                <ComboBox x:Name="cmbBank" Height="45" FontSize="16" FontWeight="Bold" VerticalContentAlignment="Center" Padding="10,0" Margin="0,5,0,15">
                    <ComboBoxItem Content="Bank of Ceylon (BOC)" IsSelected="True"/>
                    <ComboBoxItem Content="Commercial Bank of Ceylon"/>
                    <ComboBoxItem Content="People's Bank"/>
                    <ComboBoxItem Content="Sampath Bank"/>
                    <ComboBoxItem Content="Hatton National Bank (HNB)"/>
                    <ComboBoxItem Content="Seylan Bank"/>
                    <ComboBoxItem Content="Nations Trust Bank (NTB)"/>
                    <ComboBoxItem Content="DFCC Bank"/>
                    <ComboBoxItem Content="NDB Bank"/>
                    <ComboBoxItem Content="Pan Asia Bank"/>
                    <ComboBoxItem Content="Union Bank of Colombo"/>
                    <ComboBoxItem Content="Amana Bank"/>
                    <ComboBoxItem Content="National Savings Bank (NSB)"/>
                </ComboBox>

                <!-- CHEQUE NUMBER -->
                <TextBlock Text="Cheque Number:" FontSize="15" FontWeight="Bold" Foreground="{StaticResource TextDarkBrush}"/>
                <TextBox x:Name="txtChequeNumber" Background="White" Foreground="Black" FontSize="22" FontWeight="Bold" Padding="8,6" Margin="0,5,0,10"/>

            </StackPanel>
        </Grid>

        <!-- FOOTER ACTIONS -->
        <Grid Grid.Row="2" Background="{StaticResource HeaderBgBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Button Click="CancelBtn_Click" Grid.Column="0" Background="{StaticResource CancelBtnBrush}" Content="CANCEL" FontSize="18" Margin="12,12,6,12"/>
            <Button Click="ConfirmBtn_Click" Grid.Column="1" Background="{StaticResource ExpressBtnBrush}" Content="APPLY" FontSize="18" Margin="6,12,12,12"/>
        </Grid>
    </Grid>
</Window>