<Window x:Class="POS.Cashier.UI.Views.Dialogs.UnifiedCheckoutView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Unified Checkout" Height="760" Width="1100"
        WindowStartupLocation="CenterScreen" WindowStyle="None" ResizeMode="NoResize"
        Background="#F4F6F9" FontFamily="Segoe UI">

    <Window.Resources>

        <Style TargetType="Button" x:Key="NumpadBtn">
            <Setter Property="FontSize" Value="24"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#D0D4DB"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#E2E6EA"/>
                                <Setter Property="BorderBrush" Value="#B0B5BD"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#F8F9FA"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button" x:Key="QuickTenderBtn">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="#0056B3"/>
            <Setter Property="Background" Value="#E6F2FF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#B3D7FF"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#CCE5FF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button" x:Key="ExactDueBtn" BasedOn="{StaticResource QuickTenderBtn}">
            <Setter Property="Foreground" Value="#155724"/>
            <Setter Property="Background" Value="#D4EDDA"/>
            <Setter Property="BorderBrush" Value="#C3E6CB"/>
        </Style>

        <Style TargetType="Button" x:Key="PaymentBtn">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Opacity" Value="0.8"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button" x:Key="CancelBtn">
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="#F8D7DA"/>
            <Setter Property="Foreground" Value="#721C24"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#F5C6CB"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#F1B0B7"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="Button" x:Key="CompleteSaleBtn">
            <Setter Property="FontSize" Value="22"/>
            <Setter Property="FontWeight" Value="Heavy"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#E0E0E0"/>
                    <Setter Property="Foreground" Value="#A0A0A0"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="True">
                    <Setter Property="Background" Value="#28A745"/>
                    <Setter Property="Foreground" Value="#FFFFFF"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.9"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#E9ECEF"/>
            <Setter Property="Foreground" Value="#495057"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="BorderBrush" Value="#DEE2E6"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#EEF0F2"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Style.Triggers>
                <Trigger Property="AlternationIndex" Value="1">
                    <Setter Property="Background" Value="#F8F9FA"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#E6F2FF"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#212529"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Padding" Value="10,6"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Foreground" Value="#0056B3"/>
                </Trigger>
            </Style.Triggers>
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#002244" Padding="15,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="CHECKOUT TERMINAL" Foreground="#FFFFFF" FontSize="20" FontWeight="Heavy" Margin="0,0,20,0"/>
                    <Border Background="#173E68" Padding="10,4" CornerRadius="4">
                        <TextBlock Text="MULTI-TENDER" Foreground="#A9C6E2" FontSize="12" FontWeight="Bold"/>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="INVOICE:" Foreground="#A9C6E2" FontSize="14" FontWeight="Bold" Margin="0,0,8,0" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding InvoiceNo}" Foreground="#FFD700" FontSize="18" FontWeight="Heavy" Margin="0,0,25,0" VerticalAlignment="Center"/>

                    <TextBlock Text="CUSTOMER:" Foreground="#A9C6E2" FontSize="14" FontWeight="Bold" Margin="0,0,8,0" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding CustomerName}" Foreground="#FFFFFF" FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>

                    <Button Command="{Binding CancelCommand}" Background="Transparent" BorderThickness="0" Margin="20,0,0,0" Cursor="Hand">
                        <TextBlock Text="✕" Foreground="#FFFFFF" FontSize="20" FontWeight="Bold"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="5.5*"/>
                <ColumnDefinition Width="4.5*"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0" Margin="0,0,15,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="#FFFFFF" BorderBrush="#D0D4DB" BorderThickness="1" CornerRadius="6" Padding="20,15" Margin="0,0,0,10">
                    <Grid>
                        <TextBlock Text="ENTER TENDER AMOUNT" Foreground="#6C757D" FontSize="14" FontWeight="Bold" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding TenderedInput, StringFormat=Rs. \{0\}}" Foreground="#002244" FontSize="50" FontWeight="Heavy" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                    </Grid>
                </Border>

                <UniformGrid Grid.Row="1" Columns="4" Rows="1" Height="60" Margin="0,0,0,10">
                    <Button Style="{StaticResource ExactDueBtn}" Content="EXACT DUE" Command="{Binding QuickTenderCommand}" CommandParameter="Exact"/>
                    <Button Style="{StaticResource QuickTenderBtn}" Content="{Binding QuickTender1, StringFormat=Rs. \{0:N0\}}" Command="{Binding QuickTenderCommand}" CommandParameter="{Binding QuickTender1}"/>
                    <Button Style="{StaticResource QuickTenderBtn}" Content="{Binding QuickTender2, StringFormat=Rs. \{0:N0\}}" Command="{Binding QuickTenderCommand}" CommandParameter="{Binding QuickTender2}"/>
                    <Button Style="{StaticResource QuickTenderBtn}" Content="{Binding QuickTender3, StringFormat=Rs. \{0:N0\}}" Command="{Binding QuickTenderCommand}" CommandParameter="{Binding QuickTender3}"/>
                </UniformGrid>

                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="6*"/>
                        <ColumnDefinition Width="4*"/>
                    </Grid.ColumnDefinitions>

                    <UniformGrid Grid.Column="0" Columns="3" Rows="4" Margin="0,0,10,0">
                        <Button Style="{StaticResource NumpadBtn}" Content="7" Click="Numpad_Click"/>
                        <Button Style="{StaticResource NumpadBtn}" Content="8" Click="Numpad_Click"/>
                        <Button Style="{StaticResource NumpadBtn}" Content="9" Click="Numpad_Click"/>
                        <Button Style="{StaticResource NumpadBtn}" Content="4" Click="Numpad_Click"/>
                        <Button Style="{StaticResource NumpadBtn}" Content="5" Click="Numpad_Click"/>
                        <Button Style="{StaticResource NumpadBtn}" Content="6" Click="Numpad_Click"/>
                        <Button Style="{StaticResource NumpadBtn}" Content="1" Click="Numpad_Click"/>
                        <Button Style="{StaticResource NumpadBtn}" Content="2" Click="Numpad_Click"/>
                        <Button Style="{StaticResource NumpadBtn}" Content="3" Click="Numpad_Click"/>
                        <Button Style="{StaticResource NumpadBtn}" Content="C" Click="NumpadClear_Click" Background="#F8D7DA" Foreground="#DC3545" BorderBrush="#F5C6CB"/>
                        <Button Style="{StaticResource NumpadBtn}" Content="0" Click="Numpad_Click"/>
                        <Button Style="{StaticResource NumpadBtn}" Content="." Click="Numpad_Click"/>
                    </UniformGrid>

                    <UniformGrid Grid.Column="1" Columns="1" Rows="7">
                        <Button Style="{StaticResource PaymentBtn}" Background="#28A745" Content="CASH" Command="{Binding AddPaymentCommand}" CommandParameter="Cash"/>
                        <Button Style="{StaticResource PaymentBtn}" Background="#0056B3" Content="CARD" Command="{Binding AddPaymentCommand}" CommandParameter="Card"/>
                        <Button Style="{StaticResource PaymentBtn}" Background="#E67E22" Content="CREDIT NOTE" Command="{Binding AddPaymentCommand}" CommandParameter="Credit Note"/>
                        <Button Style="{StaticResource PaymentBtn}" Background="#6C757D" Content="CHEQUE" Command="{Binding AddPaymentCommand}" CommandParameter="Cheque"/>
                        <Button Style="{StaticResource PaymentBtn}" Background="#17A2B8" Content="BANK TFR" Command="{Binding AddPaymentCommand}" CommandParameter="Bank Transfer"/>
                        <Button Style="{StaticResource PaymentBtn}" Background="#D32F2F" Content="CUST CREDIT" Command="{Binding AddPaymentCommand}" CommandParameter="Customer Credit"/>
                        <Button Style="{StaticResource PaymentBtn}" Background="#6F42C1" Content="LOYALTY PTS" Command="{Binding AddPaymentCommand}" CommandParameter="Loyalty"/>
                    </UniformGrid>
                </Grid>
            </Grid>

            <Border Grid.Column="1" Background="#FFFFFF" BorderBrush="#D0D4DB" BorderThickness="1" CornerRadius="6" Padding="15">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#002244" CornerRadius="4" Padding="15" Margin="0,0,0,15">
                        <Grid>
                            <TextBlock Text="TOTAL DUE" Foreground="#A9C6E2" FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding TotalDue, StringFormat=Rs. \{0:N2\}}" Foreground="#FFFFFF" FontSize="36" FontWeight="Heavy" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <DataGrid Grid.Row="1" ItemsSource="{Binding AppliedPayments}" AutoGenerateColumns="False" CanUserAddRows="False" 
                              HeadersVisibility="Column" RowHeight="45" Background="#FFFFFF" BorderBrush="#DEE2E6" BorderThickness="1"
                              GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#EEF0F2" AlternationCount="2" Margin="0,0,0,15">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Payment Type" Binding="{Binding PaymentType}" Width="120" IsReadOnly="True" FontWeight="Bold"/>
                            <DataGridTextColumn Header="Reference" Binding="{Binding ReferenceNo}" Width="*" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Amount" Binding="{Binding Amount, StringFormat=N2}" Width="120" IsReadOnly="True">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Right"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="Padding" Value="0,0,8,0"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTemplateColumn Width="50">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="✕" FontSize="14" FontWeight="Bold" Foreground="#FFFFFF" Background="#DC3545" BorderThickness="0" Margin="6" Cursor="Hand"
                                                Command="{Binding DataContext.RemovePaymentCommand, RelativeSource={RelativeSource AncestorType=Window}}" 
                                                CommandParameter="{Binding}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <StackPanel Grid.Row="2" Margin="0,0,0,20">
                        <Grid Margin="0,0,0,10">
                            <TextBlock Text="Total Tendered Applied:" FontSize="16" FontWeight="Bold" Foreground="#6C757D"/>
                            <TextBlock Text="{Binding TotalTendered, StringFormat=Rs. \{0:N2\}}" FontSize="18" FontWeight="Heavy" Foreground="#212529" HorizontalAlignment="Right"/>
                        </Grid>

                        <Border Background="#F8F9FA" BorderBrush="#E9ECEF" BorderThickness="2" CornerRadius="6" Padding="20,15">
                            <Grid>
                                <TextBlock Text="{Binding BalanceLabel}" FontSize="18" FontWeight="Bold" Foreground="#6C757D" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding BalanceAmount, StringFormat=Rs. \{0:N2\}}" FontSize="42" FontWeight="Heavy" HorizontalAlignment="Right">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="#DC3545"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsChangeDue}" Value="True">
                                                    <Setter Property="Foreground" Value="#28A745"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                        </Border>
                    </StackPanel>

                    <Grid Grid.Row="3" Height="65">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="15"/>
                            <ColumnDefinition Width="2.5*"/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0" Style="{StaticResource CancelBtn}" Content="CANCEL" Command="{Binding CancelCommand}"/>
                        <Button Grid.Column="2" Style="{StaticResource CompleteSaleBtn}" Content="COMPLETE SALE" Command="{Binding CompleteSaleCommand}"/>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>