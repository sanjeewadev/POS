<Window x:Class="POS.Cashier.UI.Dialogs.PayDialogView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Payment Dialog" Height="550" Width="900"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="{StaticResource MainBgBrush}"
        BorderBrush="{StaticResource HeaderBgBrush}"
        BorderThickness="3"
        FontFamily="Arial">

    <Window.Resources>
        <!-- Flat, Zero-Radius Button Style -->
        <Style TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource TextLightBrush}"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderBrush" Value="{StaticResource ControlBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="5" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,5,0,15"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{StaticResource NumpadBtnBrush}"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="BorderBrush" Value="{StaticResource HeaderBgBrush}"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="FontSize" Value="18"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="45"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="80"/>
        </Grid.RowDefinitions>

        <!-- Custom Header -->
        <Border Grid.Row="0" Background="{StaticResource HeaderBgBrush}">
            <TextBlock Text="CHECKOUT" Foreground="{StaticResource TextLightBrush}" FontSize="20" FontWeight="Heavy" HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Border>

        <!-- Main Content Area -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="4*"/>
                <ColumnDefinition Width="6*"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT SIDE: Order & Customer -->
            <Border Grid.Column="0" Background="{StaticResource InfoPanelBgBrush}" Padding="20" BorderBrush="{StaticResource HeaderBgBrush}" BorderThickness="0,0,2,0">
                <StackPanel>
                    <!-- Total Display -->
                    <TextBlock Text="TOTAL DUE" Foreground="{StaticResource HeaderBgBrush}" FontSize="18" FontWeight="Bold" Margin="0,0,0,5"/>
                    <Border Background="White" BorderBrush="{StaticResource HeaderBgBrush}" BorderThickness="2" Padding="10" Margin="0,0,0,30">
                        <TextBlock x:Name="TotalDueTxt" Text="0.00" Foreground="{StaticResource TextDangerBrush}" FontSize="48" FontWeight="Heavy" TextAlignment="Right"/>
                    </Border>

                    <!-- Customer Details -->
                    <TextBlock Text="Customer Name (Optional)" Foreground="{StaticResource TextBlackBrush}" FontSize="14" FontWeight="Bold"/>
                    <TextBox x:Name="CustomerNameTxt" />

                    <TextBlock Text="Phone Number (Optional)" Foreground="{StaticResource TextBlackBrush}" FontSize="14" FontWeight="Bold"/>
                    <TextBox x:Name="CustomerPhoneTxt" />
                </StackPanel>
            </Border>

            <!-- RIGHT SIDE: Payment Methods -->
            <Grid Grid.Column="1" Background="{StaticResource PopupBgBrush}" Margin="8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="50"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- TABS (Cash / Card) -->
                <UniformGrid Grid.Row="0" Columns="2" Margin="0,0,0,15">
                    <Button x:Name="CashTabBtn" Click="CashTabBtn_Click" Background="{StaticResource ActionBtnBrush}" Content="CASH" FontSize="20" Margin="0,0,5,0"/>
                    <Button x:Name="CardTabBtn" Click="CardTabBtn_Click" Background="{StaticResource HeaderBgBrush}" Content="CARD" FontSize="20" Margin="5,0,0,0" Foreground="{StaticResource TextInactiveBrush}"/>
                </UniformGrid>

                <!-- CASH PANEL (Visible) -->
                <Grid x:Name="CashPanel" Grid.Row="1" Visibility="Visible">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="220"/>
                    </Grid.ColumnDefinitions>

                    <!-- Input and Quick Cash -->
                    <StackPanel Grid.Column="0" Margin="0,0,15,0">
                        <TextBlock Text="Amount Tendered" Foreground="{StaticResource TextDarkBrush}" FontSize="14" FontWeight="Bold"/>
                        <TextBox x:Name="TenderedTxt" Text="0.00" FontSize="36" TextAlignment="Right" Foreground="{StaticResource TextHighlightBrush}"/>

                        <TextBlock Text="Balance to Return" Foreground="{StaticResource TextDarkBrush}" FontSize="14" FontWeight="Bold" Margin="0,10,0,0"/>
                        <TextBox x:Name="BalanceTxt" Text="0.00" FontSize="36" TextAlignment="Right" IsReadOnly="True" Background="{StaticResource DisabledBgBrush}" Foreground="{StaticResource TextBalanceBrush}"/>

                        <!-- Quick Cash Buttons -->
                        <UniformGrid Columns="2" Rows="2" Margin="0,15,0,0" Height="100">
                            <Button Background="{StaticResource PaymentOrangeBrush}" Foreground="{StaticResource TextBlackBrush}" Content="Exact"/>
                            <Button Background="{StaticResource PaymentOrangeBrush}" Foreground="{StaticResource TextBlackBrush}" Content="Rs. 500"/>
                            <Button Background="{StaticResource PaymentOrangeBrush}" Foreground="{StaticResource TextBlackBrush}" Content="Rs. 1000"/>
                            <Button Background="{StaticResource PaymentOrangeBrush}" Foreground="{StaticResource TextBlackBrush}" Content="Rs. 5000"/>
                        </UniformGrid>
                    </StackPanel>

                    <!-- Cash Numpad -->
                    <UniformGrid Grid.Column="1" Columns="3" Rows="4">
                        <Button Background="{StaticResource NumpadBtnBrush}" Content="7" FontSize="26"/>
                        <Button Background="{StaticResource NumpadBtnBrush}" Content="8" FontSize="26"/>
                        <Button Background="{StaticResource NumpadBtnBrush}" Content="9" FontSize="26"/>

                        <Button Background="{StaticResource NumpadBtnBrush}" Content="4" FontSize="26"/>
                        <Button Background="{StaticResource NumpadBtnBrush}" Content="5" FontSize="26"/>
                        <Button Background="{StaticResource NumpadBtnBrush}" Content="6" FontSize="26"/>

                        <Button Background="{StaticResource NumpadBtnBrush}" Content="1" FontSize="26"/>
                        <Button Background="{StaticResource NumpadBtnBrush}" Content="2" FontSize="26"/>
                        <Button Background="{StaticResource NumpadBtnBrush}" Content="3" FontSize="26"/>

                        <Button Background="{StaticResource NumpadBtnBrush}" Content="C" FontSize="22"/>
                        <Button Background="{StaticResource NumpadBtnBrush}" Content="0" FontSize="26"/>
                        <Button Background="{StaticResource NumpadBtnBrush}" Content="." FontSize="26"/>
                    </UniformGrid>
                </Grid>

                <!-- CARD PANEL (Hidden for now) -->
                <Grid x:Name="CardPanel" Grid.Row="1" Visibility="Collapsed">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="Please process payment on the Card Terminal." FontSize="20" FontWeight="Bold" Foreground="{StaticResource TextDarkBrush}" TextAlignment="Center" Margin="0,0,0,30"/>
                        <UniformGrid Columns="3" Height="80" Width="400">
                            <!-- Brand colors for card types are kept strictly as hex to match their real-world logos -->
                            <Button Background="White" Foreground="#0000CC" Content="VISA" FontSize="18" FontWeight="Heavy"/>
                            <Button Background="White" Foreground="#CC0000" Content="MasterCard" FontSize="16"/>
                            <Button Background="White" Foreground="#0099FF" Content="AMEX" FontSize="18"/>
                        </UniformGrid>
                    </StackPanel>
                </Grid>
            </Grid>
        </Grid>

        <!-- FOOTER: Action Buttons -->
        <Grid Grid.Row="2" Background="{StaticResource HeaderBgBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Button x:Name="CancelBtn" Click="CancelBtn_Click" Grid.Column="0" Background="{StaticResource CancelBtnBrush}" Content="CANCEL" FontSize="22" Margin="10,15,5,15"/>
            <Button x:Name="ConfirmBtn" Click="ConfirmBtn_Click" Grid.Column="1" Background="{StaticResource ExpressBtnBrush}" Content="CONFIRM PAYMENT" FontSize="22" Margin="5,15,10,15"/>
        </Grid>
    </Grid>
</Window>