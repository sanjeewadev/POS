<Window x:Class="POS.Cashier.UI.Dialogs.BatchSelectionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Select Batch"
        Width="760"
        Height="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F3F4F6"
        FontFamily="Segoe UI">

    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Height" Value="34"/>
            <Setter Property="Padding" Value="18,0"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#D4D0C8"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="6"/>
            <Setter Property="BorderBrush" Value="#808080"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Padding" Value="6,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="Black"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#0A246A"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="RightText" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextAlignment" Value="Right"/>
        </Style>

        <Style x:Key="CenterText" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0"
                Background="#003366"
                Padding="12"
                BorderBrush="#222222"
                BorderThickness="1">

            <StackPanel>
                <TextBlock Text="SELECT STOCK BATCH"
                           Foreground="White"
                           FontSize="18"
                           FontWeight="Heavy"/>

                <TextBlock Text="{Binding ItemDescription}"
                           Foreground="#E5E7EB"
                           FontSize="13"
                           FontWeight="SemiBold"
                           Margin="0,4,0,0"/>

                <TextBlock Text="{Binding RequestedQty, StringFormat={}Requested Qty: {0:N3}}"
                           Foreground="#FFDD77"
                           FontSize="13"
                           FontWeight="Bold"
                           Margin="0,2,0,0"/>
            </StackPanel>
        </Border>

        <!-- STATUS -->
        <Border Grid.Row="1"
                Background="{Binding StatusColorHex}"
                Padding="8"
                Margin="0,8,0,8">

            <TextBlock Text="{Binding StatusText}"
                       Foreground="White"
                       FontSize="14"
                       FontWeight="Bold"
                       TextAlignment="Center"/>
        </Border>

        <!-- BATCH GRID -->
        <DataGrid x:Name="BatchDataGrid"
                  Grid.Row="2"
                  ItemsSource="{Binding Batches}"
                  SelectedItem="{Binding SelectedBatch, Mode=TwoWay}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  HeadersVisibility="Column"
                  GridLinesVisibility="All"
                  HorizontalGridLinesBrush="#D0D0D0"
                  VerticalGridLinesBrush="#E0E0E0"
                  Background="White"
                  BorderBrush="#808080"
                  BorderThickness="1"
                  RowHeight="34"
                  FontSize="14"
                  SelectionMode="Single"
                  MouseDoubleClick="BatchDataGrid_MouseDoubleClick">

            <DataGrid.Columns>
                <DataGridTextColumn Header="Batch No"
                                    Binding="{Binding BatchNo}"
                                    Width="160"
                                    FontWeight="Bold"/>

                <DataGridTextColumn Header="Expiry"
                                    Binding="{Binding ExpiryDisplayText}"
                                    Width="110"
                                    ElementStyle="{StaticResource CenterText}"/>

                <DataGridTextColumn Header="Available Qty"
                                    Binding="{Binding AvailableQty, StringFormat={}{0:N3}}"
                                    Width="120"
                                    FontWeight="Bold"
                                    ElementStyle="{StaticResource RightText}"/>

                <DataGridTextColumn Header="Cost"
                                    Binding="{Binding CostPrice, StringFormat={}{0:N2}}"
                                    Width="90"
                                    ElementStyle="{StaticResource RightText}"/>

                <DataGridTextColumn Header="Retail"
                                    Binding="{Binding RetailPrice, StringFormat={}{0:N2}}"
                                    Width="90"
                                    ElementStyle="{StaticResource RightText}"/>

                <DataGridTextColumn Header="Received"
                                    Binding="{Binding ReceivedDateDisplayText}"
                                    Width="110"
                                    ElementStyle="{StaticResource CenterText}"/>

                <DataGridTextColumn Header="Warning"
                                    Binding="{Binding WarningText}"
                                    Width="*"
                                    FontWeight="Bold"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- BUTTONS -->
        <Grid Grid.Row="3" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Text="Double-click a batch or press Confirm."
                       Foreground="#666666"
                       VerticalAlignment="Center"
                       FontStyle="Italic"/>

            <Button Grid.Column="1"
                    Content="CANCEL"
                    Command="{Binding CancelCommand}"
                    Background="#6B7280"
                    Foreground="White"
                    Margin="0,0,8,0"/>

            <Button Grid.Column="2"
                    Content="CONFIRM BATCH"
                    Command="{Binding ConfirmCommand}"
                    Background="#10B981"
                    Foreground="White"/>
        </Grid>
    </Grid>
</Window>