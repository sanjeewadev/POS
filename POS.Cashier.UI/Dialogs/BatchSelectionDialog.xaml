<Window x:Class="POS.Cashier.UI.Dialogs.BatchSelectionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Select Batch" Height="500" Width="800"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="{StaticResource MainBgBrush}"
        BorderBrush="{StaticResource HeaderBgBrush}"
        BorderThickness="3"
        FontFamily="Arial">

    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource TextLightBrush}"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderBrush" Value="{StaticResource ControlBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="5" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="45"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="70"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource HeaderBgBrush}">
            <TextBlock Text="SELECT PHYSICAL BATCH" Foreground="{StaticResource TextLightBrush}" FontSize="20" FontWeight="Heavy" HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Border>

        <Border Grid.Row="1" Background="{StaticResource InfoPanelBgBrush}" Padding="15" BorderBrush="{StaticResource HeaderBgBrush}" BorderThickness="0,0,0,2">
            <TextBlock Text="Multiple batches exist for this item. Please select the batch you are scanning." Foreground="{StaticResource TextDangerBrush}" FontSize="16" FontWeight="Bold" TextAlignment="Center"/>
        </Border>

        <DataGrid x:Name="dgBatches" Grid.Row="2" ItemsSource="{Binding ActiveBatches}" SelectedItem="{Binding SelectedBatch}" 
                  AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True"
                  HeadersVisibility="Column" Background="White" RowHeight="40" FontSize="16" 
                  BorderThickness="0" SelectionMode="Single" AlternatingRowBackground="#F8FAFC" Margin="10">
            <DataGrid.Resources>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="{StaticResource HeaderBgBrush}"/>
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="FontWeight" Value="Bold"/>
                    <Setter Property="Padding" Value="10"/>
                </Style>
                <Style TargetType="DataGridCell">
                    <Setter Property="VerticalContentAlignment" Value="Center"/>
                    <Setter Property="Padding" Value="10,0"/>
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="{StaticResource ActionBtnBrush}"/>
                            <Setter Property="Foreground" Value="White"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.Resources>
            <DataGrid.Columns>
                <DataGridTextColumn Header="Batch No" Binding="{Binding BatchNo}" Width="150" FontWeight="Heavy"/>
                <DataGridTextColumn Header="Expiry Date" Binding="{Binding ExpiryDate, StringFormat=d}" Width="120"/>
                <DataGridTextColumn Header="In Stock" Binding="{Binding CurrentStock}" Width="100"/>
                <DataGridTextColumn Header="Retail Price" Binding="{Binding RetailPrice, StringFormat=N2}" Width="*" FontWeight="Bold" Foreground="{StaticResource TextHighlightBrush}"/>
            </DataGrid.Columns>
        </DataGrid>

        <Grid Grid.Row="3" Background="{StaticResource HeaderBgBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Button Click="CancelBtn_Click" Grid.Column="0" Background="{StaticResource CancelBtnBrush}" Content="CANCEL SCAN" FontSize="20" Margin="10,10,5,10"/>
            <Button Click="ConfirmBtn_Click" Grid.Column="1" Background="{StaticResource ExpressBtnBrush}" Content="SELECT BATCH" FontSize="20" Margin="5,10,10,10"/>
        </Grid>
    </Grid>
</Window>