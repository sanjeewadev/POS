<Window x:Class="POS.Cashier.UI.Dialogs.ProductSeekDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Product Look-Up (PLU)" Height="750" Width="950"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        Background="#ECE9D8" FontFamily="Segoe UI, Tahoma" Topmost="True" WindowStyle="None">

    <!-- Classic Native Windows / Java Swing Resource Styles -->
    <Window.Resources>
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#828790"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="RowHeaderWidth" Value="0"/>
            <Setter Property="GridLinesVisibility" Value="All"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#C0C0C0"/>
            <Setter Property="VerticalGridLinesBrush" Value="#C0C0C0"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="RowHeight" Value="28"/>
            <Setter Property="AlternatingRowBackground" Value="#F9F9F9"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#D4D0C8"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="BorderBrush" Value="#828790"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Padding" Value="4,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="Black"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#0A246A"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="Button" x:Key="ClassicBtn">
            <Setter Property="Background" Value="#D4D0C8"/>
            <Setter Property="BorderBrush" Value="#404040"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="15,5"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>

    <Border BorderBrush="#0A246A" BorderThickness="2">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- NATIVE HEADER BAR -->
            <Border Grid.Row="0" Background="#0A246A" Padding="8">
                <TextBlock Text="PRICE LOOK-UP (PLU) &amp; ITEM SEEK" Foreground="White" FontSize="16" FontWeight="Bold"/>
            </Border>

            <!-- SEARCH BAR -->
            <Border Grid.Row="1" Background="#ECE9D8" Padding="10" BorderBrush="#828790" BorderThickness="0,0,0,1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="100"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="Search (Name / SKU):" VerticalAlignment="Center" FontWeight="Bold" Margin="0,0,10,0"/>

                    <TextBox x:Name="SearchTxt" Grid.Column="1" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" 
                             Height="28" FontSize="14" VerticalContentAlignment="Center" Padding="4,0" BorderBrush="#828790">
                        <TextBox.InputBindings>
                            <KeyBinding Key="Enter" Command="{Binding SearchCommand}" />
                        </TextBox.InputBindings>
                    </TextBox>

                    <Button Grid.Column="2" Content="SEARCH" Command="{Binding SearchCommand}" Style="{StaticResource ClassicBtn}" Margin="10,0,0,0" Height="28"/>
                </Grid>
            </Border>

            <!-- TABLE 1: PARENT ITEMS -->
            <Grid Grid.Row="2" Margin="10,10,10,5">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="Step 1: Select Master Item" FontWeight="Bold" Foreground="#333" Margin="0,0,0,4"/>

                <DataGrid Grid.Row="1" ItemsSource="{Binding ParentResults}" SelectedItem="{Binding SelectedParent}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Item Code" Binding="{Binding ItemCode}" Width="120" FontWeight="Bold"/>
                        <DataGridTextColumn Header="Master Item Name" Binding="{Binding ItemName}" Width="*"/>
                        <DataGridTextColumn Header="Category" Binding="{Binding CategoryName}" Width="150"/>
                        <DataGridTextColumn Header="Variants" Binding="{Binding ActiveVariantsCount}" Width="80">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>

            <!-- DIVIDER -->
            <Rectangle Grid.Row="3" Height="2" Fill="#828790" Margin="10,5"/>

            <!-- TABLE 2: SPECIFIC VARIANTS (SIZES/COLORS) -->
            <Grid Grid.Row="4" Margin="10,5,10,10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="Step 2: Select Specific Size / Color / Variant" FontWeight="Bold" Foreground="#333" Margin="0,0,0,4"/>

                <DataGrid Grid.Row="1" ItemsSource="{Binding VariantResults}" SelectedItem="{Binding SelectedVariant}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="SKU / Barcode" Binding="{Binding SkuCode}" Width="150" FontWeight="Bold" Foreground="#003366"/>
                        <DataGridTextColumn Header="Variant Description" Binding="{Binding VariantDescription}" Width="*"/>

                        <DataGridTextColumn Header="Price (Rs.)" Binding="{Binding RetailPrice, StringFormat=N2}" Width="120">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Right"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                    <Setter Property="Foreground" Value="#005500"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="In Stock" Binding="{Binding StockOnHand}" Width="100">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding StockOnHand}" Value="0">
                                            <Setter Property="Foreground" Value="#DC3545"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>

            <!-- FOOTER BAR -->
            <Border Grid.Row="5" Background="#D4D0C8" BorderBrush="#828790" BorderThickness="0,1,0,0" Padding="10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="150"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0" Content="CANCEL" Command="{Binding CloseCommand}" Style="{StaticResource ClassicBtn}"/>

                    <!-- DYNAMIC STATUS TEXT (Automatically changes color via WPF's built in BrushConverter) -->
                    <TextBlock Grid.Column="1" Text="{Binding StatusText}" Foreground="{Binding StatusColorHex}" 
                               FontSize="14" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Center"/>

                    <!-- ADD TO CART -->
                    <!-- Note: AddToCartCommand will run the SILENT BROADCASTER -->
                    <Button Grid.Column="2" Content="ADD TO CART ➔" Command="{Binding AddToCartCommand}" IsEnabled="{Binding CanAddVariant}" 
                            Background="#005500" Foreground="White" BorderBrush="#003300" BorderThickness="1" 
                            FontWeight="Heavy" Cursor="Hand">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Style.Triggers>
                                    <Trigger Property="IsEnabled" Value="False">
                                        <Setter Property="Background" Value="#A0A0A0"/>
                                        <Setter Property="Foreground" Value="#666666"/>
                                        <Setter Property="BorderBrush" Value="#808080"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>