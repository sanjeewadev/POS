<Window x:Class="POS.Cashier.UI.Dialogs.ProductSeekDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Product Look-Up"
        Height="760"
        Width="980"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#ECE9D8"
        FontFamily="Segoe UI, Tahoma"
        WindowStyle="None">

    <Window.InputBindings>
        <KeyBinding Key="Escape" Command="{Binding CloseCommand}"/>
    </Window.InputBindings>

    <Window.Resources>
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#828790"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="RowHeaderWidth" Value="0"/>
            <Setter Property="GridLinesVisibility" Value="All"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#C0C0C0"/>
            <Setter Property="VerticalGridLinesBrush" Value="#C0C0C0"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserDeleteRows" Value="False"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="RowHeight" Value="30"/>
            <Setter Property="AlternatingRowBackground" Value="#F9F9F9"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#D4D0C8"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="BorderBrush" Value="#828790"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Padding" Value="4,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="Black"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#0A246A"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="Button" x:Key="ClassicBtn">
            <Setter Property="Background" Value="#D4D0C8"/>
            <Setter Property="BorderBrush" Value="#404040"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="15,5"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Height" Value="32"/>
        </Style>

        <Style TargetType="Button" x:Key="AddBtn">
            <Setter Property="Background" Value="#005500"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#003300"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontWeight" Value="Heavy"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="FontSize" Value="13"/>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#A0A0A0"/>
                    <Setter Property="Foreground" Value="#666666"/>
                    <Setter Property="BorderBrush" Value="#808080"/>
                    <Setter Property="Cursor" Value="Arrow"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="TextBlock" x:Key="RightText">
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style TargetType="TextBlock" x:Key="CenterText">
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <Border BorderBrush="#0A246A"
            BorderThickness="2">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- HEADER -->
            <Border Grid.Row="0"
                    Background="#0A246A"
                    Padding="8">

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="PRICE LOOK-UP / ITEM SEEK"
                               Foreground="White"
                               FontSize="16"
                               FontWeight="Bold"
                               VerticalAlignment="Center"/>

                    <TextBlock Grid.Column="1"
                               Text="ESC = Close"
                               Foreground="#DEFF9A"
                               FontSize="12"
                               FontWeight="Bold"
                               VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- SEARCH BAR -->
            <Border Grid.Row="1"
                    Background="#ECE9D8"
                    Padding="10"
                    BorderBrush="#828790"
                    BorderThickness="0,0,0,1">

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="105"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="Search Item Code / Name / SKU / Barcode:"
                               VerticalAlignment="Center"
                               FontWeight="Bold"
                               Margin="0,0,10,0"/>

                    <TextBox x:Name="SearchTxt"
                             Grid.Column="1"
                             Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             Height="30"
                             FontSize="14"
                             VerticalContentAlignment="Center"
                             Padding="5,0"
                             BorderBrush="#828790">
                        <TextBox.InputBindings>
                            <KeyBinding Key="Enter"
                                        Command="{Binding SearchCommand}"/>
                        </TextBox.InputBindings>
                    </TextBox>

                    <Button Grid.Column="2"
                            Content="SEARCH"
                            Command="{Binding SearchCommand}"
                            Style="{StaticResource ClassicBtn}"
                            Margin="10,0,0,0"
                            Height="30"/>
                </Grid>
            </Border>

            <!-- PARENT ITEMS -->
            <Grid Grid.Row="2"
                  Margin="10,10,10,5">

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="Step 1: Select Master Item"
                           FontWeight="Bold"
                           Foreground="#333"
                           Margin="0,0,0,4"/>

                <DataGrid Grid.Row="1"
                          ItemsSource="{Binding ParentResults}"
                          SelectedItem="{Binding SelectedParent, Mode=TwoWay}">

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Item Code"
                                            Binding="{Binding ItemCode}"
                                            Width="120"
                                            FontWeight="Bold"/>

                        <DataGridTextColumn Header="Master Item Name"
                                            Binding="{Binding ItemName}"
                                            Width="*"/>

                        <DataGridTextColumn Header="Category"
                                            Binding="{Binding CategoryName}"
                                            Width="160"/>

                        <DataGridTextColumn Header="Variants"
                                            Binding="{Binding ActiveVariantsCount}"
                                            Width="85"
                                            ElementStyle="{StaticResource CenterText}"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>

            <!-- DIVIDER -->
            <Rectangle Grid.Row="3"
                       Height="2"
                       Fill="#828790"
                       Margin="10,5"/>

            <!-- VARIANTS -->
            <Grid Grid.Row="4"
                  Margin="10,5,10,10">

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="Step 2: Select Exact Variant"
                           FontWeight="Bold"
                           Foreground="#333"
                           Margin="0,0,0,4"/>

                <DataGrid Grid.Row="1"
                          ItemsSource="{Binding VariantResults}"
                          SelectedItem="{Binding SelectedVariant, Mode=TwoWay}">

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="SKU"
                                            Binding="{Binding SkuCode}"
                                            Width="145"
                                            FontWeight="Bold"
                                            Foreground="#003366"/>

                        <DataGridTextColumn Header="Barcode"
                                            Binding="{Binding Barcode}"
                                            Width="145"
                                            Foreground="#444"/>

                        <DataGridTextColumn Header="Variant Description"
                                            Binding="{Binding VariantDescription}"
                                            Width="*"/>

                        <DataGridTextColumn Header="Price Rs."
                                            Binding="{Binding RetailPrice, StringFormat=N2}"
                                            Width="110"
                                            ElementStyle="{StaticResource RightText}">
                            <DataGridTextColumn.CellStyle>
                                <Style TargetType="DataGridCell">
                                    <Setter Property="FontWeight" Value="Bold"/>
                                    <Setter Property="Foreground" Value="#005500"/>
                                </Style>
                            </DataGridTextColumn.CellStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="In Stock"
                                            Binding="{Binding StockOnHand, StringFormat=N3}"
                                            Width="100">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                    <Setter Property="Foreground" Value="#005500"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding StockOnHand}" Value="0">
                                            <Setter Property="Foreground" Value="#DC3545"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>

            <!-- FOOTER -->
            <Border Grid.Row="5"
                    Background="#D4D0C8"
                    BorderBrush="#828790"
                    BorderThickness="0,1,0,0"
                    Padding="10">

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="110"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="170"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0"
                            Content="CANCEL"
                            Command="{Binding CloseCommand}"
                            Style="{StaticResource ClassicBtn}"/>

                    <TextBlock Grid.Column="1"
                               Text="{Binding StatusText}"
                               Foreground="{Binding StatusColorHex}"
                               FontSize="14"
                               FontWeight="Bold"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center"
                               TextAlignment="Center"/>

                    <Button Grid.Column="2"
                            Content="ADD TO CART"
                            Command="{Binding AddToCartCommand}"
                            IsEnabled="{Binding CanAddVariant}"
                            Style="{StaticResource AddBtn}"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>