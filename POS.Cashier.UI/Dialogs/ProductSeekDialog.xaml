<Window x:Class="POS.Cashier.UI.Views.Dialogs.ProductSeekDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Product Lookup" Height="750" Width="900"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        Background="#D4D0C8" FontFamily="Segoe UI" Topmost="True"
        Loaded="Window_Loaded">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#003366" Padding="10" Margin="0,0,0,10">
            <TextBlock Text="ITEM LOOKUP (SEEK)" Foreground="White" FontSize="18" FontWeight="Heavy" HorizontalAlignment="Center"/>
        </Border>

        <Border Grid.Row="1" Background="#E8E6E1" BorderBrush="#AAAAAA" BorderThickness="1" Padding="10" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="120"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Search by Name or Description:" FontWeight="Bold" Foreground="#333333" Margin="0,0,0,5"/>
                <TextBox Grid.Row="1" Grid.Column="0" x:Name="SearchNameTxt" Height="40" FontSize="18" FontWeight="Bold" Background="#FFFFE0" VerticalContentAlignment="Center" Padding="5,0" TextChanged="SearchInput_TextChanged"/>

                <TextBlock Grid.Row="0" Grid.Column="2" Text="Search by Barcode / SKU:" FontWeight="Bold" Foreground="#333333" Margin="0,0,0,5"/>
                <TextBox Grid.Row="1" Grid.Column="2" x:Name="SearchBarcodeTxt" Height="40" FontSize="18" FontWeight="Bold" Background="#FFFFE0" VerticalContentAlignment="Center" Padding="5,0" TextChanged="SearchInput_TextChanged"/>

                <TextBlock Grid.Row="0" Grid.Column="4" Text="Category:" FontWeight="Bold" Foreground="#333333" Margin="0,0,0,5"/>
                <ComboBox Grid.Row="1" Grid.Column="4" x:Name="CategoryCombo" Height="40" FontSize="16" FontWeight="Bold" VerticalContentAlignment="Center" SelectionChanged="CategoryCombo_SelectionChanged"/>
            </Grid>
        </Border>

        <DataGrid Grid.Row="2" x:Name="ResultsGrid" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True"
                  HeadersVisibility="Column" GridLinesVisibility="All" RowHeight="45" FontSize="16" Background="White"
                  SelectionMode="Single" SelectionChanged="ResultsGrid_SelectionChanged">
            <DataGrid.Resources>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="#003366"/>
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="FontWeight" Value="Heavy"/>
                    <Setter Property="Padding" Value="10,8"/>
                    <Setter Property="FontSize" Value="14"/>
                </Style>
                <Style TargetType="DataGridRow">
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="#0078D7"/>
                            <Setter Property="Foreground" Value="White"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.Resources>
            <DataGrid.Columns>
                <DataGridTextColumn Header="SKU / Barcode" Binding="{Binding Barcode}" Width="150"/>
                <DataGridTextColumn Header="Item Description" Binding="{Binding Description}" Width="*"/>
                <DataGridTextColumn Header="Category" Binding="{Binding CategoryName}" Width="150"/>

                <DataGridTextColumn Header="Stock" Binding="{Binding StockOnHand}" Width="100">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Center"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding StockOnHand}" Value="0">
                                    <Setter Property="Foreground" Value="#DC3545"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn Header="Price (Rs.)" Binding="{Binding RetailPrice, StringFormat=N2}" Width="140">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Right"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                            <Setter Property="Padding" Value="0,0,10,0"/>
                            <Setter Property="FontWeight" Value="Heavy"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
            </DataGrid.Columns>
        </DataGrid>

        <Grid Grid.Row="3" Margin="0,15,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="150"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" Content="CLOSE" Click="CloseBtn_Click" Background="#E0E0E0" Foreground="Black" FontWeight="Heavy" FontSize="16" Height="60"/>

            <TextBlock Grid.Column="1" x:Name="StatusTxt" Text="Type in the boxes above to search..." Foreground="#555555" FontSize="16" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Center"/>

            <StackPanel Grid.Column="2" Orientation="Horizontal" IsEnabled="False" x:Name="ActionPanel">
                <Button Content="ADD ITEM" Click="AddToCartBtn_Click" Background="#005500" Foreground="White" FontWeight="Heavy" FontSize="18" Width="180" Height="60"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>