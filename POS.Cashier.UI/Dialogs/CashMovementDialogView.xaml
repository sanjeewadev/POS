<Window x:Class="POS.Cashier.UI.Dialogs.CashMovementDialogView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cash Movement" Height="560" Width="500"
        WindowStartupLocation="CenterOwner" WindowStyle="None" ResizeMode="NoResize"
        AllowsTransparency="True" Background="Transparent" FontFamily="Segoe UI">

    <Window.Resources>
        <Style x:Key="ReasonItemStyle" TargetType="ListBoxItem">
            <Setter Property="Height" Value="46"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Bd" Background="Transparent" BorderBrush="#DDDDDD" BorderThickness="0,0,0,1" Padding="{TemplateBinding Padding}">
                            <TextBlock Text="{Binding}" Foreground="#222222" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <!-- Binds the highlight color to the Red/Green Theme -->
                                <Setter TargetName="Bd" Property="Background" Value="{Binding DataContext.ThemeColorHex, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="IsSelected" Value="False"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Bd" Property="Background" Value="#E8F0FB"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="White" CornerRadius="8" Margin="10">
        <Border.Effect>
            <DropShadowEffect BlurRadius="15" Opacity="0.4" ShadowDepth="4" Direction="270"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="70"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="75"/>
            </Grid.RowDefinitions>

            <!-- DYNAMIC HEADER -->
            <Border Grid.Row="0" Background="{Binding ThemeColorHex}" CornerRadius="8,8,0,0">
                <StackPanel VerticalAlignment="Center" Margin="20,0">
                    <TextBlock Text="{Binding HeaderTitle}" Foreground="White" FontSize="20" FontWeight="Heavy"/>
                    <TextBlock Text="Select a reason and confirm" Foreground="#E2E8F0" FontSize="13"/>
                </StackPanel>
            </Border>

            <!-- BODY -->
            <StackPanel Grid.Row="1" Margin="20,20,20,0">
                <TextBlock Text="AMOUNT (Rs.)" Foreground="#64748B" FontSize="12" FontWeight="Bold" Margin="0,0,0,4"/>
                <TextBox Text="{Binding Amount, StringFormat=N2}" IsReadOnly="True"
                         FontSize="38" FontWeight="Heavy" TextAlignment="Right"
                         Foreground="{Binding ThemeColorHex}" Background="#F8FAFC"
                         Height="62" VerticalContentAlignment="Center" Padding="12,0"
                         BorderThickness="1" BorderBrush="#CBD5E1" Margin="0,0,0,18"/>

                <TextBlock Text="SELECT REASON *" Foreground="#64748B" FontSize="12" FontWeight="Bold" Margin="0,0,0,4"/>
                <ListBox ItemsSource="{Binding ReasonCategories}" SelectedItem="{Binding SelectedReason, UpdateSourceTrigger=PropertyChanged}"
                         Height="180" BorderThickness="1" BorderBrush="#CBD5E1" Background="White"
                         ScrollViewer.VerticalScrollBarVisibility="Auto" ItemContainerStyle="{StaticResource ReasonItemStyle}"/>

                <TextBlock Text="REMARKS (Optional)" Foreground="#64748B" FontSize="12" FontWeight="Bold" Margin="0,14,0,4"/>
                <TextBox Text="{Binding Remarks, UpdateSourceTrigger=PropertyChanged}" Height="40" FontSize="15" Background="#F8FAFC" 
                         VerticalContentAlignment="Center" Padding="10,0" BorderThickness="1" BorderBrush="#CBD5E1"/>
            </StackPanel>

            <!-- FOOTER -->
            <Border Grid.Row="2" Background="#F1F5F9" BorderThickness="0,1,0,0" BorderBrush="#CBD5E1" CornerRadius="0,0,8,8">
                <Grid Margin="16,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0" Content="CANCEL" Click="CancelBtn_Click" 
                            Background="#E2E8F0" Foreground="#334155" FontWeight="Bold" FontSize="16" BorderThickness="0" Cursor="Hand">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="6"/>
                            </Style>
                        </Button.Resources>
                    </Button>

                    <Button Grid.Column="1" Content="{Binding ButtonText}" Command="{Binding ConfirmCommand}" 
                            Background="{Binding ThemeColorHex}" Foreground="White" FontWeight="Bold" FontSize="16" BorderThickness="0" Margin="10,0,0,0" Cursor="Hand">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="6"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>