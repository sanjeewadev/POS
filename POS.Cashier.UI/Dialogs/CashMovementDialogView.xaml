<Window x:Class="POS.Cashier.UI.Dialogs.CashMovementDialogView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cash Movement" Height="550" Width="800"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None" ResizeMode="NoResize"
        Background="#E0E0E0"
        BorderBrush="#003366" BorderThickness="3"
        FontFamily="Segoe UI">

    <Window.Resources>
        <Style x:Key="PosActionButton" TargetType="Button">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontWeight" Value="Heavy"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.7"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#000000"/>
                                <Setter TargetName="Bd" Property="BorderThickness" Value="2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="NumpadButton" TargetType="Button" BasedOn="{StaticResource PosActionButton}">
            <Setter Property="FontSize" Value="28"/>
            <Setter Property="Background" Value="#1B193E"/>
            <Setter Property="BorderBrush" Value="#C0C0C0"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Margin" Value="1"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="80"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#003366">
            <TextBlock x:Name="HeaderTxt" Text="CASH MOVEMENT" Foreground="White" FontSize="20" FontWeight="Heavy" HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Border>

        <Grid Grid.Row="1" Margin="15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.2*"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" VerticalAlignment="Center">

                <TextBlock Text="AMOUNT (Rs.)" Foreground="#555555" FontSize="14" FontWeight="Bold" Margin="0,0,0,5"/>
                <TextBox x:Name="AmountTxt" Text="0" FontSize="42" FontWeight="Heavy" TextAlignment="Right" Foreground="#003366" Background="#FFFFE0" Height="60" IsReadOnly="True" VerticalContentAlignment="Center" Padding="10,0" BorderThickness="1" BorderBrush="#AAAAAA" Margin="0,0,0,20"/>

                <TextBlock Text="REASON" Foreground="#555555" FontSize="14" FontWeight="Bold" Margin="0,0,0,5"/>
                <ComboBox x:Name="ReasonCombo" FontSize="18" FontWeight="Bold" Height="45" Background="#FFFFE0" VerticalContentAlignment="Center" BorderThickness="1" BorderBrush="#AAAAAA" Margin="0,0,0,20">
                    <ComboBoxItem Content="Vendor Payment" IsSelected="True"/>
                    <ComboBoxItem Content="Store Expense (Tea/Water)"/>
                    <ComboBoxItem Content="Owner Draw / Advance"/>
                    <ComboBoxItem Content="Safe Drop / Skim"/>
                    <ComboBoxItem Content="Adding Float / Change"/>
                </ComboBox>

                <TextBlock Text="REMARKS (Optional)" Foreground="#555555" FontSize="14" FontWeight="Bold" Margin="0,0,0,5"/>
                <TextBox x:Name="RemarksTxt" Height="45" FontSize="18" FontWeight="Bold" Background="#FFFFE0" VerticalContentAlignment="Center" Padding="10,0" BorderThickness="1" BorderBrush="#AAAAAA" Margin="0,0,0,10"/>

                <StackPanel x:Name="ManagerPinPanel" Visibility="Collapsed" Margin="0,10,0,0">
                    <Border Background="#DC3545" Padding="5" Margin="0,0,0,5">
                        <TextBlock Text="⚠ MANAGER PIN REQUIRED" Foreground="#FFFFFF" FontSize="14" FontWeight="Heavy" HorizontalAlignment="Center"/>
                    </Border>
                    <PasswordBox x:Name="ManagerPinBox" Height="45" FontSize="24" FontWeight="Heavy" Background="#FFFFE0" Foreground="#003366" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" BorderThickness="1" BorderBrush="#DC3545"/>
                </StackPanel>

            </StackPanel>

            <Border Grid.Column="2" Background="#D8D8D8" BorderBrush="#C0C0C0" BorderThickness="1" Padding="10">
                <UniformGrid Columns="3" Rows="4">
                    <Button Style="{StaticResource NumpadButton}" Content="7" Click="NumpadBtn_Click"/>
                    <Button Style="{StaticResource NumpadButton}" Content="8" Click="NumpadBtn_Click"/>
                    <Button Style="{StaticResource NumpadButton}" Content="9" Click="NumpadBtn_Click"/>

                    <Button Style="{StaticResource NumpadButton}" Content="4" Click="NumpadBtn_Click"/>
                    <Button Style="{StaticResource NumpadButton}" Content="5" Click="NumpadBtn_Click"/>
                    <Button Style="{StaticResource NumpadButton}" Content="6" Click="NumpadBtn_Click"/>

                    <Button Style="{StaticResource NumpadButton}" Content="1" Click="NumpadBtn_Click"/>
                    <Button Style="{StaticResource NumpadButton}" Content="2" Click="NumpadBtn_Click"/>
                    <Button Style="{StaticResource NumpadButton}" Content="3" Click="NumpadBtn_Click"/>

                    <Button Style="{StaticResource NumpadButton}" Content="C" Background="#DC3545" Foreground="White" BorderBrush="#8B0000" Click="NumpadBtn_Click"/>
                    <Button Style="{StaticResource NumpadButton}" Content="0" Click="NumpadBtn_Click"/>
                    <Button Style="{StaticResource NumpadButton}" Content="." Click="NumpadBtn_Click"/>
                </UniformGrid>
            </Border>

        </Grid>

        <Border Grid.Row="2" Background="#D8D8D8" BorderThickness="0,1,0,0" BorderBrush="#C0C0C0">
            <Grid Margin="15,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="180"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="220"/>
                </Grid.ColumnDefinitions>

                <Button x:Name="CancelBtn" Click="CancelBtn_Click" Grid.Column="0" Style="{StaticResource PosActionButton}" Background="#EAEAEA" Foreground="#333333" BorderBrush="#AAAAAA" Content="CANCEL" FontSize="18" Height="55"/>
                <Button x:Name="ConfirmBtn" Click="ConfirmBtn_Click" Grid.Column="2" Style="{StaticResource PosActionButton}" Background="#005500" Foreground="White" BorderBrush="#003300" Content="CONFIRM" FontSize="18" Height="55"/>
            </Grid>
        </Border>
    </Grid>
</Window>