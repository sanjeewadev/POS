<Window x:Class="POS.Cashier.UI.Dialogs.CashMovementDialogView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cash Movement"
        Width="520"
        Height="590"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        FontFamily="Segoe UI"
        FontSize="14"
        PreviewKeyDown="Window_PreviewKeyDown">

    <Window.Resources>

        <DropShadowEffect x:Key="DialogShadow"
                          BlurRadius="18"
                          ShadowDepth="4"
                          Direction="270"
                          Opacity="0.35"/>

        <Style TargetType="TextBlock" x:Key="SectionLabel">
            <Setter Property="Foreground" Value="#334155"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>

        <Style TargetType="TextBox" x:Key="DialogTextBox">
            <Setter Property="Height" Value="42"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Background" Value="#F8FAFC"/>
            <Setter Property="Foreground" Value="#111827"/>
            <Setter Property="BorderBrush" Value="#94A3B8"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style TargetType="Button" x:Key="DialogButton">
            <Setter Property="Height" Value="44"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="Heavy"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#334155"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.92"/>
                            </Trigger>

                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.82"/>
                            </Trigger>

                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ReasonItemStyle" TargetType="ListBoxItem">
            <Setter Property="Height" Value="44"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Bd"
                                Background="White"
                                BorderBrush="#E2E8F0"
                                BorderThickness="0,0,0,1"
                                Padding="{TemplateBinding Padding}">
                            <TextBlock x:Name="ItemText"
                                       Text="{Binding}"
                                       Foreground="#111827"
                                       VerticalAlignment="Center"/>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#EAF2FF"/>
                            </Trigger>

                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{Binding DataContext.ThemeColorHex, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                <Setter TargetName="ItemText" Property="Foreground" Value="White"/>
                                <Setter TargetName="ItemText" Property="FontWeight" Value="Heavy"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Border Margin="12"
            Background="#F8FAFC"
            BorderBrush="#1E293B"
            BorderThickness="1"
            CornerRadius="6"
            Effect="{StaticResource DialogShadow}">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="58"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="58"/>
            </Grid.RowDefinitions>

            <!-- HEADER -->
            <Border Grid.Row="0"
                    Background="{Binding ThemeColorHex}"
                    CornerRadius="6,6,0,0"
                    MouseLeftButtonDown="Header_MouseLeftButtonDown">

                <Grid Margin="16,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0"
                                VerticalAlignment="Center">

                        <TextBlock Text="{Binding HeaderTitle}"
                                   Foreground="White"
                                   FontSize="19"
                                   FontWeight="Heavy"/>

                        <TextBlock Text="Select reason and confirm cash movement"
                                   Foreground="#E2E8F0"
                                   FontSize="12"
                                   Margin="0,2,0,0"/>
                    </StackPanel>

                    <TextBlock Grid.Column="1"
                               Text="Esc = Close"
                               Foreground="#E2E8F0"
                               FontSize="11"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- BODY -->
            <Grid Grid.Row="1"
                  Margin="18">

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="14"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- AMOUNT -->
                <Border Grid.Row="0"
                        Background="White"
                        BorderBrush="#CBD5E1"
                        BorderThickness="1"
                        Padding="14">

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"
                                   Text="AMOUNT (Rs.)"
                                   Style="{StaticResource SectionLabel}"/>

                        <TextBox Grid.Row="1"
                                 Text="{Binding Amount, StringFormat=N2}"
                                 IsReadOnly="True"
                                 FontSize="38"
                                 FontWeight="Heavy"
                                 TextAlignment="Right"
                                 Foreground="{Binding ThemeColorHex}"
                                 Background="#F8FAFC"
                                 Height="62"
                                 VerticalContentAlignment="Center"
                                 Padding="12,0"
                                 BorderThickness="1"
                                 BorderBrush="#CBD5E1"/>
                    </Grid>
                </Border>

                <!-- REASON -->
                <Border Grid.Row="2"
                        Background="White"
                        BorderBrush="#CBD5E1"
                        BorderThickness="1"
                        Padding="14">

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="184"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"
                                   Text="SELECT REASON *"
                                   Style="{StaticResource SectionLabel}"/>

                        <ListBox Grid.Row="1"
                                 ItemsSource="{Binding ReasonCategories}"
                                 SelectedItem="{Binding SelectedReason, UpdateSourceTrigger=PropertyChanged}"
                                 BorderThickness="1"
                                 BorderBrush="#CBD5E1"
                                 Background="White"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 ItemContainerStyle="{StaticResource ReasonItemStyle}"/>
                    </Grid>
                </Border>

                <!-- REMARKS -->
                <Border Grid.Row="4"
                        Background="White"
                        BorderBrush="#CBD5E1"
                        BorderThickness="1"
                        Padding="14"
                        Margin="0,14,0,0">

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"
                                   Text="REMARKS (Optional)"
                                   Style="{StaticResource SectionLabel}"/>

                        <TextBox Grid.Row="1"
                                 Text="{Binding Remarks, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource DialogTextBox}"/>
                    </Grid>
                </Border>
            </Grid>

            <!-- FOOTER -->
            <Border Grid.Row="2"
                    Background="#E5E7EB"
                    BorderBrush="#CBD5E1"
                    BorderThickness="0,1,0,0"
                    CornerRadius="0,0,6,6">

                <Grid Margin="14,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0"
                            Content="CANCEL"
                            Style="{StaticResource DialogButton}"
                            Background="#F1F5F9"
                            Foreground="#1E293B"
                            Click="CancelBtn_Click"/>

                    <Button Grid.Column="1"
                            Content="{Binding ButtonText}"
                            Command="{Binding ConfirmCommand}"
                            Style="{StaticResource DialogButton}"
                            Background="{Binding ThemeColorHex}"
                            Foreground="White"
                            Margin="10,0,0,0"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>