<Window x:Class="POS.Cashier.UI.Dialogs.FloatCashDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cash Drawer Count"
        Width="960"
        Height="700"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="#D7DCE2"
        FontFamily="Segoe UI"
        FontSize="14"
        PreviewKeyDown="Window_PreviewKeyDown">

    <Window.Resources>

        <Style TargetType="TextBlock" x:Key="SectionTitle">
            <Setter Property="Foreground" Value="#334155"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <Style TargetType="TextBox" x:Key="QtyBox">
            <Setter Property="Width" Value="104"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="TextAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Background" Value="#FFF7CC"/>
            <Setter Property="Foreground" Value="#111827"/>
            <Setter Property="BorderBrush" Value="#94A3B8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="4,0"/>
        </Style>

        <Style TargetType="Button" x:Key="DialogButton">
            <Setter Property="Height" Value="54"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Heavy"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderBrush" Value="#1E293B"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.92"/>
                            </Trigger>

                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.82"/>
                            </Trigger>

                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Border Margin="12"
            Background="#F8FAFC"
            BorderBrush="#1E293B"
            BorderThickness="1">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="56"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="78"/>
            </Grid.RowDefinitions>

            <!-- HEADER -->
            <Border Grid.Row="0"
                    Background="#0F3D5E"
                    BorderBrush="#082F49"
                    BorderThickness="0,0,0,1"
                    MouseLeftButtonDown="Header_MouseLeftButtonDown">

                <Grid Margin="16,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0"
                                VerticalAlignment="Center">

                        <TextBlock Text="CASH COUNT / FLOAT ENTRY"
                                   Foreground="White"
                                   FontSize="19"
                                   FontWeight="Heavy"/>

                        <TextBlock Text="Enter denomination quantities, then choose float operation"
                                   Foreground="#DDEAF3"
                                   FontSize="12"/>
                    </StackPanel>

                    <TextBlock Grid.Column="1"
                               Text="Esc = Close"
                               Foreground="#DDEAF3"
                               FontSize="11"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- BODY -->
            <Grid Grid.Row="1"
                  Margin="14">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="6.5*"/>
                    <ColumnDefinition Width="14"/>
                    <ColumnDefinition Width="3.5*"/>
                </Grid.ColumnDefinitions>

                <!-- DENOMINATION PANEL -->
                <Border Grid.Column="0"
                        Background="White"
                        BorderBrush="#CBD5E1"
                        BorderThickness="1">

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="42"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0"
                                Background="#E2E8F0"
                                BorderBrush="#CBD5E1"
                                BorderThickness="0,0,0,1">

                            <Grid Margin="12,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2.5*"/>
                                    <ColumnDefinition Width="1.5*"/>
                                    <ColumnDefinition Width="2*"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0"
                                           Text="Note / Coin (Rs.)"
                                           FontSize="14"
                                           FontWeight="Heavy"
                                           Foreground="#111827"
                                           VerticalAlignment="Center"/>

                                <TextBlock Grid.Column="1"
                                           Text="Quantity"
                                           FontSize="14"
                                           FontWeight="Heavy"
                                           Foreground="#111827"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>

                                <TextBlock Grid.Column="2"
                                           Text="Line Total"
                                           FontSize="14"
                                           FontWeight="Heavy"
                                           Foreground="#111827"
                                           HorizontalAlignment="Right"
                                           VerticalAlignment="Center"
                                           Margin="0,0,16,0"/>
                            </Grid>
                        </Border>

                        <ScrollViewer Grid.Row="1"
                                      VerticalScrollBarVisibility="Auto">

                            <StackPanel>

                                <!-- 5000 -->
                                <Border BorderBrush="#E2E8F0" BorderThickness="0,0,0,1" Padding="0,5">
                                    <Grid Height="45">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="2.5*"/>
                                            <ColumnDefinition Width="1.5*"/>
                                            <ColumnDefinition Width="2*"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0" Text="5000" FontSize="18" FontWeight="Heavy" Foreground="#111827" VerticalAlignment="Center" Margin="16,0,0,0"/>
                                        <TextBox Grid.Column="1" Text="{Binding Qty5000, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource QtyBox}"/>
                                        <TextBlock Grid.Column="2" Text="{Binding Total5000, StringFormat=N2}" FontSize="18" FontWeight="Bold" Foreground="#111827" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,24,0"/>
                                    </Grid>
                                </Border>

                                <!-- 1000 -->
                                <Border BorderBrush="#E2E8F0" BorderThickness="0,0,0,1" Padding="0,5">
                                    <Grid Height="45">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="2.5*"/>
                                            <ColumnDefinition Width="1.5*"/>
                                            <ColumnDefinition Width="2*"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0" Text="1000" FontSize="18" FontWeight="Heavy" Foreground="#111827" VerticalAlignment="Center" Margin="16,0,0,0"/>
                                        <TextBox Grid.Column="1" Text="{Binding Qty1000, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource QtyBox}"/>
                                        <TextBlock Grid.Column="2" Text="{Binding Total1000, StringFormat=N2}" FontSize="18" FontWeight="Bold" Foreground="#111827" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,24,0"/>
                                    </Grid>
                                </Border>

                                <!-- 500 -->
                                <Border BorderBrush="#E2E8F0" BorderThickness="0,0,0,1" Padding="0,5">
                                    <Grid Height="45">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="2.5*"/>
                                            <ColumnDefinition Width="1.5*"/>
                                            <ColumnDefinition Width="2*"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0" Text="500" FontSize="18" FontWeight="Heavy" Foreground="#111827" VerticalAlignment="Center" Margin="16,0,0,0"/>
                                        <TextBox Grid.Column="1" Text="{Binding Qty500, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource QtyBox}"/>
                                        <TextBlock Grid.Column="2" Text="{Binding Total500, StringFormat=N2}" FontSize="18" FontWeight="Bold" Foreground="#111827" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,24,0"/>
                                    </Grid>
                                </Border>

                                <!-- 100 -->
                                <Border BorderBrush="#E2E8F0" BorderThickness="0,0,0,1" Padding="0,5">
                                    <Grid Height="45">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="2.5*"/>
                                            <ColumnDefinition Width="1.5*"/>
                                            <ColumnDefinition Width="2*"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0" Text="100" FontSize="18" FontWeight="Heavy" Foreground="#111827" VerticalAlignment="Center" Margin="16,0,0,0"/>
                                        <TextBox Grid.Column="1" Text="{Binding Qty100, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource QtyBox}"/>
                                        <TextBlock Grid.Column="2" Text="{Binding Total100, StringFormat=N2}" FontSize="18" FontWeight="Bold" Foreground="#111827" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,24,0"/>
                                    </Grid>
                                </Border>

                                <!-- 50 -->
                                <Border BorderBrush="#E2E8F0" BorderThickness="0,0,0,1" Padding="0,5">
                                    <Grid Height="45">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="2.5*"/>
                                            <ColumnDefinition Width="1.5*"/>
                                            <ColumnDefinition Width="2*"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0" Text="50" FontSize="18" FontWeight="Heavy" Foreground="#111827" VerticalAlignment="Center" Margin="16,0,0,0"/>
                                        <TextBox Grid.Column="1" Text="{Binding Qty50, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource QtyBox}"/>
                                        <TextBlock Grid.Column="2" Text="{Binding Total50, StringFormat=N2}" FontSize="18" FontWeight="Bold" Foreground="#111827" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,24,0"/>
                                    </Grid>
                                </Border>

                                <!-- 20 -->
                                <Border BorderBrush="#E2E8F0" BorderThickness="0,0,0,1" Padding="0,5">
                                    <Grid Height="45">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="2.5*"/>
                                            <ColumnDefinition Width="1.5*"/>
                                            <ColumnDefinition Width="2*"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0" Text="20" FontSize="18" FontWeight="Heavy" Foreground="#111827" VerticalAlignment="Center" Margin="16,0,0,0"/>
                                        <TextBox Grid.Column="1" Text="{Binding Qty20, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource QtyBox}"/>
                                        <TextBlock Grid.Column="2" Text="{Binding Total20, StringFormat=N2}" FontSize="18" FontWeight="Bold" Foreground="#111827" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,24,0"/>
                                    </Grid>
                                </Border>

                                <!-- 10 -->
                                <Border BorderBrush="#E2E8F0" BorderThickness="0,0,0,1" Padding="0,5">
                                    <Grid Height="45">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="2.5*"/>
                                            <ColumnDefinition Width="1.5*"/>
                                            <ColumnDefinition Width="2*"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0" Text="10" FontSize="18" FontWeight="Heavy" Foreground="#111827" VerticalAlignment="Center" Margin="16,0,0,0"/>
                                        <TextBox Grid.Column="1" Text="{Binding Qty10, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource QtyBox}"/>
                                        <TextBlock Grid.Column="2" Text="{Binding Total10, StringFormat=N2}" FontSize="18" FontWeight="Bold" Foreground="#111827" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,24,0"/>
                                    </Grid>
                                </Border>

                                <!-- 5 -->
                                <Border BorderBrush="#E2E8F0" BorderThickness="0,0,0,1" Padding="0,5">
                                    <Grid Height="45">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="2.5*"/>
                                            <ColumnDefinition Width="1.5*"/>
                                            <ColumnDefinition Width="2*"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0" Text="5" FontSize="18" FontWeight="Heavy" Foreground="#111827" VerticalAlignment="Center" Margin="16,0,0,0"/>
                                        <TextBox Grid.Column="1" Text="{Binding Qty5, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource QtyBox}"/>
                                        <TextBlock Grid.Column="2" Text="{Binding Total5, StringFormat=N2}" FontSize="18" FontWeight="Bold" Foreground="#111827" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,24,0"/>
                                    </Grid>
                                </Border>

                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Border>

                <!-- OPERATION PANEL -->
                <Border Grid.Column="2"
                        Background="White"
                        BorderBrush="#CBD5E1"
                        BorderThickness="1"
                        Padding="14">

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="14"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"
                                   Text="OPERATIONS"
                                   Style="{StaticResource SectionTitle}"/>

                        <StackPanel Grid.Row="1">
                            <Button Content="ADD CASH (FLOAT IN)"
                                    Style="{StaticResource DialogButton}"
                                    Background="#10B981"
                                    Command="{Binding FloatInCommand}"/>

                            <Button Content="REMOVE CASH (FLOAT OUT)"
                                    Style="{StaticResource DialogButton}"
                                    Background="#F59E0B"
                                    Foreground="#111827"
                                    Command="{Binding FloatOutCommand}"/>
                        </StackPanel>

                        <Border Grid.Row="2"
                                Background="#E2E8F0"
                                Height="1"
                                Margin="0,0,0,12"/>

                        <TextBlock Grid.Row="3"
                                   Text="REFERENCE NOTE"
                                   Style="{StaticResource SectionTitle}"/>

                        <TextBox Grid.Row="4"
                                 Text="{Binding ReferenceNote, UpdateSourceTrigger=PropertyChanged}"
                                 Height="46"
                                 FontSize="15"
                                 Padding="10,0"
                                 VerticalContentAlignment="Center"
                                 Background="#F8FAFC"
                                 BorderBrush="#94A3B8"
                                 BorderThickness="1"/>

                        <Border Grid.Row="5"
                                Background="#F1F5F9"
                                BorderBrush="#CBD5E1"
                                BorderThickness="1"
                                Padding="12"
                                Margin="0,18,0,0"
                                VerticalAlignment="Top">

                            <StackPanel>
                                <TextBlock Text="Use this screen only for float cash in/out."
                                           Foreground="#334155"
                                           FontWeight="SemiBold"
                                           TextWrapping="Wrap"/>

                                <TextBlock Text="This is not a sales payment screen."
                                           Foreground="#64748B"
                                           Margin="0,8,0,0"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>
            </Grid>

            <!-- FOOTER -->
            <Grid Grid.Row="2"
                  Background="#111827">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="2"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="160"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0"
                            VerticalAlignment="Center"
                            Margin="18,0,0,0">

                    <TextBlock Text="CURRENT FLOAT IN TILL"
                               Foreground="#94A3B8"
                               FontSize="12"
                               FontWeight="Bold"/>

                    <TextBlock Text="{Binding CurrentSystemFloat, StringFormat=Rs. \{0:N2\}}"
                               Foreground="#F59E0B"
                               FontSize="25"
                               FontWeight="Heavy"/>
                </StackPanel>

                <Rectangle Grid.Column="1"
                           Fill="#334155"
                           Margin="0,14"/>

                <StackPanel Grid.Column="2"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Right"
                            Margin="0,0,18,0">

                    <TextBlock Text="THIS TRANSACTION ENTRY"
                               Foreground="#94A3B8"
                               FontSize="12"
                               FontWeight="Bold"
                               HorizontalAlignment="Right"/>

                    <TextBlock Text="{Binding GrandTotal, StringFormat=Rs. \{0:N2\}}"
                               Foreground="#10B981"
                               FontSize="29"
                               FontWeight="Heavy"
                               HorizontalAlignment="Right"/>
                </StackPanel>

                <Button Grid.Column="3"
                        Content="CANCEL"
                        Style="{StaticResource DialogButton}"
                        Background="#64748B"
                        Margin="10,12,14,12"
                        Click="Cancel_Click"/>
            </Grid>
        </Grid>
    </Border>
</Window>