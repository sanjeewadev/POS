<Window x:Class="POS.Cashier.UI.Views.Dialogs.CashDenominationDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cash Drawer Count" Height="650" Width="550"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        Background="#D4D0C8" FontFamily="Segoe UI" Topmost="True">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#003366" Padding="10" Margin="0,0,0,10">
            <TextBlock Text="CASH COUNT" Foreground="White" FontSize="16" FontWeight="Heavy" HorizontalAlignment="Center"/>
        </Border>

        <DataGrid Grid.Row="1" x:Name="DenominationGrid" AutoGenerateColumns="False" CanUserAddRows="False" 
                  HeadersVisibility="Column" GridLinesVisibility="All" RowHeight="40" FontSize="14" Background="White">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Note/Coin (Rs.)" Binding="{Binding DenominationValue}" Width="*" IsReadOnly="True" FontWeight="Bold"/>

                <DataGridTemplateColumn Header="Quantity" Width="120">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBox Text="{Binding Quantity, UpdateSourceTrigger=PropertyChanged}" TextAlignment="Center" VerticalContentAlignment="Center" Background="#FFFFE0" FontWeight="Bold" MaxLength="4"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTextColumn Header="Line Total" Binding="{Binding LineTotal, StringFormat=N2}" Width="140" IsReadOnly="True" FontWeight="Bold">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Right"/>
                            <Setter Property="Padding" Value="0,0,10,0"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
            </DataGrid.Columns>
        </DataGrid>

        <Border Grid.Row="2" Background="#111827" Padding="15" Margin="0,10,0,15">
            <Grid>
                <TextBlock Text="TOTAL CASH COUNT:" Foreground="#9CA3AF" FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>
                <TextBlock x:Name="GrandTotalText" Text="Rs. 0.00" Foreground="#10B981" FontSize="26" FontWeight="Heavy" HorizontalAlignment="Right"/>
            </Grid>
        </Border>

        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Content="CANCEL" Click="Cancel_Click" Background="#E0E0E0" FontWeight="Bold" FontSize="14"  Height="50"/>
            <Button Grid.Column="2" Content="CONFIRM TOTAL" Click="Confirm_Click" Background="#005500" Foreground="White" FontWeight="Bold" FontSize="14" Height="50"/>
        </Grid>
    </Grid>
</Window>