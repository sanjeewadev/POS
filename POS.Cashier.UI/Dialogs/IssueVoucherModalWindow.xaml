<Window x:Class="POS.Cashier.UI.Dialogs.IssueVoucherModalWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Issue Gift Voucher"
        SizeToContent="WidthAndHeight" 
        WindowStartupLocation="CenterOwner" 
        WindowStyle="None" 
        AllowsTransparency="True" 
        Background="Transparent"
        FontFamily="Segoe UI">

    <Border Background="White" BorderBrush="#6F42C1" BorderThickness="3" CornerRadius="8" 
            Width="450" Height="350" Margin="20">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" Opacity="0.4" ShadowDepth="5"/>
        </Border.Effect>

        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="🎁 Sell New Gift Voucher" FontSize="20" FontWeight="Bold" Foreground="#333" Margin="0,0,0,15"/>

            <StackPanel Grid.Row="1">
                <TextBlock Text="Scan Physical Card Barcode *" Foreground="#666" Margin="0,0,0,5" FontWeight="SemiBold"/>
                <Grid Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBox Grid.Column="0" Text="{Binding ScannedBarcode, UpdateSourceTrigger=PropertyChanged}" 
                             Height="35" FontSize="16" FontWeight="Bold" VerticalContentAlignment="Center" Padding="5,0">
                        <TextBox.InputBindings>
                            <KeyBinding Key="Return" Command="{Binding SearchBarcodeCommand}"/>
                        </TextBox.InputBindings>
                    </TextBox>

                    <Button Grid.Column="1" Content="🔍 Verify" Command="{Binding SearchBarcodeCommand}" 
                            Background="#E2EDF8" Foreground="#2B5B84" BorderThickness="1" BorderBrush="#2B5B84" Margin="10,0,0,0" Padding="15,0" Cursor="Hand"/>
                </Grid>

                <TextBlock Text="{Binding StatusMessage}" Foreground="#2B5B84" FontWeight="SemiBold" TextWrapping="Wrap" Margin="0,0,0,15"/>

                <StackPanel IsEnabled="{Binding IsCardFound}">
                    <TextBlock Text="Recipient / Customer Name (Optional)" Foreground="#666" Margin="0,0,0,5"/>
                    <TextBox Text="{Binding CustomerName, UpdateSourceTrigger=PropertyChanged}" Height="30" VerticalContentAlignment="Center" Padding="5,0"/>
                </StackPanel>
            </StackPanel>

            <Grid Grid.Row="2" Margin="0,15,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" Content="Cancel" Command="{Binding CancelCommand}" 
                        Background="#F5F5F5" Foreground="#333" BorderBrush="#CCC" BorderThickness="1" Height="40" FontSize="14" FontWeight="Bold" Cursor="Hand"/>

                <Button Grid.Column="2" Content="🛒 ADD TO CART" Command="{Binding AddToCartCommand}" 
                        Background="#6F42C1" Foreground="White" BorderThickness="0" Height="40" FontSize="14" FontWeight="Bold" Cursor="Hand"
                        IsEnabled="{Binding IsCardFound}"/>
            </Grid>
        </Grid>
    </Border>
</Window>