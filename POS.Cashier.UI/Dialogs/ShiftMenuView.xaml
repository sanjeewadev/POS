<Window x:Class="POS.Cashier.UI.Views.Dialogs.ShiftMenuView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Shift &amp; Security Menu" Height="550" Width="400"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None" ResizeMode="NoResize"
        Background="#1E1E1E"
        BorderBrush="#007BFF" BorderThickness="3"
        FontFamily="Segoe UI, Arial">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="70"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#007BFF">
            <TextBlock Text="SHIFT &amp; SECURITY" Foreground="White" FontSize="20" FontWeight="Heavy" HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Border>

        <Border Grid.Row="1" Background="#2B2B2B" Margin="20,20,20,10" Padding="15" CornerRadius="8" BorderBrush="#444444" BorderThickness="1">
            <StackPanel>
                <TextBlock Text="TERMINAL STATUS" Foreground="#AAAAAA" FontSize="12" FontWeight="Bold" Margin="0,0,0,10"/>

                <Grid Margin="0,0,0,5">
                    <TextBlock Text="Cashier:" Foreground="White" FontSize="16" FontWeight="Bold" HorizontalAlignment="Left"/>
                    <TextBlock x:Name="CashierNameTxt" Text="Pending..." Foreground="#007BFF" FontSize="16" FontWeight="Heavy" HorizontalAlignment="Right"/>
                </Grid>

                <Grid Margin="0,0,0,5">
                    <TextBlock Text="Shift ID:" Foreground="White" FontSize="16" FontWeight="Bold" HorizontalAlignment="Left"/>
                    <TextBlock x:Name="ShiftIdTxt" Text="#0000" Foreground="White" FontSize="16" FontWeight="Heavy" HorizontalAlignment="Right"/>
                </Grid>

                <Grid>
                    <TextBlock Text="Security Level:" Foreground="White" FontSize="16" FontWeight="Bold" HorizontalAlignment="Left"/>
                    <TextBlock x:Name="SecurityStatusTxt" Text="CASHIER MODE" Foreground="#28A745" FontSize="16" FontWeight="Heavy" HorizontalAlignment="Right"/>
                </Grid>
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="2" Margin="20,10,20,0">

            <Button x:Name="LockTerminalBtn" Click="LockTerminalBtn_Click" Background="#444444" Foreground="White" FontSize="18" FontWeight="Bold" Height="55" Margin="0,0,0,15" BorderThickness="0" Cursor="Hand">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="🔒" FontSize="20" Margin="0,0,10,0" VerticalAlignment="Center"/>
                    <TextBlock Text="LOCK TERMINAL" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

            <Button x:Name="ToggleManagerBtn" Click="ToggleManagerBtn_Click" Background="#DC3545" Foreground="White" FontSize="18" FontWeight="Bold" Height="55" BorderThickness="0" Cursor="Hand">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="🛡️" FontSize="20" Margin="0,0,10,0" VerticalAlignment="Center"/>
                    <TextBlock x:Name="ToggleManagerTxt" Text="ELEVATE TO MANAGER" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

            <Button x:Name="LogOffBtn" Click="LogOffBtn_Click" Background="#FF8C00" Foreground="White" FontSize="18" FontWeight="Bold" Height="55" Margin="0,15,0,0" BorderThickness="0" Cursor="Hand">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="🚪" FontSize="20" Margin="0,0,10,0" VerticalAlignment="Center"/>
                    <TextBlock Text="LOG OFF USER" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

        </StackPanel>

        <Button Grid.Row="3" Background="#111111" Foreground="#AAAAAA" Content="CLOSE MENU" FontSize="16" FontWeight="Bold" BorderThickness="0" Cursor="Hand" Click="CloseBtn_Click"/>
    </Grid>
</Window>