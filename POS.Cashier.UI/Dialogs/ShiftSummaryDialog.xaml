<Window x:Class="POS.Cashier.UI.Dialogs.ShiftSummaryDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Shift Summary" Height="650" Width="500"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="{StaticResource MainBgBrush}"
        BorderBrush="{StaticResource HeaderBgBrush}"
        BorderThickness="3"
        FontFamily="Arial">

    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource TextLightBrush}"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="5" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="45"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="70"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource HeaderBgBrush}">
            <TextBlock Text="X-READING / SHIFT SUMMARY" Foreground="{StaticResource TextLightBrush}" FontSize="20" FontWeight="Heavy" HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Border>

        <StackPanel Grid.Row="1" Margin="20">
            <Border Background="White" BorderBrush="{StaticResource ControlBorderBrush}" BorderThickness="1" Padding="15" Margin="0,0,0,15">
                <StackPanel>
                    <TextBlock Text="SALES REVENUE" FontWeight="Bold" Foreground="{StaticResource TextInactiveBrush}" FontSize="14" Margin="0,0,0,10"/>
                    <Grid Margin="0,5">
                        <TextBlock Text="Gross Sales:" FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextDarkBrush}"/>
                        <TextBlock Text="{Binding GrossSales, StringFormat=Rs. \{0:N2\}}" FontSize="16" FontWeight="Bold" HorizontalAlignment="Right"/>
                    </Grid>
                    <Grid Margin="0,5">
                        <TextBlock Text="Discounts &amp; Refunds:" FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextDangerBrush}"/>
                        <TextBlock Text="{Binding TotalDeductions, StringFormat=- Rs. \{0:N2\}}" FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextDangerBrush}" HorizontalAlignment="Right"/>
                    </Grid>
                    <Rectangle Height="2" Fill="{StaticResource ControlBorderBrush}" Margin="0,10"/>
                    <Grid Margin="0,5">
                        <TextBlock Text="NET SALES:" FontSize="20" FontWeight="Heavy" Foreground="{StaticResource TextBlackBrush}"/>
                        <TextBlock Text="{Binding NetSales, StringFormat=Rs. \{0:N2\}}" FontSize="20" FontWeight="Heavy" Foreground="{StaticResource TextHighlightBrush}" HorizontalAlignment="Right"/>
                    </Grid>
                </StackPanel>
            </Border>

            <Border Background="White" BorderBrush="{StaticResource ControlBorderBrush}" BorderThickness="1" Padding="15">
                <StackPanel>
                    <TextBlock Text="TENDER &amp; DRAWER BREAKDOWN" FontWeight="Bold" Foreground="{StaticResource TextInactiveBrush}" FontSize="14" Margin="0,0,0,10"/>
                    <Grid Margin="0,5">
                        <TextBlock Text="Starting Float (Opening Cash):" FontSize="16" Foreground="{StaticResource TextDarkBrush}"/>
                        <TextBlock Text="{Binding StartingFloat, StringFormat=Rs. \{0:N2\}}" FontSize="16" FontWeight="Bold" HorizontalAlignment="Right"/>
                    </Grid>
                    <Grid Margin="0,5">
                        <TextBlock Text="Cash Sales:" FontSize="16" Foreground="{StaticResource TextDarkBrush}"/>
                        <TextBlock Text="{Binding CashSales, StringFormat=+ Rs. \{0:N2\}}" FontSize="16" FontWeight="Bold" HorizontalAlignment="Right"/>
                    </Grid>
                    <Grid Margin="0,5">
                        <TextBlock Text="Card &amp; Digital Payments:" FontSize="16" Foreground="{StaticResource TextDarkBrush}"/>
                        <TextBlock Text="{Binding CardSales, StringFormat=Rs. \{0:N2\}}" FontSize="16" FontWeight="Bold" HorizontalAlignment="Right"/>
                    </Grid>
                    <Rectangle Height="2" Fill="{StaticResource ControlBorderBrush}" Margin="0,10"/>
                    <Grid Margin="0,5">
                        <TextBlock Text="EXPECTED CASH IN DRAWER:" FontSize="18" FontWeight="Heavy" Foreground="{StaticResource TextBlackBrush}"/>
                        <TextBlock Text="{Binding ExpectedCash, StringFormat=Rs. \{0:N2\}}" FontSize="22" FontWeight="Heavy" Foreground="{StaticResource PaymentDarkOrangeBrush}" HorizontalAlignment="Right"/>
                    </Grid>
                </StackPanel>
            </Border>
        </StackPanel>

        <Grid Grid.Row="2" Background="{StaticResource HeaderBgBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="2*"/>
            </Grid.ColumnDefinitions>
            <Button Click="CancelBtn_Click" Grid.Column="0" Background="{StaticResource CancelBtnBrush}" Content="CLOSE" FontSize="20" Margin="10,10,5,10"/>
            <Button Grid.Column="1" Background="{StaticResource ActionBtnBrush}" Content="🖨️ PRINT X-READING" FontSize="20" Margin="5,10,10,10"/>
        </Grid>
    </Grid>
</Window>