<Window x:Class="POS.Cashier.UI.Dialogs.QuickCustomerCreateDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Quick Customer Registration"
        Width="820"
        Height="610"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#D4D0C8"
        FontFamily="Segoe UI"
        FontSize="14"
        Loaded="Window_Loaded"
        PreviewKeyDown="Window_PreviewKeyDown">

    <Window.InputBindings>
        <KeyBinding Key="Escape" Command="{Binding CancelCommand}" />
    </Window.InputBindings>

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>

        <Style TargetType="TextBlock" x:Key="LabelText">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
        </Style>

        <Style TargetType="TextBox" x:Key="ClassicInput">
            <Setter Property="Height" Value="30"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="6,0"/>
            <Setter Property="BorderBrush" Value="#808080"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
        </Style>

        <Style TargetType="ComboBox" x:Key="ClassicCombo">
            <Setter Property="Height" Value="30"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="#808080"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
        </Style>

        <Style TargetType="DatePicker" x:Key="ClassicDate">
            <Setter Property="Height" Value="30"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="#808080"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
        </Style>

        <Style TargetType="Button" x:Key="ClassicBtn">
            <Setter Property="Height" Value="36"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="18,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="#E0E0E0"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="BorderBrush" Value="#808080"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style TargetType="Button" x:Key="SaveBtn" BasedOn="{StaticResource ClassicBtn}">
            <Setter Property="Background" Value="#005500"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#003300"/>
            <Setter Property="Height" Value="42"/>
            <Setter Property="FontSize" Value="16"/>
        </Style>
    </Window.Resources>

    <Grid Margin="6">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0"
                Background="#003366"
                BorderBrush="#002244"
                BorderThickness="1"
                Padding="10"
                Margin="0,0,0,6">

            <Grid>
                <TextBlock Text="QUICK CUSTOMER REGISTRATION"
                           Foreground="White"
                           FontSize="19"
                           FontWeight="Heavy"
                           HorizontalAlignment="Center"/>

                <TextBlock Text="Esc = Close"
                           Foreground="#BFD7EF"
                           FontSize="12"
                           FontWeight="Bold"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- BODY -->
        <Border Grid.Row="1"
                Background="#F0F0F0"
                BorderBrush="#808080"
                BorderThickness="1"
                Padding="14">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.1*"/>
                    <ColumnDefinition Width="18"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>

                <!-- LEFT: BASIC CUSTOMER DETAILS -->
                <StackPanel Grid.Column="0">
                    <TextBlock Text="1. BASIC DETAILS"
                               FontWeight="Heavy"
                               Foreground="#003366"
                               FontSize="15"
                               Margin="0,0,0,14"/>

                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="125"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="Customer Type *" Style="{StaticResource LabelText}"/>
                        <ComboBox Grid.Column="1"
                                  ItemsSource="{Binding CustomerTypes}"
                                  SelectedItem="{Binding InputCustomerType}"
                                  Style="{StaticResource ClassicCombo}"
                                  FontWeight="Bold"
                                  Background="#FFFFE0"/>
                    </Grid>

                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="125"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="Full Name *" Style="{StaticResource LabelText}"/>
                        <TextBox x:Name="FullNameTextBox"
                                 Grid.Column="1"
                                 Text="{Binding InputFullName, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource ClassicInput}"
                                 Background="#FFFFE0"
                                 FontWeight="Bold"/>
                    </Grid>

                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="125"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="Phone *" Style="{StaticResource LabelText}"/>
                        <TextBox x:Name="PhoneTextBox"
                                 Grid.Column="1"
                                 Text="{Binding InputPhone, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource ClassicInput}"
                                 Background="#FFFFE0"/>
                    </Grid>

                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="125"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="Email:" Style="{StaticResource LabelText}"/>
                        <TextBox x:Name="EmailTextBox"
                                 Grid.Column="1"
                                 Text="{Binding InputEmail, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource ClassicInput}"/>
                    </Grid>

                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="125"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="Birthday:" Style="{StaticResource LabelText}"/>
                        <DatePicker Grid.Column="1"
                                    SelectedDate="{Binding InputBirthday, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    Style="{StaticResource ClassicDate}"/>
                    </Grid>

                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="125"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="Address:" Style="{StaticResource LabelText}"/>
                        <TextBox x:Name="AddressTextBox"
                                 Grid.Column="1"
                                 Text="{Binding InputAddress, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource ClassicInput}"/>
                    </Grid>

                    <!-- RETAIL NIC -->
                    <Grid Margin="0,0,0,10">
                        <Grid.Style>
                            <Style TargetType="Grid">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsRetail}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Grid.Style>

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="125"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="NIC No:" Style="{StaticResource LabelText}"/>
                        <TextBox x:Name="NicTextBox"
                                 Grid.Column="1"
                                 Text="{Binding InputNicNumber, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource ClassicInput}"/>
                    </Grid>
                </StackPanel>

                <Rectangle Grid.Column="1"
                           Width="1"
                           Fill="#A0A0A0"
                           Margin="8,0"/>

                <!-- RIGHT: WHOLESALE / SECURITY RULES -->
                <StackPanel Grid.Column="2">
                    <TextBlock Text="2. BUSINESS DETAILS"
                               FontWeight="Heavy"
                               Foreground="#005500"
                               FontSize="15"
                               Margin="0,0,0,14"/>

                    <Border Background="#FFFFFF"
                            BorderBrush="#C0C0C0"
                            BorderThickness="1"
                            Padding="10"
                            Margin="0,0,0,12">

                        <TextBlock Text="{Binding CustomerTypeHelpText}"
                                   Foreground="#333333"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap"/>
                    </Border>

                    <StackPanel>
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsWholesale}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="115"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="Company *" Style="{StaticResource LabelText}"/>
                            <TextBox x:Name="CompanyTextBox"
                                     Grid.Column="1"
                                     Text="{Binding InputCompanyName, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource ClassicInput}"
                                     Background="#FFFFE0"
                                     FontWeight="Bold"/>
                        </Grid>

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="115"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="BR No:" Style="{StaticResource LabelText}"/>
                            <TextBox x:Name="BrTextBox"
                                     Grid.Column="1"
                                     Text="{Binding InputBusinessRegistrationNumber, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource ClassicInput}"/>
                        </Grid>

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="115"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="VAT No:" Style="{StaticResource LabelText}"/>
                            <TextBox x:Name="VatTextBox"
                                     Grid.Column="1"
                                     Text="{Binding InputVatRegistrationNumber, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource ClassicInput}"/>
                        </Grid>
                    </StackPanel>

                    <Border Background="#FFF7ED"
                            BorderBrush="#D97706"
                            BorderThickness="1"
                            Padding="10"
                            Margin="0,8,0,0">

                        <StackPanel>
                            <TextBlock Text="Cashier permission rule"
                                       FontWeight="Heavy"
                                       Foreground="#9A3412"
                                       Margin="0,0,0,6"/>

                            <TextBlock Text="This screen creates only a basic customer. Loyalty, discount eligibility, credit limit, credit days and credit approval must be changed from BackOffice/Admin."
                                       TextWrapping="Wrap"
                                       Foreground="#7C2D12"
                                       FontWeight="SemiBold"/>
                        </StackPanel>
                    </Border>

                    <Border Background="{Binding StatusColorHex}"
                            BorderBrush="#808080"
                            BorderThickness="1"
                            Padding="10"
                            Margin="0,18,0,0">

                        <TextBlock Text="{Binding StatusText}"
                                   Foreground="White"
                                   FontWeight="Heavy"
                                   FontSize="14"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"/>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- FOOTER -->
        <Border Grid.Row="2"
                Background="#E0E0E0"
                BorderBrush="#A0A0A0"
                BorderThickness="1"
                Padding="10"
                Margin="0,6,0,0">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="Required: Full Name, Phone, Customer Type"
                           Foreground="#333333"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"/>

                <Button Grid.Column="2"
                        Content="CLEAR"
                        Command="{Binding ClearCommand}"
                        Style="{StaticResource ClassicBtn}"
                        Margin="0,0,8,0"/>

                <Button Grid.Column="3"
                        Content="CANCEL"
                        Command="{Binding CancelCommand}"
                        Style="{StaticResource ClassicBtn}"
                        Margin="0,0,8,0"/>

                <Button Grid.Column="4"
        Content="SAVE CUSTOMER"
        Command="{Binding SaveCommand}">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource SaveBtn}">
                            <Setter Property="IsEnabled" Value="True"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsBusy}" Value="True">
                                    <Setter Property="IsEnabled" Value="False"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>
        </Border>
    </Grid>
</Window>