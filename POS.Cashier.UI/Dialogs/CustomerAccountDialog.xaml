<Window x:Class="POS.Cashier.UI.Views.Dialogs.CustomerAccountDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Customer Account Tender" Height="650" Width="900"
        WindowStartupLocation="CenterOwner" WindowStyle="None" ResizeMode="NoResize"
        Background="#1E1E1E" FontFamily="Segoe UI, Arial">

    <!-- Standard Flat Button Style matching the rest of the system -->
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="3"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#444444"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="5"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TextBox" x:Key="FlatTextBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- HEADER (Will change to Purple for Loyalty or Orange for Credit in Code-Behind) -->
        <Border Grid.Row="0" Background="#6F42C1" BorderBrush="#111111" BorderThickness="0,0,0,2">
            <TextBlock Text="{Binding DialogTitle, FallbackValue='LOYALTY REDEMPTION'}" Foreground="White" FontSize="32" FontWeight="Heavy" HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Border>

        <Grid Grid.Row="1" Margin="15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="5.5*"/>
                <ColumnDefinition Width="4.5*"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT SIDE: Customer Details & Math -->
            <Border Grid.Column="0" Background="#2B2B2B" BorderBrush="#444444" BorderThickness="1" Margin="0,0,10,0" Padding="20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Customer Search Bar -->
                    <StackPanel Grid.Row="0" Margin="0,0,0,25">
                        <TextBlock Text="CUSTOMER PHONE / ID" Foreground="#AAAAAA" FontSize="16" FontWeight="Bold" Margin="0,0,0,5"/>
                        <Grid Height="50">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="100"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" Style="{StaticResource FlatTextBox}" FontSize="24" Text="{Binding SearchInput}"/>
                            <Button Grid.Column="1" Background="#0056B3" Content="SEARCH" FontSize="18" Margin="5,0,0,0"/>
                        </Grid>
                    </StackPanel>

                    <!-- Customer Info Plate -->
                    <Border Grid.Row="1" Background="#111111" BorderBrush="#444444" BorderThickness="1" Padding="15" Margin="0,0,0,25">
                        <StackPanel>
                            <TextBlock Text="{Binding CustomerName, FallbackValue='NO CUSTOMER SELECTED'}" Foreground="White" FontSize="24" FontWeight="Heavy" Margin="0,0,0,10"/>
                            <Grid>
                                <TextBlock Text="{Binding BalanceLabel, FallbackValue='AVAILABLE POINTS:'}" Foreground="#AAAAAA" FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding AvailableBalance, StringFormat=N2, FallbackValue='0.00'}" Foreground="#FFD700" FontSize="32" FontWeight="Heavy" HorizontalAlignment="Right"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Amount to Apply -->
                    <StackPanel Grid.Row="3" Margin="0,0,0,20">
                        <TextBlock Text="AMOUNT TO APPLY" Foreground="#AAAAAA" FontSize="18" FontWeight="Bold" Margin="0,0,0,5"/>
                        <TextBox Style="{StaticResource FlatTextBox}" Foreground="#8B0000" FontSize="50" FontWeight="Heavy" TextAlignment="Right" Height="70" Text="{Binding AmountToApply, StringFormat=N2}"/>
                    </StackPanel>

                    <!-- Action Buttons -->
                    <Grid Grid.Row="4" Height="70">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Background="#DC3545" Content="CANCEL" FontSize="22" Margin="0,0,5,0"/>
                        <Button Grid.Column="1" Background="#28A745" Content="APPROVE" FontSize="26" FontWeight="Heavy" Margin="5,0,0,0"/>
                    </Grid>
                </Grid>
            </Border>

            <!-- RIGHT SIDE: Standard POS Numpad -->
            <Grid Grid.Column="1" Margin="10,0,0,0">
                <UniformGrid Columns="3" Rows="4">
                    <Button Background="#444444" Content="7" FontSize="45"/>
                    <Button Background="#444444" Content="8" FontSize="45"/>
                    <Button Background="#444444" Content="9" FontSize="45"/>
                    <Button Background="#444444" Content="4" FontSize="45"/>
                    <Button Background="#444444" Content="5" FontSize="45"/>
                    <Button Background="#444444" Content="6" FontSize="45"/>
                    <Button Background="#444444" Content="1" FontSize="45"/>
                    <Button Background="#444444" Content="2" FontSize="45"/>
                    <Button Background="#444444" Content="3" FontSize="45"/>
                    <Button Background="#DC3545" Content="CLR" FontSize="35"/>
                    <Button Background="#444444" Content="0" FontSize="45"/>
                    <Button Background="#0056B3" Content="&lt;&lt;" FontSize="35"/>
                </UniformGrid>
            </Grid>
        </Grid>
    </Grid>
</Window>