<Window x:Class="POS.Cashier.UI.Views.Dialogs.CreditNoteMasterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Comprehensive Credit Note Manager" Height="750" Width="1100"
        WindowStartupLocation="CenterScreen" 
        WindowStyle="None" 
        ResizeMode="NoResize"
        Background="{StaticResource MainBgBrush}" 
        BorderBrush="{StaticResource HeaderBgBrush}"
        BorderThickness="3"
        FontFamily="Arial, Segoe UI">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="45"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="70"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource HeaderBgBrush}">
            <TextBlock Text="CREDIT NOTE &amp; RETURN MANAGEMENT SYSTEM" Foreground="{StaticResource TextLightBrush}" FontSize="18" FontWeight="Heavy" HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Border>

        <Grid Grid.Row="1" Margin="20,15,20,10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="180"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="25"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Option A: Search Original Invoice Number" FontSize="13" FontWeight="Bold" Foreground="{StaticResource TextDarkBrush}"/>
                    <Grid Margin="0,5,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="80"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="txtInvoiceNumber" Background="White" Foreground="Black" FontSize="16" FontWeight="Bold" Padding="6" VerticalContentAlignment="Center"/>
                        <Button Grid.Column="1" Click="FindInvoiceBtn_Click" Background="#0056B3" Foreground="White" Content="FETCH" FontWeight="Bold" Margin="5,0,0,0" Cursor="Hand"/>
                    </Grid>
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock Text="Option B: Direct Item Tag Scan (No Invoice)" FontSize="13" FontWeight="Bold" Foreground="{StaticResource TextDarkBrush}"/>
                    <TextBox x:Name="txtBarcodeScan" Background="White" Foreground="Black" FontSize="16" FontWeight="Bold" Padding="6" Margin="0,5,0,0" KeyDown="TxtBarcodeScan_KeyDown"/>
                </StackPanel>
            </Grid>

            <GroupBox Grid.Row="1" Header="Original Invoice Contents" FontSize="12" FontWeight="Bold" Foreground="DimGray">
                <DataGrid x:Name="dgInvoiceViewer" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True" Background="White" RowHeight="32" FontSize="13" AlternatingRowBackground="#F8F9FA">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Item Code" Binding="{Binding ItemCode}" Width="100"/>
                        <DataGridTextColumn Header="Description" Binding="{Binding ItemName}" Width="*"/>
                        <DataGridTextColumn Header="Original Price" Binding="{Binding PriceSold, StringFormat=N2}" Width="100"/>
                        <DataGridTextColumn Header="Qty Purchased" Binding="{Binding QtySold}" Width="95"/>
                        <DataGridTemplateColumn Header="Action" Width="110">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="Add to Return" Background="#0056B3" Foreground="White" FontWeight="Bold" FontSize="11" Click="AddFromInvoiceToReturn_Click" Padding="4,2" Cursor="Hand"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </GroupBox>

            <TextBlock Grid.Row="2" Text="Items Selected for Credit Note Receipt Generation" FontSize="13" FontWeight="Bold" Foreground="#D9534F" Margin="0,10,0,5"/>

            <GroupBox Grid.Row="3" Header="Pending Processing Queue" FontSize="12" FontWeight="Bold" Foreground="DimGray">
                <DataGrid x:Name="dgReturnQueue" AutoGenerateColumns="False" CanUserAddRows="False" Background="White" RowHeight="40" FontSize="13" AlternatingRowBackground="#FFF5F5">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Item Code" Binding="{Binding ItemCode}" IsReadOnly="True" Width="100"/>
                        <DataGridTextColumn Header="Description" Binding="{Binding ItemName}" IsReadOnly="True" Width="*"/>

                        <DataGridTemplateColumn Header="Return Remark / Type" Width="180">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <ComboBox SelectedValue="{Binding ReturnRemarkType, UpdateSourceTrigger=PropertyChanged}" 
                                              SelectedValuePath="Tag" Height="30" FontSize="12" FontWeight="Bold" VerticalContentAlignment="Center">
                                        <ComboBoxItem Content="Normal (Add to Stock)" Tag="NORMAL"/>
                                        <ComboBoxItem Content="Damage (Wastage)" Tag="DAMAGE"/>
                                        <ComboBoxItem Content="Other (Overcharge Diff)" Tag="OTHER"/>
                                    </ComboBox>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTextColumn Header="Refund Price (Rs.)" Binding="{Binding PriceSold, UpdateSourceTrigger=PropertyChanged, StringFormat=N2}" Width="120">
                            <DataGridTextColumn.EditingElementStyle>
                                <Style TargetType="TextBox">
                                    <Setter Property="FontWeight" Value="Bold"/>
                                    <Setter Property="Background" Value="#FFFFCC"/>
                                </Style>
                            </DataGridTextColumn.EditingElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="Return Qty" Binding="{Binding ReturnQty, UpdateSourceTrigger=PropertyChanged}" Width="90">
                            <DataGridTextColumn.EditingElementStyle>
                                <Style TargetType="TextBox">
                                    <Setter Property="FontWeight" Value="Bold"/>
                                </Style>
                            </DataGridTextColumn.EditingElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="Total (Rs.)" Binding="{Binding LineTotal, StringFormat=N2, Mode=OneWay}" IsReadOnly="True" Width="110" FontWeight="Bold"/>

                        <DataGridTemplateColumn Header="Remove" Width="65">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="❌" Background="Transparent" BorderThickness="0" FontSize="12" Click="RemoveFromReturnQueue_Click" Cursor="Hand"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </GroupBox>

            <Grid Grid.Row="4" Margin="0,10,0,0">
                <StackPanel Width="250" HorizontalAlignment="Right">
                    <TextBlock Text="Total Credit Note Value (Rs.):" FontSize="13" FontWeight="Bold" Foreground="{StaticResource TextDarkBrush}" HorizontalAlignment="Right"/>
                    <TextBox x:Name="txtGrandTotalRefund" Background="#E9ECEF" Foreground="{StaticResource TextDangerBrush}" FontSize="26" FontWeight="Heavy" TextAlignment="Right" Padding="8,4" Margin="0,5,0,0" IsReadOnly="True" Text="0.00"/>
                </StackPanel>
            </Grid>
        </Grid>

        <Grid Grid.Row="2" Background="{StaticResource HeaderBgBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Button Click="CancelBtn_Click" Grid.Column="0" Background="{StaticResource CancelBtnBrush}" Foreground="White" FontWeight="Bold" Content="CANCEL" FontSize="16" Margin="15,12,7,12" Cursor="Hand"/>
            <Button Click="IssueBtn_Click" Grid.Column="1" Background="#28A745" Foreground="White" FontWeight="Bold" Content="GENERATE &amp; PRINT" FontSize="16" Margin="7,12,15,12" Cursor="Hand"/>
        </Grid>
    </Grid>
</Window>