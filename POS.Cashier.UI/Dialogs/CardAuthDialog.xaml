<Window x:Class="POS.Cashier.UI.Views.Dialogs.CardAuthDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Card Authorization" Height="650" Width="850"
        WindowStartupLocation="CenterOwner" WindowStyle="None" ResizeMode="NoResize"
        Background="#1E1E1E" FontFamily="Segoe UI, Arial">

    <!-- Insert exact same Button Resource Style here -->
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="3"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#444444"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="5"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- HEADER (Changes color based on card type in code-behind) -->
        <Border Grid.Row="0" Background="#1A1F71" BorderBrush="#111111" BorderThickness="0,0,0,2">
            <TextBlock Text="{Binding CardBrandTitle, FallbackValue='VISA PAYMENT'}" Foreground="White" FontSize="32" FontWeight="Heavy" HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Border>

        <Grid Grid.Row="1" Margin="15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="5*"/>
                <ColumnDefinition Width="5*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#2B2B2B" BorderBrush="#444444" BorderThickness="1" Margin="0,0,10,0" Padding="20">
                <Grid>
                    <StackPanel>
                        <TextBlock Text="AMOUNT TO CHARGE" Foreground="#AAAAAA" FontSize="18" FontWeight="Bold"/>
                        <TextBlock Text="{Binding TotalDue, StringFormat=Rs. \{0:N2\}}" Foreground="White" FontSize="50" FontWeight="Heavy" Margin="0,0,0,30"/>

                        <TextBlock Text="LAST 4 DIGITS" Foreground="#AAAAAA" FontSize="18" FontWeight="Bold" Margin="0,0,0,5"/>
                        <TextBox Background="White" Foreground="Black" FontSize="40" FontWeight="Bold" TextAlignment="Center" Height="65" MaxLength="4" Margin="0,0,0,20"/>

                        <TextBlock Text="AUTH / APPROVAL CODE" Foreground="#AAAAAA" FontSize="18" FontWeight="Bold" Margin="0,0,0,5"/>
                        <TextBox Background="White" Foreground="Black" FontSize="40" FontWeight="Bold" TextAlignment="Center" Height="65" MaxLength="6"/>
                    </StackPanel>

                    <Grid VerticalAlignment="Bottom" Height="80">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Background="#DC3545" Content="CANCEL" FontSize="22" Margin="0,0,5,0"/>
                        <Button Grid.Column="1" Background="#1A1F71" Content="AUTHORIZE" FontSize="24" FontWeight="Heavy" Margin="5,0,0,0"/>
                    </Grid>
                </Grid>
            </Border>

            <UniformGrid Grid.Column="1" Columns="3" Rows="4" Margin="10,0,0,0">
                <Button Background="#444444" Content="7" FontSize="40"/>
                <Button Background="#444444" Content="8" FontSize="40"/>
                <Button Background="#444444" Content="9" FontSize="40"/>
                <Button Background="#444444" Content="4" FontSize="40"/>
                <Button Background="#444444" Content="5" FontSize="40"/>
                <Button Background="#444444" Content="6" FontSize="40"/>
                <Button Background="#444444" Content="1" FontSize="40"/>
                <Button Background="#444444" Content="2" FontSize="40"/>
                <Button Background="#444444" Content="3" FontSize="40"/>
                <Button Background="#DC3545" Content="C" FontSize="40"/>
                <Button Background="#444444" Content="0" FontSize="40"/>
                <Button Background="#444444" Content="." FontSize="40"/>
            </UniformGrid>
        </Grid>
    </Grid>
</Window>