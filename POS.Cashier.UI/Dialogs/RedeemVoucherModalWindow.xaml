<Window x:Class="POS.Cashier.UI.Dialogs.RedeemVoucherModalWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Redeem Gift Voucher" 
        SizeToContent="WidthAndHeight" 
        WindowStartupLocation="CenterOwner" 
        WindowStyle="None" 
        AllowsTransparency="True" 
        Background="Transparent"
        FontFamily="Segoe UI">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Border Background="White" BorderBrush="#1E7E34" BorderThickness="4" CornerRadius="8" 
            Width="480" Height="480" Margin="20">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" Opacity="0.5" ShadowDepth="5"/>
        </Border.Effect>

        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="💳 Redeem Gift Voucher" FontSize="22" FontWeight="Bold" Foreground="#333" Margin="0,0,0,10"/>
            <Separator Grid.Row="1" Margin="0,0,0,15" Background="#E0E0E0"/>

            <StackPanel Grid.Row="2">
                <Border Background="#F4FAF6" BorderBrush="#C3E6CB" BorderThickness="1" CornerRadius="4" Padding="15" Margin="0,0,0,15">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="Remaining Bill to Pay: " FontSize="16" Foreground="#555" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding AmountDue, StringFormat=Rs. \{0:N2\}}" FontSize="20" FontWeight="Bold" Foreground="#1E7E34" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <TextBlock Text="Scan Customer Voucher Barcode *" Foreground="#666" Margin="0,0,0,5" FontWeight="SemiBold"/>
                <Grid Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBox Grid.Column="0" Text="{Binding ScannedBarcode, UpdateSourceTrigger=PropertyChanged}" 
                             Height="40" FontSize="18" FontWeight="Bold" VerticalContentAlignment="Center" Padding="10,0">
                        <TextBox.InputBindings>
                            <KeyBinding Key="Return" Command="{Binding SearchBarcodeCommand}"/>
                        </TextBox.InputBindings>
                    </TextBox>

                    <Button Grid.Column="1" Content="🔍 Verify Card" Command="{Binding SearchBarcodeCommand}" 
                            Background="#E2EDF8" Foreground="#2B5B84" BorderThickness="1" BorderBrush="#2B5B84" Margin="10,0,0,0" Padding="15,0" Cursor="Hand" FontWeight="Bold"/>
                </Grid>

                <TextBlock Text="{Binding StatusMessage}" FontSize="14" FontWeight="SemiBold" TextWrapping="Wrap" Margin="0,0,0,15" 
                           Foreground="{Binding IsCardValid, Converter={StaticResource BoolToVis}}"/>

                <Border Background="#FFF3CD" BorderBrush="#FFEEBA" BorderThickness="2" CornerRadius="4" Padding="12" 
                        Visibility="{Binding IsWarningVisible, Converter={StaticResource BoolToVis}}">
                    <StackPanel>
                        <TextBlock Text="⚠️ SINGLE-USE POLICY ALERT" FontWeight="Bold" FontSize="14" Foreground="#856404" Margin="0,0,0,5"/>
                        <TextBlock Text="The voucher value is greater than the bill. If applied, the customer will instantly forfeit the remaining balance." 
                                   Foreground="#856404" TextWrapping="Wrap" FontSize="12" Margin="0,0,0,10"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Amount to Apply:" FontSize="11" Foreground="#666"/>
                                <TextBlock Text="{Binding AmountToApply, StringFormat=Rs. \{0:N2\}}" FontWeight="Bold" FontSize="14" Foreground="#1E7E34"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Customer Forfeits:" FontSize="11" Foreground="#666"/>
                                <TextBlock Text="{Binding ForfeitedAmount, StringFormat=Rs. \{0:N2\}}" FontWeight="Bold" FontSize="14" Foreground="#A94044"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>

            <Grid Grid.Row="3" Margin="0,15,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" Content="Cancel" Command="{Binding CancelCommand}" 
                        Background="#F5F5F5" Foreground="#333" BorderBrush="#CCC" BorderThickness="1" Height="45" FontSize="14" FontWeight="Bold" Cursor="Hand"/>

                <Button Grid.Column="2" Content="💸 CONFIRM PAYMENT" Command="{Binding ConfirmRedemptionCommand}" 
                        Background="#1E7E34" Foreground="White" BorderThickness="0" Height="45" FontSize="14" FontWeight="Bold" Cursor="Hand"
                        IsEnabled="{Binding IsAwaitingConfirmation}"/>
            </Grid>
        </Grid>
    </Border>
</Window>