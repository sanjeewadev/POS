<Window x:Class="POS.Cashier.UI.Dialogs.PaymentDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Payment"
        Width="520"
        Height="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F3F4F6"
        FontFamily="Segoe UI"
        PreviewKeyDown="Window_PreviewKeyDown">

    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="18,0"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>

        <Style TargetType="TextBlock" x:Key="LabelText">
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Height" Value="36"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="TextAlignment" Value="Right"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="8,0"/>
        </Style>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0"
                Background="#003366"
                Padding="14"
                BorderBrush="#222222"
                BorderThickness="1">

            <TextBlock Text="PAYMENT"
                       Foreground="White"
                       FontSize="22"
                       FontWeight="Heavy"
                       HorizontalAlignment="Center"/>
        </Border>

        <!-- STATUS -->
        <Border Grid.Row="2"
                Background="{Binding StatusColorHex}"
                Padding="8">

            <TextBlock Text="{Binding StatusText}"
                       Foreground="White"
                       FontSize="14"
                       FontWeight="Bold"
                       TextAlignment="Center"/>
        </Border>

        <!-- BODY -->
        <Border Grid.Row="4"
                Background="White"
                BorderBrush="#999999"
                BorderThickness="1"
                Padding="14">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="50"/>
                    <RowDefinition Height="50"/>
                    <RowDefinition Height="50"/>
                    <RowDefinition Height="50"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="145"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0"
                           Grid.Column="0"
                           Text="Payment Type"
                           Style="{StaticResource LabelText}"/>

                <ComboBox Grid.Row="0"
                          Grid.Column="1"
                          ItemsSource="{Binding PaymentTypes}"
                          SelectedItem="{Binding SelectedPaymentType, Mode=TwoWay}"
                          Height="36"
                          FontSize="16"
                          FontWeight="Bold"
                          VerticalContentAlignment="Center"/>

                <TextBlock Grid.Row="1"
                           Grid.Column="0"
                           Text="Net Total"
                           Style="{StaticResource LabelText}"/>

                <Border Grid.Row="1"
                        Grid.Column="1"
                        Background="#111827"
                        Padding="8,0">

                    <TextBlock Text="{Binding NetTotal, StringFormat=N2}"
                               Foreground="#FBBF24"
                               FontSize="26"
                               FontWeight="Heavy"
                               TextAlignment="Right"
                               VerticalAlignment="Center"/>
                </Border>

                <TextBlock Grid.Row="2"
                           Grid.Column="0"
                           Text="Tendered"
                           Style="{StaticResource LabelText}"/>

                <TextBox x:Name="AmountTenderedTextBox"
                         Grid.Row="2"
                         Grid.Column="1"
                         Text="{Binding AmountTendered, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, StringFormat=N2}"
                         Background="#FFFFE0"
                         Foreground="#8B0000"/>

                <TextBlock Grid.Row="3"
                           Grid.Column="0"
                           Text="Balance"
                           Style="{StaticResource LabelText}"/>

                <Border Grid.Row="3"
                        Grid.Column="1"
                        Background="#ECFDF5"
                        BorderBrush="#10B981"
                        BorderThickness="1"
                        Padding="8,0">

                    <TextBlock Text="{Binding BalanceReturned, StringFormat=N2}"
                               Foreground="#047857"
                               FontSize="24"
                               FontWeight="Heavy"
                               TextAlignment="Right"
                               VerticalAlignment="Center"/>
                </Border>

                <Button Grid.Row="4"
                        Grid.Column="1"
                        Content="EXACT AMOUNT"
                        Command="{Binding ExactAmountCommand}"
                        Background="#6B7280"
                        Foreground="White"
                        VerticalAlignment="Top"
                        Margin="0,12,0,0"/>
            </Grid>
        </Border>

        <!-- BUTTONS -->
        <Grid Grid.Row="5" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="1"
                    Content="CANCEL"
                    Command="{Binding CancelCommand}"
                    Background="#6B7280"
                    Foreground="White"
                    Margin="0,0,8,0"/>

            <Button Grid.Column="2"
                    Content="CONFIRM PAYMENT"
                    Command="{Binding ConfirmCommand}"
                    Background="#10B981"
                    Foreground="White"
                    Padding="24,0"/>
        </Grid>
    </Grid>
</Window>