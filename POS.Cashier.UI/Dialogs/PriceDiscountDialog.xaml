<Window x:Class="POS.Cashier.UI.Dialogs.PriceDiscountDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Price and Discount" Height="650" Width="900"
        WindowStartupLocation="CenterOwner" WindowStyle="None" ResizeMode="NoResize"
        Background="#1E1E1E" FontFamily="Segoe UI, Arial">

    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="3"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#444444"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="5"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TextBox" x:Key="FlatTextBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="FontWeight" Value="Heavy"/>
            <Setter Property="FontSize" Value="36"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="60"/>
        </Style>

        <Style TargetType="PasswordBox" x:Key="FlatPasswordBox">
            <Setter Property="Background" Value="#111111"/>
            <Setter Property="Foreground" Value="#FFD700"/>
            <Setter Property="FontWeight" Value="Heavy"/>
            <Setter Property="FontSize" Value="36"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#DC3545"/>
            <Setter Property="Height" Value="60"/>
        </Style>

        <Style TargetType="ComboBox" x:Key="FlatComboBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="50"/>
        </Style>

        <Style TargetType="TextBlock" x:Key="FormLabel">
            <Setter Property="Foreground" Value="#AAAAAA"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#17A2B8" BorderBrush="#111111" BorderThickness="0,0,0,2">
            <TextBlock Text="{Binding DialogTitle, FallbackValue='ITEM DISCOUNT (%)'}" Foreground="White" FontSize="32" FontWeight="Heavy" HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Border>

        <Grid Grid.Row="1" Margin="15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="5.5*"/>
                <ColumnDefinition Width="4.5*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#2B2B2B" BorderBrush="#444444" BorderThickness="1" Margin="0,0,10,0" Padding="20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="70"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#111111" Padding="15" Margin="0,0,0,20">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="TARGET ITEM:" Foreground="#777777" FontSize="12" FontWeight="Bold"/>
                                <TextBlock Text="{Binding TargetName, FallbackValue='1x SUNLIGHT SOAP 100G'}" Foreground="White" FontSize="18" FontWeight="Bold" TextWrapping="Wrap"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                <TextBlock Text="CURRENT PRICE:" Foreground="#777777" FontSize="12" FontWeight="Bold" TextAlignment="Right"/>
                                <TextBlock Text="{Binding CurrentPrice, FallbackValue='Rs. 150.00'}" Foreground="#A9C6E2" FontSize="20" FontWeight="Heavy" TextAlignment="Right"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <StackPanel Grid.Row="1" Margin="0,0,0,20">
                        <TextBlock Text="{Binding InputLabel, FallbackValue='ENTER DISCOUNT PERCENTAGE'}" Style="{StaticResource FormLabel}"/>
                        <TextBox Style="{StaticResource FlatTextBox}" Text="{Binding InputValue, FallbackValue='15'}" TextAlignment="Right" Foreground="#8B0000"/>
                    </StackPanel>

                    <StackPanel Grid.Row="2" Margin="0,0,0,20">
                        <TextBlock Text="REASON CODE (REQUIRED)" Style="{StaticResource FormLabel}"/>
                        <ComboBox Style="{StaticResource FlatComboBox}" SelectedValue="{Binding SelectedReason}">
                            <ComboBoxItem Content="Select Reason..."/>
                            <ComboBoxItem Content="Damaged / Open Box"/>
                            <ComboBoxItem Content="Staff Discount"/>
                            <ComboBoxItem Content="Wholesale Agreement"/>
                            <ComboBoxItem Content="Manager Promotion"/>
                            <ComboBoxItem Content="Price Match"/>
                        </ComboBox>
                    </StackPanel>

                    <Border Grid.Row="3" Background="#2C1212" BorderBrush="#DC3545" BorderThickness="1" Padding="15" Margin="0,10,0,20" VerticalAlignment="Top" 
                            Visibility="{Binding IsManagerOverrideRequired, FallbackValue=Visible}">
                        <StackPanel>
                            <TextBlock Text="⚠️ SECURITY OVERRIDE REQUIRED" Foreground="#DC3545" FontSize="16" FontWeight="Heavy" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                            <TextBlock Text="This action exceeds the cashier limit. Enter Manager PIN." Foreground="#AAAAAA" FontSize="12" TextAlignment="Center" Margin="0,0,0,10"/>
                            <PasswordBox Style="{StaticResource FlatPasswordBox}" MaxLength="4"/>
                        </StackPanel>
                    </Border>

                    <Grid Grid.Row="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Background="#DC3545" Content="CANCEL" FontSize="22" Margin="0,0,5,0" Command="{Binding CancelCommand}"/>
                        <Button Grid.Column="1" Background="#28A745" Content="APPLY" FontSize="26" FontWeight="Heavy" Margin="5,0,0,0" Command="{Binding ApplyCommand}"/>
                    </Grid>
                </Grid>
            </Border>

            <Grid Grid.Column="1" Margin="10,0,0,0">
                <UniformGrid Columns="3" Rows="4">
                    <Button Background="#444444" Content="7" FontSize="45"/>
                    <Button Background="#444444" Content="8" FontSize="45"/>
                    <Button Background="#444444" Content="9" FontSize="45"/>
                    <Button Background="#444444" Content="4" FontSize="45"/>
                    <Button Background="#444444" Content="5" FontSize="45"/>
                    <Button Background="#444444" Content="6" FontSize="45"/>
                    <Button Background="#444444" Content="1" FontSize="45"/>
                    <Button Background="#444444" Content="2" FontSize="45"/>
                    <Button Background="#444444" Content="3" FontSize="45"/>
                    <Button Background="#DC3545" Content="CLR" FontSize="35"/>
                    <Button Background="#444444" Content="0" FontSize="45"/>
                    <Button Background="#0056B3" Content="." FontSize="45"/>
                </UniformGrid>
            </Grid>
        </Grid>
    </Grid>
</Window>