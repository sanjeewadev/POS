<Window x:Class="POS.Cashier.UI.Views.SalesView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Sales Checkout"
        WindowState="Maximized"
        WindowStyle="None"
        Background="{StaticResource MainBgBrush}" 
        FontFamily="Segoe UI, Arial"
        PreviewTextInput="Window_PreviewTextInput"
        PreviewKeyDown="Window_PreviewKeyDown">

    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Margin" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#222222"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="2" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TextBox" x:Key="LockedInput">
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Margin" Value="2,2,10,2"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="Background" Value="#E0E0E0"/>
            <Setter Property="Padding" Value="8,2"/>
            <Setter Property="BorderBrush" Value="#AAAAAA"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>

        <Style TargetType="TextBlock" x:Key="HeaderLabel">
            <Setter Property="Foreground" Value="#111111"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,2,0"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
    </Window.Resources>

    <Grid Margin="2">
        <Grid.RowDefinitions>
            <RowDefinition Height="45"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0" Background="{StaticResource HeaderBgBrush}" Margin="0,0,0,2" BorderBrush="#222222" BorderThickness="1">
            <Grid>
                <TextBlock Text="BANDULA TRADE CENTER" Foreground="White" FontSize="22" FontWeight="Heavy" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,10,0">
                    <TextBlock Text="2026-06-01 09:27:56" Foreground="#FFB84D" FontSize="18" FontWeight="Bold" Margin="0,0,15,0" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- INFO PANEL -->
        <Border Grid.Row="1" Background="{StaticResource InfoPanelBgBrush}" Padding="8" Margin="0,0,0,2" BorderBrush="{StaticResource HeaderBgBrush}" BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="32"/>
                    <RowDefinition Height="32"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Terminal No" Style="{StaticResource HeaderLabel}" Grid.Row="0" Grid.Column="0"/>
                <TextBox Text="1" Style="{StaticResource LockedInput}" Grid.Row="0" Grid.Column="1"/>
                <TextBlock Text="Location" Style="{StaticResource HeaderLabel}" Grid.Row="1" Grid.Column="0"/>
                <TextBox Text="CB" Style="{StaticResource LockedInput}" Grid.Row="1" Grid.Column="1"/>

                <TextBlock Text="Date" Style="{StaticResource HeaderLabel}" Grid.Row="0" Grid.Column="2"/>
                <TextBox Text="2026-06-01" Style="{StaticResource LockedInput}" Grid.Row="0" Grid.Column="3"/>
                <TextBlock Text="Cashier" Style="{StaticResource HeaderLabel}" Grid.Row="1" Grid.Column="2"/>
                <TextBox Text="Cashier Pos" Style="{StaticResource LockedInput}" Grid.Row="1" Grid.Column="3"/>

                <TextBlock Text="Customer" Style="{StaticResource HeaderLabel}" Grid.Row="0" Grid.Column="4"/>
                <TextBox Text="Walk-In" Style="{StaticResource LockedInput}" Grid.Row="0" Grid.Column="5" Background="White" IsReadOnly="False" Focusable="True"/>
                <TextBlock Text="Salesman" Style="{StaticResource HeaderLabel}" Grid.Row="1" Grid.Column="4"/>
                <TextBox Text="0" Style="{StaticResource LockedInput}" Grid.Row="1" Grid.Column="5" Background="White" IsReadOnly="False" Focusable="True"/>

                <TextBlock Text="Invoice No" Style="{StaticResource HeaderLabel}" Grid.Row="0" Grid.Column="6"/>
                <TextBox Text="INCB1002003" Style="{StaticResource LockedInput}" Foreground="#8B0000" Grid.Row="0" Grid.Column="7" />
                <TextBlock Text="Order No" Style="{StaticResource HeaderLabel}" Grid.Row="1" Grid.Column="6"/>
                <TextBox Text="ORCB1000096" Style="{StaticResource LockedInput}" Foreground="#8B0000" Grid.Row="1" Grid.Column="7" />
            </Grid>
        </Border>

        <!-- MAIN CONTENT AREA - Split into Top and Bottom -->
        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="8*"/>
                <RowDefinition Height="3*"/>
            </Grid.RowDefinitions>

            <!-- ==================== TOP PANEL ==================== -->
            <Grid Grid.Row="0" Margin="0,0,0,2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="7*"/>
                    <ColumnDefinition Width="3*"/>
                </Grid.ColumnDefinitions>

                <!-- TOP LEFT: Item Table -->
                <Grid Grid.Column="0" Margin="0,0,2,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- DataGrid -->
                    <DataGrid x:Name="CartDataGrid" ItemsSource="{Binding Cart}" SelectionChanged="CartDataGrid_SelectionChanged" Grid.Row="0" Background="White" AutoGenerateColumns="False" HeadersVisibility="Column" RowHeight="50" FontSize="18" BorderBrush="{StaticResource HeaderBgBrush}" BorderThickness="1" GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#D0D0D0">
                        <DataGrid.Resources>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="{StaticResource HeaderBgBrush}"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="Padding" Value="10,12"/>
                                <Setter Property="BorderThickness" Value="0,0,1,1"/>
                                <Setter Property="FontSize" Value="16"/>
                            </Style>
                        </DataGrid.Resources>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="#" Binding="{Binding ItemId}" Width="55"/>
                            <DataGridTextColumn Header="Code" Binding="{Binding Barcode}" Width="140"/>
                            <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="*"/>
                            <DataGridTextColumn Header="Qty" Binding="{Binding Quantity}" Width="85"/>
                            <DataGridTextColumn Header="Price" Binding="{Binding UnitPrice, StringFormat=N2}" Width="110"/>
                            <DataGridTextColumn Header="%" Binding="{Binding DiscountPercentage, StringFormat=N0}" Width="75"/>
                            <DataGridTextColumn Header="Amount" Binding="{Binding LineAmount, StringFormat=N2}" Width="130"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Contextual Qty Panel -->
                    <Border x:Name="ContextualQtyPanel" Grid.Row="0" VerticalAlignment="Bottom" Background="{StaticResource InfoPanelBgBrush}" BorderBrush="{StaticResource HeaderBgBrush}" BorderThickness="1" Margin="3" Padding="10" Visibility="Collapsed" HorizontalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Edit Qty:" Foreground="Black" FontWeight="Bold" FontSize="20" VerticalAlignment="Center" Margin="0,0,15,0"/>
                            <Button Content="-" Width="60" Height="45" FontSize="28" Background="{StaticResource NumpadBtnBrush}" Click="QtyMinusBtn_Click"/>
                            <TextBox x:Name="txtQtyInput" Width="100" Height="45" FontSize="24" FontWeight="Bold" TextAlignment="Center" Margin="2,0"/>
                            <Button Content="+" Width="60" Height="45" FontSize="28" Background="{StaticResource NumpadBtnBrush}" Click="QtyPlusBtn_Click"/>
                            <Button Content="OK" Width="100" Height="45" FontSize="20" Background="{StaticResource SystemBtnBrush}" Click="HideQtyPanel_Click" Margin="20,0,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- NET VALUE & Totals Bar -->
                    <Border Grid.Row="1" Background="{StaticResource TotalsPanelBgBrush}" Padding="15" BorderBrush="#222222" BorderThickness="1" Margin="0,2,0,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0" Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="NET VALUE" FontSize="28" FontWeight="Heavy" Foreground="White" VerticalAlignment="Center" Margin="0,0,20,0"/>
                                <Border Grid.Column="1" Background="White" Padding="5">
                                    <TextBlock Text="{Binding NetValue, StringFormat=N2}" FontSize="42" FontWeight="Heavy" Foreground="#8B0000" TextAlignment="Right"/>
                                </Border>
                            </Grid>

                            <Grid Grid.Row="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Discount / (Items/Pcs)" FontSize="14" FontWeight="Bold" Foreground="White" VerticalAlignment="Center" Margin="0,0,15,0"/>
                                <Border Grid.Column="1" Background="White" Margin="0,0,15,0" Padding="2">
                                    <TextBlock Text="{Binding TotalDiscount, StringFormat=N2}" TextAlignment="Right" FontWeight="Bold"/>
                                </Border>
                                <Border Grid.Column="2" Background="White" Margin="0,0,15,0" Padding="2">
                                    <TextBlock Text="{Binding TotalItems}" TextAlignment="Center" FontWeight="Bold"/>
                                </Border>
                                <StackPanel Grid.Column="3" Orientation="Horizontal">
                                    <TextBlock Text="English" Background="Black" Foreground="White" Padding="8,2" FontSize="11" FontWeight="Bold" Margin="2,0"/>
                                    <TextBlock Text="Slip Printer ON" Background="#32CD32" Foreground="Black" Padding="8,2" FontSize="11" FontWeight="Bold" Margin="2,0"/>
                                    <TextBlock Text="LAN" Background="#32CD32" Foreground="Black" Padding="8,2" FontSize="11" FontWeight="Bold" Margin="2,0"/>
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>

                <!-- TOP RIGHT: Numpad + Action Buttons -->
                <Grid Grid.Column="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="3*"/>
                        <RowDefinition Height="5*"/>
                    </Grid.RowDefinitions>

                    <!-- Action Buttons: Return/Void/Discount etc -->
                    <UniformGrid Grid.Row="0" Columns="3" Rows="4" Margin="0,0,0,1">
                        <Button Background="{StaticResource ActionBtnBrush}" Content="Return" Click="ReturnBtn_Click"/>
                        <Button Background="{StaticResource ActionBtnBrush}" Content="Void" Click="RemoveBtn_Click"/>
                        <Button Background="{StaticResource ActionBtnBrush}" Content="Discount" Click="DiscountBtn_Click"/>

                        <Button Background="{StaticResource ActionBtnBrush}" Content="Suspend" Click="SuspendRecallBtn_Click"/>
                        <Button Background="{StaticResource ActionBtnBrush}" Content="Recall" Click="SuspendRecallBtn_Click"/>
                        <Button Background="{StaticResource ActionBtnBrush}" Content="Dis. Price" FontSize="14" Click="DiscountBtn_Click"/>

                        <Button Background="{StaticResource ActionBtnBrush}" Content="Add Float" FontSize="14" Command="{Binding AddFloatCommand}"/>
                        <Button Background="{StaticResource ActionBtnBrush}" Content="%" Click="DiscountBtn_Click"/>
                        <Button Background="{StaticResource ActionBtnBrush}" Content="Drawer"/>

                        <Button Background="{StaticResource ActionBtnBrush}" Content="Seek" Click="SeekBtn_Click"/>
                        <Button Background="{StaticResource ActionBtnBrush}" Content="Remove" Click="RemoveBtn_Click"/>
                        <Button Background="{StaticResource CancelBtnBrush}" Content="Cancel" Click="CancelSaleBtn_Click"/>
                    </UniformGrid>

                    <!-- Numpad -->
                    <UniformGrid Grid.Row="1" Columns="3" Rows="6" Margin="0,0,0,0">
                        <Button Background="{StaticResource NumpadBtnBrush}" Content="(-)" Click="QtyMinusBtn_Click"/>
                        <Button Background="{StaticResource NumpadBtnBrush}" Content="+" Click="QtyPlusBtn_Click"/>
                        <Button Background="{StaticResource NumpadBtnBrush}" Content="*" Click="Button_Click"/>
                        <Button Background="{StaticResource NumpadBtnBrush}" Content="/"/>
                        <Button Background="{StaticResource NumpadBtnBrush}" Content="-"/>
                        <Button Background="{StaticResource NumpadBtnBrush}" Content="&lt;&lt;" Click="ClearBtn_Click"/>

                        <Button Background="{StaticResource NumpadBtnBrush}" Content="7" FontSize="28" Click="NumpadBtn_Click"/>
                        <Button Background="{StaticResource NumpadBtnBrush}" Content="8" FontSize="28" Click="NumpadBtn_Click"/>
                        <Button Background="{StaticResource NumpadBtnBrush}" Content="9" FontSize="28" Click="NumpadBtn_Click"/>
                        <Button Background="{StaticResource NumpadBtnBrush}" Content="4" FontSize="28" Click="NumpadBtn_Click"/>
                        <Button Background="{StaticResource NumpadBtnBrush}" Content="5" FontSize="28" Click="NumpadBtn_Click"/>
                        <Button Background="{StaticResource NumpadBtnBrush}" Content="6" FontSize="28" Click="NumpadBtn_Click"/>
                        <Button Background="{StaticResource NumpadBtnBrush}" Content="1" FontSize="28" Click="NumpadBtn_Click"/>
                        <Button Background="{StaticResource NumpadBtnBrush}" Content="2" FontSize="28" Click="NumpadBtn_Click"/>
                        <Button Background="{StaticResource NumpadBtnBrush}" Content="3" FontSize="28" Click="NumpadBtn_Click"/>

                        <Button Background="{StaticResource NumpadBtnBrush}" Content="Clear" FontSize="18" Click="ClearBtn_Click"/>
                        <Button Background="{StaticResource NumpadBtnBrush}" Content="0" FontSize="28" Click="NumpadBtn_Click"/>
                        <Button Background="{StaticResource NumpadBtnBrush}" Content="." FontSize="28" Click="NumpadBtn_Click"/>
                    </UniformGrid>
                </Grid>
            </Grid>

            <!-- ==================== BOTTOM PANEL ==================== -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="5*"/>
                    <ColumnDefinition Width="5*"/>
                </Grid.ColumnDefinitions>

                <!-- BOTTOM LEFT: Action Buttons (6x3 grid) -->
                <UniformGrid Grid.Column="0" Columns="5" Rows="3" Margin="0,0,2,0">
                    
                    <Button Background="{StaticResource SystemBtnBrush}" Content="Reports" FontSize="14" Click="ReportsBtn_Click"/>
                    <Button Background="{StaticResource SystemBtnBrush}" Content="Today's Sales" FontSize="14" Click="ReportsBtn_Click"/>
                    <Button Background="{StaticResource SystemBtnBrush}" Content="Paid In" FontSize="14" Click="PaidInBtn_Click"/>
                    <Button Background="{StaticResource SystemBtnBrush}" Content="Paid Out" FontSize="14" Click="PaidOutBtn_Click"/>


                    <Button Background="{StaticResource ActionBtnBrush}" Content="Discount Type" FontSize="13" Click="DiscountBtn_Click"/>
                    
                    <Button Background="{StaticResource ActionBtnBrush}" Content="Stock Inq." FontSize="14" Click="StockInquiryBtn_Click"/>
                    <Button Background="{StaticResource ActionBtnBrush}" Content="Customer" FontSize="14" Click="CustomerBtn_Click"/>
                    <Button Background="{StaticResource LoyaltyBgBrush}" Foreground="#FFD700" Content="LOYALTY" FontSize="14" Click="LoyaltyBtn_Click"/>
                    <Button Background="{StaticResource ActionBtnBrush}" Content="Reload" FontSize="14"/>
                    <Button Background="{StaticResource ActionBtnBrush}" Content="Retail" FontSize="14"/>


                    
                    <Button Background="#007BFF" Foreground="White" Content="SHIFT MENU" FontSize="14" Click="ShiftMenuBtn_Click"/>


                    <Button Background="{StaticResource ActionBtnBrush}" Content="No Sale" FontSize="14"/>
                    <Button Background="{StaticResource ActionBtnBrush}" Content="New Price" FontSize="14" Click="PriceOverrideBtn_Click"/>
                    <Button Background="{StaticResource ActionBtnBrush}" Content="Free" FontSize="14" Click="FreeBtn_Click"/>

                    <Button Background="{StaticResource ExpressBtnBrush}" Foreground="White" Content="Express Items" FontSize="13" Click="ExpressItemsBtn_Click"/>
                </UniformGrid>

                <!-- BOTTOM RIGHT: Payment Buttons -->
                <Grid Grid.Column="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="4.5*"/>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="1.6*"/>
                    </Grid.ColumnDefinitions>

                    <UniformGrid Grid.Column="0" Columns="4" Rows="2" Margin="0,0,2,0">
                        <Button Background="{StaticResource PaymentDarkOrangeBrush}" Foreground="Black" Content="Cust Credit" FontSize="15" Click="PayBtn_Click"/>
                       
                        <Button Background="#EEEEEE" Foreground="#CC0000" Content="MasterCard" FontSize="16" FontWeight="Bold" Click="PayBtn_Click"/>
                        <Button Background="#EEEEEE" Foreground="#1A1F71" Content="VISA" FontSize="20" FontWeight="Heavy" Click="PayBtn_Click"/>
                        <Button Background="#EEEEEE" Foreground="#2A71D0" Content="AMEX" FontSize="18" FontWeight="Heavy" Click="PayBtn_Click"/>
                        <Button Background="{StaticResource PaymentDarkOrangeBrush}" Foreground="Black" Content="Credit Note" FontSize="15" Click="PayBtn_Click"/>
                        <Button Background="{StaticResource PaymentOrangeBrush}" Foreground="Black" Content="Cheque" FontSize="14" Click="PayBtn_Click"/>
                  
                        <Button Background="{StaticResource LoyaltyBgBrush}" Foreground="#FFD700" Content="LOYALTY" FontSize="16" Click="PayBtn_Click"/>
                        <Button Background="{StaticResource PaymentOrangeBrush}" Foreground="Black" Content="Gift Voucher" FontSize="13" Click="PayBtn_Click"/>


                    </UniformGrid>

                    <Button Grid.Column="1" Background="{StaticResource SubTotalBtnBrush}" Content="Sub&#x0a;Total" FontSize="22" Margin="0,0,1,0" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Click="PayBtn_Click"/>

                    <Grid Grid.Column="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Button Grid.Row="0" Background="{StaticResource PluBtnBrush}" Content="PLU" FontSize="22" Margin="0,0,0,1"/>
                        <Button Grid.Row="1" Background="{StaticResource CashBtnBrush}" Content="Cash" FontSize="30" FontWeight="Heavy" Click="PayBtn_Click" Margin="0"/>
                    </Grid>
                </Grid>
            </Grid>
        </Grid>
        <Border x:Name="DimmingCurtain" 
                Background="#90000000" 
                Visibility="Collapsed" 
                Grid.RowSpan="10" 
                Grid.ColumnSpan="10" 
                Panel.ZIndex="999"/>
    </Grid>
</Window>