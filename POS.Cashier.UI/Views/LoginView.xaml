<Window x:Class="POS.Cashier.UI.Views.LoginView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="System Login"
        Background="#2F4444"
        FontFamily="Segoe UI" FontSize="14"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="NoResize"
        Height="450" Width="400">

    <Grid>
        <Border Background="#1C2B2B" 
                BorderBrush="#5DBCD2" 
                BorderThickness="2" 
                CornerRadius="4" 
                Width="350" Height="400" 
                HorizontalAlignment="Center" 
                VerticalAlignment="Center" 
                Padding="30">

            <StackPanel VerticalAlignment="Center">

                <TextBlock Text="CASHIER TERMINAL" 
                           Foreground="White" 
                           FontSize="24" 
                           FontWeight="Bold" 
                           HorizontalAlignment="Center" 
                           Margin="0,0,0,30"/>

                <TextBlock Text="Username" Foreground="LightGray" FontWeight="Bold" Margin="0,0,0,5"/>
                <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}" 
                         Height="35" 
                         VerticalContentAlignment="Center" 
                         Margin="0,0,0,15"
                         FontSize="16"
                         Padding="5,0"/>

                <TextBlock Text="Password" Foreground="LightGray" FontWeight="Bold" Margin="0,0,0,5"/>
                <PasswordBox Name="txtPassword" 
                             PasswordChanged="txtPassword_PasswordChanged" 
                             Height="35" 
                             VerticalContentAlignment="Center" 
                             Margin="0,0,0,10"
                             FontSize="16"
                             Padding="5,0"/>

                <TextBlock Text="{Binding ErrorMessage}" 
                           Foreground="#FF6666" 
                           FontWeight="Bold" 
                           HorizontalAlignment="Center" 
                           TextWrapping="Wrap"
                           TextAlignment="Center"
                           Height="40"
                           Margin="0,0,0,5"/>

                <Button Command="{Binding LoginCommand}" 
                        Foreground="White" 
                        Background="#5DBCD2"
                        FontWeight="Bold" 
                        FontSize="18" 
                        Height="50" 
                        Cursor="Hand"
                        Margin="0,10,0,0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" 
                                    CornerRadius="4">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

            </StackPanel>
        </Border>
    </Grid>
</Window>