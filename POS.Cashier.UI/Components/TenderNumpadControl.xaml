<UserControl x:Class="POS.Cashier.UI.Components.TenderNumpadControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             MinWidth="250"
             MinHeight="390"
             Focusable="False">

    <UserControl.Resources>
        <Style x:Key="TenderKeyStyle" TargetType="Button">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontWeight" Value="Heavy"/>
            <Setter Property="FontSize" Value="25"/>
            <Setter Property="Foreground" Value="#111111"/>
            <Setter Property="Background" Value="#F4F4F4"/>
            <Setter Property="BorderBrush" Value="#707070"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="MinHeight" Value="56"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="KeyBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="2">

                            <Grid>
                                <Rectangle x:Name="TopGloss"
                                           Height="18"
                                           VerticalAlignment="Top"
                                           Fill="#20FFFFFF"/>

                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="KeyBorder" Property="Background" Value="#E5E7EB"/>
                                <Setter TargetName="KeyBorder" Property="BorderBrush" Value="#374151"/>
                            </Trigger>

                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="KeyBorder" Property="Background" Value="#BFC3C9"/>
                                <Setter TargetName="TopGloss" Property="Fill" Value="#00FFFFFF"/>
                            </Trigger>

                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="KeyBorder" Property="Opacity" Value="0.40"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ActionKeyStyle" TargetType="Button" BasedOn="{StaticResource TenderKeyStyle}">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="17"/>
        </Style>
    </UserControl.Resources>

    <Border Background="#BFC4CA"
            BorderBrush="#4B5563"
            BorderThickness="2"
            CornerRadius="3"
            Padding="6">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="34"/>
                <RowDefinition Height="62"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- HEADER -->
            <Border Grid.Row="0"
                    Background="#0B3A53"
                    BorderBrush="#06293B"
                    BorderThickness="1"
                    CornerRadius="2"
                    Padding="6,0">

                <Grid>
                    <TextBlock Text="{Binding HeaderText, RelativeSource={RelativeSource AncestorType=UserControl}}"
                               Foreground="White"
                               FontSize="12"
                               FontWeight="Heavy"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Left"/>

                    <TextBlock Text="{Binding ModeText, RelativeSource={RelativeSource AncestorType=UserControl}}"
                               Foreground="#BFEAFF"
                               FontSize="11"
                               FontWeight="Bold"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Right"/>
                </Grid>
            </Border>

            <!-- DISPLAY -->
            <Border Grid.Row="1"
                    Background="#111827"
                    BorderBrush="#030712"
                    BorderThickness="2"
                    CornerRadius="2"
                    Margin="0,6,0,6"
                    Padding="8">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="16"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="{Binding TargetLabel, RelativeSource={RelativeSource AncestorType=UserControl}}"
                               Foreground="#9CA3AF"
                               FontSize="10"
                               FontWeight="Bold"/>

                    <TextBlock Grid.Row="1"
                               Text="{Binding TargetText, RelativeSource={RelativeSource AncestorType=UserControl}, FallbackValue=0}"
                               Foreground="#FBBF24"
                               FontSize="27"
                               FontWeight="Heavy"
                               TextAlignment="Right"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis"/>
                </Grid>
            </Border>

            <!-- KEYS -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="1.08*"/>
                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Button Grid.Row="0" Grid.Column="0"
                        Content="7"
                        Tag="7"
                        Style="{StaticResource TenderKeyStyle}"
                        Click="Key_Click"/>

                <Button Grid.Row="0" Grid.Column="1"
                        Content="8"
                        Tag="8"
                        Style="{StaticResource TenderKeyStyle}"
                        Click="Key_Click"/>

                <Button Grid.Row="0" Grid.Column="2"
                        Content="9"
                        Tag="9"
                        Style="{StaticResource TenderKeyStyle}"
                        Click="Key_Click"/>

                <Button Grid.Row="0" Grid.Column="3"
                        Content="⌫"
                        Tag="BACK"
                        Style="{StaticResource ActionKeyStyle}"
                        Background="#B91C1C"
                        BorderBrush="#7F1D1D"
                        FontSize="24"
                        Click="Key_Click"/>

                <Button Grid.Row="1" Grid.Column="0"
                        Content="4"
                        Tag="4"
                        Style="{StaticResource TenderKeyStyle}"
                        Click="Key_Click"/>

                <Button Grid.Row="1" Grid.Column="1"
                        Content="5"
                        Tag="5"
                        Style="{StaticResource TenderKeyStyle}"
                        Click="Key_Click"/>

                <Button Grid.Row="1" Grid.Column="2"
                        Content="6"
                        Tag="6"
                        Style="{StaticResource TenderKeyStyle}"
                        Click="Key_Click"/>

                <Button Grid.Row="1" Grid.Column="3"
                        Content="CLEAR"
                        Tag="CLR"
                        Style="{StaticResource ActionKeyStyle}"
                        Background="#D97706"
                        BorderBrush="#92400E"
                        FontSize="15"
                        Click="Key_Click"/>

                <Button Grid.Row="2" Grid.Column="0"
                        Content="1"
                        Tag="1"
                        Style="{StaticResource TenderKeyStyle}"
                        Click="Key_Click"/>

                <Button Grid.Row="2" Grid.Column="1"
                        Content="2"
                        Tag="2"
                        Style="{StaticResource TenderKeyStyle}"
                        Click="Key_Click"/>

                <Button Grid.Row="2" Grid.Column="2"
                        Content="3"
                        Tag="3"
                        Style="{StaticResource TenderKeyStyle}"
                        Click="Key_Click"/>

                <Button Grid.Row="2" Grid.Column="3"
                        Grid.RowSpan="2"
                        Content="ENTER"
                        Tag="ENTER"
                        Style="{StaticResource ActionKeyStyle}"
                        Background="#059669"
                        BorderBrush="#065F46"
                        FontSize="18"
                        Click="Key_Click"/>

                <Button x:Name="DoubleZeroButton"
                        Grid.Row="3" Grid.Column="0"
                        Content="00"
                        Tag="00"
                        Style="{StaticResource TenderKeyStyle}"
                        FontSize="22"
                        Click="Key_Click"/>

                <Button Grid.Row="3" Grid.Column="1"
                        Content="0"
                        Tag="0"
                        Style="{StaticResource TenderKeyStyle}"
                        Click="Key_Click"/>

                <Button x:Name="DecimalButton"
                        Grid.Row="3" Grid.Column="2"
                        Content="."
                        Tag="."
                        Style="{StaticResource TenderKeyStyle}"
                        FontSize="30"
                        Click="Key_Click"/>
            </Grid>
        </Grid>
    </Border>
</UserControl>