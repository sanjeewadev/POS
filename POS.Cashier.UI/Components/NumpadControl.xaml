<UserControl x:Class="POS.Cashier.UI.Components.NumpadControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <Style x:Key="NumKey" TargetType="Button">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontWeight" Value="Heavy"/>
            <Setter Property="FontSize" Value="26"/>
            <Setter Property="Foreground" Value="#111111"/>
            <Setter Property="Background" Value="#EFEFEF"/>
            <Setter Property="BorderBrush" Value="#707070"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="0">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#DCDCDC"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#444444"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#AAAAAA"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#222222"/>
                                <Setter Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.95" ScaleY="0.95" CenterX="40" CenterY="30"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <!-- Outer shell — flat grey, no radius -->
    <Border Background="#C8C8C8"
            BorderBrush="#888888"
            BorderThickness="2"
            CornerRadius="0"
            Padding="4">
        <StackPanel>

            <!-- Header bar -->
            <Border Background="#003366" Padding="0,6">
                <TextBlock Text="Q U I C K   E N T R Y"
               Foreground="White"
               FontFamily="Segoe UI"
               FontSize="11"
               FontWeight="Heavy"
               HorizontalAlignment="Center"/>
            </Border>

            <!-- Button grid -->
            <UniformGrid Columns="3" Rows="4" Margin="0,3,0,0">

                <Button Style="{StaticResource NumKey}" Content="7" Tag="7" Click="Key_Click" Height="58"/>
                <Button Style="{StaticResource NumKey}" Content="8" Tag="8" Click="Key_Click" Height="58"/>
                <Button Style="{StaticResource NumKey}" Content="9" Tag="9" Click="Key_Click" Height="58"/>

                <Button Style="{StaticResource NumKey}" Content="4" Tag="4" Click="Key_Click" Height="58"/>
                <Button Style="{StaticResource NumKey}" Content="5" Tag="5" Click="Key_Click" Height="58"/>
                <Button Style="{StaticResource NumKey}" Content="6" Tag="6" Click="Key_Click" Height="58"/>

                <Button Style="{StaticResource NumKey}" Content="1" Tag="1" Click="Key_Click" Height="58"/>
                <Button Style="{StaticResource NumKey}" Content="2" Tag="2" Click="Key_Click" Height="58"/>
                <Button Style="{StaticResource NumKey}" Content="3" Tag="3" Click="Key_Click" Height="58"/>

                <!-- C — backspace one digit -->
                <Button Style="{StaticResource NumKey}" Tag="C" Click="Key_Click" Height="58"
                        Background="#C0392B" BorderBrush="#7B241C" Foreground="White"
                        FontSize="22" Content="C"/>

                <Button Style="{StaticResource NumKey}" Content="0" Tag="0" Click="Key_Click" Height="58"/>

                <!-- Bottom-right: dot when ShowDecimal=True, CLR otherwise -->
                <Button Style="{StaticResource NumKey}" Tag="." Click="Key_Click" Height="58"
                        FontSize="30" Content="."
                        Visibility="{Binding ShowDecimal, RelativeSource={RelativeSource AncestorType=UserControl},
                                     Converter={StaticResource BoolToVis}}"/>

                <Button Style="{StaticResource NumKey}" Tag="CLR" Click="Key_Click" Height="58"
                        Background="#D4700A" BorderBrush="#935007" Foreground="White"
                        FontSize="16" FontWeight="Heavy" Content="CLR">
                    <Button.Visibility>
                        <Binding Path="ShowDecimal"
                                 RelativeSource="{RelativeSource AncestorType=UserControl}">
                            <Binding.Converter>
                                <BooleanToVisibilityConverter/>
                            </Binding.Converter>
                        </Binding>
                    </Button.Visibility>
                </Button>

            </UniformGrid>
        </StackPanel>
    </Border>
</UserControl>